                                            <hr class="my-2">
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="pro_search_group-tab-internal">
                                    <div class="row">
                                        <div class="col-md-6 mui-card">
                                            <hr class="my-2">
                                            <div class="row align-items-center mb-1">
                                                <label class="col-sm-4 col-form-label text-sm-end">Acct. Contact</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="gro_txtContact" name="gro_txtContact">
                                                </div>
                                            </div>
                                            <div class="row align-items-center mb-1">
                                                <label class="col-sm-4 col-form-label text-sm-end">Ref. Curr</label>
                                                <div class="col-sm-6">
                                                    <select id="gro_txtCurrency" name="gro_txtCurrency" class="tomselect-custom" data-placeholder="Please select Currency"></select>
                                                </div>
                                            </div>
                                            <div class="row align-items-center mb-1">
                                                <label class="col-sm-4 col-form-label text-sm-end">Account Type</label>
                                                <div class="col-sm-6">
                                                    <select id="gro_txtAccountType" name="gro_txtAccountType" class="tomselect-custom"></select>
                                                </div>
                                            </div>
                                            <div class="row align-items-center mb-1">
                                                <label class="col-sm-4 col-form-label text-sm-end">VIP</label>
                                                <div class="col-sm-6">
                                                    <select id="gro_txtVIP" name="gro_txtVIP" class="tomselect-custom" data-placeholder="Please select VIP"></select>
                                                </div>
                                            </div>
                                            <div class="row align-items-center mb-1">
                                                <label class="col-sm-4 col-form-label text-sm-end">VIP Reason</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="gro_txtVIPReason" name="gro_txtVIPReason">
                                                </div>
                                            </div>
                                            <div class="row align-items-center mb-1">
                                                <label class="col-sm-4 col-form-label text-sm-end">Notes</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="gro_txtNotes" name="gro_txtNotes">
                                                </div>
                                            </div>
                                            <div class="row align-items-center mb-2">
                                                <label class="col-sm-4 col-form-label text-sm-end">History</label>
                                                <div class="col-sm-6">
                                                    <input type="checkbox" class="" id="gro_chkHistory" name="gro_chkHistory">
                                                </div>
                                            </div>
                                            <hr class="my-2">
                                        </div>

                                        <div class="col-md-6 mui-card">
                                            <hr class="my-2">
                                            <div class="row align-items-center mb-1">
                                                <label class="col-sm-4 col-form-label text-sm-end">Telephone</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="gro_txtTelephone" name="gro_txtTelephone">
                                                </div>
                                            </div>
                                            <div class="row align-items-center mb-1">
                                                <label class="col-sm-4 col-form-label text-sm-end">Email</label>
                                                <div class="col-sm-6">
                                                    <input type="email" class="form-control" id="gro_txtEmail" name="gro_txtEmail">
                                                </div>
                                            </div>
                                            <div class="row align-items-center mb-1">
                                                <label class="col-sm-4 col-form-label text-sm-end">Website</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="gro_txtWebsite" name="gro_txtWebsite">
                                                </div>
                                            </div>
                                            <div class="row align-items-center mb-2">
                                                <label class="col-sm-4 col-form-label text-sm-end">Hand Phone</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="gro_txtHandPhone" name="gro_txtHandPhone">
                                                </div>
                                            </div>
                                            <hr class="my-2">
                                            <div class="row align-items-center mb-1">
                                                <label class="col-sm-4 col-form-label text-sm-end">Rate Code</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="gro_txtRateCode" name="gro_txtRateCode" disabled>
                                                </div>
                                            </div>
                                            <div class="row align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">A/R No</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="gro_txtARNo" name="gro_txtARNo" disabled>
