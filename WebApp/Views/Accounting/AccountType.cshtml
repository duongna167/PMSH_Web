@using DevExpress.XtraReports.UI

@{
    var selectedReport = ViewBag.ReportHeader;
    var currencylist = ViewBag.CurrencyList;
}

<div class="modal fade" id="ar_type_modal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content modal-full-height">
            <div class="modal-header bg-light py-2">
                <h5 class="modal-title">Account Type</h5>
            </div>

            <div class="modal-body d-flex flex-column" style="height: calc(100vh - 120px);">
                <div class="py-2">
                    <button id="ar_type_btnPrint" class="mui-button mui-button-new"> View</button>
                    <button id="ar_type_btnNew" class="mui-button mui-button-new"> New</button>
                    <button id="ar_type_btnUpdate" class="mui-button mui-button-edit"> Edit</button>
                    <button id="ar_type_btnDelete" class="mui-button button-report-delete"> Delete </button>
                    <button id="ar_type_btnExportExcel" class="mui-button mui-button-export" type="button"> Excel</button>
                    <button class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                </div>
                <div class="mui-card mb-2 bg-light border-0 d-flex flex-column flex-grow-1 overflow-hidden">
                    <div class="gridContainer mt-2 d-flex flex-column flex-grow-1" style="min-height: 0;">
                        <div id="ar_type_gridContainer"></div>
                        <div id="ar_type_loading" style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                        z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                        height: 100%;display: flex;align-items: center;justify-content: center;">
                            <div class="spinner-border text-primary" role="status"></div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="ar_type_itemModal" tabindex="-1" data-bs-backdrop="static" aria-labelledby="ar_type_itemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="ar_type_itemModalLabel">AR Account Type</h5>
            </div>
            <div class="modal-footer justify-content-start py-2">
                <div>
                    <button id="ar_type_btnOkAuto" class="mui-button mui-button-advance" type="button"> Ok</button>
                    <button id="ar_type_btnSaveAuto" class="mui-button mui-button-new" type="button"> Save</button>
                    <button type="button" class="mui-button mui-button-close" data-bs-dismiss="modal"> Close </button>
                </div>
            </div>
            <div class="modal-body p-4">
                <form id="ar_type_formContainer">   
                    <input type="hidden" id="ar_type_id" name="id" value="0" />
                    <div class="container-fluid">
                        <div class="mb-4">
                            <h6 class="fw-bold mb-3 border-bottom pb-2"> Info </h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold" for="ar_type_typeacc">Type</label>
                                    <input type="text" id="ar_type_typeacc" name="typeacc" class="form-control form-control-sm" />
                                </div>
                                <div class="col-md-8">
                                    <label class="form-label small fw-bold" for="ar_type_descriptionaccty">Description</label>
                                    <input type="text" id="ar_type_descriptionaccty" name="descriptionaccty" class="form-control form-control-sm" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold">Credit Limit</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" id="ar_type_creditLimit" name="creditLimit" class="form-control" />
                                        <select id="ar_type_currencyacc" name="currencyacc" class="form-select w-auto flex-grow-0" style="min-width: 80px;">
                                            @foreach (var item in currencylist)
                                            {
                                                <option value="@item.ID" selected="@(item.ID == "VND" ? "selected" : null)">@item.ID</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold" for="ar_type_statementmode">Statement Mode</label>
                                    <select id="ar_type_statementmode" name="statementmode" class="form-select form-select-sm">
                                        <option value="Individual Open Items">Individual Open Items</option>
                                        <option value="Balance Brought Forward">Balance Brought Forward</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold" for="ar_type_remindercycle">Reminder Cycle</label>
                                    <select id="ar_type_remindercycle" name="remindercycle" class="form-select form-select-sm">
                                        <option value="End of Month">End of Month</option>
                                        <option value="Days">Days</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="mb-2">
                            <h6 class="fw-bold mb-3 border-bottom pb-2"> Finance Charges </h6>
                            <div class="row g-3 align-items-end">
                                <div class="col-md-3">
                                    <label class="form-label small fw-bold" for="ar_type_dayofmonth">Day of Month</label>
                                    <input type="number" id="ar_type_dayofmonth" name="dayofmonth" class="form-control form-control-sm" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Charge Calculation</label>
                                    <div class="d-flex align-items-center bg-light p-1 rounded border" style="min-height: 38px;">
                                        <div class="form-check form-check-inline d-flex align-items-center mb-0 ms-2">
                                            <input class="form-check-input mt-0" type="checkbox" id="ar_type_amount" name="ar_type_includeOptionsTurndown" value="amount">
                                            <label class="form-check-label small ms-2" for="ar_type_amount">Amount</label>
                                        </div>
                                        <div class="form-check form-check-inline d-flex align-items-center mb-0">
                                            <input class="form-check-input mt-0" type="checkbox" id="ar_type_percentage" name="ar_type_includeOptionsTurndown" value="percentage">
                                            <label class="form-check-label small ms-2" for="ar_type_percentage">Percentage</label>
                                        </div>
                                        <input type="number" id="ar_type_amountorPercentage" name="amountorPercentage" class="form-control form-control-sm ms-auto me-1" style="width: 80px;" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-bold" for="ar_type_dayolderthan">Days Older Than</label>
                                    <input type="number" id="ar_type_dayolderthan" name="dayolderthan" class="form-control form-control-sm" />
                                </div>
                                <div class="col-12">
                                    <div class="form-check d-flex align-items-center mt-2">
                                        <input class="form-check-input mt-0" type="checkbox" id="ar_type_includeUnallocated" name="includeOptions" value="1">
                                        <label class="form-check-label small fw-bold text-secondary ms-2 mb-0" for="ar_type_includeUnallocated">
                                            Include Unallocated Payments
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    var ar_type_Module = {
        selectedRowData: null,

        init: function () {
            this.initEvents();
            this.initDOMEvents();
            $("#ar_type_modal").modal("show");
            this.reloadData();
        },

        initEvents: function () {
            window.openModalArType = () => {
                $("#ar_type_modal").modal("show");
                this.reloadData();
            };
        },

        initDOMEvents: function () {
            $("#ar_type_btnPrint").on("click", () => this.reloadData());
            $("#ar_type_btnNew").on("click", () => this.openNewModal());
            $("#ar_type_btnUpdate").on("click", () => this.openEditModal());
            $("#ar_type_btnDelete").on("click", () => this.deleteRecord());
            $("#ar_type_btnOkAuto").on("click", () => this.saveData());
            $("#ar_type_btnSaveAuto").on("click", () => this.saveData());
            $("#ar_type_btnExportExcel").on("click", () => this.exportExcel());
        },

        reloadData: function () {
            $("#ar_type_loading").show();
            $.ajax({
                url: '/Accounting/AccountTypeData',
                type: 'GET',
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                success: (result) => {
                    this.initializeGrid(result);
                    $("#ar_type_loading").hide();
                },
                error: () => {
                    alert("Không thể tải dữ liệu.");
                    $("#ar_type_loading").hide();
                }
            });
        },

        initializeGrid: function (data) {
            $("#ar_type_gridContainer").dxDataGrid({
                dataSource: data,
                height: "100%",
                width: "100%",
                showBorders: true,
                hoverStateEnabled: true,
                wordWrapEnabled: true,
                allowColumnResizing: true,
                columnResizingMode: "widget",
                columnAutoWidth: true,
                selection: { mode: "single" },
                scrolling: {
                    mode: "standard",
                    showScrollbar: "always",
                    useNative: true
                },
                paging: { pageSize: 25 },
                pager: {
                    visible: true,
                    allowedPageSizes: [25, 50, 100],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: { visible: true, applyFilter: "auto" },
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "type", caption: "Type", width: 100, fixed: true },
                    { dataField: "description", caption: "Description", minWidth: 200 },
                    { dataField: "creditLimit", caption: "Credit Limit", dataType: "number", format: "#,##0", width: 110 },
                    { dataField: "currencyID", caption: "Curr.", width: 60 },
                    { dataField: "statementMode", caption: "Stmt. Mode", width: 130 },
                    { dataField: "reminderCycle", caption: "Remind Cycle", width: 110 },
                    { dataField: "dayOfMonth", caption: "Day/Month", dataType: "number", width: 80 },
                    { dataField: "percentage", caption: "%", dataType: "number", format: "percent", width: 70 },
                    { dataField: "amount", caption: "Charge Amt", dataType: "number", format: "#,##0", width: 100 },
                    { dataField: "dayOrderThan", caption: "Days > Than", dataType: "number", width: 100 },
                    {
                        dataField: "includePayment",
                        caption: "Incl. Pay",
                        alignment: "center",
                        width: 85,
                        cellTemplate: function (container, options) {
                            let checked = options.value == 1;
                            container.addClass("d-flex justify-content-center align-items-center");
                            $("<div>").dxCheckBox({ value: checked, readOnly: true }).css("transform", "scale(0.8)").appendTo(container);
                        }
                    },
                    { dataField: "userInsert", caption: "User Ins", width: 100 },
                    { dataField: "createdDate", caption: "Created Date", dataType: "date", format: "dd/MM/yyyy", width: 110 },
                    { dataField: "userUpdate", caption: "User Update", width: 100 },
                    { dataField: "updatedDate", caption: "Updated Date", dataType: "date", format: "dd/MM/yyyy", width: 110 }
                ],
                onRowClick: (e) => {
                    this.selectedRowData = e.data;
                }
            });
        },

        openNewModal: function () {
            this.clearForm();
            $("#ar_type_id").val("0");
            $("#ar_type_itemModalLabel").text("Add AR Account Type");
            $("#ar_type_itemModal").modal("show");
        },

        openEditModal: function () {
            if (!this.selectedRowData) {
                showToast("Warning", "Please select a line to edit.", false);
                return;
            }
            const data = this.selectedRowData;
            $("#ar_type_id").val(data.id);
            $("#ar_type_typeacc").val(data.type);
            $("#ar_type_descriptionaccty").val(data.description);
            $("#ar_type_creditLimit").val(data.creditLimit);
            $("#ar_type_currencyacc").val(data.currencyID);
            $("#ar_type_statementmode").val(data.statementMode);
            $("#ar_type_remindercycle").val(data.reminderCycle);
            $("#ar_type_dayofmonth").val(data.dayOfMonth);
            $("#ar_type_dayolderthan").val(data.dayOrderThan);

            $("#ar_type_amount").prop("checked", data.amount > 0);
            $("#ar_type_percentage").prop("checked", data.percentage > 0);

            if (data.amount > 0 || data.percentage > 0) {
                $("#ar_type_amountorPercentage").val(data.amount > 0 ? data.amount : data.percentage);
            } else {
                $("#ar_type_amountorPercentage").val("");
            }

            $("#ar_type_includeUnallocated").prop("checked", data.includePayment == 1);
            $("#ar_type_itemModalLabel").text("Update AR Account Type");
            $("#ar_type_itemModal").modal("show");
        },

        saveData: function () {
            var checks = $("input[name='ar_type_includeOptionsTurndown']:checked").map(function () {
                return this.value;
            }).get();

            let loginName = (localStorage.getItem("Loginname") || "").trim().replace(/^"(.*)"$/, '$1');

            $("#ar_type_loading").show();
            $.ajax({
                url: '/Accounting/AccountTypeSave',
                type: 'POST',
                data: {
                    typeacc: $("#ar_type_typeacc").val(),
                    descriptionaccty: $("#ar_type_descriptionaccty").val(),
                    creditLimit: $("#ar_type_creditLimit").val(),
                    currencyacc: $("#ar_type_currencyacc").val(),
                    statementmode: $("#ar_type_statementmode").val(),
                    remindercycle: $("#ar_type_remindercycle").val(),
                    dayofmonth: $("#ar_type_dayofmonth").val(),
                    check: checks,
                    dayolderthan: $("#ar_type_dayolderthan").val(),
                    amountorPercentage: $("#ar_type_amountorPercentage").val(),
                    includePayment: $("#ar_type_includeUnallocated").is(":checked"),
                    id: $("#ar_type_id").val(),
                    user: loginName
                },
                traditional: true,
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                success: (result) => {
                    if (result.success) {
                        showToast('Success', result.message, true);
                        this.reloadData();
                        $("#ar_type_itemModal").modal("hide");
                    } else {
                        showToast('Error', result.message || 'Save failed.', false);
                    }
                    $("#ar_type_loading").hide();
                },
                error: () => {
                    alert("Không thể lưu dữ liệu.");
                    $("#ar_type_loading").hide();
                }
            });
        },

        deleteRecord: function () {
            if (!this.selectedRowData) {
                showToast("Warning", "Please select a line to delete.", false);
                return;
            }
            if (!confirm("Are you sure you want to delete this record?")) return;

            $.ajax({
                url: '/Accounting/AccountTypeDelete',
                type: 'POST',
                data: { id: this.selectedRowData.id },
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                success: (result) => {
                    if (result.success) {
                        showToast('Success', result.message, true);
                        this.reloadData();
                    } else {
                        showToast('Error', result.message || 'Delete failed.', false);
                    }
                }
            });
        },

        clearForm: function () {
            $("#ar_type_formContainer")[0].reset();
            $("#ar_type_id").val("0");
            $("#ar_type_currencyacc").val("VND");
        },

        exportExcel: function () {
            const grid = $("#ar_type_gridContainer").dxDataGrid("instance");
            const workbook = new ExcelJS.Workbook();
            const companyName = localStorage.getItem("CompanyName") || "System";
            const worksheet = workbook.addWorksheet("Sheet 1");

            worksheet.addRow([companyName]);
            worksheet.mergeCells('A1:D1');
            worksheet.getRow(1).font = { bold: true };

            const now = new Date();
            worksheet.addRow(['', '', '', now.toLocaleString("vi-VN")]);
            worksheet.mergeCells('D2:D2');
            worksheet.getRow(2).alignment = { horizontal: 'right' };

            worksheet.addRow([]);
            worksheet.addRow([]);

            const reportRow = worksheet.addRow(['AR Accounting Type']);
            worksheet.mergeCells('A5:D5');
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { horizontal: 'center' };

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(() => {
                workbook.xlsx.writeBuffer().then((buffer) => {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "ARAccountType.xlsx");
                });
            });
        }
    };

    $(document).ready(function () {
        ar_type_Module.init();
    });
</script>
