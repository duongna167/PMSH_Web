<!-- Existing partials kept (not refactored here because code not provided) -->
@await Html.PartialAsync("Options/Maintenance")
@await Html.PartialAsync("Options/ModalSearchProfile")

<script>
    // ======================================
// Accounting Search / AR Account Receivable
// Option A Module (aras_)
// ======================================
var aras_Module = (function () {

    // instances
        let mainModal, newModal,overCreditModal;
    let gridInstance = null;
    let tomAccountType = null;

    // state
    let selectedId = null;
    let lastSearchResult = null;
    let isMainBound = false;

    const sel = {
        mainModal: "#aras_modalMain",
        newModal: "#aras_modalNew",
        overCreditModal: "#aras_modalOverCredit",
        // filter
        accountName: "#aras_accountName",
        accountNo: "#aras_accountNo",
        accountType: "#aras_accountType",
        searchType: "input[name='aras_searchType']",

        // buttons
        btnSearch: "#aras_btnSearch",
        btnNew: "#aras_btnNew",
        btnAR: "#aras_btnAR",
        btnOCL: "#aras_btnOverCreditLimit",
        btnEdit: "#aras_btnEdit",
        btnSave: "#aras_btnSave",
        btnSearchProfile: "#aras_btnSearchProfile",

        // grid + ui
        grid: "#aras_gridContainer",
        gridocd: "#aras_gridContainerOcd",
        loading: "#aras_loading",

        // form fields
        accountTypeAdd: "#aras_accountTypeAdd",
        accountNumberAdd: "#aras_accountNumberAdd",
        creditLimitAdd: "#aras_creditLimitAdd",
        currencyAdd: "#aras_currencyAdd",
        profileAdd: "#aras_profileAdd",
        profileAddText: "#aras_profileAddText",
        contactAdd: "#aras_contactAdd",
        phoneAdd: "#aras_phoneAdd",
        faxAdd: "#aras_faxAdd",
        emailAdd: "#aras_emailAdd",
        address1Add: "#aras_address1Add",
        address2Add: "#aras_address2Add",
        address3Add: "#aras_address3Add",
        postalCode: "#aras_postalCode",
        cityAdd: "#aras_cityAdd",
        countryAdd: "#aras_countryAdd",
        paymentDueDaysAdd: "#aras_paymentDueDaysAdd",
        descriptionAdd: "#aras_descriptionAdd",
        flaggedAdd: "#aras_flaggedAdd",
        inactiveAdd: "#aras_inactiveAdd",
    };

    function init() {
        mainModal = bootstrap.Modal.getOrCreateInstance(document.querySelector(sel.mainModal), { backdrop: "static" });
        newModal = bootstrap.Modal.getOrCreateInstance(document.querySelector(sel.newModal), { backdrop: "static" });
        overCreditModal = bootstrap.Modal.getOrCreateInstance(document.querySelector(sel.overCreditModal), { backdrop: "static" });
        // Main modal lifecycle: init grid only here (STRICT)
        $(sel.mainModal).off("shown.bs.modal").on("shown.bs.modal", function () {
            if (!isMainBound) {
                isMainBound = true;
                bindEvents();
                initTomSelect();
            }

            // auto search on open (previous behavior)
            doSearch();
        });

        // Cleanup for all aras_ modals
        $(document).off("hidden.bs.modal.aras").on("hidden.bs.modal.aras", ".modal[id^='aras_']", function () {
            cleanupModal(this.id);
        });
    }

    function bindEvents() {

        $(document).off("click.aras", sel.btnSearch).on("click.aras", sel.btnSearch, doSearch);

        $(document).off("click.aras", sel.btnNew).on("click.aras", sel.btnNew, function () {
            openNewModalForCreate();
        });

        $(document).off("click.aras", sel.btnOCL).on("click.aras", sel.btnOCL, function () {
            openOCL();
        });

        // AR button: unknown details (points to partial). Keep as hook.
        $(document).off("click.aras", sel.btnAR).on("click.aras", sel.btnAR, function () {
            if (typeof window.openModalMaintenance === "function") initDateInputs(); window.openModalMaintenance();
        });

        $(document).off("click.aras", sel.btnEdit).on("click.aras", sel.btnEdit, function () {
            if (!selectedId) {
                showToast("Warning", "Please select a row first.", false);
                return;
            }
            loadById(selectedId);
        });

        $(document).off("click.aras", sel.btnSave).on("click.aras", sel.btnSave, saveAccount);

        $(document).off("click.aras", sel.btnSearchProfile).on("click.aras", sel.btnSearchProfile, function () {
            // profile search is in partial; keep call if exists
            if (typeof window.openModalSearchProfile === "function") window.openModalSearchProfile();
        });
    }

    function initTomSelect() {
        const el = document.querySelector(sel.accountType);
        if (!el) return;

        if (el.tomselect) el.tomselect.destroy();
        tomAccountType = new TomSelect(el, {
            plugins: ['remove_button'],
            create: false,
            maxItems: 1,
            allowEmptyOption: true
        });
    }

    function doSearch() {
        $(sel.loading).show();

        const payload = {
            accountName: $(sel.accountName).val(),
            accountNo: $(sel.accountNo).val(),
            accountType: $(sel.accountType).val(),
            balance: $(sel.searchType + ":checked").val(),
        };

        $.ajax({
            url: '/Accounting/SearchAccounting',
            type: 'GET',
            dataType: 'json',
            data: payload,
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() },
            success: function (result) {

                // STRICT: only render when valid
                if (!Array.isArray(result)) {
                    lastSearchResult = [];
                    destroyGrid();
                    $(sel.loading).hide();
                    showToast("Warning", "No valid data returned.", false);
                    return;
                }

                lastSearchResult = result;
                renderGrid(result);
                $(sel.loading).hide();
            },
            error: function (xhr) {
                $(sel.loading).hide();
                if (xhr.status === 401) sessionTimeout();
            }
        });
    }

    function doSearchOcl() {
        $(sel.loading).show();

 
        $.ajax({
            url: '/Accounting/AccountingOCL',
            type: 'GET',
            dataType: 'json',
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                console.log(result);
                    renderGridOcl(result);
                $(sel.loading).hide();
            },
            error: function (xhr) {
                $(sel.loading).hide();
                if (xhr.status === 401) sessionTimeout();
            }
        });
    }

    function renderGrid(data) {

            // STRICT: destroy before create
            destroyGrid();

            gridInstance = $(sel.grid).dxDataGrid({
                dataSource: data,
                allowColumnResizing: true,
                columnAutoWidth: false,
                width: "100%",
                height: "100%", // fixed, not 100%
                paging: { pageSize: 20 },
                scrolling: { rowRenderingMode: "virtual" },
                pager: {
                    visible: true,
                    allowedPageSizes: [20,50,100, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: { visible: true, applyFilter: "auto" },
                selection: { mode: "single" }, // single selection is safer for Edit
                columns: [
                    { dataField: "ID", caption: "ID", visible: false },

                    { dataField: "AccountName", caption: "Account Name", width: 260 },
                    { dataField: "AccountNo", caption: "Account No", width: 180 },
                    { dataField: "AccountTypeID", caption: "Type", width: 80 },

                    { dataField: "CurrencyID", caption: "Currency", width: 90 },
                    { dataField: "CreditLimit", caption: "Credit Limit", width: 140, alignment: "right",dataType: "number", format: "#,##0" },
                    { dataField: "BalanceVND", caption: "Balance (VND)", width: 150, alignment: "right" ,dataType: "number", format: "#,##0"},
                    { dataField: "BalanceUSD", caption: "Balance (USD)", width: 150, alignment: "right" ,dataType: "number", format: "#,##0"},
                     { dataField: "PaymentDueDays", caption: "Due Days", width: 100, alignment: "center" ,dataType: "number", format: "#,##0"},

                    { dataField: "ContactName", caption: "Contact Name", width: 200 },
                    { dataField: "TelePhone", caption: "Telephone", width: 140 },
                    { dataField: "Fax", caption: "Fax", width: 120 },
                    { dataField: "Email", caption: "Email", width: 220 },

                    { dataField: "Address1", caption: "Address", width: 280 },

                    { dataField: "Check", caption: "Check", width: 80 },
                    { dataField: "StatusFlagged", caption: "Flagged", width: 100 },
                    { dataField: "StatusInactive", caption: "Inactive", width: 100 },

                    { dataField: "Description", caption: "Description", width: 260 },

                    { dataField: "CreatedBy", caption: "Created By", width: 120 },
                    { dataField: "CreatedDate", caption: "Created Date", width: 160, dataType: "datetime", format: "dd/MM/yyyy" },
                    { dataField: "UpdatedBy", caption: "Updated By", width: 120 },
                    { dataField: "UpdatedDate", caption: "Updated Date", width: 160, dataType: "datetime", format: "dd/MM/yyyy" }
                ],
                showBorders: true,

                onContentReady: function (e) {
                    // select first row
                    const grid = e.component;
                    const firstKey = grid.getKeyByRowIndex(0);
                    if (firstKey !== undefined) {
                        grid.selectRows([firstKey], false);
                        const row = grid.getSelectedRowsData()[0];
                        selectedId = row?.ID ?? null;
                    }
                },

                onSelectionChanged: function (e) {
                    const row = e.selectedRowsData?.[0];
                    selectedId = row?.ID ?? null;
                },

                onRowClick: function (e) {
                    const grid = $(sel.grid).dxDataGrid("instance");
                    grid.selectRows([e.key], false);
                }
            }).dxDataGrid("instance");
        }

    function renderGridOcl(data) {


            gridInstance = $(sel.gridocd).dxDataGrid({
            dataSource: data,
            allowColumnResizing: true,
            columnAutoWidth: false,
            width: "100%",
            height: "100%", // fixed, not 100%
            paging: { pageSize: 20 },
            scrolling: { rowRenderingMode: "virtual" },
            pager: {
                visible: true,
                allowedPageSizes: [20,50,100, "all"],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            filterRow: { visible: true, applyFilter: "auto" },
            selection: { mode: "single" }, // single selection is safer for Edit
            columns: [


                    { dataField: "accountName", caption: "Account Name", width: 260 },
                { dataField: "accountNo", caption: "Account No", width: 180 }
              
            ],
            showBorders: true
        }).dxDataGrid("instance");
    }

    function destroyGrid() {
        try {
            const inst = $(sel.grid).dxDataGrid("instance");
            if (inst) inst.dispose();
        } catch { }
        $(sel.grid).empty();
        gridInstance = null;
        selectedId = null;
    }

    function openNewModalForCreate() {
        resetNewForm();
        $("#aras_modalNewTitle").text("AR Account Receivable");
        newModal.show();
    }

    function openOCL() {
            doSearchOcl();
        overCreditModal.show();
    }
    function resetNewForm() {
        $(sel.accountTypeAdd).val("0");
        $(sel.accountNumberAdd).val("");
        $(sel.creditLimitAdd).val("");
        $(sel.currencyAdd).val("VND");

        $(sel.profileAdd).val("0");
        $(sel.profileAddText).val("");

        $(sel.contactAdd).val("");
        $(sel.phoneAdd).val("");
        $(sel.faxAdd).val("");
        $(sel.emailAdd).val("");

        $(sel.address1Add).val("");
        $(sel.address2Add).val("");
        $(sel.address3Add).val("");
        $(sel.postalCode).val("");

        $(sel.cityAdd).val("0");
        $(sel.countryAdd).val("0");

        $(sel.paymentDueDaysAdd).val("");
        $(sel.descriptionAdd).val("");

        $(sel.flaggedAdd).prop("checked", false);
        $(sel.inactiveAdd).prop("checked", false);

        // clear validation if you use applyValidationErrors
        $(sel.newModal).find(".is-invalid").removeClass("is-invalid");
        $(sel.newModal).find(".invalid-feedback").text("");
    }

    function loadById(id) {
        $.ajax({
            url: '/Accounting/GetAccountReceivable',
            type: 'GET',
            dataType: 'json',
            data: { id: id },
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                // map to modal fields
                $(sel.accountTypeAdd).val(result.accountTypeID);
                $(sel.accountNumberAdd).val(result.accountNo);
                $(sel.creditLimitAdd).val(result.creditLimit);
                $(sel.currencyAdd).val(result.currencyID);

                $(sel.profileAdd).val(result.profileID);
                $(sel.profileAddText).val(result.profileName || "");

                $(sel.contactAdd).val(result.contactName);
                $(sel.phoneAdd).val(result.telePhone);
                $(sel.faxAdd).val(result.fax);
                $(sel.emailAdd).val(result.email);

                $(sel.address1Add).val(result.address1);
                $(sel.address2Add).val(result.address2);
                $(sel.address3Add).val(result.address3);
                $(sel.postalCode).val(result.postalCode);

                $(sel.cityAdd).val(result.cityID);
                $(sel.countryAdd).val(result.countryID);

                $(sel.paymentDueDaysAdd).val(result.paymentDueDays);
                $(sel.descriptionAdd).val(result.description);

                $(sel.flaggedAdd).prop("checked", !!result.statusFlagged);
                $(sel.inactiveAdd).prop("checked", !!result.statusInactive);

                newModal.show();
            },
            error: function (xhr) {
                if (xhr.status === 401) sessionTimeout();
            }
        });
    }

    function saveAccount() {
        const userName = JSON.parse(localStorage.getItem("Loginname") || "null");
        const userID = JSON.parse(localStorage.getItem("userID") || "null");

        // If editing: use selectedId; else 0
        const id = selectedId || 0;

        const formData = new FormData();
        formData.append("id", id);

        formData.append("accountType", $(sel.accountTypeAdd).val());
        formData.append("accountNumber", $(sel.accountNumberAdd).val());
        formData.append("creditLimit", $(sel.creditLimitAdd).val());
        formData.append("currency", $(sel.currencyAdd).val());

        formData.append("profile", $(sel.profileAdd).val());
        formData.append("contact", $(sel.contactAdd).val());
        formData.append("phone", $(sel.phoneAdd).val());
        formData.append("fax", $(sel.faxAdd).val());
        formData.append("email", $(sel.emailAdd).val());

        formData.append("address1", $(sel.address1Add).val());
        formData.append("address2", $(sel.address2Add).val());
        formData.append("address3", $(sel.address3Add).val());
        formData.append("postalCode", $(sel.postalCode).val());

        formData.append("city", $(sel.cityAdd).val());
        formData.append("country", $(sel.countryAdd).val());

        formData.append("paymentDue", $(sel.paymentDueDaysAdd).val());
        formData.append("description", $(sel.descriptionAdd).val());

        formData.append("flagged", $(sel.flaggedAdd).is(":checked") ? 1 : 0);
        formData.append("inactive", $(sel.inactiveAdd).is(":checked") ? 1 : 0);

        formData.append("userName", userName ?? "");
        formData.append("userID", userID ?? "");

        $.ajax({
            url: "/Accounting/AccountReceivableAdd",
            type: "POST",
            processData: false,
            contentType: false,
            data: formData,
            success: function (data) {
                if (data?.success === true) {
                    newModal.hide();
                    doSearch();
                    showToast("Success", data.message, true);
                } else {
                    showToast("Error", data?.message || "Save failed.", false);
                    if (data?.errors && typeof window.applyValidationErrors === "function") {
                        window.applyValidationErrors(data.errors, sel.newModal);
                    }
                }
            }
        });
    }

    function cleanupModal(modalId) {
        // module-wide cleanup
        if (modalId === "aras_modalMain") {
            destroyGrid();

            if (tomAccountType) {
                tomAccountType.destroy();
                tomAccountType = null;
            }

            isMainBound = false;
        }

        if (modalId === "aras_modalNew") {
            resetNewForm();
        }
    }

    function open() {
        mainModal.show();
    }

    return { init, open, destroy: destroyGrid };

})();

// Global entry for this module
window.openModalAras = function () {
    aras_Module.open();
};

$(document).ready(function () {
    aras_Module.init();
});
</script>
