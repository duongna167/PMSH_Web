                            </div>

                            <div class="form-row">
                                <label class="col-label">Max Occ Tonight</label>
                                <input id="maxaccRoom" type="text" class="col-val" disabled>
                                <input id="maxaccPerson" type="text" class="col-val" disabled>
                                <input id="maxaccVip" type="text" class="col-val" disabled>
                            </div>

                            <div class="form-row">
                                <label class="col-label">Max % Occ</label>
                                <input id="maxpercentonight" type="text" class="col-val" disabled>
                                <span class="col-val"></span>
