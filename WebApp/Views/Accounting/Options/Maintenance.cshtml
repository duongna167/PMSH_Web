<script>
    function openModalMaintenance() {
        const today = new Date().toISOString().split('T')[0];

        // Set default values for From Date and To Date

        searchMaintenance();
        $('#modalMaintenance').modal('show');
    }
    function closeModalMaintenance() {
        $('#modalMaintenance').modal('hide');
        resetMaintenanceFilter();
    }

    $(document).off("click", "#btn-clear-maintenanace").on("click", "#btn-clear-maintenanace", function () {
        resetMaintenanceFilter();
    })

    $(document).off("click", "#btn-detail-maintenanace").on("click", "#btn-detail-maintenanace", function () {
        getdetailReceivable();
    })


    function openModalEditPosting() {
        alert("Winform đang lỗi vui lòng đợi cập nhật hoặc liên hệ admin để biết thêm chi tiết");
    }
    function resetMaintenanceFilter(containerSelector = '#filter') {
        const container = document.querySelector(containerSelector);
        if (!container) return;

        // Text / number / date inputs
        container.querySelectorAll('input.clearable[type="text"], input.clearable[type="number"]').forEach(input => {
            input.value = '';
        });

        // Checkboxes
        container.querySelectorAll('input.clearable[type="checkbox"]').forEach(cb => {
            cb.checked = false;
        });

        // Radios: reset về radio có checked mặc định
        const radioGroups = {};
        container.querySelectorAll('input.clearable[type="radio"]').forEach(radio => {
            if (!radioGroups[radio.name]) {
                radioGroups[radio.name] = [];
            }
            radioGroups[radio.name].push(radio);
        });

        Object.values(radioGroups).forEach(group => {
            const defaultRadio = group.find(r => r.hasAttribute('checked'));
            if (defaultRadio) {
                defaultRadio.checked = true;
            } else {
                group.forEach(r => r.checked = false);
            }
        });

        // Date inputs: clear + disable
        container.querySelectorAll('[data-date-input]').forEach(wrapper => {
            const input = wrapper.querySelector('input');
            if (input) {
                input.value = '';
                input.disabled = false;
            }
        });

        // Reset Date checkbox logic
        const dateCheckbox = container.querySelector('#dateMaintenance');
        if (dateCheckbox) {
            dateCheckbox.checked = false;
        }
        reloadBusinessDate();
    }
     function getdetailReceivable() {
            var grid = $("#aras_gridContainer").dxDataGrid("instance");
         var selectedRows = grid.getSelectedRowsData();
         var selectedIds = selectedRows.map(row => row.ID);
        $.ajax({
            url: '/Accounting/GetAccountReceivable',
            type: 'get',
            dataType: 'json',
            data: {              
                id: selectedIds[0]
            },
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                console.log(result);
                $("#aras_accountTypeDetail").val(result.accountTypeID);
                $("#aras_accountNumberDetail").val(result.accountNo);
                $("#aras_creditLimitDetail").val(result.creditLimit);
                $("#aras_currencyDetail").val(result.aras_currencyDetail);

                $("#aras_profileDetail").val(result.profileID);
                $("#aras_profileDetailText").val(result.profileName || "");

                $("#aras_contactDetail").val(result.contactName);
                $("#aras_phoneDetail").val(result.telePhone);
                $("#aras_faxDetail").val(result.fax);
                $("#aras_emailDetail").val(result.email);

                $("#aras_address1Detail").val(result.address1);
                $("#aras_address2Detail").val(result.address2);
                $("#aras_address3Detail").val(result.address3);
                $("#aras_postalCodeDetail").val(result.postalCode);

                $("#aras_cityDetail").val(result.cityID);
                $("#aras_countryDetail").val(result.countryID);

                $("#aras_paymentDueDaysDetail").val(result.paymentDueDays);
                $("#aras_descriptionDetail").val(result.description);

                $("#aras_flaggedDetail").prop("checked", !!result.statusFlagged);
                $("#aras_inactiveDetail").prop("checked", !!result.statusInactive);
                    $('#aras_modalDetail').modal('show');
            },
            error: function (xhr, statusText, err) {
                if (xhr.status == 401) {
                    sessionTimeout();
                }
            },

        });

    }
    $(document).off("click", "#aras_btnSaveDetail").on("click", "#aras_btnSaveDetail", saveAccountDetail);
        function saveAccountDetail() {
        const userName = JSON.parse(localStorage.getItem("Loginname") || "null");
        const userID = JSON.parse(localStorage.getItem("userID") || "null");

         var grid = $("#aras_gridContainer").dxDataGrid("instance");
        var selectedRows = grid.getSelectedRowsData();
        var selectedIds = selectedRows.map(row => row.ID);

        const formData = new FormData();
        formData.append("id", selectedIds[0]);

        formData.append("accountType", $("#aras_accountTypeDetail").val());
        formData.append("accountNumber", $("#aras_accountNumberDetail").val());
        formData.append("creditLimit", $("#aras_creditLimitDetail").val());
        formData.append("currency", $("#aras_currencyDetail").val());

        formData.append("profile", $("#aras_profileDetail").val());
        formData.append("contact", $("#aras_contactDetail").val());
        formData.append("phone", $("#aras_phoneDetail").val());
        formData.append("fax", $("#aras_faxDetail").val());
        formData.append("email", $("#aras_emailDetail").val());

        formData.append("address1", $("#aras_address1Detail").val());
        formData.append("address2", $("#aras_address2Detail").val());
        formData.append("address3", $("#aras_address3Detail").val());
        formData.append("postalCode", $("#aras_postalCodeDetail").val());

        formData.append("city", $("#aras_cityDetail").val());
        formData.append("country", $("#aras_countryDetail").val());

        formData.append("paymentDue", $("#aras_paymentDueDaysDetail").val());
        formData.append("description", $("#aras_descriptionDetail").val());

        formData.append("flagged", $("#aras_flaggedDetail").is(":checked") ? 1 : 0);
        formData.append("inactive", $("#aras_inactiveDetail").is(":checked") ? 1 : 0);

        formData.append("userName", userName ?? "");
        formData.append("userID", userID ?? "");

        $.ajax({
            url: "/Accounting/AccountReceivableAdd",
            type: "POST",
            processData: false,
            contentType: false,
            data: formData,
            success: function (data) {
                if (data?.success === true) {
                   $('#aras_modalDetail').modal('hide');
                    showToast("Success", data.message, true);
                } else {
                    showToast("Error", data?.message || "Save failed.", false);
                    
                }
            }
        });
    }

    function searchMaintenance() {
         var grid = $("#aras_gridContainer").dxDataGrid("instance");
         var selectedRows = grid.getSelectedRowsData();
         var selectedIds = selectedRows.map(row => row.ID);
         $.ajax({
             url: '/Accounting/SearchMaintenance',
             type: 'get',
             dataType: 'json',
             data: {
                 dateCheck: $('#dateMaintenance[type="checkbox"]').is(':checked') ? "1" : "",
                 arID: selectedIds[0],
                 folioNo: $('#folioMaintenance').val(),
                 isActive: $('input[name="isActiveMaintenance"]:checked').val(),
                 paymentOnly: $('#paymentMaintenance[type="checkbox"]').is(':checked') ? "1" : "",
                 print: $('input[name="printMaintenance"]:checked').val(),
                 fromDate: $('#fromDateMaintenance').val(),
                 toDate: $('#toDateMaintenance').val(),
             },
             crossDomain: false,
             headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
             success: function (result) {
                 initializeDataGridMaintenance(result);
             },
             error: function (xhr, statusText, err) {
                 if (xhr.status == 401) {
                     sessionTimeout();
                 }
             },

         });

     }

    function initializeDataGridMaintenance(data) {

        $("#gridContainerMaintenance").dxDataGrid({
            dataSource: data,
            keyExpr: "AccountReceivableTransID",

            height: 500,                    // ✅ FIX HEIGHT
            showBorders: true,

            // ===== LAYOUT / WIDTH =====
            columnAutoWidth: true,          // cột co theo dữ liệu
            allowColumnResizing: true,
            columnResizingMode: "widget",

            // ===== SCROLLING =====
            scrolling: {
                mode: "standard",           // ✅ cho phép scroll ngang
                useNative: true
            },

            paging: { pageSize: 15 },
            pager: {
                visible: true,
                allowedPageSizes: [15, 20, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },

            filterRow: {
                visible: true,
                applyFilter: "auto"
            },

            selection: {
                mode: "multiple",
                showCheckBoxesMode: "always"
            },

            columns: [
                {
                    dataField: "TransactionDate",
                    caption: "Transaction Date",
                    dataType: "datetime",
                    format: "dd/MM/yyyy",
                    minWidth: 160
                },
                {
                    dataField: "AccountName",
                    caption: "Account Name",
                    minWidth: 220
                },
                {
                    dataField: "FolioID",
                    caption: "Folio",
                    width: 80
                },
                {
                    dataField: "Amount",
                    caption: "Amount",
                    alignment: "right",
                    minWidth: 120,dataType: "number", format: "#,##0"
                },
                {
                    dataField: "Paid",
                    caption: "Paid",
                    alignment: "right",
                    minWidth: 120,dataType: "number", format: "#,##0"
                },
                {
                    dataField: "Balance",
                    caption: "Balance",
                    alignment: "right",
                    minWidth: 120,dataType: "number", format: "#,##0"
                },
                {
                    dataField: "CurrencyID",
                    caption: "Currency",
                    width: 90
                },
                {
                    dataField: "ConfirmationNo",
                    caption: "Confirmation No",
                    width: 130
                },
                {
                    dataField: "CreatedBy",
                    caption: "Created By",
                    width: 120
                },
                {
                    dataField: "CreatedDate",
                    caption: "Created Date",
                    dataType: "datetime",
                    format: "dd/MM/yyyy",
                    minWidth: 160
                },
                {
                    dataField: "UpdatedBy",
                    caption: "Updated By",
                    width: 120
                },
                {
                    dataField: "UpdatedDate",
                    caption: "Updated Date",
                    dataType: "datetime",
                    format: "dd/MM/yyyy",
                    minWidth: 160
                }
            ],

            // ===== AUTO SELECT FIRST ROW =====
            onContentReady: function (e) {
                const grid = e.component;
                if (grid.getSelectedRowKeys().length === 0) {
                    const key = grid.getKeyByRowIndex(0);
                    if (key !== undefined) {
                        grid.selectRows([key], false);
                    }
                }
            },

            onRowClick: function (e) {
                e.component.selectRows([e.key], false);
            }
        });
    }
</script>
