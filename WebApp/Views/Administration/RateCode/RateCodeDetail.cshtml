@using DevExpress.XtraReports.UI

@{
    dynamic? rtCD_listRateCode = @ViewBag.RateCodeList;
    dynamic? rtCD_listRateCate = @ViewBag.RateCateList;
    dynamic? rtCD_listRoomType = @ViewBag.RoomTypeList;
    dynamic? rtCD_listTransaction = @ViewBag.TransactionList;
    dynamic? rtCD_listPackage = @ViewBag.PackageList;
    dynamic? rtCD_listSeason = @ViewBag.RateSeason;
}

<style>
    /* local layout only (kept minimal; main pattern is Bootstrap ERP grid) */
    .rtCD_gridLayout {
        display: grid;
        grid-template-columns: 1fr 1fr;  /* 2 cột bằng nhau */
        grid-template-rows: 40vh 40vh;
        height: 85vh;
        width: 100%;
        box-sizing: border-box;
    }
    .rtCD_gridLeft { grid-column: 1; background: #fff; min-height: 0;  }
    .rtCD_gridTopRight { grid-column: 2; min-height: 0; }
    .rtCD_gridBottom { grid-column: 1 / span 2; min-height: 0; }

    .my-2 {
    margin-top: 2px !important;
    margin-bottom: 2px !important;
    }
</style>

<!-- MAIN MODAL (XL) -->
<div class="modal fade" id="rtCD_modalMain" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title fw-bold text-primary" id="rtCD_modalTitle">Rate Code Detail</h5>
            </div>

            <div class="modal-body position-relative">

                <div class="search-filter">
                    <!-- ACTION BAR -->
                <div>
                    <button id="rtCD_btnView" type="button" class="mui-button mui-button-new">View</button>
                    <button id="rtCD_btnNew" type="button" class="mui-button mui-button-new">New</button>
                    <button id="rtCD_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                    <button id="rtCD_btnEditFull" type="button" class="mui-button mui-button-edit">Edit Full</button>
                    @* <button id="rtCD_btnDelete" type="button" class="mui-button button-report-delete">Delete</button> *@
                    <button id="rtCD_btnExportExcel" type="button" class="mui-button mui-button-export">Excel</button>
                    <button id="rtCD_btnClose" type="button" class="mui-button mui-button-new">Close</button>
                </div>

                <!-- FILTER (Bootstrap 5 ERP-style: dense grid, right-aligned labels, nested rows, compact spacing) -->
                <div class="mt-1">
                    <div class="row g-2">

                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="row g-1 align-items-center">
                                <label for="rtCD_code" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Rate Code
                                </label>
                                <div class="col-md-8">
                                    <select id="rtCD_code" name="rtCD_code" class="tomselect-custom">
                                        <option value=""></option>
                                        @if (rtCD_listRateCode != null)
                                        {
                                            foreach (dynamic u in rtCD_listRateCode)
                                            {
                                                <option value="@u.RateCode">@u.RateCode</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="row g-1 align-items-center">
                                <label for="rtCD_category" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Category
                                </label>
                                <div class="col-md-8">
                                    <select id="rtCD_category" name="rtCD_category" class="tomselect-custom">
                                        <option value=""></option>
                                        @if (rtCD_listRateCate != null)
                                        {
                                            foreach (dynamic u in rtCD_listRateCate)
                                            {
                                                <option value="@u.Code">@u.Code</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-2">
                            <div class="row g-1 align-items-center">
                                <label for="rtCD_typeDate" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Type Date
                                </label>
                                <div class="col-md-8">
                                    <select id="rtCD_typeDate" name="rtCD_typeDate" class="tomselect-custom">
                                        <option value=""></option>
                                        <option value="1">See date</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-2">
                            <div class="row g-1 align-items-center">
                                <label for="rtCD_fromDateUi" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    From
                                </label>
                                <div class="col-md-8">
                                    <div data-date-input data-format="DD/MM/YYYY" business-date data-name="rtCD_fromDate">
                                        <input id="rtCD_fromDateUi" name="rtCD_fromDateUi"
                                               type="text" class="date-ui form-control form-control-sm"
                                               placeholder="dd/mm/yyyy" autocomplete="off" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-2">
                            <div class="row g-1 align-items-center">
                                <label for="rtCD_toDateUi" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    To
                                </label>
                                <div class="col-md-8">
                                    <div data-date-input data-format="DD/MM/YYYY" business-date data-name="rtCD_toDate">
                                        <input id="rtCD_toDateUi" name="rtCD_toDateUi"
                                               type="text" class="date-ui form-control form-control-sm"
                                               placeholder="dd/mm/yyyy" autocomplete="off" />
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                </div>

                <!-- CONTENT -->
                <div class="flex-grow-1 bg-white position-relative">
                    <div class="mui-card">
                        <div class="rtCD_gridLayout">

                            <div class="rtCD_gridLeft">
                                <div class="fw-bold small">Rate Codes</div>
                                <div id="rtCD_gridRateCodes" class="gridContainer mt-2"></div>
                            </div>

                            <div class="rtCD_gridTopRight">
                                <div class="fw-bold small">Rate Details Grouped</div>
                                <div id="rtCD_gridRateDetailsGrouped" class="gridContainer mt-2"></div>
                            </div>

                            <div class="rtCD_gridBottom">
                                <div class="fw-bold small">Details</div>
                                <div id="rtCD_gridDetails" class="gridContainer mt-2"></div>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- LOADING -->
                <div id="rtCD_loadingSpinner"
                    style="display:none;position:absolute;inset:0;z-index:999;background:rgba(255,255,255,0.55);
                    align-items:center;justify-content:center;">
                    <div class="spinner-border text-primary"></div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- UPSERT MODAL (XL) -->
