    function resetFormPosting() {
        let $pane = $('.tab-pane.active');
        if ($pane.length === 0) return; // Bảo vệ nếu không tìm thấy tab active

        isReset = true;
        isSilentReset = true;

        $pane.find('input')
        .not('.js-invoice-desc, .js-invoice-ref, .js-invoice-supp, .js-invoice-checkNo, .js-trans-code, .js-trans-desc')
        .val('');

        $pane.find('.js-input-qty').val('1');
        $pane.find('.js-input-price, .js-input-price-net').val('0,00');
        $pane.find('.js-amount-gross, .js-amount-net').val('0,00');

        // $pane.find('.js-chk-express, .js-chk-discount').prop('checked', false);
        // $pane.find('.express-box input').prop('disabled', true);
        // Bỏ tích checkbox
        $pane.find('.js-chk-express, .js-chk-discount').prop('checked', false);

        // Chỉ disable các ô nhập liệu bên trong, NHƯNG phải giữ các checkbox được ENABLE
        $pane.find('.express-box').each(function() {
            // Disable text input và radio
            $(this).find('input[type="text"], input[type="radio"]').prop('disabled', true);
            // Đảm bảo checkbox luôn luôn được phép nhấn
            $(this).find('.form-check-input').prop('disabled', false);
        });
        $pane.find('.js-input-price, .js-input-price-net')
            .removeClass('active-user-input');

        // var grid = $("#gridInvoiceFooter").data("dxDataGrid");
        // if (grid) { grid.option("dataSource", []); }

        // Trả lại trạng thái sau khi xử lý xong DOM
        setTimeout(() => {
            isReset = false;
            isSilentReset = false;
        }, 200);
    }


