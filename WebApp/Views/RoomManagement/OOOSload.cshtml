@using DevExpress.XtraReports.UI

@{
    var selectedReport = @ViewBag.ReportHeader;
    var listroom = ViewBag.RoomList;
    var listrclass = ViewBag.RoomClassList;
    var listzone = ViewBag.ZoneList;
    var listcmt = ViewBag.CommentList;
    var rooms = ViewBag.AvailableRooms;
}

<style>

    .filter_wrapper {
        /*     background-color: #ececec; */
        /*   margin: 0px 8px 14px 8px; */
        padding: 18px 0px 0px 14px;
        border-radius: 8px;
    }


    .button_wrapper {
        display: flex;
        column-gap: 12px;
        margin: 0px 8px;
    }

        .button_wrapper .fa-solid {
            margin-right: 5px;
        }

    .sticky-header .form-control-sm {
        padding: .1rem .35rem;
        height: calc(1.1em + .2rem + 2px);
    }

    .sticky-header label[class*="me-"] {
        margin-right: .5rem !important;
    }

 
    .sticky-header input[type="date"].form-control-sm {
        font-size: 12px !important; /* dúng 12?px */
        height: calc(1.1em + .2rem + 2px); /* gi? cùng chi?u cao */
    }

    .sticky-header label {
        font-size: 12px !important;
        line-height: 1.2;
    }

    button:disabled {
        pointer-events: none; /* Không cho hover/click */
        opacity: 0.6; /* Cho nó mờ đi */
        cursor: not-allowed; /* Hiện con trỏ cấm */
        background-color: #ccc !important; /* tuỳ chỉnh màu khi disable */
    }

   

    #groupCode.form-control-sm,
    #subGroupCode.form-control-sm {
        height: 26px !important; /* chiều cao nhỏ */
        font-size: 12px !important; /* chữ nhỏ */
        padding: 2px 6px !important; /* padding nhỏ */
        line-height: 1.2 !important; /* căn giữa chữ */
        max-width: 180px; /* chiều rộng vừa phải */
    }

    #historyModal .modal-dialog.custom-modal-width {
        max-width: 1650px !important;
        width: 1650px !important;
    }
    .custom-modal-width {
    max-width: 560px !important; /* bạn chỉnh số px tuỳ ý */

 
}


</style>

<div class="text-center" id="reportTitle" style="font-size: 20px">Out of Order and Service </div>
<div class="sticky-header bg-white p-2 shadow-sm z-3">
    <div class="pb-2">
        <button id="btnView" class="mui-button mui-button-new">View</button>
        <button id="btnNew" class="mui-button mui-button-new" type="button">  New</button>
        <button id="btnEdit" class="mui-button mui-button-new" type="button">  Edit</button>
        <button id="btnDelete" class="mui-button mui-button-new" type="button">  Delete</button>
        <button id="btnHistory" class="mui-button mui-button-new" type="button">  History</button>
    </div>
    <div class="row g-2 align-items-center mb-1 mt-2 px-1">

        <div class="col-auto">
            <div class="row g-1 align-items-center">
                <div class="col-auto">
                    <label class="mb-0 small fw-bold">From Date:</label>
                </div>
                <div class="col-auto">
                    @* <input type="date" id="fromDate" name="fromDate" class="form-control form-control-sm" style="width: 130px;" /> *@
                        
                    <div data-date-input data-format="DD/MM/YYYY" business-date
                         data-name="fromDate" style="width: 130px;">
                        <input type="text" id="" class="date-ui form-control form-control-sm"
                               placeholder="dd/mm/yyyy" autocomplete="off" />
                    </div>
                </div>
            </div>
        </div>

        <div class="col-auto">
            <div class="row g-1 align-items-center">
                <div class="col-auto">
                    <label class="mb-0 small fw-bold">To Date:</label>
                </div>
                <div class="col-auto">
                    @* <input type="date" id="toDate" name="toDate" class="form-control form-control-sm" style="width: 130px;" /> *@
                    <div data-date-input data-format="DD/MM/YYYY" business-date
                         data-name="toDate" style="width: 130px;">
                        <input type="text" id="" class="date-ui form-control form-control-sm"
                               placeholder="dd/mm/yyyy" autocomplete="off" />
                    </div>
                </div>
            </div>
        </div>

        <div class="col-auto">
            <div class="row g-1 align-items-center">
                <div class="col-auto">
                    <label class="mb-0 small fw-bold">Room:</label>
                </div>
                <div class="col-auto" style="width: 180px;">
                    <select id="room" class="tomselect-custom" multiple>
                        @foreach (var u in ViewBag.RoomList)
                        {
                            <option value="@u.RoomNo">@u.RoomNo - @u.RoomTypeCode</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="col-auto">
            <div class="row g-1 align-items-center">
                <div class="col-auto">
                    <label class="mb-0 small fw-bold">Room Class:</label>
                </div>
                <div class="col-auto">
                    <select id="roomClass" class="tomselect-custom" style="width: 90px;">
                        @foreach (var g in ViewBag.RoomClassList)
                        {
                            <option value="@g.ID">@g.Code</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="col-auto">
            <div class="row g-1 align-items-center">
                <div class="col-auto">
                    <label class="mb-0 small fw-bold">Zone:</label>
                </div>
                <div class="col-auto" style="width: 180px;">
                    <select id="zone" class="tomselect-custom" multiple>
                        @foreach (var z in ViewBag.ZoneList)
                        {
                            <option value="@z.Code">@z.Code </option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="col-auto">
            <div class="row g-2 align-items-center">
                <div class="col-auto">
                    <label class="mb-0 small fw-bold">Type:</label>
                </div>
                <div class="col-auto">
                    <div class="form-check form-check-inline mb-0">
                        <input class="form-check-input" type="checkbox" name="optionFilter" id="outofOrder" checked>
                        <label class="form-check-label small" for="outofOrder">Out of Order</label>
                    </div>
                    <div class="form-check form-check-inline mb-0">
                        <input class="form-check-input" type="checkbox" name="optionFilter" id="outofService" checked>
                        <label class="form-check-label small" for="outofService">Out of Service</label>
                    </div>
                </div>
            </div>
        </div>

    </div>

   
</div>
<div class="mui-card">

    <div id="gridWrapper" class="mt-2" style="max-height: 500px;">
        <div class="gridContainer"  id="gridContainer"></div>
    </div>

    <!-- Modal Popup for New Item -->
    <div class="modal fade" id="itemModal" tabindex="-1" data-bs-backdrop="static" aria-labelledby="itemModalLabel" aria-hidden="true">
        <div class="modal-dialog custom-modal-width">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="itemModalLabel">Out of order/service management</h5>
                </div>

                <div class="modal-body">
                    <div class="py-2">
                        <button type="button" id="btnSaveItem" class="mui-button mui-button-new">Save</button>
                        <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                    </div>
                    
                    <form id="formContainer">
                        <div class="container-fluid px-2">
                            <input type="hidden" id="id" name="id" value="0" />

                            <div class="row g-3 mb-2 align-items-center">
                                <div class="col-md-7">
                                    <div class="row align-items-center">
                                        <label class="col-sm-5 col-form-label text-md-end fw-bold px-1">Type:</label>
                                        <div class="col-sm-7">
                                            <div class="d-flex gap-3">
                                                <div class="form-check m-0">
                                                    <input class="" type="radio" name="oooOrS" id="ooo" value="1">
                                                    <label class="form-check-label" for="ooo">OOO</label>
                                                </div>
                                                <div class="form-check m-0">
                                                    <input class="" type="radio" name="oooOrS" id="oos" value="2" checked>
                                                    <label class="form-check-label" for="oos">OOS</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-5">
                                    <div class="row align-items-center">
                                        <label class="col-sm-5 col-form-label text-md-end fw-bold px-1">From Date:</label>
                                        <div class="col-sm-7">
                                            <div data-date-input data-format="DD/MM/YYYY" business-date data-name="itemFromDate" name="itemFromDate">
                                                <input type="text" class="date-ui form-control form-control-sm" placeholder="dd/mm/yyyy" autocomplete="off" />
                                            </div>
                                            <div class="invalid-feedback"></div>

                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row g-3 mb-2 align-items-center">
                                <div class="col-md-7">
                                    <div class="row align-items-center">
                                        <label class="col-sm-5 col-form-label text-md-end fw-bold px-1">Return Status:</label>
                                        <div class="col-sm-7">
                                            <select id="rtStatus" name="rtStatus" class="tomselect-custom">
                                                <option value="2">Dirty</option>
                                                <option value="1">Clean Non-Checked</option>
                                                <option value="3">Pickup</option>
                                                <option value="4">Clean</option>
                                            </select>
                                            <div class="invalid-feedback"></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-5">
                                    <div class="row align-items-center">
                                        <label class="col-sm-5 col-form-label text-md-end fw-bold px-1">To Date:</label>
                                        <div class="col-sm-7">
                                            <div data-date-input data-format="DD/MM/YYYY" business-date data-name="itemToDate" name="itemToDate">
                                                <input type="text" class="date-ui form-control form-control-sm" placeholder="dd/mm/yyyy" autocomplete="off" />
                                            </div>
                                            <div class="invalid-feedback"></div>

                                        </div>
                                    </div>
                                </div>
                            </div>

                            <hr class="my-3 opacity-25">

                            <div class="row mb-2 align-items-center">
                                <label class="col-sm-3 col-form-label text-md-end fw-bold px-1">Reason:</label>
                                <div class="col-sm-9">
                                    <select id="comment" name="comment" class="tomselect-custom">
                                        @foreach (var dpm in ViewBag.CommentList)
                                        {
                                            <option value="@dpm.ID" data-desc="@dpm.Description">@dpm.Code - @dpm.Description</option>
                                        }
                                    </select>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>

                            <div class="row mb-2 align-items-center">
                                <label class="col-sm-3 col-form-label text-md-end fw-bold px-1">Reason Note:</label>
                                <div class="col-sm-9">
                                    <input type="text" id="txtReasonDesc" name="txtReasonDesc" class="form-control form-control-sm" placeholder="Enter additional notes..." />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>

                            <div class="row mb-2 align-items-center">
                                <label class="col-sm-3 col-form-label text-md-end fw-bold px-1">Room Select:</label>
                                <div class="col-sm-9">
                                    <select id="roomSelect" name="roomSelect" class="tomselect-custom" multiple>
                                        @foreach (var u in ViewBag.RoomList)
                                        {
                                            <option value="@u.ID">@u.RoomNo</option>
                                        }
                                    </select>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>

    <!-- History Modal -->
    <div class="modal fade" id="historyModal" tabindex="-1" aria-labelledby="historyModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <!-- rộng hơn để chứa grid -->
            <div class="modal-content"">
                <div class="modal-header">
                    <h5 class="modal-title" id="historyModalLabel">Room Change History</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
               
                <div class="modal-body">
                    <div class="item-modal-actions">
                        <button class="mui-button mui-button-new" id="btnHistorySearch">Search</button>
                        <button class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                    </div>
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2" style="border: 1px solid #ced4da; border-radius: 6px; padding: 8px;">

                        <div class="d-flex align-items-center me-2">
                            <label class="me-2 mb-0">Room:</label>
                            <input type="text" id="historyRoom" class="form-control form-control-sm w-auto" />
                        </div>
                        <div class="d-flex align-items-center me-2">
                            <label class="me-2 mb-0">User Name:</label>
                            <input type="text" id="historyUser" class="form-control form-control-sm w-auto" />
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <div class="d-flex align-items-center">
                                <label for="historyFromDate" class="me-2 mb-0">From Date:</label>
                                <input type="date" id="historyFromDate" class="form-control form-control-sm w-auto" />
                            </div>
                            <div class="d-flex align-items-center">
                                <label for="historyToDate" class="me-2 mb-0">To Date:</label>
                                <input type="date" id="historyToDate" class="form-control form-control-sm w-auto" />
                            </div>
                        </div>

                                            
                    </div>
           
                 
                    <div id="gridWrapper">
                        <div class="gridContainer mt-2" id="historyGrid"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
<div id="loadingSpinner" style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:1000;">
    <i class="fa-solid fa-spinner fa-spin"></i>
</div>
<script>
    let selectedRowData = null;

    $(document).ready(async function () {
        await window.businessDateReady;
        initTomSelect(".tomselect-custom");
        $("#btnView").trigger("click");
         
        $('#itemModal').on('hidden.bs.modal', function () {
            ValidationAdapter.clear("#formContainer");
        });

        $("#formContainer").on("input", "input, textarea", function () {
            if ($(this).hasClass("is-invalid")) {
                ValidationAdapter.clearField(this);
            }
        });

        $("#formContainer").on("change", "select.tomselect-custom", function () {
            if (this.tomselect) {
                ValidationAdapter.clearField(this);
            }
        });
    });

    document.getElementById("comment").addEventListener("change", function () {
        var desc = this.options[this.selectedIndex].getAttribute("data-desc");
        document.getElementById("txtReasonDesc").value = desc || "";
    });         

    function getStatusValue() {
        const isOOO = $('#outofOrder').is(':checked');
        const isOOS = $('#outofService').is(':checked');

        if (isOOO && isOOS) return 0; // Chọn cả hai
        if (isOOO) return 1;          // Chỉ OOO
        if (isOOS) return 2;          // Chỉ OOS
        return 3;                     // Không chọn cái nào
    }

    function loadHistoryOOOGrid(data) {
            $("#gridContainer").dxDataGrid({
            dataSource: data,
            height: 500,
            width: "100%",              
            columnAutoWidth: false,    
            allowColumnResizing: true,
            columnResizingMode: "widget",
            selection: { mode: "single" },
            columns: [
            { dataField: "id", visible:false},
            { dataField: "roomID", visible:false},
            { dataField: "reasonID", visible:false},
            { dataField: "code", caption: "Code", width: "8%" },
            { dataField: "roomNo", caption: "Room No", width: "7%" },
            { dataField: "roomType", caption: "Room Type", width: "7%" },
            { dataField: "floor", caption: "Floor", width: "6%" },
            { dataField: "zone", caption: "Zone", width: "6%" },
            { dataField: "fromDate", caption: "From Date", width: "8%", dataType: "date", format: "dd/MM/yyyy" },
            { dataField: "toDate", caption: "To Date", width: "8%", dataType: "date", format: "dd/MM/yyyy" },
            { dataField: "noOfNights", caption: "Nights", width: "8%" },
            { dataField: "reason", caption: "Reason", width: "15%" },
            { dataField: "status", caption: "Status", width: "7%" },
            { dataField: "userCreate", caption: "User Create", width: "6%" },
            { dataField: "createdDate", caption: "Create Date", dataType: "date", format: "dd/MM/yyyy", width: "8%" },
            { dataField: "userUpdate", caption: "User Update", width: "6%" },
            { dataField: "updatedDate", caption: "Update Date", dataType: "date", format: "dd/MM/yyyy", width: "8%" },
        ],
            scrolling: {
                    mode: "standard", 
                    showScrollbar: "always",
                    scrollByContent: true
                },
                paging: {
                    pageSize: 20
                },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, 'all'],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                columnAutoWidth: true,
                    filterRow: {
                visible: true,
                applyFilter: "auto"
            },
                summary: {
                totalItems: [{
                    column: "noOfNights",
                    summaryType: "sum",
                    displayFormat: "Total: {0}",
                    showInColumn: "noOfNights"
                }]
            },
            onSelectionChanged: function (e) {
                if (e.selectedRowsData.length > 0) {
                    selectedRowData = e.selectedRowsData[0]; 
                    console.log("Selected Row:", selectedRowData);
                } else {
                    selectedRowData = null;

                }
            }
        });
        }

    $(document).off("click", "#btnView").on("click", "#btnView", function () {
         reloadGrid();
    });

    function reloadGrid() {
        const roomClass = getTomSelectData("#roomClass");
        const zone = getTomSelectData("#zone");

        const status = getStatusValue();
        $("#loadingSpinner").show();

        $.ajax({
            url: '/RoomManagement/GetOOOSload',
            type: 'GET',
            data: {
                status: status,
                roomNo: $("#room").val(),
                roomClassID: roomClass?.value,
                fromDate: $("#fromDate").val() || dateSystem ,
                toDate: $("#toDate").val() || dateSystem,
                zone: zone ? zone.map(x => x.value).join(",") : ""

            },
            success: function (data) {
                loadHistoryOOOGrid(data);
                $("#loadingSpinner").hide();
            },
            error: function (xhr, status, error) {
                alert("Unable to load data");
                $("#loadingSpinner").hide();
            }
        });
    }

    $("#btnNew").on("click", function () {

        FormModal.open("#itemModal", "#formContainer", {
            onOpen: () => {
               $("#id").val(0);
                $("#itemModalLabel").text("New OOOS");

                clearMultipleTomSelect([
                    "#roomSelect",
                    "#comment"
                ]);
            }
       
        });
    });

    $("#btnEdit").on("click", function () {
        if (!selectedRowData) {
            showToast("Warning","Please select a row first!", false);
            return;
        }

        FormModal.open("#itemModal", "#formContainer", {
            onOpen: () => {
                fillEditForm(selectedRowData);
                 $("#itemModalLabel").text("Update OOOS");
            }

        });
    });
    
    const OOO_STATUS_MAP = {
        "OOO": "1",
        "OOS": "2"
    };

    function setOOOStatus(status) {
        const key = (status || "").toUpperCase();
        const value = OOO_STATUS_MAP[key];
        if (!value) return;

        $("input[name='oooOrS'][value='" + value + "']")
            .prop("checked", true);
    }

    function fillEditForm(data) {

        setOOOStatus(data.status);

        setTomSelectValue("#roomSelect", data.roomID);

        setTomSelectValue("#rtStatus", data.returnStatusID);
        setTomSelectValue("#comment", data.reasonID);

        $("#txtReasonDesc").val(data.reason || "");

        $("[data-name='itemFromDate'] input")
            .val(formatDate(data.fromDate));

        $("[data-name='itemToDate'] input")
            .val(formatDate(data.toDate));

        $("#id").val(data.id);
    }

    $("#btnHistory").click(function () {
            openHistoryPopup();
    });

    $("#btnHistorySearch").click(function () {
            openHistoryPopup();
    });

    function openHistoryPopup() {
            $("#historyModal").modal("show");

            // gọi ajax load dữ liệu
            $.ajax({
                url: "/RoomManagement/GetRoomStatusHistoryOOO",
                type: "GET",
                data: { 
                    roomNo: $("#historyRoom").val(),
                    userName: $("#historyUser").val(),
                    fromDate: $("#historyFromDate").val(),
                    toDate: $("#historyToDate").val()
             
                },
                success: function (data) {
                    $("#historyGrid").dxDataGrid({
                        dataSource: data, // bind dữ liệu trả về
                        columnAutoWidth: true,
                        showBorders: true,
                        showColumnLines: true, // hiện đường kẻ cột
                        showRowLines: true,    // hiện đường kẻ hàng
                        height: 600,  // chiều cao lưới
                        width: "100%", // full chiều rộng popup
                        scrolling: { mode: "virtual" },
                        columns: [
                            { dataField: "roomNo", caption: "Room No" , width: "6%"},
                            { dataField: "action", caption: "Action", width: "9%" },
                            { dataField: "oldValue", caption: "Old Value", width: "32%" },
                            { dataField: "newValue", caption: "New Value" , width: "32%"},
                            { dataField: "userName", caption: "User" , width: "5%"},
                            { dataField: "computerName", caption: "Computer" , width: "6%"},
                            { dataField: "changeDate", caption: "Change Date", dataType: "date", format: "dd/MM/yyyy HH:mm", width: "9%" }
                        ]
                    });
                },
                error: function () {
                    alert("Lỗi khi load dữ liệu history");
                }
            });
        }
    
    $("#btnSaveItem").click(function () {
        SaveOOOS();
    });

    function SaveOOOS() {
        const userName = JSON.parse(localStorage.getItem("Loginname"));
        const userID = JSON.parse(localStorage.getItem("userID"));
        var formData = new FormData();

        const rooms = getTomSelectData("#roomSelect") || [];
        const status = getTomSelectData("#rtStatus");
        const comment = getTomSelectData("#comment");

        // Append vào formData
        formData.append("roomSelect", rooms.map(x => x.value).join(","));
        formData.append("roomNo", rooms.map(x => x.text).join(","));
        formData.append(
          'oooOrS',
          $("input[name='oooOrS']:checked").val()
        );
        formData.append("rtStatus", status?.value ?? "");
        formData.append("comment", comment?.value ?? "");
        formData.append('txtReasonDesc', $("#txtReasonDesc").val());
        formData.append('itemFromDate', $("#itemFromDate").val());
        formData.append('itemToDate', $("#itemToDate").val());
        formData.append('userName', userName);
        formData.append('userID', userID);

        // Nếu đang edit, lấy id từ selectedRowData
        if (selectedRowData && selectedRowData.id) {
            formData.append('id', selectedRowData.id);
        }

        $.ajax({
            url: '/RoomManagement/UpdateandInsertBusinessBlock',
            type: 'POST',
            processData: false,
            contentType: false,
            data: formData,
            success: function (res) {
                if (res.success) {
                    showToast("Success", res.message, true);
                    FormModal.close("#itemModal", "#formContainer");
                    $("#btnView").trigger("click");
                } else {
                    ValidationAdapter.apply(res.errors || [], "#formContainer");
                    showToast("Warning", res.message || "Invalid data", false);
                }
            },
            error: function (xhr, statusText, err) {
                showToast('Error', "Save error!", false);
            }
        });
    }

    $("#btnDelete").click(function () {
        if (!selectedRowData) {
            DevExpress.ui.notify("Please select a row first!", "warning", 2000);
            return;
        }
        if (confirm("Bạn có chắc chắn muốn xoá bản ghi này không?")) {
               deleteSelectedItem();
        }
    });

    function deleteSelectedItem() {
        $.post("/RoomManagement/DeleteBusinessBlock", { id: selectedRowData.id }, function (res) {
            if (res.deleted > 0) {
                showToast("Success", "Deleted successfully!", true);
                   $("#btnView").trigger("click");
                selectedRowData = null;
            } else {
                showToast("Error", "Delete failed!", false);
            }
        }).fail(function (xhr) {
            console.error("Delete error:", xhr.responseText);
            showToast("Error", "Delete error!", false);
        });
    }


     

</script>
