<!-- Main Modal -->
<div class="modal fade"
     id="proTp_mainModal"
     tabindex="-1"
     aria-labelledby="proTp_mainModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-md-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="proTp_mainModalLabel">Property Type</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <button id="proTp_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="proTp_btnUpdate" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="proTp_btnDelete" type="button" class="mui-button mui-button-delete">Delete</button>
                        <button type="button"
                                class="mui-button mui-button-new"
                                data-bs-dismiss="modal"
                                aria-label="Close">
                            Close
                        </button>
                    </div>
                </div>

                <div class="mui-card mt-1">
                    <div id="proTp_gridContainer" class="gridContainer"></div>
                </div>

                <div id="proTp_loadingSpinner"
                     style="position: absolute;
                            top: 50%;
                            left: 50%;
                            transform: translate(-50%, -50%);
                            z-index: 999;
                            background: rgba(255, 255, 255, 0.55);
                            backdrop-filter: blur(2px);
                            width: 100%;
                            height: 100%;
                            display: flex;
                            align-items: center;
                            justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade"
     id="proTp_itemModal"
     tabindex="-1"
     aria-labelledby="proTp_itemModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="proTp_itemModalLabel">Add Property Type</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <button type="button" id="proTp_btnSave" class="mui-button mui-button-new">Save</button>
                    <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>

                <form id="proTp_formContainer">
                    <div class="row g-2 mt-1 mb-2">
                        <div class="col-12 col-lg-6">
                            <div class="row g-2">
                                <label for="proTp_code"
                                       class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Code
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <input id="proTp_code"
                                           name="proTp_code"
                                           type="text"
                                           class="form-control form-control-sm"
                                           placeholder="Enter code..." />
                                    <div class="invalid-feedback" id="proTp_codeError"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-2">
                                <label for="proTp_sequence"
                                       class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Sequence
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <input id="proTp_sequence"
                                           name="proTp_sequence"
                                           type="number"
                                           class="form-control form-control-sm"
                                           placeholder="0" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="proTp_description"
                                       class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Description
                                </label>
                                <div class="col-md-10">
                                    <textarea id="proTp_description"
                                              name="proTp_description"
                                              rows="4"
                                              class="form-control form-control-sm"
                                              style="height:100px"
                                              placeholder="Enter description..."></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="proTp_id" name="proTp_id" value="0" />
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    var proTp_Module = (() => {
        let proTp_selectedRowData = null;

        const proTp_selectors = {
            mainModal: "#proTp_mainModal",
            itemModal: "#proTp_itemModal",
            form: "#proTp_formContainer",
            grid: "#proTp_gridContainer",
            loading: "#proTp_loadingSpinner",
            btnNew: "#proTp_btnNew",
            btnUpdate: "#proTp_btnUpdate",
            btnDelete: "#proTp_btnDelete",
            btnSave: "#proTp_btnSave",
            modalLabel: "#proTp_itemModalLabel",
            id: "#proTp_id",
            code: "#proTp_code",
            description: "#proTp_description",
            sequence: "#proTp_sequence"
        };

        function proTp_init() {
            proTp_bindEvents();
            proTp_clearForm();
            proTp_loadGrid([]);
            proTp_reloadGrid();
        }

        function proTp_bindEvents() {
            $(document)
                .off("input change", `${proTp_selectors.form} input, ${proTp_selectors.form} select, ${proTp_selectors.form} textarea`)
                .on("input change", `${proTp_selectors.form} input, ${proTp_selectors.form} select, ${proTp_selectors.form} textarea`, function () {
                    if ($(this).hasClass("is-invalid")) {
                        $(this).removeClass("is-invalid");
                        $(this).next(".invalid-feedback").text("");
                    }
                });

            $(proTp_selectors.itemModal)
                .off("hidden.bs.modal")
                .on("hidden.bs.modal", function () {
                    applyValidationErrors([], proTp_selectors.form);
                });

            $(document)
                .off("click", proTp_selectors.btnNew)
                .on("click", proTp_selectors.btnNew, function () {
                    proTp_openAddModal();
                });

            $(document)
                .off("click", proTp_selectors.btnUpdate)
                .on("click", proTp_selectors.btnUpdate, function () {
                    proTp_openEditModal();
                });

            $(document)
                .off("click", proTp_selectors.btnSave)
                .on("click", proTp_selectors.btnSave, function () {
                    proTp_save();
                });

            $(document)
                .off("click", proTp_selectors.btnDelete)
                .on("click", proTp_selectors.btnDelete, function () {
                    proTp_delete();
                });
        }

        function proTp_showLoading() {
            $(proTp_selectors.loading).show();
        }

        function proTp_hideLoading() {
            $(proTp_selectors.loading).hide();
        }

        function proTp_loadGrid(proTp_data) {
            const proTp_dataSource = proTp_data || [];

            $(proTp_selectors.grid).dxDataGrid({
                dataSource: proTp_dataSource,
                width: "100%",
                columnAutoWidth: true,
                allowColumnResizing: true,
                selection: {
                    mode: "single"
                },
                hoverStateEnabled: true,
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "code", caption: "Code", width: "100" },
                    { dataField: "description", caption: "Description", minWidth: 120, cssClass: "col-description" },
                    { dataField: "sequence", caption: "Squence", width: "80" }
                ],
                filterRow: {
                    visible: true,
                    applyFilter: "auto"
                },
                paging: {
                    pageSize: 20
                },
                pager: {
                    showPageSizeSelector: true,
                    allowedPageSizes: [20, 50],
                    showInfo: true
                },
                onSelectionChanged: function (e) {
                    proTp_selectedRowData = e.selectedRowsData.length > 0
                        ? e.selectedRowsData[0]
                        : null;
                }
            });
        }

        function proTp_reloadGrid() {
            proTp_showLoading();

            $.ajax({
                url: "/Administration/GetPropertyType",
                type: "GET",
                dataType: "json",
                cache: false,
                success: function (proTp_data) {
                    proTp_loadGrid(proTp_data);
                },
                error: function () {
                    showToast("Error", "Load data failed", false);
                },
                complete: function () {
                    proTp_hideLoading();
                }
            });
        }

        function proTp_clearForm() {
            $(proTp_selectors.id).val("0");
            $(proTp_selectors.code).val("");
            $(proTp_selectors.description).val("");
            $(proTp_selectors.sequence).val("0");
        }

        function proTp_openAddModal() {
            const proTp_form = $(proTp_selectors.form)[0];

            if (proTp_form) {
                proTp_form.reset();
            }

            $(proTp_selectors.id).val("0");
            $(proTp_selectors.modalLabel).text("Add Property Type");
            $(proTp_selectors.itemModal).modal("show");
        }

        function proTp_openEditModal() {
            if (!proTp_selectedRowData) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }

            $(proTp_selectors.modalLabel).text("Edit Property Type");
            $(proTp_selectors.itemModal).modal("show");
            $(proTp_selectors.id).val(proTp_selectedRowData.id);
            $(proTp_selectors.code).val(proTp_selectedRowData.code);
            $(proTp_selectors.description).val(proTp_selectedRowData.description);
            $(proTp_selectors.sequence).val(proTp_selectedRowData.sequence);
        }

        function proTp_getSaveModel() {
            const proTp_id = parseInt($(proTp_selectors.id).val()) || 0;
            let proTp_loginName = (localStorage.getItem("Loginname") || "")
                .trim()
                .replace(/^"(.*)"$/, "$1");

            return {
                id: proTp_id,
                code: $(proTp_selectors.code).val().trim(),
                description: $(proTp_selectors.description).val().trim(),
                sequence: $(proTp_selectors.sequence).val() || 0,
                createdBy: proTp_loginName,
                updatedBy: proTp_loginName
            };
        }

        function proTp_save() {
            const proTp_model = proTp_getSaveModel();

            $.ajax({
                url: "/Administration/PropertyTypeSave",
                type: "POST",
                cache: false,
                contentType: "application/json",
                data: JSON.stringify(proTp_model),
                success: function (proTp_res) {
                    if (proTp_res.success) {
                        showToast("Success", proTp_res.message, true);
                        proTp_reloadGrid();
                        proTp_clearForm();
                        $(proTp_selectors.itemModal).modal("hide");
                    } else {
                        if (proTp_res.errors && proTp_res.errors.length > 0) {
                            applyValidationErrors(proTp_res.errors, proTp_selectors.form);
                            showToast("Warning", "Please check input fields.", false);
                        } else {
                            showToast("Error", proTp_res.message || "Save failed", false);
                        }
                    }
                },
                error: function () {
                    showToast("Error", "Save failed", false);
                }
            });
        }

        function proTp_delete() {
            if (!proTp_selectedRowData) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }

            if (!confirm("Are you sure you want to delete this Property type?")) {
                return;
            }

            $.ajax({
                url: `/Administration/PropertyTypeDelete/` + proTp_selectedRowData.id,
                type: "POST",
                success: function (proTp_res) {
                    if (proTp_res.success) {
                        showToast("Success", "Deleted successfully", true);
                        proTp_reloadGrid();
                        $("#btnCancel").trigger("click");
                    } else {
                        showToast("Error", proTp_res.message, false);
                    }
                }
            });
        }

        return {
            init: proTp_init,
            reloadGrid: proTp_reloadGrid,
            openAddModal: proTp_openAddModal,
            openEditModal: proTp_openEditModal
        };
    })();

    window.openModalPropertyType = function () {
        const modalEl = document.querySelector("#proTp_mainModal");
        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

        $(modalEl).one("shown.bs.modal", function () {
            proTp_Module.init();
        });
        modal.show();
    };
</script>