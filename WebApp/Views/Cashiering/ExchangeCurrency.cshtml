@using DevExpress.XtraReports.UI

@{
    var selectedReport = @ViewBag.ReportHeader;
}

<div class="modal fade" id="exCu_modalMain" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title fw-bold text-primary" id="exCu_modalTitle">Exchange Currency</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">
                    <!-- ACTIONS -->
                    <div>
                        <button id="exCu_btnView" type="button" class="mui-button mui-button-new">View</button>
                        <button id="exCu_btnExportExcel" type="button" class="mui-button mui-button-new">Excel</button>
                        <button id="exCu_btnPrintGrid" type="button" class="mui-button mui-button-new">Print</button>
                        <button id="exCu_btnClose" type="button" class="mui-button mui-button-new">Close</button>
                    </div>

                    <!-- FILTER -->
                    <div class="mt-1">
                        <div class="row g-2 align-items-center">

                            <!-- From -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2 col-xl-2">
                                <div class="d-flex align-items-center gap-2">
                                    <label for="exCu_fromDateUi"
                                        class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 fw-bold mb-0 text-nowrap text-md-end">
                                        From:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <div data-date-input data-format="DD/MM/YYYY" business-date data-name="exCu_fromDate">
                                            <input id="exCu_fromDateUi"
                                                name="exCu_fromDateUi"
                                                type="text"
                                                class="date-ui form-control form-control-sm"
                                                placeholder="dd/mm/yyyy"
                                                autocomplete="off" />
                                        </div>
                                        <input type="hidden" id="exCu_fromDate" name="exCu_fromDate" />
                                    </div>
                                </div>
                            </div>

                            <!-- To -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2 col-xl-2">
                                <div class="d-flex align-items-center gap-2">
                                    <label for="exCu_toDateUi"
                                        class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 fw-bold mb-0 text-nowrap text-md-end">
                                        To:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <div data-date-input data-format="DD/MM/YYYY" business-date data-name="exCu_toDate">
                                            <input id="exCu_toDateUi"
                                                name="exCu_toDateUi"
                                                type="text"
                                                class="date-ui form-control form-control-sm"
                                                placeholder="dd/mm/yyyy"
                                                autocomplete="off" />
                                        </div>
                                        <input type="hidden" id="exCu_toDate" name="exCu_toDate" />
                                    </div>
                                </div>
                            </div>

                            <!-- Account -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2 col-xl-2">
                                <div class="d-flex align-items-center gap-2">
                                    <label for="exCu_account"
                                        class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 fw-bold mb-0 text-nowrap text-md-end">
                                        Account:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <input type="text"
                                            id="exCu_account"
                                            name="exCu_account"
                                            class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>

                            <!-- Room -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2 col-xl-2">
                                <div class="d-flex align-items-center gap-2">
                                    <label for="exCu_roomNo"
                                        class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 fw-bold mb-0 text-nowrap text-md-end">
                                        Room:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <input type="text"
                                            id="exCu_roomNo"
                                            name="exCu_roomNo"
                                            class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>

                            <!-- ID/Passport -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl-3">
                                <div class="d-flex align-items-center gap-2">
                                    <label for="exCu_passPort"
                                        class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 fw-bold mb-0 text-nowrap text-md-end">
                                        ID/Passport:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <input type="text"
                                            id="exCu_passPort"
                                            name="exCu_passPort"
                                            class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>

                            <!-- Include Delete -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl-3">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="col-4 col-sm-4 col-md-3 col-lg-3 col-xl-3 fw-bold mb-0 text-nowrap text-md-end">
                                        Include:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <div class="form-check d-flex align-items-center gap-1 mb-0">
                                            <input
                                                type="checkbox"
                                                id="exCu_isDelete"
                                                name="exCu_isDelete">
                                            <label class="form-check-label fw-bold text-danger mb-0"
                                                for="exCu_isDelete"
                                                style="cursor:pointer;">
                                                Include Delete
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- GRID -->
                <div class="gridContainer flex-grow-1 bg-white position-relative" id="exCu_gridWrapper">
                    <div id="exCu_gridContainer" style="height: 100%; width: 100%;"></div>
                </div>

                <!-- LOADING -->
                <div id="exCu_loadingSpinner"
                        style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                            z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                            height: 100%;display: flex;align-items: center;justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    var exCu_Module = (function () {

        let mainModal = null;

        let selectedRow = null;
        let gridInstance = null;

        const sel = {
            modalMain: "#exCu_modalMain",

            btnView: "#exCu_btnView",
            btnExcel: "#exCu_btnExportExcel",
            btnPrint: "#exCu_btnPrintGrid",
            btnClose: "#exCu_btnClose",

            loading: "#exCu_loadingSpinner",

            fromHidden: "#exCu_fromDate",
            toHidden: "#exCu_toDate",

            account: "#exCu_account",
            roomNo: "#exCu_roomNo",
            passPort: "#exCu_passPort",
            isDelete: "#exCu_isDelete",

            grid: "#exCu_gridContainer"
        };

        function init() {
            DevExpress.localization.locale("vi");
            mainModal = bootstrap.Modal.getOrCreateInstance(document.querySelector(sel.modalMain), { backdrop: "static" });

            $(sel.modalMain).off("shown.bs.modal.exCu").on("shown.bs.modal.exCu", async function () {
                bindEvents();
                initPickers();
                await ensureBusinessDate();
                await view(true);
            });

            $(sel.modalMain).off("hidden.bs.modal.exCu").on("hidden.bs.modal.exCu", function () {
                cleanup();
            });
        }

        function open() {
            mainModal.show();
        }

        function bindEvents() {
            $(document).off("click.exCu", sel.btnView).on("click.exCu", sel.btnView, async function () {
                await view(false);
            });

            $(document).off("click.exCu", sel.btnPrint).on("click.exCu", sel.btnPrint, function () {
                printSelected();
            });

            $(document).off("click.exCu", sel.btnExcel).on("click.exCu", sel.btnExcel, function () {
                exportExcel();
            });

            $(document).off("click.exCu", sel.btnClose).on("click.exCu", sel.btnClose, function () {
                mainModal.hide();
            });
        }

        function initPickers() {
            if (typeof window.initDateInputs === "function") window.initDateInputs();
        }

        async function ensureBusinessDate() {
            // Preferred business-date pipeline
            try {
                if (typeof window.waitForBusinessDate === "function") {
                    const fromIso = await window.waitForBusinessDate("exCu_fromDate", 10000);
                    const toIso = await window.waitForBusinessDate("exCu_toDate", 10000);
                    if (fromIso) $(sel.fromHidden).val(fromIso);
                    if (toIso) $(sel.toHidden).val(toIso);
                    if (fromIso && toIso) return;
                }
            } catch { }

            // Fallback endpoint
            return $.ajax({
                url: '/Reservation/GetBusinessDate',
                type: 'get',
                dataType: 'json',
                crossDomain: false,
                headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() },
                success: function (result) {
                    const iso = (result || "").split('T')[0];
                    $(sel.fromHidden).val(iso);
                    $(sel.toHidden).val(iso);
                },
                error: function (xhr) {
                    if (xhr.status === 401) sessionTimeout();
                }
            });
        }

        function getPayload() {
            const fromDate = $(sel.fromHidden).val() || "";
            const toDate = $(sel.toHidden).val() || "";

            return {
                account: $(sel.account).val() || "",
                passPort: $(sel.passPort).val() || "",
                roomNo: $(sel.roomNo).val() || "",
                fromDate: fromDate,
                toDate: toDate,
                isDelete: $(sel.isDelete).is(":checked") ? 1 : 0
            };
        }

        async function view(isInitial) {
            $(sel.loading).show();

            const payload = getPayload();

            if (!payload.fromDate || !payload.toDate) {
                $(sel.loading).hide();
                showToast("Warning", "Please select From/To date.", false);
                return;
            }

            $.ajax({
                url: '/Cashiering/GetExchangeCurrency',
                type: 'GET',
                data: payload,
                success: function (data) {
                    renderGrid(Array.isArray(data) ? data : []);
                    $(sel.loading).hide();
                },
                error: function (xhr, status, error) {
                    console.error("AJAX Error", status, error);
                    console.error("Response Text:", xhr.responseText);
                    $(sel.loading).hide();
                    showToast("Error", "Failed to load data.", false);
                    destroyGrid();
                }
            });
        }

        function destroyGrid() {
            try {
                if (gridInstance) {
                    gridInstance.dispose();
                    gridInstance = null;
                }
            } catch { }
            $(sel.grid).empty();
            selectedRow = null;
        }

        function renderGrid(data) {
            destroyGrid();

            gridInstance = $(sel.grid).dxDataGrid({
                dataSource: data,
                showBorders: true,
                height: "100%",
                width: "100%",

                columnAutoWidth: true,
                allowColumnResizing: true,

                selection: { mode: "single" },

                scrolling: {
                    mode: "standard",
                    showScrollbar: "always",
                    scrollByContent: true
                },

                paging: { pageSize: 50 },

                pager: {
                    visible: true,
                    allowedPageSizes: [50, 100, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },

                filterRow: { visible: true, applyFilter: "auto" },

                columns: [
                    { dataField: "invoiceNo", caption: "Invoice No", width: 90 },
                    { dataField: "transactionDate", caption: "Trans. Date", dataType: "datetime", format: "dd/MM/yyyy", width: 110 },

                    { dataField: "account", caption: "Guest Name", width: 160 },
                    { dataField: "passPort", caption: "PassPort", width: 120 },
                    { dataField: "roomNo", caption: "Room No", width: 80 },

                    { dataField: "totalAmount", caption: "Total Amount", dataType: "number", format: "#,##0.00", width: 120, alignment: "right" },

                    { dataField: "address", caption: "Address", width: 200 },
                    { dataField: "description", caption: "Description", width: 240 },

                    { dataField: "statusText", caption: "Status", width: 90 },
                    { dataField: "cashierName", caption: "Cashier Name", width: 130 },

                    { dataField: "createdBy", caption: "Created By", width: 100 },
                    { dataField: "createddate", caption: "Created Date", dataType: "datetime", format: "dd/MM/yyyy HH:mm", width: 150 },

                    { dataField: "updatedBy", caption: "Updated By", width: 100 },
                    { dataField: "updatedDate", caption: "Updated Date", dataType: "datetime", format: "dd/MM/yyyy HH:mm", width: 150 }
                ],

                onRowClick: function (e) {
                    selectedRow = e.data || null;
                }
            }).dxDataGrid("instance");
        }

        function printSelected() {
            if (!selectedRow || !selectedRow.id) {
                showToast("Warning", "Please select 1 row before printing.", false);
                return;
            }

            $(sel.loading).show();

            $.ajax({
                url: '/Cashiering/ExchangeCurrencyPrint',
                type: 'GET',
                data: { id: selectedRow.id },
                success: function (data) {
                    if (data && data.pdfBase64) {
                        const pdfWindow = window.open("");
                        pdfWindow.document.write(
                            "<iframe width='100%' height='100%' style='border:none' src='" + data.pdfBase64 + "'></iframe>"
                        );
                    } else {
                        showToast("Warning", "No PDF data returned.", false);
                    }
                    $(sel.loading).hide();
                },
                error: function (xhr, status, error) {
                    console.error("AJAX Error", status, error);
                    console.error("Response Text:", xhr.responseText);
                    $(sel.loading).hide();
                    showToast("Error", "Failed to print.", false);
                }
            });
        }

        function exportExcel() {
            const grid = $(sel.grid).dxDataGrid("instance");
            if (!grid) {
                showToast("Warning", "No data to export.", false);
                return;
            }

            const workbook = new ExcelJS.Workbook();
            const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const worksheet = workbook.addWorksheet("Sheet 1");

            worksheet.addRow([companyName]);
            worksheet.mergeCells('A1:D1');
            worksheet.getRow(1).font = { bold: true };
            worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

            const now = new Date();
            const exportDate = now.toLocaleString("vi-VN");
            worksheet.addRow(['', '', '', exportDate]);
            worksheet.mergeCells('D2:D2');
            worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

            worksheet.addRow([]);
            worksheet.addRow([]);

            const reportRow = worksheet.addRow(['Exchange Currency']);
            worksheet.mergeCells('A5:D5');
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

            worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const lastRow = worksheet.lastRow.number + 2;
                worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
                worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
                worksheet.getCell(`A${lastRow}`).font = { italic: true };

                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "Exchange Currency.xlsx");
                });
            });
        }

        function cleanup() {
            $(document).off(".exCu");
            destroyGrid();
        }

        return { init, open };

    })();

    // Option A global entry
    window.openModalExCu = function () {
        exCu_Module.open();
    };

    $(document).ready(function () {
        exCu_Module.init();
        // Auto-open if needed:
        // window.openModalExCu();
    });
</script>