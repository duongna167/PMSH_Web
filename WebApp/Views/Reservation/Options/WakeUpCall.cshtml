<div id="loadingSpinner">
    <i class="fa-solid fa-spinner fa-spin"></i>
</div>

<script>

     function openModalWakeupCall()  {
        initializeTomSelects();
        getBusinessDate();
        $("#popupWakeUpCall").modal('show');

        $("#viewWakeupcall").hide();
        toggleSection();

        $("input[name='call']").change(toggleSection);
        $("input[name='wake']").change(toggleSection);

        // radio timeView cho phép uncheck
        $("#rdoTimeView").on("click", function () {
            if ($(this).data("waschecked")) {
                $(this).prop("checked", false);
                $(this).data("waschecked", false);
            } else {
                $("input[name='timeView']").data("waschecked", false);
                $(this).data("waschecked", true);
            }
        });

        $("#btnCloseWakeup").on("click", function () {
            $("#popupWakeUpCall").modal("hide");
        });
    }

    function toggleSection() {
        $("#dateSection, #dailySection, #roomnoGroup, #scheduleGroup")
            .removeClass("show-important hidden-important show-important1");

        // Date/Daily
        if ($("#rdoDate").is(":checked")) {
            $("#dateSection").addClass("show-important");
            $("#dailySection").addClass("hidden-important");
        } else {
            $("#dateSection").addClass("hidden-important");
            $("#dailySection").addClass("show-important1");
        }

        // Set/Cancel/View
        if ($("#rdoSet").is(":checked")) {
            $("#setWakeup").show();
            $("#viewWakeupcall").hide();
            $("#roomnoGroup").addClass("show-important");
            $("#scheduleGroup").addClass("hidden-important");

            $("#rdoDate").next("label").text("Date");
            $("#rdoDaily").next("label").text("Daily");
            $("#dateSection :input, #dailySection :input").prop("readonly", false);

            $("#btnSetwakeup").show();
            $("#btnCancelwakeup").hide();
            $("#btnViewwakeup").hide();

        } else if ($("#rdoCancle").is(":checked")) {
            $("#setWakeup").show();
            $("#viewWakeupcall").hide();
            $("#roomnoGroup").addClass("hidden-important");
            $("#scheduleGroup").addClass("show-important");

            $("#rdoDate").next("label").text("Special Call");
            $("#rdoDaily").next("label").text("All Call");

            $("#scheduleLabel").text($("#rdoDaily").is(":checked") ? "Room:" : "Schedule:");

            $("#dateSection :input, #dailySection :input").prop("readonly", true);

            $("#btnSetwakeup").hide();
            $("#btnCancelwakeup").show();
            $("#btnViewwakeup").hide();

        } else if ($("#rdoView").is(":checked")) {
            $("#setWakeup").hide();
            $("#viewWakeupcall").show();

            $("#roomnoGroup, #scheduleGroup").addClass("hidden-important");

            $("#rdoDate").next("label").text("Date");
            $("#rdoDaily").next("label").text("Daily");
            $("#btnSetwakeup").hide();
            $("#btnCancelwakeup").hide();
            $("#btnViewwakeup").show();
        }
    }

    function getBusinessDate() {
        return $.ajax({
            url: '/Reservation/GetBusinessDate',
            type: 'get',
            dataType: 'json',
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                const d = result.split('T')[0];
                $('#singleDate').val(d);
                $('#fromDate').val(d);
                $('#toDate').val(d);
                $('#fromDateview').val(d);
                $('#toDateview').val(d);
            },
            error: function (xhr) {
                if (xhr.status == 401) sessionTimeout();
            }
        });
    }

    function initializeTomSelects() {
        const selectors = ["#zone", "#roomview"];
        for (const id of selectors) {
            const el = document.querySelector(id);
            if (!el) continue;
            if (el.tomselect) el.tomselect.destroy();
            new TomSelect(el, {
                plugins: ['remove_button'],
                create: false,
                maxItems: null,
                allowEmptyOption: true,
                placeholder: '',
                persist: false
            });
        }
    }

    // ======================= SET WAKEUP =======================
    $(document).off("click", "#btnSetwakeup").on("click", "#btnSetwakeup", function () {
        const callType = $("input[name='call']:checked").val();
        $("#loadingSpinner").show();

        const requestData = {
            callType: callType,
            singleDate: $("#singleDate").val(),
            timeDate: $("#timeDate").val(),
            fromDate: $("#fromDate").val(),
            toDate: $("#toDate").val(),
            timeDaily: $("#timeDaily").val(),
            selectedRows: selectedRowsData,
            userID: localStorage.getItem("userID")
        };

        $.ajax({
            url: '/FrontDesk/SetWakeUpCall',
            type: 'POST',
            contentType: "application/json",
            data: JSON.stringify(requestData),
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                showToast(result.success ? 'Success' : 'Error', result.message, result.success);
                $("#loadingSpinner").hide();
            },
            error: function () {
                alert("Không thể tải báo cáo.");
                $("#loadingSpinner").hide();
            }
        });
    });

    // ======================= CANCEL WAKEUP =======================
    $(document).off("click", "#btnCancelwakeup").on("click", "#btnCancelwakeup", function () {
        const callType = $("input[name='call']:checked").val();
        const confirmMessage = callType === "date"
            ? "Are you sure to delete?"
            : "Are you sure to delete all wake up call schedule in those rooms?";

        if (!confirm(confirmMessage)) return;

        $("#loadingSpinner").show();

        const requestData = {
            callType: callType,
            singleDate: $("#singleDate").val(),
            timeDate: $("#timeDate").val(),
            fromDate: $("#fromDate").val(),
            toDate: $("#toDate").val(),
            timeDaily: $("#timeDaily").val(),
            selectedRows: selectedRowsData,
            userID: localStorage.getItem("userID")
        };

        $.ajax({
            url: '/FrontDesk/CancelWakeUpCall',
            type: 'POST',
            contentType: "application/json",
            data: JSON.stringify(requestData),
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                showToast(result.success ? 'Success' : 'Error', result.message, result.success);
                $("#loadingSpinner").hide();
            },
            error: function () {
                alert("Không thể tải báo cáo.");
                $("#loadingSpinner").hide();
            }
        });
    });

    // ======================= VIEW WAKEUP =======================
    $(document).off("click", "#btnViewwakeup").on("click", "#btnViewwakeup", function () {
        $("#loadingSpinner").show();

        $.ajax({
            url: '/FrontDesk/ViewWakeUpCall',
            type: 'GET',
            data: {
                name: $("#nameView").val(),
                group: $("#groupName").val(),
                roomview: ($("#roomview").val() || []).join(","),
                fromDateview: $("#fromDateview").val(),
                timeDailyview: $("#rdoTimeView").is(":checked") ? $("#timeDailyview").val() : null,
                toDateview: $("#toDateview").val(),
                roomClass: $("#roomClass").val()
            },
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                initializeViewWakeUpCallGrid(result);
                $("#popupviewGrid").modal('show');
                $("#loadingSpinner").hide();
            },
            error: function () {
                alert("Không thể tải báo cáo.");
                $("#loadingSpinner").hide();
            }
        });
    });

    // ======================= OPEN FIND ROOM =======================
    $(document).off("click", "#listRoom").on("click", "#listRoom", function () {
        // mở grid lần đầu (hoặc search theo filter hiện tại)
        $("#btnSearchFindRoom").trigger("click");
    });

    // Search FindRoom
    $(document).off("click", "#btnSearchFindRoom").on("click", "#btnSearchFindRoom", function () {
        $("#loadingSpinner").show();
        $.ajax({
            url: '/FrontDesk/WakeUpCallFindRoom',
            type: 'GET',
            data: {
                roomNoset: $("#roomNoset").val(),
                reservationHolder: $("#reservationHolder").val(),
                zone: ($("#zone").val() || []).join(","),
                confirmNo: $("#confirmNo").val()
            },
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                if (result && result.length > 0) {
                    initializeWakeUpCallFindRoomGrid(result);
                    $("#popupLogGrid").modal('show');
                } else {
                    showToast('Warning', 'The returned data is invalid or empty.', false);
                }
                $("#loadingSpinner").hide();
            },
            error: function () {
                $("#loadingSpinner").hide();
            }
        });
    });

    // ======================= OPEN CANCEL LIST =======================
    $(document).off("click", "#cancleRoom").on("click", "#cancleRoom", function () {
        const callType = $("input[name='call']:checked").val();
        $("#loadingSpinner").show();

        $.ajax({
            url: '/FrontDesk/WakeUpCallSearch',
            type: 'GET',
            data: {
                currentDate: $("#singleDate").val(),
                searchforName: $("#searchforName").val(),
                isSpecial: $("#rdoDate").is(":checked") ? 1 : 0
            },
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                if (result && result.length > 0) {
                    initializeWakeUpCallSearchGrid(result, callType);
                    $("#popupcancleGrid").modal('show');
                } else {
                    showToast('Warning', 'The returned data is invalid or empty.', false);
                }
                $("#loadingSpinner").hide();
            },
            error: function () {
                $("#loadingSpinner").hide();
            }
        });
    });

    // ======================= GRIDS =======================
    function initializeWakeUpCallFindRoomGrid(data) {
        isAllSelected = false;
        logGrid = $("#logGridContainer").dxDataGrid({
            dataSource: data,
            allowColumnResizing: true,
            columnAutoWidth: true,
            height: 500,
            columns: [
                { dataField: "id", caption: "ID", visible: false },
                { dataField: "room", caption: "Room", width: 100 },
                { dataField: "confirmNo", caption: "Confirm no", width: 120 },
                { dataField: "name", caption: "Name", width: 180 },
                { dataField: "shareRoom", caption: "Share Room", width: 120 },
                { dataField: "arrDate", caption: "Arr date", dataType: "date", format: "yyyy-MM-dd", width: 120 },
                { dataField: "depDate", caption: "Dep date", dataType: "date", format: "yyyy-MM-dd", width: 120 },
                { dataField: "reservationHolder", caption: "Reservation holder", width: 180 }
            ],
            paging: { pageSize: 25 },
            scrolling: { useNative: true, showScrollbar: "always" },
            pager: {
                visible: true,
                allowedPageSizes: [25, 50, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            filterRow: { visible: true, applyFilter: "auto" },
            headerFilter: { visible: true },
            selection: { mode: "multiple", showCheckBoxesMode: "always" },
            showBorders: true,
            onSelectionChanged: function (e) {
                selectedRowsData = e.selectedRowsData; // ✅ đúng
            }
        }).dxDataGrid("instance");
    }

    function initializeWakeUpCallSearchGrid(data, callType) {
        isAllSelected = false;

        logGrid = $("#logcancelContainer").dxDataGrid({
            dataSource: data,
            allowColumnResizing: true,
            columnAutoWidth: true,
            columns: [
                { dataField: "id", caption: "ID", visible: false },
                { dataField: "roomID", caption: "RoomID", visible: false },
                { dataField: "room", caption: "Room", width: 100 },
                { dataField: "name", caption: "Name", width: 180 },
                { dataField: "dateTime", caption: "Date/Time", width: 180, visible: callType === "date" }
            ],
            paging: { pageSize: 25 },
            scrolling: { useNative: true, showScrollbar: "always" },
            pager: {
                visible: true,
                allowedPageSizes: [25, 50, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            filterRow: { visible: true, applyFilter: "auto" },
            headerFilter: { visible: true },
            selection: { mode: "multiple", showCheckBoxesMode: "always" },
            showBorders: true,
            onSelectionChanged: function (e) {
                selectedRowsData = e.selectedRowsData; // ✅ đúng
            }
        }).dxDataGrid("instance");
    }

    function initializeViewWakeUpCallGrid(data) {
        logGrid = $("#logviewContainer").dxDataGrid({
            dataSource: data,
            allowColumnResizing: true,
            columnAutoWidth: true,
            height: 700,
            columns: [
                { dataField: "id", caption: "ID", visible: false },
                { dataField: "shareRoom", caption: "ShareRoom", visible: false },
                { dataField: "status", caption: "Status", width: 120 },
                { dataField: "confirmationNo", caption: "Conf. no", width: 120 },
                { dataField: "roomNo", caption: "RoomNo", width: 120 },
                { dataField: "guestName", caption: "Guest Name", width: 160 },
                { dataField: "arrDate", caption: "Arr date", dataType: "date", format: "yyyy-MM-dd", width: 120 },
                { dataField: "depDate", caption: "Dep date", dataType: "date", format: "yyyy-MM-dd", width: 120 },
                { dataField: "wudate", caption: "WU Date", dataType: "date", format: "yyyy-MM-dd", width: 120 },
                { dataField: "wutime", caption: "WU Time", width: 120 },
                { dataField: "createdDate", caption: "Created Date", dataType: "date", format: "yyyy-MM-dd", width: 120 },
                { dataField: "updatedDate", caption: "Updated Date", dataType: "date", format: "yyyy-MM-dd", width: 120 },
                { dataField: "userCancel", caption: "User Cancel", width: 120 },
                { dataField: "userSetup", caption: "User Setup", width: 120 },
                { dataField: "remarks", caption: "Remarks", width: 160 }
            ],
            paging: { pageSize: 25 },
            scrolling: { useNative: true, showScrollbar: "always" },
            pager: {
                visible: true,
                allowedPageSizes: [25, 50, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            filterRow: { visible: true, applyFilter: "auto" },
            headerFilter: { visible: true },
            selection: { mode: "single" },
            showBorders: true,
            onRowClick: function (e) {
                const rowData = e.data;
                $.ajax({
                    url: '/FrontDesk/ViewWakeUpCallAccount',
                    type: 'GET',
                    data: { roomID: rowData.id, shareRoom: rowData.shareRoom },
                    headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                    success: function (result) {
                        initializeViewWakeUpCallAccountGrid(result);
                    }
                });
            }
        }).dxDataGrid("instance");
    }

    function initializeViewWakeUpCallAccountGrid(data) {
        $("#logviewdetailContainer").dxDataGrid({
            dataSource: data,
            allowColumnResizing: true,
            columnAutoWidth: true,
            columns: [
                { dataField: "account", caption: "Account", width: 140 }
            ],
            paging: { pageSize: 25 },
            scrolling: { useNative: true, showScrollbar: "always" },
            pager: {
                visible: true,
                allowedPageSizes: [25, 50, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            filterRow: { visible: true, applyFilter: "auto" },
            headerFilter: { visible: true },
            showBorders: true
        });
    }

    // ======================= GRID BUTTONS =======================
    $(document).off("click", "#btnCheckAllFindRoom, #btnCheckAllCancelList")
        .on("click", "#btnCheckAllFindRoom, #btnCheckAllCancelList", function () {
            if (!logGrid) return;
            if (!isAllSelected) {
                logGrid.selectAll();
                isAllSelected = true;
                $(this).text("Unselect All");
            } else {
                logGrid.clearSelection();
                isAllSelected = false;
                $(this).text("Select All");
            }
        });

    $(document).off("click", "#btnCheckVisibleFindRoom")
        .on("click", "#btnCheckVisibleFindRoom", function () {
            if (!logGrid) return;
            const visibleKeys = logGrid.getVisibleRows().map(r => r.key);
            logGrid.selectRows(visibleKeys, true);
        });

    // Ok FindRoom -> fill roomno
    $(document).off("click", "#btnOkFindRoom").on("click", "#btnOkFindRoom", function () {
        if (!selectedRowsData || selectedRowsData.length === 0) {
            alert("Vui lòng chọn ít nhất 1 phòng!");
            return;
        }
        const rooms = selectedRowsData.map(x => x.room);
        $("#roomno").val(rooms.join(", "));
        $("#roomnoCancel").val(rooms.join(", "));
        $("#popupLogGrid").modal("hide");
    });

    // Ok CancelList -> fill schedule room list (nếu cần)
    $(document).off("click", "#btnOkCancelList").on("click", "#btnOkCancelList", function () {
        if (!selectedRowsData || selectedRowsData.length === 0) {
            alert("Vui lòng chọn ít nhất 1 dòng!");
            return;
        }
        const rooms = selectedRowsData.map(x => x.room);
        $("#roomnoCancel").val(rooms.join(", "));
        $("#popupcancleGrid").modal("hide");
    });

    // ======================= EXPORT EXCEL (giữ logic của bạn) =======================
    $("#btnExportExcel").click(function () {
        const grid = $("#logviewContainer").dxDataGrid("instance");
        const selectedReport = "View Wake Up Call";
        const workbook = new ExcelJS.Workbook();
        const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
        const worksheet = workbook.addWorksheet("Sheet 1");

        worksheet.addRow([companyName]);
        worksheet.mergeCells('A1:E1');
        worksheet.getRow(1).font = { bold: true };
        worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

        const now = new Date();
        const exportDate = now.toLocaleString("vi-VN");
        worksheet.addRow(['', '', '', '', ' ' + exportDate]);
        worksheet.mergeCells('E2:H2');
        worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

        worksheet.addRow([]);
        worksheet.addRow([]);

        const reportRow = worksheet.addRow(['', '', selectedReport]);
        worksheet.mergeCells('C5:F5');
        reportRow.font = { bold: true, size: 14 };
        reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

        worksheet.addRow([]);

        DevExpress.excelExporter.exportDataGrid({
            component: grid,
            worksheet: worksheet,
            autoFilterEnabled: true,
            topLeftCell: { row: 7, column: 1 }
        }).then(function () {
            const lastRow = worksheet.lastRow.number + 2;
            worksheet.mergeCells(`A${lastRow}:F${lastRow}`);
            worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
            worksheet.getCell(`A${lastRow}`).font = { italic: true };

            const fileName = selectedReport + ".xlsx";
            workbook.xlsx.writeBuffer().then(function (buffer) {
                saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
            });
        });
    });
</script>