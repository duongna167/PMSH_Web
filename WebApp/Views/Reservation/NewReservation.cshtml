    function applyButtonVisibility(result) {

        const map = {
            addOn: "addonButton",
            billing: "billingButton",
            packageOption: "packageButton",
            depositCancelation: "depositButton",
            wakeUpCall: "wucButton",
            waitList: "waitlistButton",
            registerCard: "recaButton",
            shares: "sharesButton",
            accompany: "accompanyButton",
            routing: "routingButton",
            roomMove: "roommoveButton",
            messages: "messageButton",
            del: "deleteButton",
            fixedCharges: "fixchaButton",
            cancel: "cancelButton"
        };

        if (!result || typeof result !== "object") {
            hideAllButtons();
            return;
        }

        Object.entries(map).forEach(([key, id]) => {
            $("#" + id).toggle(!!result[key]);
        });

        // Đã checkout (2) vẫn cần vào Billing — ghi đè nếu cờ DB tắt nhầm
        const status = typeof reservationStatus !== "undefined" ? Number(reservationStatus) : NaN;
        if (status === 2) {
