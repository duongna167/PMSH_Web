        function fetchDetailAndOpen(title, fullToolbar) {
            const grid = gridDetails;
            const row = grid?.getSelectedRowsData()?.[0];
            if (!row?.id) {
                showToast("Warning", "Please select one row in the Details grid.", false);
                return;
            }

            showLoading(true);
            $.ajax({
                url: "/Administration/RateCode/GetRateCodeDetailById",
                type: "GET",
                data: { id: row.id },
                success: function (res) {
                    if (!res?.success) {
                        showToast("Error", res?.message || "Cannot load record.", false);
                        return;
                    }
                    populateForm(res);
                    $(sel.upsertTitle).text(title);
                    if (fullToolbar) {
                        $(sel.btnEditUpdate).show();
                        $(sel.btnEditNew).hide();
                        $(sel.btnEditChanges).hide();
                        $(sel.btnEditRepeat).hide();
                    } else {
                        $(sel.btnEditUpdate).hide();
                        $(sel.btnEditNew).show();
                        $(sel.btnEditChanges).show();
                        $(sel.btnEditRepeat).show();
                    }
                    upsertModal.show();
                },
                error: function () {
                    showToast("Error", "Cannot load record.", false);
                },
                complete: function () {
                    showLoading(false);
                }
            });
        }

        function openEdit() {
            fetchDetailAndOpen("Edit Rate Code Detail", false);
