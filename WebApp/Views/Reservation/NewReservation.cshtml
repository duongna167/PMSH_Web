    function validateName(name) {
        // Regex for "FirstName MiddleName, LastName" or "FirstName MiddleName,LastName"
        const namePattern = /^[A-Z][a-z]*\s[A-Z][a-z]*,\s*[A-Z][a-z]*$/;
        return namePattern.test(name.trim());
