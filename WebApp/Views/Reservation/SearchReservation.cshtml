    /** Arr.To mặc định = Arr.From + 7 ngày (ISO yyyy-MM-dd). */
    function normalizeSearchArrivalRange() {
        var fromIso = ($('#arrivalForm').val() || '').split('T')[0] || (typeof window.dateSystem !== 'undefined' ? window.dateSystem : '');
        var toIso = ($('#departureForm').val() || '').split('T')[0] || '';
        if (typeof UI !== 'undefined' && UI.addDaysIso) {
            if (!fromIso && window.dateSystem) {
                fromIso = window.dateSystem;
                UI.setHiddenDate('arrivalForm', fromIso);
            }
            if (!toIso && fromIso) {
                toIso = UI.addDaysIso(fromIso, 7);
                UI.setHiddenDate('departureForm', toIso);
            } else if (fromIso && toIso && fromIso === toIso) {
                toIso = UI.addDaysIso(fromIso, 7);
                UI.setHiddenDate('departureForm', toIso);
            }
        }
        return { fromIso: fromIso, toIso: toIso || fromIso };
    }

    $(document).on('change', 'input[name="arrivalForm"]', function () {
        var v = ($(this).val() || '').split('T')[0];
        if (!v || typeof UI === 'undefined' || !UI.addDaysIso || !UI.setHiddenDate) return;
        var next = UI.addDaysIso(v, 7);
        if (next) UI.setHiddenDate('departureForm', next);
    });


