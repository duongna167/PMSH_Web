<script>
    function formatDate(date) {
        let year = date.getFullYear();
        let month = (date.getMonth() + 1).toString().padStart(2, '0'); // Ð?m b?o có 2 ch? s?
        let day = date.getDate().toString().padStart(2, '0'); // Ð?m b?o có 2 ch? s?
        return `${year}-${month}-${day}`;
    }


    $(document).ready(function () {

        document.getElementById("reportTitle").innerText = 'Room Attendent Daily Worksheet';
        getBusinessDate();
        initializeTomSelects();
        // initializeTomSelectstasksheet();
        var taskSheetNew = '@(ViewBag.TaskSheetNew ?? "")';

        if (taskSheetNew && taskSheetNew.trim() !== "" && $("#tasksheet option[value='" + taskSheetNew + "']").length) {
            console.log(taskSheetNew);
            $('#tasksheet').val(taskSheetNew);
            $("#btnExportExcel, #btnReport").attr("style", "display: none !important");
        } else {
            console.log("Không tìm thấy option khớp với", taskSheetNew);
            $('#tasksheet').val('').trigger('change');
        }


    });

    function getBusinessDate() {
        return $.ajax({
            url: '/Reservation/GetBusinessDate',
            type: 'get',
            dataType: 'json',
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {

                const fromDateStr = result.split('T')[0];
                $('#fromDate').val(fromDateStr);
                $("#btnPrint").trigger("click");
            },
            error: function (xhr, statusText, err) {
                if (xhr.status == 401) {
                    sessionTimeout();
                }
            }
        });
    }

    $("#btnReport").on("click", function () {

        $('#popupNewGrid').modal('show');
    });
    $('#btnClosePopup, #overlay').click(function () {
        $('#popupNewGrid').modal('hide');

    });
