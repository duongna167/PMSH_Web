<script>
    var isReset = false;
    var isSilentReset = false;

    // --- UTILS ---
    function formatNumberWithComma(num) {
        if (num === null || num === undefined || isNaN(num) || num === '') return '0,00';
        return parseFloat(num).toLocaleString('vi-VN', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });
    }
    
    function parseNumberWithComma(str) {
        if (!str) return 0;

        return Number(
            str
                .replace(/\s/g, '')
                .replace(/\./g, '')
                .replace(',', '.')
        ) || 0;
    }

    // --- HELPER: Lấy element trong Tab đang active ---
    function getActiveEl(selector) {
        return $('.tab-pane.active').find(selector);
    }

    function getPostingFolioValue(folio) {
        if (!folio) return 0;
        return folio.isMasterFolio ? -Math.abs(folio.folioNo) : Math.abs(folio.folioNo);
    }

    function renderFolioOptions(selectedValue) {
        const currentValue = selectedValue ?? $('#selectFolioDetail').val() ?? $('#selectFolioInvoice').val();
        const existingMap = {};
        let html = '';

        if (Array.isArray(listFolioData)) {
            listFolioData.forEach(function (folio) {
                existingMap[getPostingFolioValue(folio)] = folio;
            });
        }

        for (let i = 1; i <= 8; i++) {
            const folio = existingMap[i];
            html += `<option value="${i}" data-folio-id="${folio ? folio.id : 0}">${i}</option>`;
        }

        for (let i = 1; i <= 8; i++) {
            const folioValue = -i;
            const folio = existingMap[folioValue];
            html += `<option value="${folioValue}" data-folio-id="${folio ? folio.id : 0}">M${i}</option>`;
        }

        $('#selectFolioDetail, #selectFolioInvoice').html(html);

        if (currentValue !== null && currentValue !== undefined && currentValue !== '') {
            $('#selectFolioDetail, #selectFolioInvoice').val(String(currentValue));
        }
    }

    function syncPostingFolioSelectionFromBilling(selectedFolioId) {
        let selectedFolio = null;

        if (Array.isArray(listFolioData) && listFolioData.length > 0) {
            selectedFolio = listFolioData.find(f => f.id === selectedFolioId)
                || listFolioData.find(f => f.id === folioNoID)
                || listFolioData[0];
        }

        renderFolioOptions(selectedFolio ? getPostingFolioValue(selectedFolio) : null);
    }

    function getSelectedPostingFolioId(selector) {
        return parseInt($(selector).find('option:selected').attr('data-folio-id')) || 0;
    }

    // --- API CALCULATIONS  ---
    function resetActivePriceFields() {
        const $pane = $('.tab-pane.active');
        $pane.find('.js-input-price, .js-input-price-net, .js-amount-gross, .js-amount-net').val('0,00');
    }

    // Nhập Net -> Ra Gross (amount++)
    function apiCalcPlusFromNet() {
        if (isReset || isSilentUpdate) return;

        let tCode = getActiveEl('.js-trans-code').val();
        let $netInput = getActiveEl('.js-input-price-net');
        let netVal = parseNumberWithComma($netInput.val());

        if (netVal <= 0) {
            resetActivePriceFields();
            return;
        }

        if (!tCode) return;

        $.ajax({
            url: '/Billing/CalculatePricePlusPlus',
            type: 'GET',
            data: { transactionCode: tCode, netPrice: netVal },
            success: function (res) {
                if (typeof res === "number" && !isNaN(res)) {

                    isSilentUpdate = true;

                    getActiveEl('.js-input-price').val(formatNumberWithComma(res));

                    isSilentUpdate = false;

                    calculateLineTotal();
                }
            }
        });
    }

    // Nhập Gross(price++) -> Ra Net
    function apiCalcNetFromPlus() {
        if (isReset || isSilentUpdate) return;

        let tCode = getActiveEl('.js-trans-code').val();
        let $grossInput = getActiveEl('.js-input-price');
        let grossVal = parseNumberWithComma($grossInput.val());

        if (grossVal <= 0) {
            resetActivePriceFields();
            return;
        }

        if (!tCode) return;

        $.ajax({
            url: '/Billing/CalculatePriceNet',
            type: 'GET',
            data: { transactionCode: tCode, grossPrice: grossVal },
            success: function (res) {
                if (typeof res === "number" && !isNaN(res)) {

                    isSilentUpdate = true;

                    getActiveEl('.js-input-price-net').val(formatNumberWithComma(res));

                    isSilentUpdate = false;

                    setTimeout(calculateLineTotal, 0);
                }
            }
        });
    }

    // Tính tổng tiền
    function calculateLineTotal() {
        let qty = parseFloat(getActiveEl('.js-input-qty').val()) || 0;
        let priceGross = parseNumberWithComma(getActiveEl('.js-input-price').val());
        let priceNet   = parseNumberWithComma(getActiveEl('.js-input-price-net').val());

        if (priceGross <= 0 || priceNet <= 0) {
            getActiveEl('.js-amount-gross').val('0,00');
            getActiveEl('.js-amount-net').val('0,00');
            return;
        }

        let totalGross = qty * priceGross;
        let totalNet   = qty * priceNet;

        getActiveEl('.js-amount-gross').val(formatNumberWithComma(totalGross));
        getActiveEl('.js-amount-net').val(formatNumberWithComma(totalNet));
    }

    var isComposing = false;
    var isSilentUpdate = false;

    // --- EVENTS ---
    $(document).ready(function() {
        $('#modalPosting').on('show.bs.modal', function () {
            resetAllPostingData();
        });

        $('#modalPosting').on('shown.bs.modal', function () {
            loadGroups();
            loadCurrencies();
            console.log("idReservation:", idReservation);
            $('.js-search-box[data-target="#list-group-container"]').focus();
            syncPostingFolioSelectionFromBilling(folioNoID);
        });

        $(document).on('change', '#selectFolioDetail, #selectFolioInvoice', function() {
            var val = $(this).val();
            $('#selectFolioDetail, #selectFolioInvoice').val(val);
        });

        // Bắt sự kiện click vào các nút Tab 
        $(document).on('click', '#detail-tab, #invoice-tab', function (e) {
            resetFormPosting();
            const keyToTrigger = (this.id === 'invoice-tab') ? 'F3' : 'F2'; 

            // Tạo và bắn sự kiện keydown giả lập
            const event = new KeyboardEvent('keydown', {
                key: keyToTrigger,
                keyCode: (keyToTrigger === 'F3') ? 114 : 113, // F3=114, F2=113
                which: (keyToTrigger === 'F3') ? 114 : 113,
                bubbles: true,
                cancelable: true
            });

            document.dispatchEvent(event); 

            syncToolbarLogic(this.id); 
        });

        $('#modalPosting').on('hidden.bs.modal', function () {
            resetAllPostingData();
        });

        // --- SỰ KIỆN NHẬP LIỆU TIỀN TỆ TỨC THÌ ---
        $(document).on('compositionstart', '.js-input-price, .js-input-price-net, #amountAdjust, #amountAdjustNet', function () {
            isComposing = true;
        });

        $(document).on('compositionend', '.js-input-price, .js-input-price-net, #amountAdjust, #amountAdjustNet', function () {
            isComposing = false;

            // Sau khi gõ xong mới format
            formatCurrencyLive(this);
        });

        // Format dấu chấm phân cách ngay khi đang gõ (Live Format)
        $(document).on('input', '.js-input-price, .js-input-price-net, #amountAdjust, #amountAdjustNet', function() {
            formatCurrencyLive(this);
        });

        //  Khi Focus: Xóa "0,00" để nhập mới
        $(document).on('focus', '.js-input-price, .js-input-price-net', function() {
            let val = $(this).val();
            if (val === "0,00" || val === "0") {
                $(this).val("");
            }
        });

        // Khi Blur: Thêm đuôi thập phân và gọi API tính toán
        $(document).on('blur', '.js-input-price, .js-input-price-net', function() {
            if (isSilentReset) return;

            let val = $(this).val();
            let num = parseNumberWithComma(val);

            if (val === "" || val === "-" || num <= 0) {
                resetActivePriceFields();
                return;
            }

            $(this).val(formatNumberWithComma(num));

            // Gọi API tính toán logic Net/Gross
            if ($(this).hasClass('js-input-price')) {
                apiCalcNetFromPlus();
            } else if ($(this).hasClass('js-input-price-net')) {
                apiCalcPlusFromNet();
            }
        });

        //  Search List (transGroup,...,article)
        $(document).on('keyup', '.js-search-box', function() {
            var value = $(this).val().toLowerCase();
            var valueNoTone = removeVietnameseTones(value);
            var targetId = $(this).data('target');

            // Duyệt qua tất cả các thẻ <a> (item) trong danh sách tương ứng
            $(targetId + ' .list-group-item').filter(function() {
                var itemText = $(this).text().toLowerCase();
                var itemTextNoTone = removeVietnameseTones(itemText);

                var isMatch = itemText.indexOf(value) > -1 || itemTextNoTone.indexOf(valueNoTone) > -1;
                $(this).toggle(isMatch);
            });
        });

        // Chỉ cho phép nhập số dương và dấu chấm/phẩy (cho Price, Percent, Quantity)
        $(document).on('keypress', '.js-input-qty, .js-input-price, .js-input-price-net, .js-input-express-pct, .js-input-discount-pct', function(e) {
            // Mã ký tự (char code)
            var charCode = (e.which) ? e.which : e.keyCode;

            if ((charCode >= 48 && charCode <= 57) || charCode === 46 || charCode === 44) {
                return true;
            }

            return false;
        });

        // Xử lý sự kiện Paste (Dán)
        $(document).on('paste', '.js-input-qty, .js-input-price, .js-input-price-net, .js-input-express-pct, .js-input-discount-pct', function(e) {
            e.preventDefault();

            var pastedData = (e.originalEvent || e).clipboardData.getData('text/plain');

            var cleanData = pastedData
            .replace(/\s/g, '')
            .replace(/[^\d.,]/g, '');

            $(this).val(cleanData);
            $(this).trigger('input');
        });

        //  Kiểm tra input để đảm bảo không âm khi blur
        $(document).on('blur', '.js-input-qty', function() {
            if (isSilentReset) return;
            var valStr = $(this).val();
            // Chuyển dấu phẩy thành chấm để parse
            var cleanStr = valStr.replace(/\./g, '').replace(/,/g, '.');
            var valNum = parseFloat(cleanStr);

            if (valNum < 0) {
                alert("Negative numbers are not allowed!");
                $(this).val(0);
                if($(this).hasClass('js-input-qty')) $(this).val(1);
            }
        });

        //  INPUT PRICE ++
        $(document).on('keypress', '.js-input-price', function(e) {
            if (isSilentReset) return;
            if (e.which !== 13) return;

            e.preventDefault();
            $(this).blur();
        });

        //  INPUT PRICE NET
        $(document).on('keypress', '.js-input-price-net', function(e) {
            if (isSilentReset) return;
            if (e.which !== 13) return;

            e.preventDefault();
            $(this).blur();
        });

        //  QUANTITY
        $(document).on('blur keypress', '.js-input-qty', function(e) {
             if (isSilentReset) return;
             if (e.type === 'keypress' && e.which !== 13) return;
             if (e.type === 'keypress') { e.preventDefault(); $(this).blur(); return; }
             calculateLineTotal();
        });
        
        //  FOCUS EFFECT
        $(document).on('focus click', '.js-input-price', function() {
            $(this).addClass('active-user-input');
            getActiveEl('.js-input-price-net').removeClass('active-user-input');
        });

        $(document).on('focus click', '.js-input-price-net', function() {
            $(this).addClass('active-user-input');
            getActiveEl('.js-input-price').removeClass('active-user-input');
        });

        // --- EXPRESS/DISCOUNT SERVICE ---
        //  Sự kiện Radio & Input Express và Discount
        $(document).on('change', '.js-express-radio, .js-discount-radio', function() {
            var val = parseFloat($(this).val()).toFixed(2);
            $(this).closest('.express-input-group').find('input[type="text"]').val(val);
            updateReferenceText();
        });

        $(document).on('input blur propertychange', '.js-input-express-pct, .js-input-discount-pct', function() {
            var valNum = parseFloat($(this).val());
            var $container = $(this).closest('.express-box');

            $container.find('input[type="radio"]').prop('checked', false);

            if ([10, 20, 50, 100].includes(valNum)) {
                $container.find(`input[value="${valNum}"]`).prop('checked', true);
            }
            updateReferenceText();
        });

        function updateReferenceText() {
            var $activePane = $('.tab-pane.active');
            var $refInput = $activePane.find('.js-ref-main');
            var baseRef = $refInput.data('base-ref') || ""; // Lấy gốc

            var suffix = "";
            if ($activePane.find('.js-chk-express').is(':checked')) {
                suffix = " - Express " + $activePane.find('.js-input-express-pct').val() + "%";
            } else if ($activePane.find('.js-chk-discount').is(':checked')) {
                suffix = " - Discount " + $activePane.find('.js-input-discount-pct').val() + "%";
            }

            $refInput.val(baseRef + suffix);
        }

        function toggleInputs($container, isChecked) {
            $container.find('input[type="text"], input[type="radio"]').prop('disabled', !isChecked);
        }

        //  Sự kiện Checkbox EXPRESS
        $(document).on('change', '.js-chk-express', function() {
            var isChecked = $(this).is(':checked');
            var $activePane = $(this).closest('.tab-pane');
            var $container = $(this).closest('.express-box');

            toggleInputs($container, isChecked);

            if(isChecked) {
                var $chkDiscount = $activePane.find('.js-chk-discount');
                if ($chkDiscount.is(':checked')) {
                    $chkDiscount.prop('checked', false).trigger('change');
                }
                updateReferenceText();
                getActiveEl('.js-ref-main').focus();
            } else {
                updateReferenceText();
            }
        });

        //  Sự kiện Checkbox DISCOUNT
        $(document).on('change', '.js-chk-discount', function() {
            var isChecked = $(this).is(':checked');
            var $activePane = $(this).closest('.tab-pane');
            var $container = $(this).closest('.express-box');

            toggleInputs($container, isChecked);

            if(isChecked) {
                var $chkExpress = $activePane.find('.js-chk-express');
                if ($chkExpress.is(':checked')) {
                    $chkExpress.prop('checked', false).trigger('change');
                }
                updateReferenceText();
                getActiveEl('.js-ref-main').focus();
            } else {
                updateReferenceText();
            }
        });

    });

    function syncToolbarLogic(forceTabId) {
        const btnAdd = document.getElementById("btn-add");
        if (!btnAdd) return;

        // Nếu không có forceTabId (trường hợp click chuột), lấy ID của tab đang có class active
        let activeTabId = forceTabId;
        if (!activeTabId) {
            const activeTab = document.querySelector('.nav-tabs .nav-link.active');
            activeTabId = activeTab ? activeTab.id : "";
        }

        if (activeTabId === "invoice-tab") {
            btnAdd.style.setProperty("display", "flex", "important");
            if (typeof refreshInvoiceGrid === 'function') refreshInvoiceGrid();
        } else {
            btnAdd.style.setProperty("display", "none", "important");
        }
    }

