@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    var zoneList = ViewBag.ZoneList;
    var roomList = ViewBag.RoomList;
    var roomClassList = ViewBag.RoomClassList;
}
<style>
    .wake-container {
        display: flex;
        gap: 30px;
        justify-content: center;
        margin: 20px 0;
        /*         background: white; */
    }

    .group-box {
        border: 1px solid #ccc;
        padding: 15px;
        border-radius: 5px;
        background: white;
        width: 360px; /* cố định chiều rộng */
        min-height: 290px; /* đủ lớn cho group lớn nhất */
        box-sizing: border-box;
    }

    .radio-inline {
        margin-bottom: 15px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-top: 10px;
    }

    .form-row {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .form-row label {
        width: 80px;
        text-align: right;
    }


    .browse-btn {
        width: 30px;
        height: 25px;
        padding: 0;
        margin-left: 5px;
    }

    .btn-row {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-top: 20px;
    }

    .btn-delete,
    .btn-close {
        padding: 6px 20px;
        border: 1px solid #aaa;
        border-radius: 3px;
        background: #f5f5f5;
        cursor: pointer;
    }

    .btn-delete:hover {
        background: #fdd;
        border-color: red;
    }

    .btn-close:hover {
        background: #ddd;
    }

    .hidden-important {
        display: none !important;
    }

    .show-important {
        display: flex !important;
    }

    .show-important1 {
        display: block !important;
    }

    #popupviewGrid {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: white;
        padding: 20px;
        border-radius: 0;
        /* full màn không cần bo góc */
        z-index: 1000;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.3);
        overflow-y: auto;
        /* bật scroll dọc nếu nội dung vượt quá */
    }

    .ellipsis-icon {

        margin-left: 10px;
        left: 0;
        top: 0;
        position: relative;
    }

    #popupWakeUpCall {
        display: flex !important;
        align-items: center;
        justify-content: center;
    }

        #wakeup-fit,
        #popupWakeUpCall .modal-dialog.wakeup-fit {
            max-width: none;
            width: auto;
        }

        #popupWakeUpCall .modal-content {
            display: inline-block;
            width: auto;
        }

 
</style>


<div class="modal fade" id="popupWakeUpCall" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered wakeup-fit">



        <div class="modal-content">

            <!-- Modal Header -->
            <div class="modal-header">
                <h5 class="modal-title">Wake Up Call</h5>
      
            </div>
  
            <!-- Modal Body -->
            <div class="modal-body">
                <div class="d-flex justify-content-start mb-2 gap-2 pt-2">
                    <button id="btnCancelwakeup" class="mui-button mui-button-cancel"
                            type="button">
                        Delete
                    </button>
                    <button id="btnSetwakeup" class="mui-button mui-button-card"
                            type="button">
                        Set
                    </button>
                    <button id="btnViewwakeup" class="mui-button mui-button-new"
                            type="button">
                        View
                    </button>
                    <button id="close" class="mui-button mui-button-new" onclick="window.location.href='/Home/Index'">Close</button>

                </div>
                <div class="wake-container">

                    <!-- Left Group -->
                    <div class="group-box mb-3">
                     
                        <label>
                            <input type="radio" name="wake" value="set" id="rdoSet" checked>
                            Set Wake Up Call
                        </label><br />
                        <label>
                            <input type="radio" name="wake" value="cancel" id="rdoCancle">
                            Cancel Wake Up Call
                        </label><br />
                        <label>
                            <input type="radio" name="wake" value="view" id="rdoView">
                            View Wake Up Calls
                        </label>
                    </div>

                    <!-- Set Wakeup -->
                    <div class="group-box mb-3" id="setWakeup">

                        <div class="radio-inline mb-2">
                            <label>
                                <input type="radio" name="call" id="rdoDate" value="date" checked>
                                Date
                            </label>
                            <label class="ms-3">
                                <input type="radio" name="call" id="rdoDaily" value="daily">
                                Daily
                            </label>
                        </div>

                        <!-- Room -->
                        <div class="d-flex align-items-center mb-2" id="roomnoGroup">
                            <label class="me-2">Room No(s):</label>
                            <input type="text" id="roomno"
                                   class="form-control form-control-sm w-auto">
                            <i id="listRoom"
                               class="fas fa-ellipsis-h ellipsis-icon ms-2"
                               style="cursor:pointer"></i>
                        </div>

                        <!-- Schedule -->
                        <div class="d-flex align-items-center mb-2" id="scheduleGroup">
                            <label id="scheduleLabel" class="me-2">Schedule:</label>
                            <input type="text" id="roomnoCancel"
                                   class="form-control form-control-sm w-auto">
                            <i id="cancleRoom"
                               class="fas fa-ellipsis-h ellipsis-icon ms-2"
                               style="cursor:pointer"></i>
                        </div>

                        <!-- Date Section -->
                        <div id="dateSection">
                            <div class="d-flex align-items-center mb-2">
                                <label class="me-2">Date:</label>
                                <input type="date" id="singleDate"
                                       class="form-control form-control-sm w-auto">
                            </div>
                            <div class="d-flex align-items-center mb-2">
                                <label class="me-2">Time:</label>
                                <input type="time" id="timeDate"
                                       value="07:00"
                                       class="form-control form-control-sm w-auto">
                            </div>
                        </div>

                        <!-- Daily Section -->
                        <div id="dailySection">
                            <div class="d-flex align-items-center mb-2">
                                <label class="me-2">From Date:</label>
                                <input type="date" id="fromDate"
                                       class="form-control form-control-sm w-auto">
                            </div>
                            <div class="d-flex align-items-center mb-2">
                                <label class="me-2">Time:</label>
                                <input type="time" id="timeDaily"
                                       value="07:00"
                                       class="form-control form-control-sm w-auto">
                            </div>
                            <div class="d-flex align-items-center mb-2">
                                <label class="me-2">To Date:</label>
                                <input type="date" id="toDate"
                                       class="form-control form-control-sm w-auto">
                            </div>
                        </div>
                    </div>

                    <!-- View Wakeup -->
                    <div class="group-box" id="viewWakeupcall">

                        <div class="d-flex align-items-center mb-2">
                            <label class="me-2">Name:</label>
                            <input type="text" id="nameView"
                                   class="form-control form-control-sm w-auto">
                        </div>

                        <div class="d-flex align-items-center mb-2">
                            <label class="me-2">Group:</label>
                            <input type="text" id="groupName"
                                   class="form-control form-control-sm w-auto">
                        </div>

                        <div class="d-flex align-items-center mb-2">
                            <label class="me-2">Room:</label>
                            <select id="roomview"
                                    class="tomselect-custom"
                                    style="width:200px"
                                    multiple>
                                @foreach (var item in roomList)
                                {
                                    <option value="@item.RoomNo">@item.RoomNo</option>
                                }
                            </select>
                        </div>

                        <div class="d-flex align-items-center mb-2">
                            <label class="me-2">From Date:</label>
                            <input type="date" id="fromDateview"
                                   class="form-control form-control-sm w-auto">
                        </div>

                        <div class="d-flex align-items-center mb-2">
                            <label class="me-2">Time:</label>
                            <input type="time" id="timeDailyview"
                                   value="07:00"
                                   class="form-control form-control-sm w-auto">
                            <input type="radio" name="timeView" id="rdoTimeView" class="ms-2">
                        </div>

                        <div class="d-flex align-items-center mb-2">
                            <label class="me-2">To Date:</label>
                            <input type="date" id="toDateview"
                                   class="form-control form-control-sm w-auto">
                        </div>

                        <div class="d-flex align-items-center">
                            <label class="me-2">Room Class:</label>
                            <select id="roomClass"
                                    class="form-control form-control-sm"
                                    style="width:120px">
                                <option value="">--All--</option>
                                @foreach (var item in roomClassList)
                                {
                                    <option value="@item.ID">@item.Code</option>
                                }
                            </select>
                        </div>

                    </div>

                </div>
            </div>

         

        </div>
    </div>
</div>




<div class="modal fade" id="popupLogGrid" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">

            <!-- Modal Header -->
            <div class="modal-header">
                <h5 class="modal-title">Wake Up Call Find Room</h5>
              
            </div>

            <!-- Modal Body -->
            <div class="modal-body">

                <!-- Action Buttons -->
                <div class="d-flex justify-content-start mb-3 gap-2">
                    <button id="btnSearch" class="mui-button mui-button-new">Search</button>
                    <button id="btnOke" class="mui-button mui-button-edit">Ok</button>
                    <button id="btnCheckAll" class="mui-button mui-button-advance" type="button">
                        Select All
                    </button>
                    <button id="btnCheckone" class="mui-button mui-button-advance" type="button">
                        Select
                    </button>
                    <button type="button" class="mui-button mui-button-advance" data-bs-dismiss="modal">
                        Close
                    </button>
                </div>

                <!-- Filter Area -->
                <div class="container mb-2">
                    <div class="row g-2 align-items-center">

                        <!-- Room No -->
                        <div class="col-md-6">
                            <div class="row align-items-center">
                                <label class="col-md-4 col-form-label">Room No:</label>
                                <div class="col-md-8">
                                    <input id="roomNoset"
                                           type="text"
                                           class="form-control form-control-sm">
                                </div>
                            </div>
                        </div>

                        <!-- Zone -->
                        <div class="col-md-6">
                            <div class="row align-items-center">
                                <label class="col-md-4 col-form-label">Zone:</label>
                                <div class="col-md-8">
                                    <select id="zone"
                                            name="zone"
                                            class="tomselect-custom w-100"
                                            multiple>
                                        @foreach (var item in zoneList)
                                        {
                                            <option value="@item.Code">@item.Code</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Reservation Holder -->
                        <div class="col-md-6">
                            <div class="row align-items-center">
                                <label class="col-md-4 col-form-label">Reservation Holder:</label>
                                <div class="col-md-8">
                                    <input id="reservationHolder"  
                                           type="text"
                                           class="form-control form-control-sm">
                                </div>
                            </div>
                        </div>

                        <!-- Confirm No -->
                        <div class="col-md-6">
                            <div class="row align-items-center">
                                <label class="col-md-4 col-form-label">Confirm No:</label>
                                <div class="col-md-8">
                                    <input id="confirmNo"
                                           type="text"
                                           class="form-control form-control-sm">
                                </div>
                            </div>
                        </div>

                    </div>
                </div>


                <!-- Grid -->
                <div id="logGridContainer" class="gridContainer mt-2"></div>

            </div>

         

        </div>
    </div>
</div>


<div class="modal fade" id="popupcancleGrid" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">

            <!-- Modal Header -->
            <div class="modal-header">
                <h5 class="modal-title">Wake Up Call Deleting</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Modal Body -->
            <div class="modal-body">

                <!-- Action Buttons -->
                <div class="d-flex justify-content-start mb-3 gap-2">
                    <button id="btnOke" class="mui-button mui-button-edit">Ok</button>

                    <button id="btnCheckAllcalcel"
                            class="mui-button mui-button-advance"
                            type="button">
                        Select All
                    </button>
                    <button type="button"
                            class="mui-button mui-button-advance"
                            data-bs-dismiss="modal">
                        Close
                    </button>
                </div>

                <!-- Search Area -->
                <div class="container mb-2">
                    <div class="d-flex align-items-center flex-wrap mb-2">
                        <div class="d-flex align-items-center me-3 mb-2">
