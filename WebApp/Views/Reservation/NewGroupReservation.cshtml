<!-- Modal new group reservation-->
<div class="modal fade modal-lg" id="modalNewGroupReservation" data-bs-backdrop="static" data-bs-keyboard="false"
    tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="staticBackdropLabel">New Group Reservation</h5>
                @* <button type="button" class="btn-close" onclick="closemodalNewGroupReservation()"></button> *@
            </div>
            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <button class="mui-button mui-button-new" onclick="searchRoomAvailale()">Search</button>
                        <button class="mui-button mui-button-new" onclick="SaveGroupReservation();">Save</button>
                        <button class="mui-button mui-button-new" onclick="clearModelNew();">Clear</button>
                        <button class="mui-button mui-button-search" onclick="closeModalNew();">Close</button>

                    </div>
                </div>
                <div class="mt-1">
                    <div class="row">

                        <!-- Book From -->
                        <div class="col-12 col-md-6 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Book from
                                </label>
                                <div class="col-12 col-md-8">
                                    <select id="bookForm">
                                        <option value="0" selected>Availability</option>
                                        <option value="1">Allotment</option>
                                        <option value="2">Rate Code</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Res Type -->
                        <div class="col-12 col-md-6 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Res. Type
                                </label>
                                <div class="col-12 col-md-8">
                                    <select id="resType" asp-items="ViewBag.cboReservationType">
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Arrival -->
                        <div class="col-12 col-md-6 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Arrival
                                </label>
                                <div class="col-12 col-md-8">
                                    <div class="clearable" data-date-input data-format="DD/MM/YYYY" business-date
                                        data-name="arrival2">
                                        <input type="text" class="date-ui form-control" placeholder="dd/mm/yyyy"
                                            autocomplete="off" id="arrivalShow" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Departure -->
                        <div class="col-12 col-md-6 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Departure
                                </label>
                                <div class="col-12 col-md-8">
                                    <div class="clearable" data-date-input data-format="DD/MM/YYYY" business-date
                                        data-name="departure2">
                                        <input type="text" class="date-ui form-control" placeholder="dd/mm/yyyy"
                                            autocomplete="off" id="departureShow" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Nights -->
                        <div class="col-12 col-md-6 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Nights
                                </label>
                                <div class="col-12 col-md-8">
                                    <input type="text" class="form-control text-end" id="nights2" readonly>
                                </div>
                            </div>
                        </div>

                        <!-- Currency -->
                        <div class="col-12 col-md-6 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Currency
                                </label>
                                <div class="col-12 col-md-8">
                                    <select id="currency">
                                        <option value="VND" selected>VND</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Package -->
                        <div class="col-12 col-md-6 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Package
                                </label>
                                <div class="col-12 col-md-8">
                                    <select id="package" asp-items="ViewBag.cboPackage">
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Market -->
                        <div class="col-12 col-md-6 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Market
                                </label>
                                <div class="col-12 col-md-8">
                                    <select id="market" asp-items="ViewBag.cboMarket">
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Name -->
                        <div class="col-12 col-md-6 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Name
                                </label>
                                <div class="col-12 col-md-8 d-flex gap-2">
                                    <input id="nameText" class="form-control">
                                    <button type="button" class="btn-search-icon" onclick="openModalSearchProfile()">
                                        <i class="fa-solid fa-arrow-down"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <div id="loadingSpinnerRoom" style="display: none; text-align: center; padding: 20px;">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
                <div class="mui-card mt-2">
                    <div id="gridContainerRoom" class="mt-2 gridContainer"></div>
                </div>
            </div>
        </div>
    </div>
</div>
@await Html.PartialAsync("~/Views/Reservation/GroupReservation/ModalSearchProfile.cshtml")
<script>

    function openModalNew() {
        clearModelNew();
        searchRoomAvailale();
        $('#modalNewGroupReservation').modal('show');
    }

    function closeModalNew() {
        clearModelNew();
        $('#modalNewGroupReservation').modal('hide');
    }

    function clearSearch() {
        $('#nameProfileSearch, #firstNameProfileSearch, #keywordProfileSearch, #codeProfileSearch').val('');
        $('#cityProfileSearch').val(0);
        $('#sale').prop('checked', false);
    }


    function searchRoomAvailale() {
        // Hiển thị biểu tượng tải DevExtreme
        $('#loadingSpinnerRoom').show();
        $.ajax({
            url: '/Reservation/GetRoomAvailable',
            type: 'get',
            dataType: 'json',
            data: {
                fromDate: $('#arrival2').val(),
                toDate: $('#departure2').val(),
            },
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                initializeDataGridRoomAvailable(result);
                // Ẩn biểu tượng tải sau khi dữ liệu tải xong
                $('#loadingSpinnerRoom').hide();
            },
            error: function (xhr, statusText, err) {
                // Ẩn biểu tượng tải nếu xảy ra lỗi
                $('#loadingSpinnerRoom').hide();
                if (xhr.status == 401) {
                    sessionTimeout();
                } else {
                    showToast('Error', 'Đã xảy ra lỗi khi tìm kiếm phòng trống.', false);
                }
            }
        });
    }

    $('#nameText').on('blur', function () {
        var input = $(this).val().trim();
        // Regex hỗ trợ tiếng Việt, định dạng: "LastName, FirstName MiddleName"
        var regex = /^[a-zA-ZÀ-ỹ]+(?:\s[a-zA-ZÀ-ỹ]+)*,\s*[a-zA-ZÀ-ỹ]+(?:\s[a-zA-ZÀ-ỹ]+)*$/i;

        if (regex.test(input)) {
            $('#errorMessage').hide();
            $(this).removeClass('is-invalid').addClass('is-valid');

            // Tách chuỗi theo định dạng "LastName, FirstName MiddleName"
            var parts = input.split(',');
            var lastName = parts[0].trim();          // "Nguyễn Văn"
            var firstMiddlePart = parts[1].trim();   // "Tuấn Anh"
            var nameTokens = firstMiddlePart.split(/\s+/); // ["Tuấn", "Anh"]

            var firstName = nameTokens[0];
            var middleName = nameTokens.slice(1).join(' '); // Có thể là rỗng

            CreateProfile(input, lastName, firstName, middleName);

        } else {
            $('#errorMessage').show();
            $(this).removeClass('is-valid').addClass('is-invalid');

        }
    });

    function calculateNights() {
        const arrival = new Date(document.getElementById('arrival2').value);
        const departure = new Date(document.getElementById('departure2').value);
        console.log('departure', departure);

        if (arrival && departure) {
            const diffTime = departure - arrival;
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            document.getElementById('nights2').value = diffDays >= 0 ? diffDays : 0;
        }
    }

    // Lắng nghe sự kiện thay đổi ngày
    $(document).on('change', '#arrivalShow', async function () {
        isSyncingDates = true;
        if (isSyncingDates) return;

        // 2. Chờ arrival ISO từ hidden (nguồn sự thật)
        const arrivalIso = await waitForBusinessDate("arrival2");

        const nights = parseInt($('#nights2').val(), 10) || 1;

        const departureIso = UI.addDaysIso(arrivalIso, nights);
        UI.setHiddenDate("departure2", departureIso);

        updateDates();
        isSyncingDates = false;
    });

    $(document).on('change', '#departureShow,#nights2', async function (e) {
        if (isSyncingDates) return;
        isSyncingDates = true;
        try {
            const targetId = e.target.id; // Kiểm tra xem cái nào vừa bị thay đổi
            const arrivalIso = $('#arrival2').val() || await waitForBusinessDate("arrival2");
            let departureIso = $('#departure2').val();
            const nights = parseInt($('#nights2').val(), 10) || 1;

            if (targetId === 'departureShow') {
                if (arrivalIso && departureIso) {
                    if (departureIso <= arrivalIso) {
                        // Nếu chọn ngày đi <= ngày đến: Giữ nguyên số đêm, lùi ngày đến lại
                        const currentNights = nights > 0 ? nights : 1;
                        const newArrival = UI.addDaysIso(departureIso, -currentNights);
                        UI.setHiddenDate("arrival2", newArrival);
                    } else {
                        // Nếu ngày đi hợp lệ: Tính lại số đêm
                        calculateNights();
                    }
                }
            }
            // TRƯỜNG HỢP 2: Người dùng thay đổi SỐ ĐÊM (Nights)
            else if (targetId === 'nights2') {
                if (arrivalIso && !isNaN(nights)) {
                    if (nights < 1) {
                        nights = 1;
                        $('#nights2').val(1);

                    }
                    // Giữ nguyên ngày đến, đẩy ngày đi ra xa theo số đêm
                    const newDeparture = UI.addDaysIso(arrivalIso, nights);
                    UI.setHiddenDate("departure2", newDeparture);
                }
            }
            // Cuối cùng cập nhật lại Thứ hiển thị và các logic phụ
            updateDates();

        } catch (error) {
            console.error("Lỗi cập nhật ngày tháng:", error);
        } finally {
            isSyncingDates = false;
        }
    });

    function initializeDataGridRoomAvailable(data) {
        // Add default values for Currency and RateCode
        data.forEach(item => {
            item.Currency = "VND";
            item.RateCode = "0";
        });

        // Define the columns array
        const columns = [];

        // Explicitly define the desired columns in the specified order
        const predefinedColumns = [
            {
                dataField: "Currency",
                caption: "Currency",
                alignment: "left",
                width: 150 // Fixed width of 150px
            },
            {
                dataField: "RateCode",
                caption: "Rate Code",
                alignment: "left",
                width: 150 // Fixed width of 150px
            },
            {
                dataField: "RoomType",
                caption: "Room Type",
                alignment: "left",
                width: 150 // Fixed width of 150px
            },
            {
                dataField: "NumofRoom",
                caption: "Num of Room",
                alignment: "right",
                width: 150 // Fixed width of 150px
            }
        ];

        // Add remaining columns dynamically, excluding specified ones
        if (data.length > 0) {
            for (const key of Object.keys(data[0])) {
                if (!["Currency", "RateCode", "RoomType", "NumofRoom", "RoomTypeID"].includes(key)) {
                    columns.push({
                        dataField: key,
                        caption: key,
                        alignment: typeof data[0][key] === 'number' ? 'right' : 'left',
                        width: 150 // Fixed width of 150px
                    });
                }
            }
        }

        // Combine predefined columns with dynamically generated ones
        const finalColumns = [...predefinedColumns, ...columns];

        // Hide RoomTypeID column (in case it was added elsewhere)
        const roomTypeIdColumn = finalColumns.find(col => col.dataField === "RoomTypeID");
        if (roomTypeIdColumn) {
            roomTypeIdColumn.visible = false;
        }

        // Initialize the DevExtreme DataGrid
        $("#gridContainerRoom").dxDataGrid({
            dataSource: data,
            columns: finalColumns,
            paging: {
                pageSize: 15,
                enabled: true
            },
            pager: {
                visible: true,
                allowedPageSizes: [15, 20, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            filterRow: {
                visible: true,
                applyFilter: "auto"
            },
            editing: {
                mode: "cell",
                allowUpdating: true,
                allowAdding: false,
                allowDeleting: false
            },
            scrolling: {
                mode: 'standard',
                showScrollbar: 'always',
                useNative: false
            },
            selection: {
                mode: "single"
            }, width: "100%",
        });
    }
    function SaveGroupReservation() {
        const userName = JSON.parse(localStorage.getItem("Loginname"));
        const userID = JSON.parse(localStorage.getItem("userID"));
        const gridData = $("#gridContainerRoom").dxDataGrid("instance").getVisibleRows().map(r => r.data);
        var formData = new FormData();
        formData.append('lastName', $('#nameText').val());
        formData.append('resType', $("#resType").val());
        formData.append("gridData", JSON.stringify(gridData));
        formData.append('arrivalDate', $("#arrival2").val());
        formData.append('departureDate', $("#departure2").val());
        formData.append('noOfNight', $("#nights2").val());
        formData.append('profileIndividualID', $("#name").val());
        formData.append('package', $("#package").val());
        formData.append('packageCode', $("#package").find('option:selected').text());
        formData.append('market', $("#market").val());
        formData.append('marketCode', $("#market").find('option:selected').text());
        formData.append('resTypeCode', $('#resType').find('option:selected').text());
        formData.append('userName', userName);
        formData.append('userID', userID);
        $.ajax({
            url: '/Reservation/SaveGroupReservation',
            type: 'POST',
            processData: false,
            contentType: false,
            data: formData,
            success: function (data) {
                if (data.code == 0) {
                    @* closeModalNew();
                    searchGroupReservation(); *@
                        showToast('Thành công', data.msg, true);
                } else {
                    showToast('Lỗi', data.msg, false);
                }
            },
            error: function (xhr, statusText, err) {
                showToast('Lỗi', 'Đã xảy ra lỗi khi lưu đặt phòng nhóm.', false);
            }
        });
    }

</script>
