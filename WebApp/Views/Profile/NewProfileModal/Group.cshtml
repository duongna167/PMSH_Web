                                            <div class="row align-items-center mb-1">
                                                <label class="col-sm-4 col-form-label text-sm-end">Home Address</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="gro_txtHomeAddress" name="gro_txtHomeAddress">
                                                </div>
                                            </div>
                                            <div class="row align-items-center mb-1">
                                                <label class="col-sm-4 col-form-label text-sm-end">City</label>
                                                <div class="col-sm-6">
                                                    <select id="gro_txtCity" name="gro_txtCity" class="tomselect-custom" data-placeholder="Please select City"></select>
                                                </div>
                                            </div>
                                            <div class="row align-items-center mb-1">
                                                <label class="col-sm-4 col-form-label text-sm-end">Postal Code</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="gro_txtPostalCode" name="gro_txtPostalCode">
                                                </div>
                                            </div>
                                            <div class="row align-items-center mb-1">
                                                <label class="col-sm-4 col-form-label text-sm-end">Country / State <span class="text-danger">*</span></label>
                                                <div class="col-sm-3">
