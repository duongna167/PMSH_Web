@using DevExpress.XtraReports.UI

@{
    dynamic? listRateCode = @ViewBag.RateCodeList;
    dynamic? listRateCate = @ViewBag.RateCateList;
    dynamic? listRateClass = @ViewBag.RateClass;
}
<div class="modal fade" id="rtCode_modalMain" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="rtCode_modalTitle">Rate Code</h5>
            </div>

            <div class="modal-body position-relative">

                <div class="search-filter">
                    <!-- ACTIONS -->
                    <div>
                        <button id="rtCode_btnView" type="button" class="mui-button mui-button-new">View</button>
                        <button id="rtCode_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="rtCode_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="rtCode_btnDelete" type="button"
                                class="mui-button button-report-delete">Delete</button>
                        <button id="rtCode_btnHistory" type="button"
                                class="mui-button mui-button-resolve">History</button>
                        <button id="rtCode_btnClose" type="button"
                                class="mui-button mui-button-new">Close</button>
                    </div>

                    <!-- FILTER (ERP-style aligned with previous pattern) -->
                    <div class="mt-1">
                        <div class="row g-2 align-items-center">

                            <!-- Rate Code -->
                            <div class="col-12 col-sm-12 col-md-6 ">
                                <div class="row g-1 align-items-center">
                                    <label for="rtCode_rateCodeFilter"                                        class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4
                                        col-form-label col-form-label-sm text-md-end mb-0 text-nowrap">
                                        Rate Code
                                    </label>
                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <select id="rtCode_rateCodeFilter" name="rtCode_rateCodeFilter"
                                                class="tomselect-custom">
                                            <option value=""></option>
                                            @foreach (dynamic u in ViewBag.RateCodeList)
                                            {
                                                <option value="@u.RateCode">@u.RateCode \ @u.Descripton</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Rate Category -->
                            <div class="col-12 col-sm-12 col-md-6">
                                <div class="row g-1 align-items-center">
                                    <label for="rtCode_rateCategoryFilter" class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4
                                        col-form-label col-form-label-sm text-md-end mb-0 text-nowrap">
                                        Rate Category
                                    </label>
                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <select id="rtCode_rateCategoryFilter"      name="rtCode_rateCategoryFilter"
                                                class="tomselect-custom">
                                            <option value=""></option>
                                            @foreach (dynamic u in ViewBag.RateCateList)
                                            {
                                                <option value="@u.Code">@u.Code \ @u.Name</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- GRID -->
                <div class="mui-card">
                    <div id="rtCode_gridContainer" class="gridContainer" style="height: 520px;"></div>
                </div>

                <!-- LOADING (hidden until reload/save; no backdrop-filter to avoid stuck blur look) -->
                <div id="rtCode_loadingSpinner"
                    style="display:none;position:absolute;inset:0;z-index:999;background:rgba(255,255,255,0.55);
                    align-items:center;justify-content:center;">
                    <div class="spinner-border text-primary"></div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- UPSERT MODAL (XL per requirement) -->
<div class="modal fade" id="rtCode_modalUpsert" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered ">
        <div class="modal-content">

            <div class="modal-header">
                <h6 class="modal-title" id="rtCode_upsertTitle">New Rate Code</h6>
            </div>

            <div class="modal-body mb-2">

                <div class="search-filter">
                    <button id="rtCode_btnSaveItem" type="button" class="mui-button mui-button-save">Save</button>
                    <button id="rtCode_btnCloseUpsert" type="button" class="mui-button mui-button-close"
                            data-bs-dismiss="modal">Close</button>
                </div>

                <form id="rtCode_formItem" novalidate>
                    <input type="hidden" id="rtCode_itemId" name="rtCode_itemId" value="0" />

                    <div class="row g-2">

                        <div class="col-12 col-lg-6">
                            <div class="row g-1 align-items-center">
                                <label for="rtCode_rateCode"
                                       class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Rate Code <span class="text-danger">*</span>
                                </label>
                                <div class="col-md-8">
                                    <input type="text" id="rtCode_rateCode" name="txtRateCode"
                                           class="form-control form-control-sm" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>

                            <div class="row g-1 align-items-center mt-1">
                                <label for="rtCode_description"
                                       class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Description
                                </label>
                                <div class="col-md-8">
                                    <input type="text" id="rtCode_description" name="_description"
                                           class="form-control form-control-sm" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>

                            <div class="row g-1 align-items-center mt-1">
                                <label for="rtCode_rateClassId"
                                       class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Rate Class <span class="text-danger">*</span>
                                </label>
                                <div class="col-md-8">
                                    <select id="rtCode_rateClassId" name="modalRateCodeSel" class="tomselect-custom">
                                        <option value=""></option>
                                        @foreach (dynamic u in ViewBag.RateClass)
                                        {
                                            <option value="@u.ID">@u.Code \ @u.Name</option>
                                        }
                                    </select>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>

                            <div class="row g-1 align-items-center mt-1">
                                <label for="rtCode_rateCategoryId"
                                       class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Rate Category <span class="text-danger">*</span>
                                </label>
                                <div class="col-md-8">
                                    <select id="rtCode_rateCategoryId" name="modalRateCategorySel"
                                            class="tomselect-custom">
                                        <option value=""></option>
                                        @foreach (dynamic u in ViewBag.RateCateList)
                                        {
                                            <option value="@u.ID">@u.Code \ @u.Name</option>
                                        }
                                    </select>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>

                            <div class="row g-1 align-items-center mt-1">
                                <label for="rtCode_sequence"
                                       class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Sequence
                                </label>
                                <div class="col-md-8">
                                    <input type="number" id="rtCode_sequence" name="sequence"
                                           class="form-control form-control-sm text-end" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">

                            <div class="row g-1 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Default Display
                                </label>
                                <div class="col-md-8">
                                    <div class="d-flex gap-3">
                                        <div class="form-check mb-0">
                                            <input type="radio" name="rtCode_display" id="rtCode_displayNet" value="1"
                                                   checked>
                                            <label class="form-check-label" for="rtCode_displayNet">.Net</label>
                                        </div>
                                        <div class="form-check mb-0">
                                            <input type="radio" name="rtCode_display" id="rtCode_displayCpp" value="0">
                                            <label class="form-check-label" for="rtCode_displayCpp">C++</label>
                                        </div>
                                    </div>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>

                            <div class="row g-1 align-items-start mt-1">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Properties
                                </label>
                                <div class="col-md-8">
                                    <div class="d-flex flex-column gap-1">
                                        <div class="form-check mb-0">
                                            <input type="checkbox" id="rtCode_dayUse" name="rtCode_dayUse">
                                            <label class="form-check-label" for="rtCode_dayUse">DayUse</label>
                                        </div>
                                        <div class="form-check mb-0">
                                            <input type="checkbox" id="rtCode_active" name="rtCode_active">
                                            <label class="form-check-label" for="rtCode_active">Active</label>
                                        </div>
                                        <div class="form-check mb-0">
                                            <input type="checkbox" id="rtCode_negotiated" name="rtCode_negotiated">
                                            <label class="form-check-label" for="rtCode_negotiated">Negotiated</label>
                                        </div>
                                        <div class="form-check mb-0">
                                            <input type="checkbox" id="rtCode_individualOnly"
                                                   name="rtCode_individualOnly">
                                            <label class="form-check-label" for="rtCode_individualOnly">Individual Only</label>
                                        </div>
                                        <div class="form-check mb-0">
                                            <input type="checkbox" id="rtCode_isModifiable" name="rtCode_isModifiable">
                                            <label class="form-check-label" for="rtCode_isModifiable">Is Modifiable</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>

                    </div>
                </form>

            </div>

        </div>
    </div>
</div>

<script>
    var rtCode_Module = (function () {

        let mainModal = null;
        let upsertModal = null;

        let gridInstance = null;
        let selectedRow = null;

        const sel = {
            modalMain: "#rtCode_modalMain",
            modalUpsert: "#rtCode_modalUpsert",

            btnView: "#rtCode_btnView",
            btnNew: "#rtCode_btnNew",
            btnEdit: "#rtCode_btnEdit",
            btnDelete: "#rtCode_btnDelete",
            btnHistory: "#rtCode_btnHistory",
            btnClose: "#rtCode_btnClose",

            grid: "#rtCode_gridContainer",
            loading: "#rtCode_loadingSpinner",

            rateCodeFilter: "#rtCode_rateCodeFilter",
            rateCategoryFilter: "#rtCode_rateCategoryFilter",

            form: "#rtCode_formItem",
            itemId: "#rtCode_itemId",
            rateCode: "#rtCode_rateCode",
            description: "#rtCode_description",
            rateClassId: "#rtCode_rateClassId",
            rateCategoryId: "#rtCode_rateCategoryId",
            sequence: "#rtCode_sequence",
            displayName: "rtCode_display",
            dayUse: "#rtCode_dayUse",
            active: "#rtCode_active",
            negotiated: "#rtCode_negotiated",
            individualOnly: "#rtCode_individualOnly",
            isModifiable: "#rtCode_isModifiable",

            upsertTitle: "#rtCode_upsertTitle",
            btnSave: "#rtCode_btnSaveItem"
        };

        function init() {
            initTomSelect(".tomselect-custom");
            mainModal = bootstrap.Modal.getOrCreateInstance(document.querySelector(sel.modalMain), { backdrop: "static" });
            upsertModal = bootstrap.Modal.getOrCreateInstance(document.querySelector(sel.modalUpsert), { backdrop: "static" });

            $(sel.modalMain).off("shown.bs.modal.rtCode").on("shown.bs.modal.rtCode", function () {
                bindEvents();
                reloadGrid();
            });

            $(sel.modalMain).off("hidden.bs.modal.rtCode").on("hidden.bs.modal.rtCode", function () {
                cleanup();
            });

            $(sel.modalUpsert).off("hidden.bs.modal.rtCode").on("hidden.bs.modal.rtCode", function () {
                clearForm();
                if (typeof window.applyValidationErrors === "function") applyValidationErrors([], sel.form);
            });
        }

        function open() {
            mainModal.show();
        }

        function bindEvents() {
            $(document).off("click.rtCode", sel.btnView).on("click.rtCode", sel.btnView, function () {
                reloadGrid();
            });

            $(document).off("change.rtCode", sel.rateCodeFilter).on("change.rtCode", sel.rateCodeFilter, function () {
                reloadGrid();
            });

            $(document).off("change.rtCode", sel.rateCategoryFilter).on("change.rtCode", sel.rateCategoryFilter, function () {
                reloadGrid();
            });

            $(document).off("click.rtCode", sel.btnNew).on("click.rtCode", sel.btnNew, function () {
                openNew();
            });

            $(document).off("click.rtCode", sel.btnEdit).on("click.rtCode", sel.btnEdit, function () {
                openEdit();
            });

            $(document).off("click.rtCode", sel.btnDelete).on("click.rtCode", sel.btnDelete, function () {
                doDelete();
            });

            $(document).off("click.rtCode", sel.btnHistory).on("click.rtCode", sel.btnHistory, function () {
                showToast("Warning", "History: not implemented in provided code.", false);
            });

            $(document).off("click.rtCode", sel.btnClose).on("click.rtCode", sel.btnClose, function () {
                mainModal.hide();
            });

            $(document).off("click.rtCode", sel.btnSave).on("click.rtCode", sel.btnSave, function () {
                save();
            });
        }

        function showLoading(on) {
            if (on) $(sel.loading).css("display", "flex"); else $(sel.loading).hide();
        }

        function getFilterPayload() {
            return {
                rateCode: $(sel.rateCodeFilter).val() || "",
                rateCategory: $(sel.rateCategoryFilter).val() || ""
            };
        }

        function reloadGrid() {
            showLoading(true);

            $.ajax({
                url: '/Administration/RateCode/GetAllRateCode',
                type: 'GET',
                data: getFilterPayload(),
                success: function (result) {
                    try {
                        const rows = result?.data || [];
                        renderGrid(rows);
                        if (!rows.length) showToast("Warning", "No records.", false);
                    } catch (e) {
                        console.error(e);
                        showToast("Error", "Cannot render grid.", false);
                        destroyGrid();
                    }
                },
                error: function () {
                    showToast("Error", "Cannot load data.", false);
                    destroyGrid();
                },
                complete: function () {
                    showLoading(false);
                }
            });
        }

        function destroyGrid() {
            try {
                if (gridInstance) {
                    gridInstance.dispose();
                    gridInstance = null;
                }
            } catch { }
            $(sel.grid).empty();
            selectedRow = null;
        }

        function renderGrid(data) {
            destroyGrid();

            gridInstance = $(sel.grid).dxDataGrid({
                dataSource: data,
                keyExpr: "id",
                width: "100%",

                allowColumnResizing: true,
                columnAutoWidth: true,
                selection: { mode: "single" },

                filterRow: { visible: true, applyFilter: "auto" },
                sorting: { mode: "multiple" },
                paging: { pageSize: 20 },
                pager: { visible: true, showInfo: true, showNavigationButtons: true, allowedPageSizes: [20, 50, "all"], showPageSizeSelector: true },

                columns: [
                    { dataField: "id", visible: false, sortOrder: "desc", sortIndex: 0 },
                    { dataField: "rateCode", caption: "Code", width: 150 },
                    { dataField: "category", caption: "Category", width: 150 },
                    { dataField: "description", caption: "Description",width:300 },
                ],

                onSelectionChanged: function (e) {
                    selectedRow = e.selectedRowsData[0] || null;
                },
                onRowClick: function (e) {
                    const grid = $(sel.grid).dxDataGrid("instance");
                    if (grid) grid.selectRows([e.key], false);
                }
            }).dxDataGrid("instance");
        }

        function clearForm() {
            $(sel.itemId).val(0);
            $(sel.rateCode).val("");
            $(sel.description).val("");
            clearMultipleTomSelect(["#rtCode_rateClassId","#rtCode_rateCategoryId"],true);
            $(sel.sequence).val("");
            $(`input[name='${sel.displayName}'][value='1']`).prop("checked", true);

            $(sel.dayUse).prop("checked", false);
            $(sel.active).prop("checked", false);
            $(sel.negotiated).prop("checked", false);
            $(sel.individualOnly).prop("checked", false);
            $(sel.isModifiable).prop("checked", false);
        }

        function openNew() {
            clearForm();
            if (typeof window.applyValidationErrors === "function") applyValidationErrors([], sel.form);
            $(sel.upsertTitle).text("New Rate Code");
            upsertModal.show();
        }

        function openEdit() {
            if (!selectedRow) {
                showToast("Warning", "Please select 1 row to update.", false);
                return;
            }

            clearForm();
            if (typeof window.applyValidationErrors === "function") applyValidationErrors([], sel.form);

            $.ajax({
                url: '/Administration/RateCode/GetByID',
                type: 'GET',
                data: { id: selectedRow.id },
                success: function (res) {
                    if (!res?.success) {
                        showToast("Error", res?.message || "Cannot load item.", false);
                        return;
                    }

                    const d = res.data || {};
                    $(sel.itemId).val(d.id || 0);
                    $(sel.rateCode).val(d.rateCode || "");
                    $(sel.description).val(d.descripton || "");
                    setTomSelectValue(sel.rateClassId, String(d.rateClassID || 0));
                    setTomSelectValue(sel.rateCategoryId, String(d.rateCategoryID || 0));
                    $(sel.sequence).val(d.sequence ?? "");

                    if (Number(d.defaultDisplay) === 1) {
                        $("#rtCode_displayNet").prop("checked", true);
                    } else {
                        $("#rtCode_displayCpp").prop("checked", true);
                    }

                    $(sel.dayUse).prop("checked", !!d.dayUse);
                    $(sel.active).prop("checked", !!d.status);
                    $(sel.negotiated).prop("checked", !!d.negotiated);
                    $(sel.individualOnly).prop("checked", !!d.individualOnly);
                    $(sel.isModifiable).prop("checked", !!d.isModify);

                    $(sel.upsertTitle).text("Edit Rate Code");
                    upsertModal.show();
                },
                error: function () {
                    showToast("Error", "Cannot load item.", false);
                }
            });
        }

        function save() {
            const payload = {
                id: parseInt($(sel.itemId).val()) || 0,
                rateCode: $(sel.rateCode).val(),
                description: $(sel.description).val(),
                rateClass: parseInt($(sel.rateClassId).val()) || 0,
                rateCategory: parseInt($(sel.rateCategoryId).val()) || 0,
                sequence: parseInt($(sel.sequence).val()) || 0,
                display: parseInt($(`input[name='${sel.displayName}']:checked`).val()) || 0,

                dayUse: $(sel.dayUse).is(":checked") ? 1 : 0,
                active: $(sel.active).is(":checked"),
                negotiated: $(sel.negotiated).is(":checked"),
                individualOnly: $(sel.individualOnly).is(":checked"),
                isModifiable: $(sel.isModifiable).is(":checked"),

                userID: parseInt(localStorage.getItem("userID")) || 0
            };

            showLoading(true);

            $.ajax({
                url: "/Administration/RateCode/Save",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(payload),
                success: function (res) {
                    showLoading(false);

                    if (res?.success) {
                        showToast("Success", res.message, true);
                        upsertModal.hide();
                        reloadGrid();
                    } else {
                        if (typeof window.applyValidationErrors === "function") {
                            applyValidationErrors(res?.errors || [], sel.form);
                        } else {
                            showToast("Error", res?.message || "Save failed.", false);
                        }
                    }
                },
                error: function (xhr) {
                    showLoading(false);
                    showToast("Error", xhr.responseJSON?.message || "Save failed.", false);
                }
            });
        }

        function doDelete() {
            if (!selectedRow) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }

            // Lấy id từ selectedRow (tùy grid của bạn, sửa key nếu khác)
            const id = parseInt(selectedRow.id || selectedRow.ID || selectedRow.Id, 10) || 0;

            if (id <= 0) {
                showToast("Warning", "Invalid selected row ID.", false);
                return;
            }

            if (!confirm(`Delete RateCode?`)) return;

            $.ajax({
                url: `/Administration/RateCode/RateCodeDelete?id=${encodeURIComponent(id)}`, // vì action nhận int id (querystring)
                type: "POST",
                contentType: "application/json; charset=utf-8",
                success: function (res) {
                    if (res && res.success) {
                        showToast("Success", res.message || "Deleted successfully.", true);
                       reloadGrid();
                    } else {
                        showToast("Warning", res?.message || "Delete failed.", false);
                    }
                },
                error: function (xhr) {
                    // API bạn trả về BadRequest với JSON: {success:false,message:"..."}
                    const res = xhr.responseJSON;
                    showToast("Warning", res?.message || `Delete failed (${xhr.status}).`, false);
                }
            });
        }

        function cleanup() {
            $(document).off(".rtCode");
            destroyGrid();
        }

        return { init, open };

    })();

    // Option A global entry
    window.openModalRtCode = function () {
        rtCode_Module.open();
    };

    $(document).ready(function () {
        rtCode_Module.init();
        // Auto-open if needed:
        // window.openModalRtCode();
    });
</script>
