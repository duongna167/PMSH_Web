        let gridNewDetails = null;

        let selectedRateCodesRow = null;   // from left grid
        let selectedGroupedRow = null;     // from grouped grid
        let selectedDetailId = null;       // from bottom grid selection
        let suppressLeftGridCascade = false;

        const sel = {
            modalMain: "#rtCD_modalMain",
            modalUpsert: "#rtCD_modalUpsert",

            btnView: "#rtCD_btnView",
            btnNew: "#rtCD_btnNew",
            btnEdit: "#rtCD_btnEdit",
            btnEditFull: "#rtCD_btnEditFull",
            btnDelete: "#rtCD_btnDelete",
            btnExportExcel: "#rtCD_btnExportExcel",
            btnClose: "#rtCD_btnClose",

            btnEditNew: "#rtCD_editNew",
            btnEditUpdate: "#rtCD_editUpdate",
            btnEditDelete: "#rtCD_editDelete",
            btnEditChanges: "#rtCD_editChanges",
            btnEditRepeat: "#rtCD_editRepeat",

            code: "#rtCD_code",
            category: "#rtCD_category",
            typeDate: "#rtCD_typeDate",
            fromDateUi: "#rtCD_fromDateUi",
            toDateUi: "#rtCD_toDateUi",

            gridRateCodes: "#rtCD_gridRateCodes",
            gridGrouped: "#rtCD_gridRateDetailsGrouped",
            gridDetails: "#rtCD_gridDetails",
            gridNewDetails: "#gridContainerRateCodeDetail",

            loading: "#rtCD_loadingSpinner",

            form: "#rtCD_form",
            upsertTitle: "#rtCD_upsertTitle",
            btnSave: "#rtCD_btnSave",
            btnSaveClose: "#rtCD_btnSaveClose",

            modalDetailId: "#rtCD_modalDetailId",
            rateCode: "#rtCD_rateCode",
            season: "#rtCD_season",
            package: "#rtCD_package",
            roomType: "#rtCD_roomType",
            modalFromDateUi: "#rtCD_modalFromDateUi",
            modalToDateUi: "#rtCD_modalToDateUi",
            transCode: "#rtCD_transCode",
            currency: "#rtCD_currency",
            minLos: "#rtCD_minLos",
            maxLos: "#rtCD_maxLos",
            minNoOfRoom: "#rtCD_minNoOfRoom",
            maxNoOfRoom: "#rtCD_maxNoOfRoom",
            printRate: "#rtCD_printRate",
            discount: "#rtCD_discount",
            amt1: "#rtCD_amt1", amt1Net: "#rtCD_amt1Net",
            amt2: "#rtCD_amt2", amt2Net: "#rtCD_amt2Net",
            amt3: "#rtCD_amt3", amt3Net: "#rtCD_amt3Net",
            amt4: "#rtCD_amt4", amt4Net: "#rtCD_amt4Net",
            amt5: "#rtCD_amt5", amt5Net: "#rtCD_amt5Net",
            amt6: "#rtCD_amt6", amt6Net: "#rtCD_amt6Net",
            amt7: "#rtCD_amt7", amt7Net: "#rtCD_amt7Net",
            amt8: "#rtCD_amt8", amt8Net: "#rtCD_amt8Net",
            amt9: "#rtCD_amt9", amt9Net: "#rtCD_amt9Net",
            amt10: "#rtCD_amt10", amt10Net: "#rtCD_amt10Net",
            amt11: "#rtCD_amt11", amt11Net: "#rtCD_amt11Net",
            amt12: "#rtCD_amt12", amt12Net: "#rtCD_amt12Net",
            amt13: "#rtCD_amt13", amt13Net: "#rtCD_amt13Net",
            amt14: "#rtCD_amt14", amt14Net: "#rtCD_amt14Net",
            amt15: "#rtCD_amt15", amt15Net: "#rtCD_amt15Net",
            child1: "#rtCD_child1", child1Net: "#rtCD_child1Net",
            child2: "#rtCD_child2", child2Net: "#rtCD_child2Net",
            child3: "#rtCD_child3", child3Net: "#rtCD_child3Net",
            extraAdult: "#rtCD_extraAdult", extraAdultNet: "#rtCD_extraAdultNet"
        };

        function init() {
            mainModal = bootstrap.Modal.getOrCreateInstance(document.querySelector(sel.modalMain), { backdrop: "static" });
            upsertModal = bootstrap.Modal.getOrCreateInstance(document.querySelector(sel.modalUpsert), { backdrop: "static" });

            $(sel.modalMain).off("shown.bs.modal.rtCD").on("shown.bs.modal.rtCD", async function () {
                bindEvents();

                // Init selects + date inputs (reuse your shared helpers if present)
                try { if (typeof window.initTomSelect === "function") window.initTomSelect(".tomselect-custom"); } catch { }
                try { if (typeof window.initDateInputs === "function") await window.initDateInputs(); } catch { }

                await reloadAll(true);
            });

            $(sel.modalMain).off("hidden.bs.modal.rtCD").on("hidden.bs.modal.rtCD", function () {
                cleanup();
            });

            $(sel.modalUpsert).off("hidden.bs.modal.rtCD").on("hidden.bs.modal.rtCD", function () {
                clearForm();
                if (typeof window.applyValidationErrors === "function") applyValidationErrors([], sel.form);
            });
        }

        function open() {
            mainModal.show();
        }

        function bindEvents() {
            $(document).off("click.rtCD", sel.btnView).on("click.rtCD", sel.btnView, function () {
                reloadAll(false);
            });

            $(document).off("click.rtCD", sel.btnNew).on("click.rtCD", sel.btnNew, function () {
                openNew();
            });

            $(document).off("click.rtCD", sel.btnEdit).on("click.rtCD", sel.btnEdit, function () {
                openEdit();
            });

            $(document).off("click.rtCD", sel.btnDelete).on("click.rtCD", sel.btnDelete, function () {
                doDelete();
            });

            $(document).off("click.rtCD", sel.btnExportExcel).on("click.rtCD", sel.btnExportExcel, function () {
                exportExcel();
            });

            $(document).off("click.rtCD", sel.btnClose).on("click.rtCD", sel.btnClose, function () {
                mainModal.hide();
            });

            $(document).off("click.rtCD", sel.btnSave).on("click.rtCD", sel.btnSave, function () {
                save(false);
            });

            $(document).off("click.rtCD", sel.btnSaveClose).on("click.rtCD", sel.btnSaveClose, function () {
                save(true);
            });

            $(document).off("click.rtCD", sel.btnEditFull).on("click.rtCD", sel.btnEditFull, function () {
                openEditFull();
            });

            $(document).off("click.rtCD", sel.btnEditNew).on("click.rtCD", sel.btnEditNew, function () {
                openNew();
            });

            $(document).off("click.rtCD", sel.btnEditUpdate).on("click.rtCD", sel.btnEditUpdate, function () {
                save(false);
            });

            $(document).off("click.rtCD", sel.btnEditDelete).on("click.rtCD", sel.btnEditDelete, function () {
                deleteDetailRow();
            });

            $(document).off("click.rtCD", sel.btnEditChanges).on("click.rtCD", sel.btnEditChanges, function () {
                showToast("Info", "Changes feature is not yet implemented.", false);
            });

            $(document).off("click.rtCD", sel.btnEditRepeat).on("click.rtCD", sel.btnEditRepeat, function () {
                showToast("Info", "Repeat feature is not yet implemented.", false);
            });
        }

        function cleanup() {
            $(document).off(".rtCD");
            destroyGrid(sel.gridRateCodes, gridRateCodes); gridRateCodes = null;
            destroyGrid(sel.gridGrouped, gridGrouped); gridGrouped = null;
            destroyGrid(sel.gridDetails, gridDetails); gridDetails = null;
            destroyGrid(sel.gridNewDetails, gridNewDetails); gridNewDetails = null;

            selectedRateCodesRow = null;
            selectedGroupedRow = null;
            selectedDetailId = null;
        }

        function showLoading(on) {
            if (on) $(sel.loading).css("display", "flex"); else $(sel.loading).hide();
        }

        // --------- API ---------
        async function apiGetAllRateCodeDetail() {
            return $.ajax({
                url: "/Administration/RateCode/GetAllRateCodeDetail",
                type: "GET",
                data: {
                    rateCode: $(sel.code).val(),
                    rateCategory: $(sel.category).val(),
                    typeOfDate: $(sel.typeDate).val(),
                    fromDate: $("#rtCD_fromDate").val() || $(sel.fromDateUi).val(), // allow hidden ISO if you use DateInput
                    toDate: $("#rtCD_toDate").val() || $(sel.toDateUi).val()
                },
                traditional: true,
                crossDomain: false,
                headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() }
            });
        }

        async function apiRateCodeGroupDataByID(rateCodeID) {
            return $.ajax({
                url: "/Administration/RateCode/RateCodeGroupDataByID",
                type: "GET",
                data: { rateCodeID: rateCodeID }
            });
        }

        async function apiGetDetails(groupRow) {
            const pid = groupRow.packageID != null && groupRow.packageID !== "" ? groupRow.packageID : 0;
            return $.ajax({
                url: "/Administration/RateCode/GetDetails",
                type: "GET",
                data: {
                    RateCodeID: groupRow.rateCodeID ?? groupRow.RateCodeID,
                    BeginDate: groupRow.beginDate,
                    EndDate: groupRow.endDate,
                    RoomType: groupRow.roomType,
                    TransCode: groupRow.transaction,
                    CurrencyID: groupRow.curr,
                    PackageID: pid,
                    A1: groupRow.a1,
                    A2: groupRow.a2,
                    A3: groupRow.a3,
                    A4: groupRow.a4,
                    A5: groupRow.a5,
                    A6: groupRow.a6,
                    C1: groupRow.c1,
                    C2: groupRow.c2,
                    C3: groupRow.c3,
                    MinLOS: groupRow.minLOS,
                    MaxLOS: groupRow.maxLOS,
                    MinRoom: groupRow.minNoOfRoom,
                    MaxRoom: groupRow.maxNoOfRoom
                },
                traditional: true,
                crossDomain: false,
                headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() }
            });
        }

        // --------- LOAD ---------
        function pickAnchorGroupedRow(grouped, anchor) {
            if (!anchor || !Array.isArray(grouped) || !grouped.length) return grouped?.[0] ?? null;
            const tx = String(anchor.transaction ?? "");
            const rt = String(anchor.roomType ?? "");
            const found = grouped.find(g =>
                String(g.roomType ?? "") === rt &&
                String(g.transaction ?? "") === tx
            );
            return found || grouped[0];
        }

        function mapDetailModelToGridRow(m, rateCodeText) {
            if (!m) return null;
            return {
                id: m.id ?? m.ID,
                roomTypeID: m.roomTypeID ?? m.RoomTypeID,
                rateCode: rateCodeText || "",
                roomType: m.roomType ?? "",
                rateDate: m.rateDate,
                transactionCode: m.transactionCode ?? "",
                currencyID: m.currencyID ?? "",
                a1: m.a1, a1AfterTax: m.a1AfterTax,
                a2: m.a2, a2AfterTax: m.a2AfterTax,
                a3: m.a3, a3AfterTax: m.a3AfterTax,
                a4: m.a4, a4AfterTax: m.a4AfterTax,
                a5: m.a5, a5AfterTax: m.a5AfterTax,
                a6: m.a6, a6AfterTax: m.a6AfterTax,
                c1AfterTax: m.c1AfterTax,
                c2AfterTax: m.c2AfterTax,
                c3AfterTax: m.c3AfterTax,
                adultExtraTax: m.adultExtraTax
            };
        }

        async function mergeHighlightDetail(details, highlightId) {
            const hid = parseInt(highlightId, 10);
            if (!hid || !Array.isArray(details)) return details || [];
            if (details.some(d => parseInt(d.id, 10) === hid)) return details;
            try {
                const gr = await $.getJSON("/Administration/RateCode/GetRateCodeDetailById", { id: hid });
                if (gr?.success && gr.data) {
                    const row = mapDetailModelToGridRow(gr.data, gr.rateCode);
                    if (row) return [row, ...details];
                }
            } catch (e) { console.error(e); }
            return details;
        }

        async function reloadAll(isInitial = false, opts) {
            try {
                showLoading(true);

                if (isInitial) {
                    try {
                        if (typeof window.waitForBusinessDate === "function") {
                            await waitForBusinessDate("rtCD_fromDate", 10000);
                            await waitForBusinessDate("rtCD_toDate", 10000);
                        }
                    } catch { }
                }

                const rateCodes = await apiGetAllRateCodeDetail();

                if (!Array.isArray(rateCodes) || !rateCodes.length) {
                    renderAllGrids([], [], []);
                    showToast("Warning", "No Rate Code data found.", false);
                    return;
                }

                const pref = opts && opts.preferredRateCodeId ? parseInt(opts.preferredRateCodeId, 10) : 0;
                const targetRateCodeId = pref > 0 && rateCodes.some(r => r.idRateCode === pref)
                    ? pref
                    : rateCodes[0].idRateCode;

                let grouped = await apiRateCodeGroupDataByID(targetRateCodeId);
                grouped = Array.isArray(grouped) ? grouped : [];

                const anchor = opts && opts.anchorGroup ? opts.anchorGroup : null;
                const groupRow = pickAnchorGroupedRow(grouped, anchor);

                let details = groupRow ? await apiGetDetails(groupRow) : [];
                details = Array.isArray(details) ? details : [];

                if (opts && opts.highlightDetailId) {
                    details = await mergeHighlightDetail(details, opts.highlightDetailId);
                }

                renderAllGrids(rateCodes, grouped, details);

                if (gridRateCodes && targetRateCodeId) {
                    suppressLeftGridCascade = true;
                    try {
                        gridRateCodes.selectRows([targetRateCodeId], false);
                    } catch (e) {
                        console.error(e);
                    } finally {
                        suppressLeftGridCascade = false;
                    }
                }

            } catch (err) {
                console.error(err);
                renderAllGrids([], [], []);
                showToast("Error", "The report could not be loaded.", false);
            } finally {
                showLoading(false);
            }
        }

