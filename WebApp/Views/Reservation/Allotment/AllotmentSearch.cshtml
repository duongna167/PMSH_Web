                    </div>

                    <div class="gridContainer flex-grow-1 d-flex flex-column position-relative py-2">
                        <div id="allot_transHis_grid"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>

    var allot_search_Module = {
        selectedRowData: null,
        selectedDetailRow: null,
        currentNoOfDays: 20,

        baseGridOptions: {
            height: "100%",
            width: "100%",
            showBorders: true,
            hoverStateEnabled: true,
            wordWrapEnabled: false,
            allowColumnResizing: true,
            columnResizingMode: "widget",
            columnAutoWidth: false,
            selection: { mode: "single" },
            scrolling: {
                mode: "standard",
                showScrollbar: "always",
                useNative: false
            },
            loadPanel: {
                enabled: false
            },
            filterRow: { visible: true, applyFilter: "auto" }
        },

        initGrid: function (containerId, options) {
            const fullOptions = $.extend(true, {}, this.baseGridOptions, options);
            return $(containerId).dxDataGrid(fullOptions);
        },

        init: function () {
            if (typeof LoadingGlobal !== 'undefined') LoadingGlobal.init();
            this.initEvents();
            this.intitDOMEvents();
        },

        initEvents: function () {
            const self = this;

            window.openModalAllotSearch = function () {
                initTomSelect(".tomselect-custom");
                clearMultipleTomSelect([
                    "#allot_search_market",
                    "#allot_search_type"
                ]);
                self.reloadGrid();

            };

            $('#allot_setup_itemModal').on('hidden.bs.modal', function () {
                ValidationAdapter.clear("#allot_setup_formContainer");
            });

            $('#allot_transfer_modal').on('hidden.bs.modal', function () {
                ValidationAdapter.clear("#allot_transfer_formContainer");
                clearMultipleTomSelect([
                    "#allot_trans_roomTypeID",
                    "#allot_trans_toID",
                    "#allot_trans_stageID"
                ]);
            });

            const syncTransferDates = (triggerField) => {
                // Log để kiểm tra xem hàm có chạy vào không
                console.log("Triggered sync by:", triggerField);

                const fromIso = $("#allot_trans_fromDate").val();
                const toIso = $("#allot_trans_toDate").val();
                const count = parseInt($("#allot_trans_count").val() || 0);

                if (triggerField === 'fromDate' || triggerField === 'count') {
                    if (fromIso && count > 0) {
                        const newToIso = UI.addDaysIso(fromIso, count);
                        UI.setHiddenDate("allot_trans_toDate", newToIso);
                    }
                }
                else if (triggerField === 'toDate') {
                    if (fromIso && toIso) {
                        const dFrom = new Date(fromIso);
                        const dTo = new Date(toIso);
                        const diffDays = Math.ceil((dTo - dFrom) / (1000 * 60 * 60 * 24));

                        if (diffDays > 0) {
                            $("#allot_trans_count").val(diffDays);
                        } else {
                            const minTo = UI.addDaysIso(fromIso, 1);
                            UI.setHiddenDate("allot_trans_toDate", minTo);
                            $("#allot_trans_count").val(1);
                        }
                    }
                }
            };

            // Lắng nghe trực tiếp trên ID thẻ hidden (được sinh ra bởi data-name)
            $(document).on("change", "#allot_trans_fromDate", () => syncTransferDates('fromDate'));
            $(document).on("change", "#allot_trans_toDate", () => syncTransferDates('toDate'));
            $(document).on("input change", "#allot_trans_count", () => syncTransferDates('count'));

        },

        intitDOMEvents: function () {
            const self = this;
            $("#allot_search_btnView").on("click", () => self.reloadGrid());
            $("#allot_search_btnNew").on("click", () => self.openNewModal());
            $("#allot_search_btnEdit").on("click", () => self.openEditModal());
            $("#allot_setup_btnSaveItem").on("click", () => self.saveAllotment());
            $("#allot_search_btnDelete").on("click", () => self.confirmDelete());
            $("#allot_search_btnTransHistory").on("click", () => self.opemdModalTransHistory());
            $("#allot_search_btnExportExcel").on("click", () => self.exportAllotInfoToExcel());
            $("#allot_search_btnDetail").on("click", () => self.openModalDetail());
            $("#allot_detail_btnSearchDetail").on("click", () => self.fetchDetailByStage());
            $("#allot_detail_btnExport").on("click", () => self.exportDetailStageToExcel());
            $("#allot_transHis_btnExportExcel").on("click", () => self.exportTransHisToExcel());
            $("#allot_search_btnFromAllotment").on("click", () => self.openTransferModal(1));
            $("#allot_search_btnFromInventory").on("click", () => self.openTransferModal(0));

            $("#allot_trans_btnInput").on("click", () => self.handleInputTransfer());
            $("#allot_trans_btnOK").on("click", () => self.saveTransfer());

                $("#allot_search_profileName").on("input", function() {
                if ($(this).val().trim() === "") {
                    $("#allot_search_profileId").val("");
                }
            });

            $("#allot_detail_noOfDays").on("change", function () {
                allot_search_Module.fetchDetailByStage();
            });
        },

        reloadGrid: function () {
            const self = this;
            const filterData = {
                code: $("#allot_search_code").val(),
                marketID: getTomSelectData("#allot_search_market")?.value,
                allotmentTypeID: getTomSelectData("#allot_search_type")?.value,
                profileID: $("#allot_search_profileId").val(),
                zone: (getTomSelectData("#allot_search_zone") || []).map(x => x.value).join(","),
                isDefault: $('#allot_search_default').is(':checked') ? 1 : 0
            };

            self.renderDetailGrid([]);
            self.renderResvGrid([]);

            $.ajax({
                url: '/Allotment/GetAllotmentSearch',
                type: 'GET',
                data: filterData,
                loadingGrid: '#allot_search_gridAllotInfor',
                success: function (data) {
                    self.renderMainGrid(data);

                    if (data && data.length > 0) {
                        const firstRow = data[0];
                        self.selectedRowData = firstRow;

                        self.fetchAllotmentDetail(firstRow.id);
                        self.fetchReservation(firstRow.id, "");

                        setTimeout(() => {
                            const gridInstance = $("#allot_search_gridAllotInfor").dxDataGrid("instance");
                            if (gridInstance) {
                                gridInstance.selectRowsByIndexes([0]);
                            }
                        }, 100); 
                    } else {
                        self.selectedRowData = null;
                    }
                },
                error: function (xhr, status, error) {
                    showToast("Error", "Unable to load data", false);
                }
            });
        },

        renderMainGrid: function (data) {
            const self = this;
            var listMarket = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.MarketList ?? new List<object>()));
            var listAllType = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.AllotTypeList ?? new List<object>()));

            self.initGrid("#allot_search_gridAllotInfor", {
                dataSource: data,
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "profileID", visible: false },
                    { dataField: "code",caption: "All.Code",width: 110 },
                    { dataField: "allotmentName",caption: "All.Name",width: 180},
                    { dataField: "accountName",caption: "Profile",width: 180},
                    // { dataField: "marketID", visible: false },
                    {
                        dataField: "marketID",
                        caption: "Market",
                        width: 100,
                        lookup: {
                            dataSource: listMarket,
                            valueExpr: "ID",
                            displayExpr: "Name"
                        }
                    },
                    // { dataField: "allotmentTypeID", visible: false },
                    {
                        dataField: "allotmentTypeID",
                        caption: "All.Type",
                        width: 100,
                        lookup: {
                            dataSource: listAllType,
                            valueExpr: "ID",
                            displayExpr: "Name"
                        }
                    },
                    { dataField: "cuttOfDay", caption: "Cutt.Day",width: 70 },
                    { dataField: "cuttOfDate", caption: "Cutt.Date", dataType: "date", format: "dd/MM/yyyy",  width: 110 },
                    { dataField: "createBy", caption: "Created By", width: 90 },
                    { dataField: "createDate",  caption: "Created Date", dataType: "date", format: "dd/MM/yyyy hh:mm", width: 110 }, 
                    { dataField: "updateBy", caption: "Updated By", width: 90 },
                    { dataField: "updateDate", caption: "Updated Date", dataType: "date", format: "dd/MM/yyyy hh:mm", width: 110 }
                ],
                onContentReady: function(e) {
                    if (data && data.length > 0 && e.component.getSelectedRowKeys().length === 0) {
                        setTimeout(() => {
                            e.component.selectRowsByIndexes([0]);
                        }, 20);
                    }
                },
                onSelectionChanged: function (e) {
                    const selectedRow = e.selectedRowsData[0];
                    if (selectedRow) {
                        self.selectedRowData = selectedRow;

                        self.resetDetailGrids();
                            
                        self.fetchAllotmentDetail(selectedRow.id);
                        self.fetchReservation(selectedRow.id, "");
                    }
                }
            });

        },

        fetchAllotmentDetail: function(allotmentId) {
            const self = this;
        
            const isHistory = $("#allot_search_history").is(":checked");

            $.ajax({
                url: '/Allotment/GetAllotmentDetail',
                type: 'GET',
                loadingGrid: '#allot_search_gridAllotDetail',
                data: {
                    allotmentId: allotmentId,
                    isHistoryChecked: isHistory
                },
                success: function (res) {
                    self.renderDetailGrid(res.data, res.roomTypeColumns);
                },
                error: function (xhr, status, error) {
                    console.error('GetAllotmentDetail error:', error);
                    showToast("Error", "Unable to load allotment detail", false);
                }
            });
        },

        renderDetailGrid: function (data, roomTypeColumns) {
            const self = this;

            // Định nghĩa các cột cố định ban đầu
            let dynamicColumns = [
                { dataField: "From Date", caption: "From Date", width: 90 },
                { dataField: "To Date", caption: "To Date", width: 90 },
                { dataField: "Stage", caption: "Stage", width: 70 },
                { dataField: "CutOff", caption: "CutOff", width: 60 }
            ];

            // Thêm các cột RoomType dựa trên danh sách từ Server (luôn có dù data rỗng)
            if (roomTypeColumns) {
                roomTypeColumns.forEach(colName => {
                    dynamicColumns.push({
                        dataField: colName,
                        caption: colName,
                        width: 60,
                        alignment: "right"
                    });
                });
            }

            // Thêm cột Total cuối cùng và xử lý lề (padding)
            dynamicColumns.push({
                dataField: "Total",
                caption: "Total",
                width: 70,
                alignment: "right",
                cssClass: "grid-column-total"
            });

            self.initGrid("#allot_search_gridAllotDetail", {
                dataSource: data,
                columns: dynamicColumns,
                columnAutoWidth: false,
                wordWrapEnabled: false
            });
        },

        resetDetailGrids: function () {
            const detailGrid = $("#allot_search_gridAllotDetail").dxDataGrid("instance");
            const reservationGrid = $("#allot_search_gridReservation").dxDataGrid("instance");

            if (detailGrid) {
                detailGrid.option("dataSource", []);
            }

            if (reservationGrid) {
                reservationGrid.option("dataSource", []);
            }
        },

        fetchReservation: function(allotmentId, roomTypeCode) {
            const self = this;

            $.ajax({
                url: '/Allotment/GetAllotmentResvSearch',
                type: 'GET',
                loadingGrid: '#allot_search_gridReservation',
                data: {
                    allotmentId: allotmentId,
                    roomTypeCode: roomTypeCode
                },
                success: function (res) {
                    self.renderResvGrid(res);
                },
                error: function (xhr, status, error) {
                    console.error('GetAllotmentResvSearch error:', error);
                    showToast("Error", "Lỗi khi load danh sách Reservation", false);
                }
            });
        },

        renderResvGrid: function (data) {
            const self = this;
            self.initGrid("#allot_search_gridReservation", {
                dataSource: data,
                columns: [
                    { dataField: "reservationID", visible: false },
                    { dataField: "confNo", caption: "Conf. No", width: 90 },
                    { dataField: "mg", caption: "MG", width: 40 },
                    { dataField: "nat", caption: "Nat", width: 60 },
                    { dataField: "guestName", caption: "Guest Name", width: 180 },
                    { dataField: "rms", caption: "Rms", width: 50 },
                    { dataField: "roNo", caption: "Ro. No", width: 70 },
                    { dataField: "roType", caption: "Ro. Type", width: 80 },
                    { dataField: "arr", caption: "Arr.", width: 90 },
                    { dataField: "n", caption: "N", width: 40 },
                    { dataField: "dep", caption: "Dep.", width: 90},
                    { dataField: "adults", caption: "A", width: 30},
                    { dataField: "child", caption: "C", width: 30},
                    { dataField: "child1", caption: "C1", width: 30},
                    { dataField: "child2", caption: "C2", width: 30},
                    { dataField: "status", caption: "Status", width: 100 },
                    { dataField: "price", caption: "Price", format: "#,##0.##", width: 100 },
                    { dataField: "priceNet", caption: "PriceNet", format: "#,##0.##", width: 100 },
                    { dataField: "curr", caption: "Curr.", width: 50 },
                    { dataField: "packages", caption: "Packages", width: 80 },
                    { dataField: "marketCode", caption: "Market", width: 100 },
                    { dataField: "createBy", caption: "CreatedBy", width: 80 },
                    { dataField: "createDate", caption: "CreateDate", width: 110 },
                    { dataField: "updateBy", caption: "UpdateBy", width: 80 },
                    { dataField: "updateDate", caption: "UpdateDate", width: 110 }
                ],
                //mở new reservation
                onRowDblClick: function(e) {
                    // if (e.data && e.data.ReservationID) {
                    //     if (typeof openReservationDetail === "function") {
                    //         openReservationDetail(e.data.ReservationID);
                    //     }
                    // }
                }
            });
        },

        openNewModal: function () {
            $("#allot_setup_itemModal").modal("show");
            $("#allot_setup_code").prop("disabled",false);

            $("#allot_setup_id").val(0);
            $("#allot_setup_label").text("Allotment Setup");
            $("#allot_setup_formContainer")[0].reset();
            clearMultipleTomSelect(["#allot_setup_marketID", "#allot_setup_type"]);
        },

        openEditModal: function (){
            const self = this;
            if (!self.selectedRowData) {
                showToast("Warning", "Please select a row to edit!", false);
                return;
            }
            $("#allot_setup_label").text("Allotment Setup");
            $("#allot_setup_code").prop("disabled",true);
            self.fillEditForm(self.selectedRowData);
            $("#allot_setup_itemModal").modal("show");
        },

        saveAllotment: function () { 
            const self = this;

            const loginName = (localStorage.getItem("Loginname") || "")
            .trim()
            .replace(/^"(.*)"$/, '$1');
            const loginUser = parseInt(localStorage.getItem("userID")) || 0;


            const payload = {
                ID: parseInt($("#allot_setup_id").val() || 0),
                Code: $("#allot_setup_code").val(),
                Name: $("#allot_setup_name").val(),
                AccountName: $("#allot_setup_name").val(),
                ProfileID: parseInt($("#allot_setup_profileID").val() || 0),
                MarketID: parseInt(toBackendValue(getTomSelectData("#allot_setup_marketID"), "value") || 0),
                AllotmentTypeID: parseInt(toBackendValue(getTomSelectData("#allot_setup_type"), "value") || 0),
                IsDefault: false, //true =1 ,false =0
                CuttOffDay: 1,
                CreateBy: loginName,
                UpdateBy: loginName
            };

            $.ajax({
                url: "/Allotment/SaveAllotment",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(payload),
                success: function (res) {
                    if (res.success) {
                        showToast("Success", res.message, true);
                        $("#allot_setup_itemModal").modal("hide");
                        self.reloadGrid(); 
                    } else {
                        if (res.errors && res.errors.length > 0) {
                            ValidationAdapter.apply(res.errors, "#allot_setup_formContainer");
                            showToast("Warning", "Please check your input *", false);
                        } else {
                            showToast("Error", res.message || "Something went wrong.", false);
                        }
                    }
                },
                error: function () {
                    showToast("Error", "Server error occurred.", false);
                },
            });
        },
            
        confirmDelete: function () {
            const self = this;
            if (!self.selectedRowData) {
                showToast("Warning", "Please select an allotment to delete!", false);
                return;
            }

            if (confirm("Are you sure you want to delete this allotment?")) {
                $.ajax({
                    url: "/Allotment/DeleteAllot/" + self.selectedRowData.id,
                    type: "POST",
                    success: function (res) {
                        if (res.success) {
                            showToast("Success", res.message, true);
                            self.reloadGrid();
                        } else {
                            showToast("Warning", res.message, false); 
                        }
                    },
                    error: function (xhr) {
                        const msg = xhr.responseJSON ? xhr.responseJSON.message : "Delete failed";
                        showToast("Error", msg, false);
                    }
                });
            }
        },

        fillEditForm: function (data) {
            const self = this;
            
            $("#allot_setup_id").val(data.id);
            $("#allot_setup_code").val(data.code);
            $("#allot_setup_name").val(data.allotmentName);

            $("#allot_setup_profileID").val(data.profileID);
            $("#allot_setup_profileName").val(data.accountName);

            setTomSelectValue("#allot_setup_marketID", data.marketID);
            setTomSelectValue("#allot_setup_type", data.allotmentTypeID);

            // $("#allot_setup_isDefault").prop("checked", data.isDefault === "True" || data.isDefault === true);
        },

        openProSearchModal: function() {
            // Gọi hàm global từ Layout
            openProSearch((selectedData) => {

                $("#allot_search_profileName").val(selectedData.account);
                $("#allot_search_profileId").val(selectedData.id);

            });
        },

        openProAllotModal: function() {
            // Gọi hàm global từ Layout
            openProSearch((selectedData) => {
                
                $("#allot_setup_name").val(selectedData.account);
                $("#allot_setup_profileName").val(selectedData.account);
                $("#allot_setup_profileID").val(selectedData.id);

                ValidationAdapter.clearField($("#allot_setup_profileName"));
            });
        },

        exportAllotInfoToExcel: function () {
            // 1. Lấy instance của Grid Allotment Information
            const grid = $("#allot_search_gridAllotInfor").dxDataGrid("instance");
            if (!grid || grid.getDataSource().items().length === 0) {
                showToast("Warning", "No data available in Allotment Information to export!", false);
                return;
            }

            const workbook = new ExcelJS.Workbook();
            const worksheet = workbook.addWorksheet("Allotment Info");
            const companyName = localStorage.getItem("CompanyName") || "Hotel Management System";
            const now = new Date();
            const exportDateStr = "Export Date: " + now.toLocaleString("vi-VN");

            // 2. Cấu hình tiêu đề và định dạng file
            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 6, column: 1 }, // Dữ liệu bắt đầu từ dòng 6
                customizeCell: function (options) {
                    const { gridCell, excelCell } = options;
                    if (gridCell.rowType === "header") {
                        excelCell.font = { bold: true };
                        excelCell.alignment = { horizontal: 'center' };
                        excelCell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFD3D3D3' } };
                    }
                }
            }).then(function () {
                // 3. Thêm Header tùy chỉnh phía trên bảng dữ liệu
                // Dòng 1: Tên công ty
                worksheet.mergeCells('A1:D1');
                const row1 = worksheet.getCell('A1');
                row1.value = companyName;
                row1.font = { bold: true, size: 14 };

                // Dòng 2: Ngày giờ xuất
                worksheet.mergeCells('A2:D2');
                const row2 = worksheet.getCell('A2');
                row2.value = exportDateStr;
                row2.font = { italic: true };

                // Dòng 4: Tiêu đề báo cáo
                worksheet.mergeCells('A4:F4');
                const reportTitle = worksheet.getCell('A4');
                reportTitle.value = "ALLOTMENT INFORMATION REPORT";
                reportTitle.font = { bold: true, size: 16 };
                reportTitle.alignment = { horizontal: 'center' };

                // 4. Thực hiện ghi file và tải về
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "Allotment_Information.xlsx");
                });
            });
        },

        disposeGrid: function (containerId) {
            if ($(containerId).data("dxDataGrid")) {
                $(containerId).dxDataGrid("dispose");
                $(containerId).empty();
            }
        },

        openModalDetail: function() {
            const self = this;
            initDateInputs();
            const detailGrid = $("#allot_search_gridAllotDetail").dxDataGrid("instance");
            const selectedRows = detailGrid.getSelectedRowsData();

            if (selectedRows.length === 0) {
                showToast("Warning", "Please select a row in Allotment Detail first!", false);
                return;
            }

            self.selectedDetailRow = selectedRows[0];

            //Hiển thị ngày giờ ở title
            const now = new Date();
            const timeString = now.toLocaleString('vi-VN', {
                hour12: true,
                year: 'numeric', month: '2-digit', day: '2-digit',
                hour: '2-digit', minute: '2-digit', second: '2-digit'
            });
            $("#allot_detail_label").text(`Allotment Detail by Stage - ${timeString}`);

            $("#allot_detail_modal").modal("show");

            // Ngày bắt đầu là ngày của dòng đang chọn
            const fromDateStr = self.selectedDetailRow["From Date"];
            UI.setHiddenDate("allot_detail_searchDate", fromDateStr);

            self.fetchDetailByStage();
        },

        // Hàm xử lý nút + / - ngày
        changeDetailDate: function(days) {
            const self = this;
            const currentIso = $("#allot_detail_searchDate").val();
            if (currentIso) {
                // Sử dụng UI.addDaysIso để tính toán ngày mới
                const newIso = UI.addDaysIso(currentIso, days);
                UI.setHiddenDate("allot_detail_searchDate", newIso);
                self.fetchDetailByStage();
            }
        },

        fetchDetailByStage: function() {
            const self = this;
            const gridStage = document.querySelector("#allot_detail_gridAllotDetailByStage");

            const fromDateIso = $("#allot_detail_searchDate").val();
            const noOfDays = parseInt($("#allot_detail_noOfDays").val() || 20);

            if (!fromDateIso) {
                showToast("Warning", "Please select a start date", false);
                return;
            }

            LoadingGlobal.showElement(gridStage);

            $.get('/Allotment/GetAllotmentDetailFull', {
                allotmentId: self.selectedRowData.id,
                fromDate: fromDateIso,
                noOfDays: noOfDays
            }, function(res) {
                LoadingGlobal.hideElement(gridStage);

                if (res.success && res.data) {
                    self.renderStageGrid(res.data);
                } else {
                    showToast("Error", res.message || "No data found", false);
                }
            }).fail(function() {
                showToast("Error", "Server connection error", false);
            })
        },

        renderStageGrid: function(displayData) {
            const self = this;
            if (!displayData || displayData.length === 0) return;

            let columns = [
                {
                    dataField: "RoomType",
                    caption: "Room Type",
                    fixed: true,
                    width: 120,
                    alignment: "left"
                }
            ];

            // Lấy tất cả các Keys là ngày tháng (dd/MM) từ dòng đầu tiên
            const dateKeys = Object.keys(displayData[0]).filter(key => key !== "RoomType");

            dateKeys.forEach(dateKey => {
                // Phân tích ngày để tính Thứ và Cw
                const currentYear = new Date().getFullYear();
                const [day, month] = dateKey.split('/');
                const dateObj = new Date(currentYear, parseInt(month) - 1, parseInt(day));

                const dayOfWeek = dateObj.toLocaleDateString('en-US', { weekday: 'short' });
                const cw = self.getWeekNumber(dateObj);

                // Template tiêu đề 3 dòng 
                const customCaption = `
                    <div style="text-align: center; line-height: 1.2; font-size: 11px;">
                        <div class="fw-bold">${dateKey}</div>
                        <div>${dayOfWeek}</div>
                        <div class="text-muted">Cw ${cw}</div>
                    </div>
                `;

                columns.push({
                    dataField: dateKey,
                    headerCellTemplate: function(container) {
                        $(container).append(customCaption);
                    },
                    width: 80,
                    alignment: "center"
                });
            });

            //  Khởi tạo Grid
            self.initGrid("#allot_detail_gridAllotDetailByStage", {
                dataSource: displayData,
                columns: columns,
                columnAutoWidth: false,
                showColumnLines: true,
                // Hàng "Total Picked Up" màu vàng
                onRowPrepared: function(e) {
                    if (e.rowType === "data" && e.data.RoomType === "Total Picked Up") {
                        e.rowElement.css({ "background-color": "#ffff00", "font-weight": "bold" });
                    }
                }
            });
        },

        getWeekNumber: function(d) {
            d = new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
            d.setUTCDate(d.getUTCDate() + 4 - (d.getUTCDay() || 7));
            var yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
            var weekNo = Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
            return weekNo;
        },

        exportDetailStageToExcel: function () {
            const grid = $("#allot_detail_gridAllotDetailByStage").dxDataGrid("instance");
            if (!grid) {
                showToast("Warning", "No data to export!", false);
                return;
            }

            const workbook = new ExcelJS.Workbook();
            const worksheet = workbook.addWorksheet("Detail Stage");
            const now = new Date();
            const timeStr = now.toLocaleString('vi-VN');

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 4, column: 1 }, // Để dành 3 dòng đầu cho Header
                customizeCell: function (options) {
                    const { gridCell, excelCell } = options;

                    // 1. Định dạng Header tiêu đề 3 dòng
                    if (gridCell.rowType === "header") {
                        excelCell.alignment = { vertical: 'middle', horizontal: 'center', wrapText: true };
                        excelCell.font = { bold: true };
                        excelCell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFE0E0E0' } };
                    }

                    // 2. Định dạng hàng "Total Picked Up" màu vàng
                    if (gridCell.rowType === "data" && gridCell.data.RoomType === "Total Picked Up") {
                        excelCell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFFFFF00' } };
                        excelCell.font = { bold: true };
                    }
                }
            }).then(function () {
                // Thêm tiêu đề báo cáo ở dòng 1
                worksheet.mergeCells('A1:E1');
                const titleCell = worksheet.getCell('A1');
                titleCell.value = "ALLOTMENT DETAIL BY STAGE";
                titleCell.font = { bold: true, size: 14 };
                titleCell.alignment = { horizontal: 'left' };

                // Thêm thời gian xuất báo cáo ở dòng 2
                worksheet.mergeCells('A2:E2');
                worksheet.getCell('A2').value = "Export Date: " + timeStr;
                worksheet.getCell('A2').font = { italic: true };

                // Xuất file
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "Allotment_Detail_Stage.xlsx");
                });
            });
        },

        openTransferModal: function (mode) {
            const self = this;

            if (mode === 1) {
                if (!self.selectedRowData) {
                    showToast("Warning", "Please select an Allotment from the list first!", false);
                    return;
                }
            }

            initDateInputs();
            UI.setHiddenDate(
                "allot_trans_cutoffDateInput",
                new Date()
            );
            $("#allot_trans_cutoffDayInput").val(1);
            self.initCutOffToggle();
            $("#allot_transfer_modal").modal("show");

            const fromID = (mode === 1 && self.selectedRowData) ? self.selectedRowData.id : 0;

            loadDataToTomSelect("#allot_trans_roomTypeID", `/Allotment/GetRoomTypesLookup?allotmentId=${fromID}`, (item) => ({
                value: item.id,
                text: `${item.code} - ${item.name}`, 
                data: item 
            }));
            // .then(() => {
            //     const tsRoomType = getTomSelect("#allot_trans_roomTypeID");
        
            //     if (tsRoomType && Object.keys(tsRoomType.options).length <= 1) {
            //         showToast("Warning", "This Allotment has no Room Types configured!", false);
            //         $("#allot_trans_btnInput").prop("disabled", true);
            //     } else {
            //         $("#allot_trans_btnInput").prop("disabled", false);
            //     }
            // });

            loadDataToTomSelect("#allot_trans_toID", `/Allotment/GetAllotmentLookup?excludeID=${fromID}`, (item) => ({
                value: item.id,
                text: `${item.code} - ${item.name}`, 
                data: item 
            }));
            
            loadDataToTomSelect("#allot_trans_stageID", "/Allotment/GetStagesLookup", (item) => ({
                value: item.id,
                text: `${item.code} - ${item.name}`, 
                data: item
            }));

            this.disposeGrid("#allot_trans_grid");
            this.initGrid("#allot_trans_grid", {
                dataSource: [],
                columns: [
                    { dataField: "roomType", caption: "Ro. Type" },
                    { dataField: "quantity", caption: "Qty", width: 60 },
                    { dataField: "fromDate", caption: "From Date", dataType: "date", format: "dd/MM/yyyy" },
                    { dataField: "night", caption: "N", width: 40},
                    { dataField: "toDate", caption: "To Date", dataType: "date", format: "dd/MM/yyyy" }
                ],
                height: 200
            });

            // Fill dữ liệu vào phần "From"
            const tsFrom = document.getElementById('allot_trans_fromID').tomselect;

            if (mode === 0) {
                $("#allot_trans_chkInventory").prop("checked", true).prop("disabled", true);
                $("#allot_trans_allotName").text("Inventory").addClass("text-danger");

                if(tsFrom) {
                    tsFrom.clear();
                    tsFrom.addOption({value: 0, text: 'Inventory'});
                    tsFrom.addItem(0);
                    tsFrom.disable();
                }
            } else {
                $("#allot_trans_chkInventory").prop("checked", false).prop("disabled", true);

                const selectedAllot = self.selectedRowData;
                const displayName = `${selectedAllot.code} - ${selectedAllot.allotmentName}`;

                $("#allot_trans_allotName").text(displayName).removeClass("text-danger").addClass("text-primary");

                // Fill ID vào TomSelect ẩn
                if(tsFrom) {
                    tsFrom.enable();
                    tsFrom.clear();
                    tsFrom.addOption({ value: selectedAllot.id, text: displayName });
                    tsFrom.addItem(selectedAllot.id);
                    tsFrom.disable(); 
                }
            }

            const bizDate = window.dateSystem;
            if (bizDate) {
                UI.setHiddenDate("allot_trans_fromDate", bizDate);
                $("#allot_trans_count").val(1);
                UI.setHiddenDate("allot_trans_toDate", UI.addDaysIso(bizDate, 1));
            }
        },

        initCutOffToggle: function () {

            const $dateRadio = $("#allot_trans_cutoffDate");
            const $dayRadio  = $("#allot_trans_cutoffDay");

            const $dateInput = $('[data-name="allot_trans_cutoffDateInput"] input');
            const $dayInput  = $("#allot_trans_cutoffDayInput");

            const updateUI = () => {

                if ($dateRadio.is(":checked")) {
                    $dateInput.prop("disabled", false);
                    $dayInput.prop("disabled", true);
                }
                else if ($dayRadio.is(":checked")) {
                    $dateInput.prop("disabled", true);
                    $dayInput.prop("disabled", false);
                }
                else {
                    $dateInput.prop("disabled", true);
                    $dayInput.prop("disabled", true);
                }
            };

            $dateRadio.off("change").on("change", updateUI);
            $dayRadio.off("change").on("change", updateUI);

            updateUI();
        },

        handleInputTransfer: function () {
            const self = this;
            const grid = $("#allot_trans_grid").dxDataGrid("instance");

            ValidationAdapter.clear("#allot_transfer_formContainer");

            const rtData = getTomSelectData("#allot_trans_roomTypeID");
            if (!rtData || !rtData.value || rtData.value == 0) {
                showToast("Warning", "Please select a Room Type from the list.", false);
        
                ValidationAdapter.apply([{ 
                    Field: "allot_trans_roomTypeID", 
                    Message: "Room Type selection is mandatory." 
                }], "#allot_transfer_formContainer");
        
                return; 
            }

            const qty = parseInt($("#allot_trans_qty").val() || 0);
            const fromID = parseInt(toBackendValue(getTomSelectData("#allot_trans_fromID"), "value") || 0);
            const fromDate = $("#allot_trans_fromDate").val();
            const night = parseInt($("#allot_trans_count").val() || 1);

            $.ajax({
                url: '/Allotment/CheckTransferAvailability',
                type: 'GET',
                loadingGrid: '#allot_trans_grid', 
                data: {
                    fromAllotmentId: fromID,
                    roomTypeId: rtData.value,
                    fromDate: fromDate,
                    night: night,
                    quantity: qty
                },
                success: function (res) {
                    if (!res.success) {
                        if (res.errors && res.errors.length > 0) {
                            ValidationAdapter.apply(res.errors, "#allot_transfer_formContainer");
                            showToast("Warning", "Check input data again.", false);
                        } else {
                            showToast("Error", res.message, false);
                        }
                        return;
                    }

                    const newItem = {
                        roomType: rtData.text,
                        roomTypeID: parseInt(rtData.value),
                        quantity: qty,
                        fromDate: fromDate,
                        toDate: $("#allot_trans_toDate").val(),
                        night: night
                    };

                    const dataSource = grid.option("dataSource") || [];
                    dataSource.push(newItem);
                    grid.option("dataSource", dataSource);

                    $("#allot_trans_qty").val(1);
                }
            }); 
        },

        saveTransfer: function () {
            const self = this;
            const grid = $("#allot_trans_grid").dxDataGrid("instance");
            const dataSource = grid.option("dataSource");

            ValidationAdapter.clear("#allot_transfer_formContainer");
            if (!dataSource || dataSource.length === 0) {
                showToast("Warning", "Input info transfer to grid.", false);
                return;
            }

            const cutoffType = $("input[name='cutoffType']:checked").val();
            const cutoffDay = cutoffType === "day" ? parseInt($("#allot_trans_cutoffDayInput").val() || 0) : -1;
            const cutoffDate = cutoffType === "date" ? $("#allot_trans_cutoffDateInput").val() : null;

            const stageID = parseInt(toBackendValue(getTomSelectData("#allot_trans_stageID"), "value") || 0); 
            const fromID = parseInt(toBackendValue(getTomSelectData("#allot_trans_fromID"), "value") || 0);
            const toID = parseInt(toBackendValue(getTomSelectData("#allot_trans_toID"), "value") || 0); 

            const loginName = (localStorage.getItem("Loginname") || "").trim().replace(/^"(.*)"$/, '$1');

            const firstItem = dataSource[0];
            const validatePayload = {
                FromAllotmentID: fromID,
                ToAllotmentID: toID,
                RoomTypeID: firstItem.roomTypeID,
                Quantity: firstItem.quantity,
                FromDate: firstItem.fromDate,
                ToDate: firstItem.toDate,
                CreateBy: loginName,
                AllotmentStageID: stageID,
                CutOffDay: cutoffDay,
                CutOffDate: cutoffDate
            };

            $.ajax({
                url: "/Allotment/ExecuteTransfer",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(validatePayload),
                success: function (res) {
                    if (!res.success && res.errors) {
                        ValidationAdapter.apply(res.errors, "#allot_transfer_formContainer");
                        showToast("Warning", "Please check required fields.", false);
                        return; 
                    }

                    const promises = dataSource.map(item => {
                        return $.ajax({
                            url: "/Allotment/ExecuteTransfer",
                            type: "POST",
                            contentType: "application/json",
                            data: JSON.stringify({
                                ...validatePayload, // lấy các trường chung
                                RoomTypeID: item.roomTypeID,
                                Quantity: item.quantity,
                                FromDate: item.fromDate,
                                ToDate: item.toDate
                            })
                        });
                    });

                    Promise.all(promises).then(() => {
                        showToast("Success", "Transfer completed!", true);
                        $("#allot_transfer_modal").modal("hide");
                        self.reloadGrid();
                    }).catch(() => {
                        showToast("Error", "Transfer failed during processing.", false);
                    });
                }
            });
        },

        /* Transfer History */
        opemdModalTransHistory: function() {
            const self = this;
            $("#allot_transHis_modal").modal("show");
            initDateInputs();

            const now = new Date();
            const firstDay = new Date(now.getFullYear(), now.getMonth(), 1);
            UI.setHiddenDate("allot_transHis_fromDate", firstDay);
            UI.setHiddenDate("allot_transHis_toDate", now);

            loadDataToTomSelect("#allot_transHis_roomType", "/Allotment/GetRoomTypesLookup", (item) => ({
                value: item.code,
                text: item.code
            }));

            const allotLookupUrl = "/Allotment/GetAllotmentLookup";
            loadDataToTomSelect("#allot_transHis_fromID", allotLookupUrl, (item) => ({
                value: item.id,
                text: `${item.code} - ${item.name}`
            }));

            loadDataToTomSelect("#allot_transHis_toID", allotLookupUrl, (item) => ({
                value: item.id,
                text: `${item.code} - ${item.name}`
            }));

            self.renderTransHisGrid([]);

            // Thêm vào cuối hàm opemdModalTransHistory
            $("#allot_transHis_chkFrom").on("change", function() {
                $('[data-name="allot_transHis_fromDate"] input').prop("disabled", !this.checked);
            });
            $("#allot_transHis_chkTo").on("change", function() {
                $('[data-name="allot_transHis_toDate"] input').prop("disabled", !this.checked);
            });
            // Gán sự kiện nút View trong modal history
            $("#allot_transHis_btnView").off("click").on("click", () => self.reloadTransHisGrid());
            self.reloadTransHisGrid();
        },

        reloadTransHisGrid: function() {
            const self = this;
            const gridTrans = document.querySelector("#allot_transHis_grid");

            const isFilterFrom = $("#allot_transHis_chkFrom").is(":checked");
            const isFilterTo = $("#allot_transHis_chkTo").is(":checked");

            const filter = {
                fromDate: isFilterFrom ? $("#allot_transHis_fromDate").val() : "",
                toDate: isFilterTo ? $("#allot_transHis_toDate").val() : "",
                roomType: toBackendValue(getTomSelectData("#allot_transHis_roomType"), "value") || "",
                fromAllotId: parseInt(toBackendValue(getTomSelectData("#allot_transHis_fromID"), "value") || 0),
                toAllotId: parseInt(toBackendValue(getTomSelectData("#allot_transHis_toID"), "value") || 0)
            };

             LoadingGlobal.showElement(gridTrans);

            $.ajax({
                url: '/Allotment/GetAllotmentTransferSearch',
                type: 'GET',
                data: filter,
                success: function(res) {
                    self.renderTransHisGrid(res);
                },
                error: function() {
                    showToast("Error", "API error", false);
                },
                complete: function() {
                    LoadingGlobal.hideElement(gridTrans);
                }
            });
        },

        renderTransHisGrid: function(data) {
            const self = this;
            self.initGrid("#allot_transHis_grid", {
                dataSource: data,
                columns: [
                    { dataField: "fromAllotment", caption: "From Allotment", width: 130 },
                    { dataField: "toAllotment", caption: "To Allotment", width: 170 },
                    { dataField: "roomType", caption: "Ro.Type", width: 60 },
                    { dataField: "quantity", caption: "Qty", width: 40 },
                    { dataField: "fromDate", caption: "From Date", width: 100 ,dataType:"date", format:"dd/MM/yyyy"},
                    { dataField: "toDate", caption: "To Date", width: 100, dataType:"date", format:"dd/MM/yyyy"},
                    { dataField: "description", caption: "Description", width: 110},
                    { dataField: "createdBy", caption: "CreatedBy", width: 70 },
                    { dataField: "createdDate", caption: "Date Time", width: 120,dataType:"date", format:"dd/MM/yyyy" },
                    { dataField: "updatedBy", caption: "UpdatedBy", width: 70 },
                    { dataField: "updatedDate", caption: "UpdatedBy", width: 120,dataType:"date", format:"dd/MM/yyyy" }
                ]
            });
        },

        exportTransHisToExcel: function() {
            const grid = $("#allot_transHis_grid").dxDataGrid("instance");
            if (!grid) {
                showToast("Warning", "No data to export!", false);
                return;
            }

            const workbook = new ExcelJS.Workbook();
            const worksheet = workbook.addWorksheet("Transfer Search");
            const companyName = localStorage.getItem("CompanyName") || "Hotel Management System";
            const now = new Date();
            const exportDateStr = "Export Date: " + now.toLocaleString("vi-VN");

            // 2. Cấu hình tiêu đề và định dạng file
            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 6, column: 1 }, // Dữ liệu bắt đầu từ dòng 6
                customizeCell: function (options) {
                    const { gridCell, excelCell } = options;
                    if (gridCell.rowType === "header") {
                        excelCell.font = { bold: true };
                        excelCell.alignment = { horizontal: 'center' };
                        excelCell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFD3D3D3' } };
                    }
                }
            }).then(function () {
                // 3. Thêm Header tùy chỉnh phía trên bảng dữ liệu
                // Dòng 1: Tên công ty
                worksheet.mergeCells('A1:D1');
                const row1 = worksheet.getCell('A1');
                row1.value = companyName;
                row1.font = { bold: true, size: 14 };

                // Dòng 2: Ngày giờ xuất
                worksheet.mergeCells('A2:D2');
                const row2 = worksheet.getCell('A2');
                row2.value = exportDateStr;
                row2.font = { italic: true };

                // Dòng 4: Tiêu đề báo cáo
                worksheet.mergeCells('A4:F4');
                const reportTitle = worksheet.getCell('A4');
                reportTitle.value = "Transfer History";
                reportTitle.font = { bold: true, size: 16 };
                reportTitle.alignment = { horizontal: 'center' };

                // 4. Thực hiện ghi file và tải về
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "Allotment_Transfer_History.xlsx");
                });
            });
        },
        /*End Transfer History */

    };

