@using DevExpress.XtraReports.UI

@{
    var transactionsList = ViewBag.TransactionsList;
    var currList = ViewBag.CurrencyList;
    var transactionGroupList = ViewBag.TransactionGroupList;
    var transactionSubGroupList = ViewBag.TransactionSubGroupList;
    var vatTypeList = ViewBag.VatTypeList;
    var transactionTypeList = ViewBag.TransactionTypeList;
    var listARAccountList = ViewBag.listARAccountList;
}

<!-- =========================================================
     MAIN VIEW (Everything is a Bootstrap modal) - modal-xl
     ========================================================= -->
<div class="modal fade" id="trans_modalMain" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Transaction Code Search</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">
                    <!-- Toolbar -->
                    <div>
                        <button id="trans_btnView" type="button" class="mui-button button-report-view">View</button>
                        <button id="trans_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="trans_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="trans_btnDelete" type="button" class="mui-button button-report-delete">Delete</button>
                        <button id="trans_btnExcel" type="button" class="mui-button mui-button-export">Excel</button>
                        <button id="trans_btnClose" type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                    </div>

                    <!-- ERP Search Filter (dense, nested rows, right aligned labels) -->
                    <div class="row g-2 mt-1">

                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end" for="trans_transactionGroupList">Group.Code</label>
                                <div class="col-md-8">
                                    <select id="trans_transactionGroupList" name="trans_transactionGroupList" class="tomselect-custom">
                                        <option value="">-- Group --</option>
                                        @foreach (var item in transactionGroupList)
                                        {
                                            <option value="@item.ID">@item.Code</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-5 col-form-label col-form-label-sm text-md-end" for="trans_transactionSubGroupList">Subgroup.Code</label>
                                <div class="col-md-7">
                                    <select id="trans_transactionSubGroupList" name="trans_transactionSubGroupList" class="tomselect-custom">
                                        <option value="">-- Subgroup --</option>
                                        @foreach (var item in transactionSubGroupList)
                                        {
                                            <option value="@item.ID" data-groupid="@item.TransactionGroupID">@item.Code</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end" for="trans_transCode">Trans.Code</label>
                                <div class="col-md-8">
                                    <input id="trans_transCode" name="trans_transCode" type="text" class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end" for="trans_adjCode">Adj.Code</label>
                                <div class="col-md-8">
                                    <input id="trans_adjCode" name="trans_adjCode" type="text" class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-lg-2 col-form-label col-form-label-sm text-md-end" for="trans_description">Description</label>
                                <div class="col-md-8">
                                    <input id="trans_description" name="trans_description" type="text" class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Grid -->
                <div class="mui-card">
                    <div id="trans_grid" class="gridContainer"></div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- =========================================================
     EDIT/CREATE MODAL (modal-xl) - replaces #popupNewTransaction
     Includes Generate actions
     ========================================================= -->
<div class="modal fade" id="trans_modalEdit" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title mb-0" id="trans_modalEditTitle">Transaction Screen</h5>
            </div>

            <div class="modal-body pt-2">

                <div class="search-filter">
                    <button id="trans_btnOk" type="button" class="mui-button mui-button-advance">Ok</button>
                    <button id="trans_btnSave" type="button" class="mui-button mui-button-advance">Save</button>
                    <button id="trans_btnDeleteAuto" type="button" class="mui-button button-report-delete">Delete</button>
                    <button id="trans_btnGenerate" type="button" class="mui-button mui-button-resolve">Generate</button>
                    <button id="trans_btnEditClose" type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                </div>

                <div class="mt-1 mb-2">
                    <form id="trans_formEdit" novalidate>
                        <input type="hidden" id="trans_id" name="trans_id" />
                        <input type="hidden" id="trans_generateID" name="trans_generateID" />
                        <input type="hidden" id="trans_transactionGroupID" name="trans_transactionGroupID" />
                        <input type="hidden" id="trans_groupType" name="trans_groupType" />
                        <input type="hidden" id="trans_groupCode" name="trans_groupCode" />

                        <div class="row g-2">

                            <!-- SubGroup -->
                            <div class="col-12 col-lg-6">
                                <div class="row g-2 align-items-center">
                                    <label class="col-md-4 col-form-label col-form-label-sm text-md-end" for="trans_transactionNewSubGroupList">SubGroup</label>
                                    <div class="col-md-8">
                                        <select id="trans_transactionNewSubGroupList" name="trans_transactionNewSubGroupList" class="tomselect-custom">
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Group (readonly code) -->
                            <div class="col-12 col-lg-6">
                                <div class="row g-2 align-items-center">
                                    <label class="col-md-4 col-form-label col-form-label-sm text-md-end" for="trans_groupnew">Group</label>
                                    <div class="col-md-8">
                                        <input id="trans_groupnew" name="trans_groupnew" type="text" class="form-control form-control-sm" readonly />
                                    </div>
                                </div>
                            </div>

                            <!-- VAT -->
                            <div class="col-12 col-lg-6">
                                <div class="row g-2 align-items-center">
                                    <label class="col-md-4 col-form-label col-form-label-sm text-md-end" for="trans_vatinfor">VAT.Infor</label>
                                    <div class="col-md-8">
                                        <select id="trans_vatinfor" name="trans_vatinfor" class="tomselect-custom">
                                            <option value="">-- Select a Item --</option>
                                            @foreach (var item in vatTypeList)
                                            {
                                                <option value="@item.ID">@item.Name</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Trans.Type -->
                            <div class="col-12 col-lg-6">
                                <div class="row g-2 align-items-center">
                                    <label class="col-md-4 col-form-label col-form-label-sm text-md-end" for="trans_transactionTypeList">Trans.Type</label>
                                    <div class="col-md-8">
                                        <select id="trans_transactionTypeList" name="trans_transactionTypeList" class="tomselect-custom">
                                            <option value=""></option>
                                            @foreach (var item in transactionTypeList)
                                            {
                                                <option value="@item.ID">@item.Name</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Code -->
                            <div class="col-12 col-lg-6">
                                <div class="row g-2 align-items-center">
                                    <label class="col-md-4 col-form-label col-form-label-sm text-md-end" for="trans_codenew">Code</label>
                                    <div class="col-md-8">
                                        <input id="trans_codenew" name="trans_codenew" type="text" class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>

                            <!-- Description -->
                            <div class="col-12 col-lg-6">
                                <div class="row g-2 align-items-center">
                                    <label class="col-md-4 col-form-label col-form-label-sm text-md-end" for="trans_descriptionnew">Description</label>
                                    <div class="col-md-8">
                                        <input id="trans_descriptionnew" name="trans_descriptionnew" type="text" class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>

                            <!-- Adj.Code -->
                            <div class="col-12 col-lg-6">
                                <div class="row g-2 align-items-center">
                                    <label class="col-md-4 col-form-label col-form-label-sm text-md-end" for="trans_transactionsListnew">Adj.Code</label>
                                    <div class="col-md-8">
                                        <select id="trans_transactionsListnew" name="trans_transactionsListnew" class="tomselect-custom">
                                            @foreach (var item in transactionsList)
                                            {
                                                <option value="@item.Code">@item.Code-@item.Description</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Price -->
                            <div class="col-12 col-lg-6">
                                <div class="row g-2 align-items-center">
                                    <label class="col-md-4 col-form-label col-form-label-sm text-md-end" for="trans_dfprice">Price</label>
                                    <div class="col-md-8">
                                        <input id="trans_dfprice" name="trans_dfprice" type="text" class="form-control form-control-sm text-md-end" />
                                    </div>
                                </div>
                            </div>

                            <!-- Currency -->
                            <div class="col-12 col-lg-6">
                                <div class="row g-2 align-items-center">
                                    <label class="col-md-4 col-form-label col-form-label-sm text-md-end" for="trans_currList">Currency</label>
                                    <div class="col-md-8">
                                        <select id="trans_currList" name="trans_currList" class="tomselect-custom">
                                            <option value="">-ALL--</option>
                                            @foreach (var item in currList)
                                            {
                                                <option value="@item.ID">@item.ID-@item.Description</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Tax include -->
                            <div class="col-12 col-lg-6">
                                <div class="row g-2 align-items-center">
                                    <div class="col-md-4"></div>
                                    <div class="col-md-8">
                                        <div class="form-check">
                                            <input type="checkbox" id="trans_isTaxInclude" name="trans_isTaxInclude" value="1">
                                            <label class="form-check-label" for="trans_isTaxInclude">Tax Include</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Inactive -->
                            <div class="col-12 col-lg-6">
                                <div class="row g-2 align-items-center">
                                    <div class="col-md-4"></div>
                                    <div class="col-md-8">
                                        <div class="form-check">
                                            <input type="checkbox" id="trans_inactive" name="trans_inactive" value="1">
                                            <label class="form-check-label" for="trans_inactive">Inactive</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- AR Account (enabled/disabled by group type logic) -->
                            <div class="col-12 col-lg-6" data-trans-role="arAccount">
                                <div class="row g-2 align-items-center">
                                    <label class="col-md-4 col-form-label col-form-label-sm text-md-end" for="trans_listARAccountList">AR. Account</label>
                                    <div class="col-md-8">
                                        <select id="trans_listARAccountList" name="trans_listARAccountList" class="tomselect-custom">
                                            <option value=""></option>
                                            @foreach (var item in listARAccountList)
                                            {
                                                <option value="@item.AccountNo">@item.AccountNo-@item.AccountName</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <!-- Checkbox blocks (kept but compact) -->
                        <div class="mt-2 border rounded-2 p-2">
                            <div class="row g-2">

                                <div class="col-12 col-lg-6">
                                    <div class="d-flex flex-wrap gap-3">
                                        <div class="form-check" data-trans-scope="pnlRevenue">
                                            <input type="checkbox" id="trans_revenueGroup" name="trans_revenueGroup">
                                            <label class="form-check-label" for="trans_revenueGroup">Revenue group</label>
                                        </div>

                                        <div class="form-check" data-trans-scope="pnlRevenuememberShip">
                                            <input type="checkbox" id="trans_memberShip" name="trans_memberShip">
                                            <label class="form-check-label" for="trans_memberShip">Member ship</label>
                                        </div>

                                        <div class="form-check" data-trans-scope="pnlRevenue">
                                            <input type="checkbox" id="trans_manualPosting" name="trans_manualPosting">
                                            <label class="form-check-label" for="trans_manualPosting">Manual posting</label>
                                        </div>

                                        <div class="form-check" data-trans-scope="pnlRevenue">
                                            <input type="checkbox" id="trans_paidOut" name="trans_paidOut">
                                            <label class="form-check-label" for="trans_paidOut">Paid out</label>
                                        </div>

                                        <div class="form-check" data-trans-scope="pnlRevenuedis">
                                            <input type="checkbox" id="trans_generateInclusive" name="trans_generateInclusive" disabled>
                                            <label class="form-check-label" for="trans_generateInclusive">Generates inclusive</label>
                                        </div>

                                        <div class="form-check" data-trans-scope="pnlRevenuedis">
                                            <input type="checkbox" id="trans_trackNights" name="trans_trackNights" disabled>
                                            <label class="form-check-label" for="trans_trackNights">Track nights</label>
                                        </div>

                                        <div class="form-check" data-trans-scope="interHotelSales">
                                            <input type="checkbox" id="trans_interHotelSales" name="trans_interHotelSales" disabled>
                                            <label class="form-check-label" for="trans_interHotelSales">Inter Hotel Sales</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12 col-lg-6">
                                    <div class="d-flex flex-wrap gap-3">
                                        <div class="form-check" data-trans-scope="pnlPayment">
                                            <input type="checkbox" id="trans_frontOfficePayments" name="trans_frontOfficePayments">
                                            <label class="form-check-label" for="trans_frontOfficePayments">Front Office Payments</label>
                                        </div>

                                        <div class="form-check" data-trans-scope="pnlPayment">
                                            <input type="checkbox" id="trans_arPayments" name="trans_arPayments">
                                            <label class="form-check-label" for="trans_arPayments">AR Payments</label>
                                        </div>

                                        <div class="form-check" data-trans-scope="pnlPayment">
                                            <input type="checkbox" id="trans_depositPayments" name="trans_depositPayments">
                                            <label class="form-check-label" for="trans_depositPayments">Deposit Payments</label>
                                        </div>
                                    </div>

                                    <hr class="my-2" />

                                    <div class="d-flex flex-wrap gap-3">
                                        <div class="form-check" data-trans-scope="pnlPaymentType">
                                            <input type="checkbox" id="trans_creditCard" name="trans_paymentType" value="CreditCard">
                                            <label class="form-check-label" for="trans_creditCard">Credit Card</label>
                                        </div>

                                        <div class="form-check" data-trans-scope="pnlPaymentType">
                                            <input type="checkbox" id="trans_cash" name="trans_paymentType" value="Cash">
                                            <label class="form-check-label" for="trans_cash">Cash</label>
                                        </div>

                                        <div class="form-check" data-trans-scope="pnlPaymentType">
                                            <input type="checkbox" id="trans_check" name="trans_paymentType" value="Check">
                                            <label class="form-check-label" for="trans_check">Check</label>
                                        </div>

                                        <div class="form-check" data-trans-scope="pnlPaymentType">
                                            <input type="checkbox" id="trans_others" name="trans_paymentType" value="Others">
                                            <label class="form-check-label" for="trans_others">Others</label>
                                        </div>

                                        <div class="form-check" data-trans-scope="pnlPaymentTypedis">
                                            <input type="checkbox" id="trans_eft" name="trans_paymentTypeDis" value="EFT" disabled>
                                            <label class="form-check-label" for="trans_eft">EFT</label>
                                        </div>

                                        <div class="form-check" data-trans-scope="pnlPaymentTypedis">
                                            <input type="checkbox" id="trans_manual" name="trans_paymentTypeDis" value="Manual" disabled>
                                            <label class="form-check-label" for="trans_manual">Manual</label>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>

                    </form>
                </div>

            </div>

        </div>
    </div>
</div>

<!-- =========================================================
     GENERATE LIST MODAL (modal-xl) - replaces #popupGenerate
     ========================================================= -->
<div class="modal fade" id="trans_modalGenerateList" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="trans_titleGenerateList"></h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <button id="trans_btnNewGenerate" type="button" class="mui-button mui-button-new">New</button>
                    <button id="trans_btnEditGenerate" type="button" class="mui-button mui-button-edit">Edit</button>
                    <button id="trans_btnDeleteGenerate" type="button" class="mui-button button-report-delete">Delete</button>
                    <button id="trans_btnGenerateClose" type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                </div>

                <div id="trans_gridGenerate" class="gridContainer"></div>
            </div>

        </div>
    </div>
</div>

<!-- =========================================================
     GENERATE EDIT MODAL (modal-xl) - replaces #popupGenerateNewEdit
     ========================================================= -->
<div class="modal fade" id="trans_modalGenerateEdit" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="trans_titleGenerateEdit"></h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <button id="trans_btnOkGenerate" type="button" class="mui-button mui-button-new">OK</button>
                    <button id="trans_btnGenerateEditClose" type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                </div>

                <form id="trans_formGenerate" novalidate>
                    <input type="hidden" id="trans_generateDetailId" name="trans_generateDetailId" />

                    <div class="row g-2 mb-2">

                        <div class="col-11">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end" for="trans_transactionsGernew">Transactions Code</label>
                                <div class="col-md-8">
                                    <select id="trans_transactionsGernew" name="trans_transactionsGernew" class="tomselect-custom">
                                        @* <option value="">--ALL--</option>
                                        @foreach (var item in transactionsList)
                                        {
                                            <option value="@item.Code">@item.Code-@item.Description</option>
                                        } *@
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Percentage -->
                        <div class="col-11">
                            <div class="row g-2 align-items-center">
                                <div class="col-md-4 text-md-end">
                                    <div class="form-check d-inline-flex align-items-center">
                                        <input type="radio" id="trans_percentageRadio" name="trans_percenOption" class=" me-2" />
                                        <label class="form-check-label" for="trans_percentageRadio">Percentage</label>
                                    </div>
                                </div>
                                <div class="col-md-8">
                                    <div class="d-flex flex-wrap gap-2 align-items-center">
                                        <input type="number" id="trans_percentagetext" name="trans_percentagetext" class="form-control form-control-sm text-md-end" style="max-width:160px;" step="1" min="0" value="0"/>
                                        <span>%</span>
                                        <select id="trans_percengegre" name="trans_percengegre" class="tomselect-custom" style="min-width:120px;">
                                            <option value=""></option>
                                            <option value="0">Base</option>
                                            <option value="1">Sub_total1</option>
                                            <option value="2">Sub_total2</option>
                                            <option value="3">Sub_total3</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Amount -->
                        <div class="col-11">
                            <div class="row g-2 align-items-center">
                                <div class="col-md-4 text-md-end">
                                    <div class="form-check d-inline-flex align-items-center">
                                        <input type="radio" id="trans_amountRadio" name="trans_percenOption" class=" me-2" />
                                        <label class="form-check-label" for="trans_amountRadio">Amount</label>
                                    </div>
                                </div>
                                <div class="col-md-8">
                                    <input type="number" id="trans_amountPer" name="trans_amountPer" class="form-control form-control-sm text-md-end" style="max-width:220px;" step="1000" min="0" value="0" />
                                </div>
                            </div>
                        </div>

                        <!-- Subtotals -->
                        <div class="col-11">
                            <div class="row g-2 align-items-center">
                                <div class="col-md-4"></div>
                                <div class="col-md-8">
                                    <div class="d-flex flex-wrap gap-3">
                                        <div class="form-check">
                                            <input type="checkbox" id="trans_subTotal1" name="trans_subTotal" value="1">
                                            <label class="form-check-label" for="trans_subTotal1">Sub total 1</label>
                                        </div>
                                        <div class="form-check">
                                            <input type="checkbox" id="trans_subTotal2" name="trans_subTotal" value="2">
                                            <label class="form-check-label" for="trans_subTotal2">Sub total 2</label>
                                        </div>
                                        <div class="form-check">
                                            <input type="checkbox" id="trans_subTotal3" name="trans_subTotal" value="3">
                                            <label class="form-check-label" for="trans_subTotal3">Sub total 3</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Formular -->
                        <!-- Winform không hoạt đọng tạm thời ẩn -->
                        
                        @* <div class="col-11">
                            <div class="row g-2 align-items-center">
                                <div class="col-md-4 text-md-end">
                                    <div class="form-check d-inline-flex align-items-center">
                                        <input type="radio" id="trans_formularRadio" name="trans_percenOption" class=" me-2" />
                                        <label class="form-check-label" for="trans_formularRadio">Formular</label>
                                    </div>
                                </div>
                                <div class="col-md-8">
                                    <input type="text" id="trans_formular" name="trans_formular" class="form-control form-control-sm text-md-end" />
                                </div>
                            </div>
                        </div> *@

                    </div>
                </form>

            </div>

        </div>
    </div>
</div>

<!-- Loading Spinner -->
<div id="trans_loadingSpinner"
    style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
    z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
    height: 100%;display: flex;align-items: center;justify-content: center;">
    <div class="spinner-border text-primary"></div>
</div>

<script>
    // =========================================================
    // Transaction Module (Option A, prefixed trans_)
    // Fix: TomSelect timing + async flow for Edit/New
    // =========================================================
    var trans_Module = (function () {
