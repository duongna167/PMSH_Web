@using DevExpress.XtraReports.UI
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewBag.Title = ViewBag.ReportHeader;
    var listatt = ViewBag.hkpAttendantList;
}

<style>
    .ttsr_status-color-box {
        display: inline-block;
        width: 22px;
        height: 22px;
        margin-right: 4px;
        vertical-align: middle;
        border: 1px solid #ccc;
    }

    .ttsr_color-clean-uncheck {
        background-color: cyan;
    }

    .ttsr_color-dirty {
        background-color: red;
    }

    .ttsr_color-outoforder {
        background-color: lightgray;
    }

    .ttsr_color-pickup {
        background-color: yellow;
    }

    .ttsr_color-clean {
        background-color: lime;
    }

    .ttsr_color-outofservices {
        background-color: lightgray;
    }

    .ttsr_hk-clean-uncheck {
        background-color: cyan;
        color: black;
    }

    .ttsr_hk-dirty {
        background-color: red;
        color: white;
    }

    .ttsr_hk-outoforder {
        background-color: lightgray;
        color: black;
    }

    .ttsr_hk-pickup {
        background-color: yellow;
        color: black;
    }

    .ttsr_hk-clean {
        background-color: lime;
        color: black;
    }

    .ttsr_hk-outofservices {
        background-color: lightgray;
        color: black;
    }
</style>

<!-- =========================
     MAIN VIEW AS BS5 MODAL
     ========================= -->
<div class="modal fade" id="ttsr_modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable modal-4by3">
        <div class="modal-content">

            <div class="modal-header py-2">
                <h5 class="modal-title mb-0">
                    Turn down Task sheet
                </h5>
            </div>

            <div class="modal-body pt-2">

                <div class="search-filter">
                    <div class="d-flex flex-wrap gap-2">
                        <button id="ttsr_btnPrint" class="mui-button mui-button-new" type="button">View</button>

                        <button id="ttsr_btnCheckAll" class="mui-button mui-button-advance" type="button">
                            Check All
                        </button>

                        <button id="ttsr_btnDailytasksheet" class="mui-button mui-button-profile" type="button">
                            Daily
                        </button>

                        <button id="ttsr_btnExportExcel" class="mui-button mui-button-new" type="button">
                            Excel
                        </button>
                        <button class="mui-button mui-button-new" data-bs-dismiss="modal" aria-label="Close">Close</button>
                    </div>

                    <div class="d-flex flex-wrap align-items-center gap-2 mb-1 filter-panel mt-1">

                        <div class="d-flex flex-column">
                            <div class="d-flex align-items-center me-3">
                                <label class="mb-1 me-2">Room Status: </label>

                                <div class="form-check me-3">
                                    <span class="ttsr_status-color-box ttsr_color-clean-uncheck"></span>
                                    <input type="checkbox" id="ttsr_cleanUncheck" name="ttsr_includeOptions" value="1"
                                           checked>
                                    <label class="form-check-label" for="ttsr_cleanUncheck">Clean Non-Checked</label>
                                </div>

                                <div class="form-check me-3">
                                    <span class="ttsr_status-color-box ttsr_color-dirty"></span>
                                    <input type="checkbox" id="ttsr_dirty" name="ttsr_includeOptions" value="2" checked>
                                    <label class="form-check-label" for="ttsr_dirty">Dirty</label>
                                </div>

                                <div class="form-check me-3">
                                    <span class="ttsr_status-color-box ttsr_color-outoforder"></span>
                                    <input type="checkbox" id="ttsr_outofOrder" name="ttsr_includeOptions" value="5"
                                           checked>
                                    <label class="form-check-label" for="ttsr_outofOrder">Out of Order</label>
                                </div>

                                <div class="form-check me-3">
                                    <span class="ttsr_status-color-box ttsr_color-pickup"></span>
                                    <input type="checkbox" id="ttsr_pickup" name="ttsr_includeOptions" value="3"
                                           checked>
                                    <label class="form-check-label" for="ttsr_pickup">Pickup</label>
                                </div>

                                <div class="form-check me-3">
                                    <span class="ttsr_status-color-box ttsr_color-clean"></span>
                                    <input type="checkbox" id="ttsr_clean" name="ttsr_includeOptions" value="4" checked>
                                    <label class="form-check-label" for="ttsr_clean">Clean</label>
                                </div>

                                <div class="form-check me-3">
                                    <span class="ttsr_status-color-box ttsr_color-outofservices"></span>
                                    <input type="checkbox" id="ttsr_outofServices" name="ttsr_includeOptions" value="6"
                                           checked>
                                    <label class="form-check-label" for="ttsr_outofServices">Out of Services</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-3">

                            <div class="d-flex align-items-center" style="width: 220px;">
                                <label class="me-2 mb-0 text-nowrap">Attendant ID:</label>
                                <select id="ttsr_attendant" name="ttsr_attendant" class="tomselect-custom" multiple>
                                    @foreach (var item in listatt)
                                    {
                                        <option value="@item.ID">@item.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="d-flex align-items-center" style="display:none !important">
                                <label class="me-2 mb-0 text-nowrap">Task Date:</label>
                                <input type="date" id="ttsr_fromDate" name="ttsr_fromDate"
                                       class="form-control form-control-sm w-auto" />
                            </div>

                        </div>

                    </div>

                </div>

                <div class="mui-card">
                    <div id="ttsr_gridContainer" class="gridContainer mt-2"></div>
                </div>

            </div>

        </div>
    </div>
</div>

<!-- =========================
     POPUP GRID AS BS5 MODAL
     ========================= -->
<div class="modal fade" id="ttsr_popupNewGridModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content">

            <div class="modal-header py-2">
                <h5 id="ttsr_attendantPointTitle" class="modal-title mb-0">Turndown Tasksheet</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body pt-2">

                <div class="d-flex justify-content-start mb-3 gap-2">
                    <button id="ttsr_btnExportpopExcel" class="mui-button mui-button-new" type="button">Excel</button>
                    <button id="ttsr_btnClosePopup" class="btn btn-sm btn-danger" type="button">
                        Close
                    </button>
                </div>

                <div id="ttsr_logGridContainer" class="gridContainer mt-2"></div>

            </div>

        </div>
    </div>
</div>

<div id="ttsr_loadingSpinner"
     style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:1000;">
    <i class="fa-solid fa-spinner fa-spin"></i>
</div>

<script>
    var ttsr_Module = {

        tsAttendant: null,

        gridMain: null,
        gridPopup: null,

        parsedBusinessDate: null,
        toggleSelectAll: false,

        init: function () {
            const self = this;

            self.getBusinessDate();
            self.initializeTomSelects();
            self.bindEvents();
            self.bindModalLifecycle();
        },

        bindModalLifecycle: function () {
            const self = this;

            // MAIN GRID must init in shown.bs.modal (height != 0)
            $("#ttsr_modal").off("shown.bs.modal.ttsr").on("shown.bs.modal.ttsr", function () {
                // original logic: after business date success => trigger print
                // here we do nothing, because the AJAX call is already triggered in getBusinessDate()
                // and will render the grid only after data returns.
            });

            // POPUP GRID must init in shown.bs.modal too
            $("#ttsr_popupNewGridModal").off("shown.bs.modal.ttsr").on("shown.bs.modal.ttsr", function () {
                // no automatic render here (original code only shows modal)
            });
        },

        destroy: function () {

            if (this.tsAttendant) {
                this.tsAttendant.destroy();
                this.tsAttendant = null;
            }

            if (this.gridMain) {
                this.gridMain.dispose();
                this.gridMain = null;
            }

            if (this.gridPopup) {
                this.gridPopup.dispose();
                this.gridPopup = null;
            }

            $("#ttsr_gridContainer").empty();
            $("#ttsr_logGridContainer").empty();

            this.parsedBusinessDate = null;
            this.toggleSelectAll = false;
        },

        formatDate: function (date) {
            let year = date.getFullYear();
            let month = (date.getMonth() + 1).toString().padStart(2, '0');
            let day = date.getDate().toString().padStart(2, '0');
            return `${year}-${month}-${day}`;
        },

        getBusinessDate: function () {
            const self = this;

            return $.ajax({
                url: '/Reservation/GetBusinessDate',
                type: 'get',
                dataType: 'json',
                crossDomain: false,
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                success: function (result) {

                    const fromDateStr = result.split('T')[0];
                    $('#ttsr_fromDate').val(fromDateStr);
                    $("#ttsr_btnPrint").trigger("click");

                },
                error: function (xhr, statusText, err) {
                    if (xhr.status == 401) {
                        sessionTimeout();
                    }
                }
            });
        },

        initializeTomSelects: function () {
            const self = this;

            const selectors = ["#ttsr_attendant"];

            for (const id of selectors) {
                const el = document.querySelector(id);
                if (!el) continue;

                if (el.tomselect) el.tomselect.destroy();

                const ts = new TomSelect(el, {
                    plugins: ['remove_button'],
                    create: false,
                    maxItems: null,
                    allowEmptyOption: true,
                    placeholder: '',
                    persist: false,
                    render: {
                        option: function (data, escape) {
                            return `<div>${escape(data.text)}</div>`;
                        }
                    }
                });

                self.tsAttendant = ts;
            }
        },

        bindEvents: function () {
            const self = this;

            $(document).off("click", "#ttsr_btnPrint").on("click", "#ttsr_btnPrint", function () {
                $("#ttsr_loadingSpinner").show();

                var selectedStatuses = $("input[name='ttsr_includeOptions']:checked")
                    .map(function () {
                        return this.value;
                    }).get().join(",");

                $.ajax({
                    url: '/HouseKeeping/TurndownTasksheetData',
                    type: 'GET',
                    data: {
                        fromDate: $("#ttsr_fromDate").val(),
                        attendant: $("#ttsr_attendant").val().join(","),
                        IsDueOut: $("#ttsr_dirty").prop("checked") ? "1" : "",
                        roomStatus: selectedStatuses,
                    },
                    traditional: true,
                    crossDomain: false,
                    headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                    success: function (data) {

                        console.log(data);

                        // Only render if response is valid array
                        if (!Array.isArray(data)) {
                            $("#ttsr_loadingSpinner").hide();
                            return;
                        }

                        // Main grid must be rendered only when modal is shown (height != 0)
                        if (!$("#ttsr_modal").hasClass("show")) {
                            $("#ttsr_loadingSpinner").hide();
                            return;
                        }

                        self.initializeTurndownTasksheetDataGrid(data);
                        self.initializeTurndownTasksheetGrid(data);

                        $("#ttsr_loadingSpinner").hide();
                    },
                    error: function () {
                        alert("Không th? t?i báo cáo.");
                        $("#ttsr_loadingSpinner").hide();
                    }
                });
            });

            $(document).off("click", "#ttsr_btnCheckAll").on("click", "#ttsr_btnCheckAll", function () {
                const grid = $("#ttsr_gridContainer").dxDataGrid("instance");

                if (!self.toggleSelectAll) {
                    grid.selectAll();
                    self.toggleSelectAll = true;
                    $(this).html('Uncheck All');
                } else {
                    grid.deselectAll();
                    self.toggleSelectAll = false;
                    $(this).html('Check All');
                }
            });

            $(document).off("click", "#ttsr_btnDailytasksheet").on("click", "#ttsr_btnDailytasksheet", function () {
                $("#ttsr_loadingSpinner").show();
                const modalEl = document.getElementById("ttsr_modal");
                const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

                modal.hide(); // đóng modal trước

                // chờ bootstrap remove backdrop xong rồi mới open
                $(modalEl).one("hidden.bs.modal", function () {
                    window.openRoomAttendentDailyWorksheet();
                });
            });

            $(document).off("click", "#ttsr_btnExportExcel").on("click", "#ttsr_btnExportExcel", function () {
                const grid = $("#ttsr_gridContainer").dxDataGrid("instance");
                var selectedReport = 'Room Attendent Daily Worksheet';
                if (!selectedReport) {
                    alert("Vui lòng ch?n báo cáo tru?c khi xu?t Excel.");
                    return;
                }

                const workbook = new ExcelJS.Workbook(); const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
                const worksheet = workbook.addWorksheet("Sheet 1");

                worksheet.addRow(['Công ty C? ph?n Gi?i pháp Công ngh? CS-Solution']);
                worksheet.mergeCells('A1:E1');
                worksheet.getRow(1).font = { bold: true };
                worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

                const now = new Date();
                const exportDate = now.toLocaleString("vi-VN");
                worksheet.addRow(['', '', '', '', ' ' + exportDate]);
                worksheet.mergeCells('E2:H2');
                worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

                worksheet.addRow([]);
                worksheet.addRow([]);

                const reportRow = worksheet.addRow(['', '', selectedReport]);
                worksheet.mergeCells('C5:F5');
                reportRow.font = { bold: true, size: 14 };
                reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

                worksheet.addRow([]);

                DevExpress.excelExporter.exportDataGrid({
                    component: grid,
                    worksheet: worksheet,
                    autoFilterEnabled: true,
                    topLeftCell: { row: 7, column: 1 }
                }).then(function () {
                    const lastRow = worksheet.lastRow.number + 2;
                    worksheet.getCell(`A${lastRow}`).value = "--- END  ---";
                    worksheet.mergeCells(`A${lastRow}:F${lastRow}`);
                    worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
                    worksheet.getCell(`A${lastRow}`).font = { italic: true };

                    let fileName = selectedReport + ".xlsx";
                    workbook.xlsx.writeBuffer().then(function (buffer) {
                        saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
                    });
                });
            });

            $(document).off("click", "#ttsr_btnExportpopExcel").on("click", "#ttsr_btnExportpopExcel", function () {
                const grid = $("#ttsr_logGridContainer").dxDataGrid("instance");
                var selectedReport = 'Turndown Tasksheet Report';
                if (!selectedReport) {
                    alert("Vui lòng ch?n báo cáo tru?c khi xu?t Excel.");
                    return;
                }

                const workbook = new ExcelJS.Workbook(); const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
                const worksheet = workbook.addWorksheet("Sheet 1");

                worksheet.addRow(['Công ty C? ph?n Gi?i pháp Công ngh? CS-Solution']);
                worksheet.mergeCells('A1:E1');
                worksheet.getRow(1).font = { bold: true };
                worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

                const now = new Date();
                const exportDate = now.toLocaleString("vi-VN");
                worksheet.addRow(['', '', '', '', ' ' + exportDate]);
                worksheet.mergeCells('E2:H2');
                worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

                worksheet.addRow([]);
                worksheet.addRow([]);

                const reportRow = worksheet.addRow(['', '', selectedReport]);
                worksheet.mergeCells('C5:F5');
                reportRow.font = { bold: true, size: 14 };
                reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

                worksheet.addRow([]);

                DevExpress.excelExporter.exportDataGrid({
                    component: grid,
                    worksheet: worksheet,
                    autoFilterEnabled: true,
                    topLeftCell: { row: 7, column: 1 }
                }).then(function () {
                    const lastRow = worksheet.lastRow.number + 2;
                    worksheet.getCell(`A${lastRow}`).value = "--- END  ---";
                    worksheet.mergeCells(`A${lastRow}:F${lastRow}`);
                    worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
                    worksheet.getCell(`A${lastRow}`).font = { italic: true };

                    let fileName = selectedReport + ".xlsx";
                    workbook.xlsx.writeBuffer().then(function (buffer) {
                        saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
                    });
                });
            });

            $(document).off("click", "#ttsr_btnClosePopup").on("click", "#ttsr_btnClosePopup", function () {
                var modalEl = document.getElementById("ttsr_popupNewGridModal");
                var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                modal.hide();
            });
        },

        initializeTurndownTasksheetDataGrid: function (data) {
            const self = this;

            // Dispose old
            if (self.gridMain) {
                self.gridMain.dispose();
                self.gridMain = null;
            }
            $("#ttsr_gridContainer").empty();


            self.gridMain = $("#ttsr_gridContainer").dxDataGrid({
                dataSource: data,
                allowColumnResizing: true,
                columnAutoWidth: true,
                width: "100%",
                height: "100%",
                columns: [

                    {
                        dataField: "hkstatusID_color",
                        caption: "Room Status",
                        cellTemplate: function (container, options) {
                            let colorClass = "";
                            switch (options.value) {
                                case "Clean Non-Checked":
                                    colorClass = "ttsr_hk-clean-uncheck";
                                    break;
                                case "Dirty":
                                    colorClass = "ttsr_hk-dirty";
                                    break;
                                case "Out Of Order":
                                    colorClass = "ttsr_hk-outoforder";
                                    break;
                                case "Pickup":
                                    colorClass = "ttsr_hk-pickup";
                                    break;
                                case "Clean":
                                    colorClass = "ttsr_hk-clean";
                                    break;
                                case "Out Of Services":
                                    colorClass = "ttsr_hk-outofservices";
                                    break;
                                default:
                                    colorClass = "";
                            }

                            $(container)
                                .addClass(colorClass)
                                .text(options.value)
                                .css({
                                    "text-align": "center",
                                    "color": "#000"
                                });
                        }
                    },
                    { dataField: "Sheet No", caption: "Sheet No" },
                    { dataField: "roomNo", caption: "Room No" },
                    { dataField: "attendant", caption: "Attendant", groupIndex: 0, visible: false },
                    { dataField: "roomType", caption: "Room Type" },
                    { dataField: "credits", caption: "Credits", dataType: "number", format: "#,##0" },
                    { dataField: "facilityTask", caption: "Facility Task" },
                    { dataField: "foStatus", caption: "FO Status" },
                    { dataField: "timeIn", caption: "Time In" },
                    { dataField: "timeOut", caption: "Time Out" },
                    { dataField: "Description", caption: "Description" },
                ],

                paging: { pageSize: 20 },
                scrolling: {
                    useNative: true,
                    showScrollbar: "always"
                },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, 'all'],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: { visible: true, applyFilter: "auto" },
                headerFilter: { visible: true },
                selection: { mode: "multiple", showCheckBoxesMode: "always" },
                showBorders: true,

                onRowClick: function (e) {
                    selectedRowData = e.data;
                }
            }).dxDataGrid("instance");
        },

        initializeTurndownTasksheetGrid: function (data) {
            const self = this;

            // Dispose old
            if (self.gridPopup) {
                self.gridPopup.dispose();
                self.gridPopup = null;
            }
            $("#ttsr_logGridContainer").empty();

            const columnWidth = 120;
            const gridHeight = 600;

            self.gridPopup = $("#ttsr_logGridContainer").dxDataGrid({
                dataSource: data,
                allowColumnResizing: true,
                columnAutoWidth: true,
                height: gridHeight,
                columns: [
                    { dataField: "roomNo", caption: "RoomNo", width: columnWidth },
                    { dataField: "hkStatusID", caption: "Room Status", width: columnWidth + 20 },
                    { dataField: "foStatus", caption: "FOStatus", width: columnWidth },
                    {
                        dataField: "attendant",
                        caption: "Attendant",
                        width: columnWidth,
                        groupIndex: 0,
                        visible: false,
                        groupCellTemplate: function (cellElement, cellInfo) {
                            const groupAttendant = cellInfo.value;
                            const groupData = cellInfo.data.items || [];

                            if (groupData.length > 0) {
                                const firstItem = groupData[0];
                                const taskDate = firstItem.taskDate ? DevExpress.localization.formatDate(new Date(firstItem.taskDate), "dd/MM/yyyy") : "";
                                const taskSheetNo = firstItem.taskSheetNo || "";

                                const html = `
                            <div><strong>Task Date:</strong> ${taskDate}</div>
                            <div><strong>Attendant ID and Name:</strong> ${groupAttendant}</div>
                            <div><strong>Task Sheet No.:</strong> ${taskSheetNo}</div>
                        `;
                                cellElement.html(html);
                            } else {
                                cellElement.text(groupAttendant);
                            }
                        }
                    },
                    { dataField: "credits", caption: "Credits", width: columnWidth, dataType: "number", format: "#,##0" },
                    { dataField: "section", caption: "Section", width: columnWidth },
                    { dataField: "status", caption: "Status", width: columnWidth },
                    { dataField: "turndownStatus", caption: "Turndown Status", width: columnWidth + 30 },
                    { dataField: "lastName", caption: "Name", width: columnWidth + 40 },
                    { dataField: "arrivalDate", caption: "Arr.", width: columnWidth, dataType: "date", format: "dd/MM/yyyy" },
                    { dataField: "arrivalTime", caption: "Arrival Time", width: columnWidth },
                    { dataField: "departureDate", caption: "Dep.", width: columnWidth, dataType: "date", format: "dd/MM/yyyy" },
                    { dataField: "vip", caption: "VIP", width: columnWidth },
                    { dataField: "adult", caption: "A", width: columnWidth, dataType: "number", format: "#,##0" },
                    { dataField: "child", caption: "C", width: columnWidth, dataType: "number", format: "#,##0" },
                    { dataField: "specials", caption: "Specials", width: columnWidth },
                    { dataField: "facilityTask", caption: "Facility Task", width: columnWidth },
                ],
                grouping: { autoExpandAll: true },
                groupPanel: { visible: false },
                paging: { pageSize: 25 },
                scrolling: { useNative: true, showScrollbar: "always" },
                pager: {
                    visible: true,
                    allowedPageSizes: [25, 50, 'all'],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: { visible: true, applyFilter: "auto" },
                headerFilter: { visible: true },
                selection: { mode: "multiple", showCheckBoxesMode: "none" },
                showBorders: true,
                summary: {
                    groupItems: [
                        { column: "roomNo", summaryType: "count", displayFormat: "Total Room :{0}", showInGroupFooter: true },
                        { column: "adult", summaryType: "sum", displayFormat: "{0}", showInGroupFooter: true },
                        { column: "child", summaryType: "sum", displayFormat: "{0}", showInGroupFooter: true },
                        { column: "credits", summaryType: "sum", displayFormat: "{0}", showInGroupFooter: true }
                    ]
                }
            }).dxDataGrid("instance");
        }
    };

    // Global entry points
    window.openModalTTSR = function () {
        ttsr_Module.init();
        var modalEl = document.getElementById("ttsr_modal");
        var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();
    };

</script>