<style>
    .wake-container {
        display: flex;
        gap: 30px;
        justify-content: center;
        margin: 10px 0 0 0;
    }

    .group-box {
        border: 1px solid #ccc;
        padding: 15px;
        border-radius: 5px;
        background: white;
        width: 360px;
        min-height: 290px;
        box-sizing: border-box;
    }

    .hidden-important { display: none !important; }
    .show-important1 { display: block !important; }

    .ellipsis-icon {
        margin-left: 10px;
        position: relative;
        cursor: pointer;
    }

    #popupWakeUpCall {
        z-index: 1060;
        align-items: center;
        justify-content: center;
    }
    #popupviewGrid{
        z-index: 1061;
        /* Blur nền phía sau */
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        background: rgba(255,255,255,0.6);
    }



    #popupWakeUpCall .modal-content {
        display: inline-block;
    }

    #loadingSpinner {
        display: none;
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 2000;
    }
</style>

<!-- ======================= MAIN MODAL ======================= -->
<div class="modal fade" id="popupWakeUpCall" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-lg modal-dialog-centered wakeup-fit">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Wake Up Call</h5>
            </div>
            <div class="modal-body">
                <!-- Top buttons (layout cũ) -->
                <div class="search-filter">
                    <button id="btnCancelwakeup" class="mui-button mui-button-cancel" type="button">Delete</button>
                    <button id="btnSetwakeup" class="mui-button mui-button-card" type="button">Set</button>
                    <button id="btnViewwakeup" class="mui-button mui-button-new" type="button">View</button>
                    <button id="btnCloseWakeup" class="mui-button mui-button-new" type="button">Close</button>
                </div>
                <div class="wake-container">
                    <!-- LEFT: radio mode -->
                    <div class="group-box mb-3">
                        <div class="row g-2 align-items-center">
                            <div class="col-12">
                                <div class="row g-1 align-items-center">
                                    <div class="d-flex flex-column gap-1">
                                        <div class="form-check mb-0">
                                            <input 
                                                type="radio"
                                                name="wake"
                                                value="set"
                                                id="rdoSet"
                                                checked>
                                            <label class="form-check-label" for="rdoSet">
                                                Set Wake Up Call
                                            </label>
                                        </div>
                                        <div class="form-check mb-0">
                                            <input 
                                                type="radio"
                                                name="wake"
                                                value="cancel"
                                                id="rdoCancle">
                                            <label class="form-check-label" for="rdoCancle">
                                                Cancel Wake Up Call
                                            </label>
                                        </div>
                                        <div class="form-check mb-0">
                                            <input 
                                                type="radio"
                                                name="wake"
                                                value="view"
                                                id="rdoView">
                                            <label class="form-check-label" for="rdoView">
                                                View Wake Up Calls
                                            </label>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- MIDDLE: Set/Cancel panel -->
                    <div class="group-box mb-3" id="setWakeup">
                        <div class="row g-2 align-items-center">
                            <!-- Call Type: Date / Daily -->
                            <div class="col-12">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 col-form-label col-form-label-sm text-md-end">
                                        Call Type
                                    </label>
                                    <div class="col-8">
                                        <div class="d-flex flex-wrap gap-4">
                                            <div class="form-check mb-0">
                                                <input 
                                                    type="radio"
                                                    name="call"
                                                    id="rdoDate"
                                                    value="date">
                                                <label class="form-check-label" for="rdoDate">Date</label>
                                            </div>

                                            <div class="form-check mb-0">
                                                <input 
                                                    type="radio"
                                                    name="call"
                                                    id="rdoDaily"
                                                    value="daily" checked>
                                                <label class="form-check-label" for="rdoDaily">Daily</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Room No(s) -->
                            <div class="col-12" id="roomnoGroup">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 col-form-label col-form-label-sm text-md-end">
                                        Room No(s)
                                    </label>
                                    <div class="col-8">
                                        <div class="input-group input-group-sm">
                                            <input type="text" id="roomno" class="form-control form-control-sm">
                                            <button type="button"
                                                    class="btn btn-outline-secondary"
                                                    id="listRoom"
                                                    aria-label="Select rooms">
                                                <i class="fas fa-ellipsis-h"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Schedule (cancel) -->
                            <div class="col-12" id="scheduleGroup">
                                <div class="row g-1 align-items-center">
                                    <label id="scheduleLabel"
                                        class="col-4 col-form-label col-form-label-sm text-md-end">
                                        Schedule
                                    </label>
                                    <div class="col-8">
                                        <div class="input-group input-group-sm">
                                            <input type="text" id="roomnoCancel" class="form-control form-control-sm">
                                            <button type="button"
                                                    class="btn btn-outline-secondary"
                                                    id="cancleRoom"
                                                    aria-label="Select schedule">
                                                <i class="fas fa-ellipsis-h"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- DATE SECTION -->
                            <div class="col-12" id="dateSection">
                                <div class="row g-2">

                                    <!-- Date -->
