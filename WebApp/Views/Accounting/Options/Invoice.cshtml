<!-- Modal billimg-->
<div class="modal fade modal-xl" id="modalInvoice" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
    aria-labelledby="staticBackdropLabelBilling" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content" style="border: 1px solid #bcbcbc">
            <div class="modal-header">
                <h5 class="modal-title" id="staticBackdropLabelBilling">Invoice Detail</h5>
            </div>
            <div class="modal-body">
                @* <div class="mb-2">
                    <button class="mui-button mui-button-search" >Post</button>
                </div> *@
                <div class="search-filter">
                    <div>
                        <button class="mui-button mui-button-new" onclick="openModalTransfer();">Transfer</button>
                        <button class="mui-button mui-button-new" onclick="openModalPosting();">Post</button>
                        <button class="mui-button mui-button-new" onclick="adjustTransaction();">Adjust</button>
                        <button class="mui-button mui-button-new" onclick="closeModalInvoice()">Close</button>
                    </div>
                    <div class="row mt-1" id="filter">
                        <div class="col-12">
                            <div class="row">

                                <!-- Account Name -->
                                <div class="col-12 col-md-3 mt-2">
                                    <div class="row g-2">
                                        <label class="col-12 col-md-4 col-form-label text-md-end">
                                            Account Name
                                        </label>
                                        <div class="col-12 col-md-8">
                                            <input type="text" class="form-control" id="accountNameInvoice" readonly>
                                        </div>
                                    </div>
                                </div>

                                <!-- Account No -->
                                <div class="col-12 col-md-3 mt-2">
                                    <div class="row g-2">
                                        <label class="col-12 col-md-4 col-form-label text-md-end">
                                            Account No
                                        </label>
                                        <div class="col-12 col-md-8">
                                            <input type="text" class="form-control" id="accountNoInvoice" readonly>
                                        </div>
                                    </div>
                                </div>

                                <!-- Name -->
                                <div class="col-12 col-md-3 mt-2">
                                    <div class="row g-2">
                                        <label class="col-12 col-md-4 col-form-label text-md-end">
                                            Name
                                        </label>
                                        <div class="col-12 col-md-8">
                                            <input type="text" class="form-control" id="nameInvoice" readonly>
                                        </div>
                                    </div>
                                </div>

                                <!-- Confirmation No -->
                                <div class="col-12 col-md-3 mt-2">
                                    <div class="row g-2">
                                        <label class="col-12 col-md-4 col-form-label text-md-end">
                                            Confirmation No
                                        </label>
                                        <div class="col-12 col-md-8">
                                            <input type="text" class="form-control" id="confirmationNoInvoice" readonly>
                                        </div>
                                    </div>
                                </div>

                                <!-- Folio No -->
                                <div class="col-12 col-md-3 mt-2">
                                    <div class="row g-2">
                                        <label class="col-12 col-md-4 col-form-label text-md-end">
                                            Folio No
                                        </label>
                                        <div class="col-12 col-md-8">
                                            <input type="text" class="form-control" id="folioNoInvoice" readonly>
                                        </div>
                                    </div>
                                </div>

                                <!-- Arrival -->
                                <div class="col-12 col-md-3 mt-2">
                                    <div class="row g-2">
                                        <label class="col-12 col-md-4 col-form-label text-md-end">
                                            Arrival
                                        </label>
                                        <div class="col-12 col-md-8">
                                            <div data-date-input data-format="DD/MM/YYYY" business-date
                                                data-name="arrivalInvoice">
                                                <input type="text" class="date-ui form-control" placeholder="dd/mm/yyyy"
                                                    autocomplete="off" disabled />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Departure -->
                                <div class="col-12 col-md-3 mt-2">
                                    <div class="row g-2">
                                        <label class="col-12 col-md-4 col-form-label text-md-end">
                                            Departure
                                        </label>
                                        <div class="col-12 col-md-8">
                                            <div data-date-input data-format="DD/MM/YYYY" business-date
                                                data-name="departureInvoice">
                                                <input type="text" class="date-ui form-control" placeholder="dd/mm/yyyy"
                                                    autocomplete="off" disabled />
                                            </div>

                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
                <div id="gridContainerInvoice" class="gridContainer mt-2"></div>

            </div>
        </div>
    </div>
</div>
@await Html.PartialAsync("Options/Transfer")
@await Html.PartialAsync("Options/Posting")
@await Html.PartialAsync("Options/Adjust")

<script>
    async function openModalInvoice() {
        await window.initDateInputs();
        // Validate trước
        const isValid = await getInfoInvoice();
        if (!isValid) {
            return; // ❗ CHẶN TẠI ĐÂY
        }
        searchInvoice();
        $('#modalInvoice').modal('show');
    }
    function closeModalInvoice() {
        $('#modalInvoice').modal('hide');
    }
    async function getInfoInvoice() {
        var grid = $("#aras_gridContainer").dxDataGrid("instance");
        var selectedRows = grid.getSelectedRowsData();
        var selectedIds = selectedRows.map(row => row.ID);

        var grid2 = $("#gridContainerMaintenance").dxDataGrid("instance");
        var selectedRows2 = grid2.getSelectedRowsData();

        if (!selectedRows2 || selectedRows2.length === 0) {
            showToast("Warning", "Please select at least 1 Maintenance row.", false);
            return false;
        }

        var selectedIds2 = selectedRows2.map(row => row.FolioID);

        const result = await $.ajax({
            url: '/Accounting/SearchInfoInvoice',
            type: 'get',
            dataType: 'json',
            data: {
                arID: selectedIds[0],
                folioID: selectedIds2[0]
            },
            headers: {
                "X-CSRF-TOKEN-HEADERNAME":
                    $("input[name='__RequestVerificationToken']").val()
            }
        });

        if (result.code == 1) {
            showToast("Error", result.msg, false);
            return false;
        }       
        // SET GIÁ TRỊ TỪ AJAX
        $('#accountNameInvoice').val(result.result3[0].AccountName);
        $('#accountNoInvoice').val(result.result3[0].AccountNo);
        $('#nameInvoice').val(result.result1[0].AccountName);
        $('#confirmationNoInvoice').val(result.result1[0].ConfirmationNo);
        $('#folioNoInvoice').val(selectedIds2[0]);
        UI.setHiddenDate(
            "arrivalInvoice",
            result.result2[0].ArrivalDate
        );
        UI.setHiddenDate(
            "departureInvoice",
            result.result2[0].DepartureDate
        );
        let arrivalDate = $('#arrivalInvoice').val();
        let departureDate = $('#departureInvoice').val();

        // CHỈ fallback NẾU THẬT SỰ RỖNG
        if (!arrivalDate || !departureDate) {
            arrivalDate = await waitForBusinessDate("arrivalInvoice", 10000);
            departureDate = await waitForBusinessDate("departureInvoice", 10000);
        }

        if (!arrivalDate || !departureDate) {
            console.log("Không tải được ngày mặc định.");
            return false;
        }

        return true;
    }
    function searchInvoice() {
        var grid = $("#gridContainerMaintenance").dxDataGrid("instance");
        var selectedRows = grid.getSelectedRowsData();
        var selectedIds = selectedRows.map(row => row.FolioID);
        if (!selectedIds || selectedIds.length === 0) {
            showToast("Warning", "Please select 1 row Maintenanace.", false);
            return;
        }
        $.ajax({
            url: '/Accounting/InvoiceSearch',
            type: 'get',
            dataType: 'json',
            data: {
                folioID: selectedIds[0],

            },
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                initializeDataGridInvoice(result.result1);
            },
            error: function (xhr, statusText, err) {
                if (xhr.status == 401) {
                    sessionTimeout();
                }
            },

        });

    }
    function initializeDataGridInvoice(data) {

        $("#gridContainerInvoice").dxDataGrid({
            dataSource: data,
            keyExpr: "ID",

            height: 500,                     // ✅ FIX HEIGHT
            showBorders: true,

            // ===== LAYOUT =====
            columnAutoWidth: true,
            allowColumnResizing: true,
            columnResizingMode: "widget",

            // ===== SCROLLING =====
            scrolling: {
                mode: "standard",            // scroll ngang tự nhiên
                useNative: true
            },

            paging: { pageSize: 15 },
            pager: {
                visible: true,
                allowedPageSizes: [15, 20, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },

            filterRow: {
                visible: true,
                applyFilter: "auto"
            },

            selection: {
                mode: "multiple",
                showCheckBoxesMode: "always"
            },

            columns: [
                {
                    dataField: "InvoiceNo",
                    caption: "Invoice No",
                    width: 100
                },
                {
                    dataField: "TransactionNo",
                    caption: "Transaction No",
                    width: 130
                },
                {
                    dataField: "Date",
                    caption: "Date",
                    dataType: "datetime",
                    format: "dd/MM/yyyy",
                    minWidth: 140
                },
                {
                    dataField: "Time",
                    caption: "Time",
                    dataType: "datetime",
                    format: "HH:mm",
                    width: 100
                },
                {
                    dataField: "Code",
                    caption: "Code",
                    width: 90
                },
                {
                    dataField: "Description",
                    caption: "Description",
                    minWidth: 260
                },
                {
                    dataField: "Amount",
                    caption: "Amount",
                    alignment: "right",
                    minWidth: 120
                },
                {
                    dataField: "Currency",
                    caption: "Currency",
                    width: 90
                },
                {
                    dataField: "Supplement",
                    caption: "Supplement",
                    minWidth: 220
                },
                {
                    dataField: "Reference",
                    caption: "Reference",
                    minWidth: 180
                },
                {
                    dataField: "UserName",
                    caption: "User",
                    width: 100
                },
                {
                    dataField: "RoomType",
                    caption: "Room Type",
                    width: 110
                }
            ],

            // ===== AUTO SELECT FIRST ROW =====
            onContentReady: function (e) {
                const grid = e.component;
                if (grid.getSelectedRowKeys().length === 0) {
                    const key = grid.getKeyByRowIndex(0);
                    if (key !== undefined) {
                        grid.selectRows([key], false);
                    }
                }
            },

            onRowClick: function (e) {
                e.component.selectRows([e.key], false);
            }
        });
    }
</script>
