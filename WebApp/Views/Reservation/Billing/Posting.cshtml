        });

        $('.js-input-express-pct, .js-input-discount-pct').on('input', function () {
            let $pane = $(this).closest('.tab-pane');
            buildRefAndSuppl($pane);
        });

        $('input[name="expressRadio"], input[name="discountRadio"]').on('change', function () {
            let $pane = $(this).closest('.tab-pane');
            buildRefAndSuppl($pane);
        });

        function updateReferenceText() {
            let $pane = $('.tab-pane.active');
            let rs = buildRefAndSuppl($pane);

            $pane.find('.js-ref-main').val(rs.reference);
        }

        // sự kiện xử lý ô nhập phần trăm
        $(document).on('input', '.js-pct-input', function () {
            let rawVal = $(this).val();
            let val = parseFloat(rawVal) || 0;
            let $parentGroup = $(this).closest('.express-input-group');

            // Đồng bộ trạng thái radio dựa trên số vừa nhập
            $parentGroup.find('.js-radio-opt').each(function() {
                if (parseFloat($(this).val()) === val) {
                    $(this).prop('checked', true);
                } else {
                    $(this).prop('checked', false);
                }
            });

            updateReferenceText();
            calculateLineTotal();
        });

        //sự kiện xử lý các nút radio
        $(document).on('change', '.js-radio-opt', function () {
            let val = $(this).val();
            // Tìm đến group chứa cả radio và input percent
            let $parentGroup = $(this).closest('.express-input-group');
            // Gán giá trị vào ô input percent tương ứng (Express hoặc Discount)
            $parentGroup.find('.js-pct-input').val(val).trigger('input');
        });

        // express/discount
        $(document).on('change', '.js-chk-express, .js-chk-discount', function () {
            let isChecked = $(this).is(':checked');
            let $box = $(this).closest('.express-box');

            // Gỡ disabled cho cả ô nhập percent và các nút radio
            $box.find('.js-pct-input, .js-radio-opt').prop('disabled', !isChecked);

            updateReferenceText();
            calculateLineTotal();
        });

        // amount    
        $(document).on('blur', '.js-input-qty, .js-input-price, .js-input-price-net', function () {
            if (isSilentReset) return;

            let $el = $(this);
            let isQty = $el.hasClass('js-input-qty');
            let isGross = $el.hasClass('js-input-price');
            let isNet = $el.hasClass('js-input-price-net');

            let num = validateAndNormalizeNumberInput(this, {
                allowNegative: false,
                defaultValue: isQty ? 1 : 0
            });

            if (isQty) {
                $el.val(num || 1);
                calculateLineTotal();
                return;
            }

            // price / net
            $el.val(formatNumberWithComma(num));

            if (isGross) {
                debounceApi(apiCalcNetFromPlus);
            } else if (isNet) {
                debounceApi(apiCalcPlusFromNet);
            }
        });

        var formatTimer;
        $(document).on('input', '.js-input-price, .js-input-price-net', function () {
            clearTimeout(formatTimer);
            let el = this;

            formatTimer = setTimeout(() => {
                formatCurrencyLive(el);
            }, 50);
        });

        $(document).on('focus', '.js-ref-main', function () {
            let currentVal = $(this).val();

            $(this).data("base-ref", currentVal);
        });
    });

    var apiTimer;
    var isCallingApi = false;
        
    function debounceApi(fn, delay = 300) {
        clearTimeout(apiTimer);
        apiTimer = setTimeout(() => {
            if (isCallingApi) return;
            isCallingApi = true;

            Promise.resolve(fn()).finally(() => {
                isCallingApi = false;
            });
        }, delay);
    }

