@{
    Layout = null;
    ViewBag.Title = ViewBag.ReportHeader;
    var zoneList = ViewBag.ZoneList;
    var roomtypeList = ViewBag.RoomTypeList;
}

<style>
    #modalHouseStatus .modal-body {
        background-color: #f0f2f5;
        padding: 15px;
        max-height: 85vh;
        overflow-y: auto;
    }

    .pos-card {
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
        padding: 12px 15px;
        height: 100%;
        border: 1px solid #e1e4e8;
        display: flex;
        flex-direction: column;
    }

    .pos-card-header {
        font-size: 0.95rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #333;
        margin-bottom: 12px;
        padding-bottom: 8px;
        border-bottom: 2px solid #f0f2f5;
        display: block;
    }

    .form-row {
        display: flex;
        align-items: center;
        margin-bottom: 6px;
        font-size: 0.85rem;
    }

        .form-row label {
            flex: 1;
            color: #495057;
            font-weight: 600;
            margin-bottom: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .form-row input[disabled], .form-row input[readonly] {
            background-color: #f8f9fa;
            border: 1px solid #ced4da;
            color: #212529;
            font-weight: 700;
            text-align: right;
            padding: 2px 8px;
            border-radius: 4px;
            height: 28px;
            width: 70px;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

    .form-control-pos {
        border: 1px solid #ced4da;
        border-radius: 4px;
        padding: 4px 8px;
        height: 32px;
        font-size: 0.9rem;
    }

    .status-input {
        color: #fff !important;
        border: none !important;
    }

    .green {
        background-color: #28a745 !important;
    }

    .red {
        background-color: #dc3545 !important;
    }

    .pink {
        background-color: #ff00ff !important;
    }

    .gray {
        background-color: #6c757d !important;
    }

    .ellipsis-icon {
        color: #3b9ac6;
        cursor: pointer;
        margin-left: 6px;
        width: 16px;
        text-align: center;
        transition: color 0.2s;
    }

        .ellipsis-icon:hover {
            color: #0056b3;
            transform: scale(1.2);
        }

    .grid-header-row {
        display: flex;
        margin-bottom: 8px;
        border-bottom: 1px solid #eee;
        padding-bottom: 4px;
    }

        .grid-header-row label {
            font-size: 0.75rem;
            font-weight: 700;
            color: #6c757d;
            text-align: center;
        }

    .col-label {
        flex: 1;
        text-align: left !important;
        font-weight: 600;
        font-size: 0.85rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .col-val {
        width: 70px; /* Tăng nhẹ độ rộng để chứa đủ số */
        flex-shrink: 0;
        text-align: center;
        height: 28px; /* Cố định chiều cao bằng với input */
        line-height: 28px; /* Căn giữa chữ theo chiều dọc cho label và span */
        display: block;
    }

    /* Đồng nhất kiểu dáng cho cả input và các span giữ chỗ */
    .form-row input.col-val,
    .form-row span.col-val {
        padding: 2px 5px;
        font-size: 0.8rem;
        border-radius: 4px;
    }

    .form-row input.col-val {
        border: 1px solid #ced4da;
        text-align: right;
    }

    /* Span giữ chỗ không màu, không biên nhưng phải có đúng width */
    .form-row span.col-val {
        border: 1px solid transparent; /* Quan trọng: để width bằng với input có border */
        background: transparent;
    }
    .col-icon {
        width: 22px;
    }

    .filter-bar {
        background: #fff;
        padding: 10px 15px;
        border-radius: 8px;
        margin-bottom: 15px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        display: flex;
        gap: 15px;
        align-items: center;
        flex-wrap: wrap;
    }

    #popupLogGrid {
        z-index: 1100 !important;
    }

    #loadingSpinnerHouseStatus {
        z-index: 1200 !important;
    }

    #modalHouseStatus .row.g-3 {
        --bs-gutter-x: 3px;
        --bs-gutter-y: 3px;
    }

    #modalHouseStatus .d-flex.flex-column.gap-3 {
        gap: 3px !important;
    }

    #modalHouseStatus .modal-body {
        padding: 4px;
    }

    #modalHouseStatus .filter-bar {
        margin-bottom: 4px;
        padding: 4px 6px;
        gap: 6px;
    }

    #modalHouseStatus .pos-card {
        padding: 4px 6px;
        border-radius: 4px;
    }

    #modalHouseStatus .pos-card-header {
        margin-bottom: 2px;
        padding-bottom: 3px;
        font-size: 0.8rem;
    }

    #modalHouseStatus .form-row {
        margin-bottom: 1px;
        min-height: 26px;
    }

    #modalHouseStatus hr.my-2 {
        margin: 3px 0;
    }

</style>

<div class="modal fade" id="modalHouseStatus" aria-labelledby="houseStatusLabel" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title fw-bold">House Status </h5>
            </div>

            <div class="modal-body">
                <div class="filter-bar">
                    <div class="d-flex align-items-center">
                        <label class="me-2 mb-0 fw-bold">Date:</label>
                        <input type="date" id="datebunisess" class="form-control-pos" style="width: 135px;">
                    </div>
                    <div class="d-flex align-items-center">
                        <label class="me-2 mb-0 fw-bold">Room Type:</label>
                        <select id="roomtype" class="form-control-pos" style="width: 110px;">
                            <option value="">--ALL--</option>
                            @foreach (var item in roomtypeList)
                            {
                                <option value="@item.ID">@item.Code</option>
                            }
                        </select>
                    </div>
                    <div class="d-flex align-items-center">
                        <label class="me-2 mb-0 fw-bold">Zone:</label>
                        <select id="zone" class="form-control-pos" style="width: 100px;">
                            @foreach (var item in zoneList)
                            {
                                <option value="@item.ID">@item.Code</option>
                            }
                        </select>
                    </div>

                    <div class="ms-auto d-flex gap-2">
                        <button id="btnViewHS" class="mui-button mui-button-view"> View</button>
                        @* <button id="btnPrintGrid" class="mui-button mui-button-export" type="button"> Print</button> *@
                        <button class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>

                <div class="row g-3">

                    <div class="col-lg-4 col-md-12">
                        <div class="d-flex flex-column gap-3 h-100">
                            <div class="pos-card">
                                <span class="pos-card-header">Room Summary</span>
                                <div class="form-row">
                                    <label>Total Physical Room:</label>
                                    <input type="text" id="totalRoom" disabled>
                                </div>
                                <div class="form-row">
                                    <label>Total Room to Sell:</label>
                                    <input type="text" id="roomToSell" disabled>
                                </div>
                                <div class="form-row mt-2">
                                    <label>Out of Order:</label>
                                    <input type="text" id="outOfOrder" class="status-input pink" disabled>
                                    <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                                </div>
                                <div class="form-row">
                                    <label>Out of Service:</label>
                                    <input type="text" id="outOfService" class="status-input gray" disabled>
                                    <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                                </div>
                            </div>

                            <div class="pos-card">
                                <span class="pos-card-header">Housekeeping Room Status</span>
                                <div class="grid-header-row">
                                    <label class="col-label"></label>
                                    <label class="col-val">Vacant</label>
                                    <label class="col-icon"></label>
                                    <label class="col-val">Occupied</label>
                                    <label class="col-icon"></label>
                                    <label class="col-val">Total</label>
                                </div>

                                <div class="form-row">
                                    <label class="col-label">Clean</label>
                                    <input id="cleanVacant" type="text" class="status-input green col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="cleanOccupied" type="text" class="status-input green col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="cleanTotal" type="text" class="col-val" disabled>
                                </div>

                                <div class="form-row">
                                    <label class="col-label">Clean (NC)</label>
                                    <input id="cleannonVacant" type="text" class="col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="cleannonOccupied" type="text" class="col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="cleannonTotal" type="text" class="col-val" disabled>
                                </div>

                                <div class="form-row">
                                    <label class="col-label">Dirty</label>
                                    <input id="dirtyVacant" type="text" class="status-input red col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="dirtyOccupied" type="text" class="status-input red col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="dirtyTotal" type="text" class="col-val" disabled>
                                </div>

                                <div class="form-row">
                                    <label class="col-label">Due Out</label>
                                    <span class="col-val"></span>
                                    <span class="col-icon"></span>
                                    <input id="doeoutOccupied" type="text" class="col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <span class="col-val"></span>
                                </div>
                                <hr class="my-2">
                                <div class="form-row">
                                    <label class="col-label fw-bold">TOTAL</label>
                                    <input id="totalVacant" type="text" class="col-val fw-bold" disabled>
                                    <span class="col-icon"></span>
                                    <input id="totalOccupied" type="text" class="col-val fw-bold" disabled>
                                    <span class="col-icon"></span>
                                    <span class="col-val"></span>
                                </div>

                                <div class="form-row mt-2">
                                    <label class="col-label">OOO / OOS</label>
                                    <input id="outoforderVacant" type="text" class="status-input pink col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="outofserviveOccupied" type="text" class="status-input gray col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="outofserviveVacant" type="text" class=" status-input gray col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6">
                        
                        <div class="d-flex flex-column h-100 gap-2">
                            <div class="pos-card">
                                <span class="pos-card-header">Activity</span>

                                <div class="grid-header-row">
                                    <label class="col-label"></label>
                                    <label class="col-val">Rooms</label>
                                    <label class="col-icon"></label>
                                    <label class="col-val">Perssons</label>
                                    <label class="col-val">VIP</label>
                                </div>

                                <div class="form-row">
                                    <label class="col-label">Stayovers</label>
                                    <input id="stayoverRoom" type="text" class="col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="stayoverPerson" type="text" class="col-val" disabled>
                                    <input id="stayoverVip" type="text" class="col-val" disabled>
                                </div>

                                <div class="form-row">
                                    <label class="col-label">Dep. Expected</label>
                                    <input id="depExpectedRoom" type="text" class="col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="depExpectedPerson" type="text" class="col-val" disabled>
                                    <input id="depExpectedVip" type="text" class="col-val" disabled>
                                </div>

                                <div class="form-row">
                                    <label class="col-label">Dep. Actual</label>
                                    <input id="actualRoom" type="text" class="col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="actualPerson" type="text" class="col-val" disabled>
                                    <input id="actualVip" type="text" class="col-val" disabled>
                                </div>

                                <div class="form-row">
                                    <label class="col-label">Arr. Expected</label>
                                    <input id="arrivalExpectedRoom" type="text" class="col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="arrivalExpectedPerson" type="text" class="col-val" disabled>
                                    <input id="arrivalExpectedVip" type="text" class="col-val" disabled>
                                </div>

                                <div class="form-row">
                                    <label class="col-label">Arr. Actual</label>
                                    <input id="arrivalActualRoom" type="text" class="col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="arrivalActualPerson" type="text" class="col-val" disabled>
                                    <input id="arrivalActualVip" type="text" class="col-val" disabled>
                                </div>

                                <div class="form-row">
                                    <label class="col-label">Extended Stays</label>
                                    <input id="extendedStaysRoom" type="text" class="col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="extendedStaysPerson" type="text" class="col-val" disabled>
                                    <input id="extendedStaysVip" type="text" class="col-val" disabled>
                                </div>

                                <div class="form-row">
                                    <label class="col-label">Early Dep.</label>
                                    <input id="earlyDeparturesRoom" type="text" class="col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="earlyDeparturesPerson" type="text" class="col-val" disabled>
                                    <input id="earlyDeparturesVip" type="text" class="col-val" disabled>
                                </div>

                                <div class="form-row">
                                    <label class="col-label">Day Use</label>
                                    <input id="dayUseRoom" type="text" class="col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="dayUsePerson" type="text" class="col-val" disabled>
                                    <input id="dayUseVip" type="text" class="col-val" disabled>
                                </div>

                                <div class="form-row">
                                    <label class="col-label">Walk In</label>
                                    <input id="walkinRoom" type="text" class="col-val" disabled>
                                    <span class="col-icon"><i class="fas fa-ellipsis-h ellipsis-icon"></i></span>
                                    <input id="walkinPerson" type="text" class="col-val" disabled>
                                    <input id="walkinVip" type="text" class="col-val" disabled>
                                </div>
                            </div>
                            <div class="pos-card" style="margin-top: auto;">
                                <span class="pos-card-header">Print Options</span>
                                <div class="d-flex flex-column gap-2 py-1">
                                    <div class="form-check d-flex align-items-center gap-2">
                                        <input class="form-check-input" type="radio" name="printType" id="radioFast" checked style="margin-top:0">
                                        <label class="form-check-label small fw-bold" for="radioFast">Save File and Print</label>
                                    </div>
                                    <div class="form-check d-flex align-items-center gap-2">
                                        <input class="form-check-input" type="radio" name="printType" id="radioSave" style="margin-top:0">
                                        <label class="form-check-label small fw-bold" for="radioSave">Fast Print</label>
                                    </div>
                                    <button id="btnExecutePrint" class="mui-button mui-button-export w-100 mt-1">
                                        Print
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6">
                        <div class="pos-card">
                            <span class="pos-card-header">End Of Day Projection</span>

                            <div class="grid-header-row">
                                <label class="col-label"></label>
                                <label class="col-val">Rooms</label>
                                <label class="col-val">Pers</label>
                                <label class="col-val">VIP</label>
                            </div>

                            <div class="form-row">
                                <label class="col-label">Occupancy</label>
                                <input id="occupancyRoom" type="text" class="col-val" disabled>
                                <input id="occupancyPersons" type="text" class="col-val" disabled>
                                <input id="occupancyvVip" type="text" class="col-val" disabled>
                            </div>

                            <div class="form-row">
                                <label class="col-label">% Occupancy</label>
                                <input id="occupancyPercent" type="text" class="col-val" disabled>
