<script>
    $(document).ready(async function () {
        window.tomSelectInstances = window.tomSelectInstances || {};
        await setSelectCompany();
    });

    // const tomSelectCompany = {};
    async function setSelectCompany() {
        const configs = [
            "#pro_search_select-beast-empty", "#pro_search_txtCityCOM", "#pro_search_txtCountryCOM",
            "#pro_search_txtStateCOM", "#pro_search_txtOwnerCOM", "#pro_search_txtTerritoryCOM",
            "#pro_search_txtCompanyTypeCOM", "#pro_search_txtSaleInChargeCOM", "#pro_search_txtCurrencyCOM",
            "#pro_search_txtMarketCOM", "#pro_search_txtMarketTypeCOM",
        ];

        for (const id of configs) {
            const el = document.querySelector(id);
            if (!el) continue;

            if (window.tomSelectInstances[id]) {
                window.tomSelectInstances[id].destroy();
            }

            window.tomSelectInstances[id] = new TomSelect(el, {
                valueField: 'value',
                labelField: 'text',
                searchField: 'text',
                create: false,
                allowEmptyOption: true,
                plugins: ['clear_button']
            });
        }
    }

    $('#pro_search_blackListCOM').on('change', function () {
        const isChecked = this.checked;
        const $reasonInput = $('#pro_search_blackListReasonCOM');
        $reasonInput.prop('disabled', !isChecked).toggleClass('is-invalid', false);
        if (isChecked) {
            $reasonInput.css({ 'background-color': 'black', 'color': 'white' });
        } else {
            $reasonInput.css({ 'background-color': '', 'color': '' });
        }
    });
</script>
