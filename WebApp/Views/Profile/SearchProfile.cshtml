        checkFullName: function (options) {
            return new Promise(function (resolve, reject) {
                const { fullNameSelector, firstNameSelector, middleNameSelector, lastNameSelector, salutationSelector, titleSelector, idForm } = options;
                const $fullName = $(fullNameSelector);
                if (!$fullName.length) { resolve(true); return; }
                const input = $fullName.val().trim();
                if (input === '') { resolve(true); return; }

                $.ajax({
                    url: '/Profile/FullNameChange',
                    type: 'POST',
                    dataType: 'json',
                    headers: { "X-CSRF-TOKEN-HEADERNAME": $('input[name="__RequestVerificationToken"]').val() },
                    data: { fullName: input },
                    success: function (res) {
                        if (res && res.success) {
                            $fullName.val(res.fullName);
                            if (firstNameSelector) $(firstNameSelector).val(res.firstName || '');
                            if (middleNameSelector) $(middleNameSelector).val(res.middleName || '');
                            if (lastNameSelector) $(lastNameSelector).val(res.lastName || '');
                            if (salutationSelector) $(salutationSelector).val(res.salutation || '');
                            if (res.titleID && titleSelector) {
                                let select = $(titleSelector)[0]?.tomselect;
                                if (select) select.setValue(res.titleID);
                            }
                            resolve(true);
                        } else {
                            if (typeof applyValidationErrors === "function") applyValidationErrors(res.errors, idForm);
                            resolve(false);
                        }
                    },
                    error: function () { resolve(false); }
                });
            });
        },

        deleteProfile: function () {
            const self = this;
            if (!this.profileID || this.profileID <= 0) {
                showToast("Error", "Please choose 1 profile to delete", false);
                return;
            }
            if (!confirm("Are you sure you want to delete this profile?")) return;

            $.ajax({
                url: '/Profile/DeleteProfile',
                type: 'POST',
                data: { profileID: this.profileID },
                success: function (res) {
                    if (res.success) {
                        showToast("Success", res.message, true);
                        self.getAllProfiles();
                    } else {
                        showToast("Error", res.message, false);
                    }
                }
            });
        },

        closeFormProfile: function () {
            this.resetForm();
            if (typeof applyValidationErrors === "function") {
                applyValidationErrors([], "#profile_individual");
                applyValidationErrors([], "#profile_com_ta_source");
                applyValidationErrors([], "#profile_group");
                applyValidationErrors([], "#profile_contact");
            }
        },

        editProfile: function (mode) {
            const self = this;
            var grid = this.gridInstance;
            if (!grid) return;
            var selectedRowsData = grid.getSelectedRowsData();

            if (mode === 'NEW') {
                this.resetForm();
                let type = $('#pro_search_txtType').val();
                if (type == 0 || type === '') {
                    $('#modalProfileIndividual').modal('show');
                    $('#btnView').hide();
                    $('#changeTypeIN').hide();
                } else if (type == 4) {
                    $('#modalProfileGroup').modal('show');
                    $('#changeTypeGR').hide();
                } else if (type == 5) {
                    $('#modalProfileContact').modal('show');
                    $('#changeTypeCON').hide();
                } else {
                    $('#modalProfileCompany').modal('show');
                    $('#changeTypeCOM').hide();
                }
                return;
            }

            if (mode === 'EDIT') {
                if (selectedRowsData.length < 1) {
                    showToast("Warning", "Please choose 1 profile to edit", false);
                    return;
                }
                $("#profileTypeModalLabel").text("Edit Profile");
                $.ajax({
                    url: '/Profile/GetProfileByID',
                    type: 'get',
                    dataType: 'json',
                    headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                    data: { id: selectedRowsData[0].id },
                    success: function (result) {
                        if (result.code != 0) {
                            showToast("Error", result.msg, false);
                        } else {
                            self.fillProfileForm(result.profile);
                        }
                    }
                });
            }
        },

        fillProfileForm: function (profile) {
            const self = this;

            // ==========================================
            // CASE 0: INDIVIDUAL (Cá nhân)
            // ==========================================
            if (profile.type == 0) {
                $("#pro_search_idIndividual").val(profile.id);
                $("#pro_search_txtCodeIndividual").val(profile.code);
                $("#pro_search_txtFullNameIndividual").val(profile.account);
                $("#pro_search_txtLastNameIndividual").val(profile.lastName);
                $("#pro_search_txtFirstNameIndividual").val(profile.firstname);
                $("#pro_search_txtMiddleNameIndividual").val(profile.middleName);
                $("#pro_search_txtReasonIndividual").val(profile.vipReason);
                $("#pro_search_txtPostalIndividual").val(profile.postalCode);
                $("#pro_search_txtReligionIndividual").val(profile.religion);
                $("#pro_search_txtNationIndividual").val(profile.nation);
                $("#pro_search_txtPurposeIndividual").val(profile.purposeOfStay);
                $("#pro_search_txtAddressIndividual").val(profile.address);
                $("#pro_search_txtSalutationIndividual").val(profile.salutation);
                $("#pro_search_txtPrefRoomIndividual").val(profile.prefRoom);
                $("#pro_search_txtOtherIndividual").val(profile.other);
                $("#pro_search_txtPassportIndividual").val(profile.passPort);
                $("#pro_search_txtCardIndividual").val(profile.identityCard);
                $("#pro_search_txtDobIndividual").val(typeof formatDateForInputISO === "function" ? formatDateForInputISO(profile.dateOfBirth) : profile.dateOfBirth);
                $("#pro_search_txtActiveIndividual").prop("checked", profile.active === true);
                $("#pro_search_txtContactIndividual").prop("checked", profile.contact === true);
                $("#pro_search_txtKeywordIndividual").val(profile.keyword);
                $("#pro_search_txtCompanyIndividual").val(profile.fullAccount);
                $("#pro_search_txtCompany2Individual").val(profile.company);
                $("#pro_search_txtTaxIndividual").val(profile.taxCode);
                $("#pro_search_txtBusAddressIndividual").val(profile.homeAddress);
                $("#pro_search_txtTelephoneIndividual").val(profile.telephone);
                $("#pro_search_txtHandPhoneIndividual").val(profile.handPhone);
                $("#pro_search_txtFaxIndividual").val(profile.fax);
                $("#pro_search_txtEmailIndividual").val(profile.email);
                $("#pro_search_txtWebsiteIndividual").val(profile.website);
                $("#pro_search_txtBusinessTitleIndividual").val(profile.businessTitle);
                $("#pro_search_txtBlackListIndividual").prop("checked", profile.isBlackList === true);
                $("#pro_search_blackListIndividual").val(profile.blackListReason);
                $("#pro_search_txtNoteIndividual").val(profile.description);

                // TomSelect Individual
                if ($('#pro_search_txtCityIndividual')[0]?.tomselect) $('#pro_search_txtCityIndividual')[0].tomselect.setValue(profile.city);
                if ($('#pro_search_txtLanguageIndividual')[0]?.tomselect) $('#pro_search_txtLanguageIndividual')[0].tomselect.setValue(profile.languageID);
                if ($('#pro_search_txtTitleIndividual')[0]?.tomselect) $('#pro_search_txtTitleIndividual')[0].tomselect.setValue(profile.titleID);
                if ($('#pro_search_txtNationalityIndividual')[0]?.tomselect) $('#pro_search_txtNationalityIndividual')[0].tomselect.setValue(profile.nationalityID);
                if ($('#pro_search_txtCountryIndividual')[0]?.tomselect) $('#pro_search_txtCountryIndividual')[0].tomselect.setValue(profile.countryID);
                if ($('#pro_search_txtStateIndividual')[0]?.tomselect) $('#pro_search_txtStateIndividual')[0].tomselect.setValue(profile.stateID);
                if ($('#pro_search_txtVIPIndividual')[0]?.tomselect) $('#pro_search_txtVIPIndividual')[0].tomselect.setValue(profile.vipid);

                $('#modalProfileIndividual').modal('show');
                $('#pro_search_changeTypeIN').hide();
            }
            // ==========================================
            // CASE 1, 2, 3: COMPANY / TRAVEL AGENT / SOURCE
            // ==========================================
            else if (profile.type == 1 || profile.type == 2 || profile.type == 3) {
                $("#pro_search_idCOM").val(profile.id);
                $("#pro_search_txtCodeCOM").val(profile.code);
                $("#pro_search_txtAccountCOM").val(profile.account);
                $("#pro_search_txtAddressCOM").val(profile.address);
                $("#pro_search_txtPostalCOM").val(profile.postalCode);
                $("#pro_search_txtCompanyCOM").val(profile.fullAccount);
                $("#pro_search_txtTaxCOM").val(profile.taxCode);
                $("#pro_search_txtBusAddressCOM").val(profile.homeAddress);
                $("#pro_search_txtContractName").val(profile.acctContact);
                $("#pro_search_txtTelephoneCOM").val(profile.telephone);
                $("#pro_search_txtContactNameCOM").val(profile.acctContact);
                $("#pro_search_txtEmailCOM").val(profile.email);
                $("#pro_search_txtWebsiteCOM").val(profile.website);
                $("#pro_search_txtHandPhoneCOM").val(profile.handPhone);
                $("#pro_search_txtCompany2COM").val(profile.company);
                $("#pro_search_txtBusTitleCOM").val(profile.businessTitle);
                $("#pro_search_txtKeywordCOM").val(profile.keyword);
                $("#pro_search_txtARCOM").val(profile.arNo);
                $("#pro_search_txtActiveCOM").prop("checked", profile.active === true);
                $("#pro_search_txtBlackListCOM").prop("checked", profile.isBlackList === true);
                $("#pro_search_blackListCOM").val(profile.blackListReason);
                $("#pro_search_txtNoteCOM").val(profile.description);

                // TomSelect Company
                if ($('#pro_search_txtCountryCOM')[0]?.tomselect) $('#pro_search_txtCountryCOM')[0].tomselect.setValue(profile.countryID);
                if ($('#pro_search_txtCityCOM')[0]?.tomselect) $('#pro_search_txtCityCOM')[0].tomselect.setValue(profile.city);
                if ($('#pro_search_txtStateCOM')[0]?.tomselect) $('#pro_search_txtStateCOM')[0].tomselect.setValue(profile.stateID);
                if ($('#pro_search_txtOwnerCOM')[0]?.tomselect) $('#pro_search_txtOwnerCOM')[0].tomselect.setValue(profile.ownerID);
                if ($('#pro_search_txtTerritoryCOM')[0]?.tomselect) $('#pro_search_txtTerritoryCOM')[0].tomselect.setValue(profile.territoryID);
                if ($('#pro_search_txtCompanyTypeCOM')[0]?.tomselect) $('#pro_search_txtCompanyTypeCOM')[0].tomselect.setValue(profile.memberType);
                if ($('#pro_search_txtCurrencyCOM')[0]?.tomselect) $('#pro_search_txtCurrencyCOM')[0].tomselect.setValue(profile.currencyID);
                if ($('#pro_search_txtMarketCOM')[0]?.tomselect) $('#pro_search_txtMarketCOM')[0].tomselect.setValue(profile.marketID);
                if ($('#pro_search_txtSaleInChargeCOM')[0]?.tomselect) $('#pro_search_txtSaleInChargeCOM')[0].tomselect.setValue(profile.personInChargeID);

                $('#modalProfileCompany').modal('show');
                $('#pro_search_changeTypeCOM').hide();
            }
            // ==========================================
            // CASE 4: GROUP
            // ==========================================
            else if (profile.type == 4) {
                $("#pro_search_idGroup").val(profile.id);
                $("#pro_search_txtCodeGroup").val(profile.code);
                $("#pro_search_txtGroupName").val(profile.account);
                $("#pro_search_txtAddressGroup").val(profile.address);
                $("#pro_search_txtPostalGroup").val(profile.postalCode);
                $("#pro_search_txtFax").val(profile.fax);
                $("#pro_search_txtHomeAddressGroup").val(profile.homeAddress);
                $("#pro_search_txtContractNameGroup").val(profile.acctContact);
                $("#pro_search_txtTelephoneGroup").val(profile.telephone);
                $("#pro_search_txtEmailGroup").val(profile.email);
                $("#pro_search_txtWebsiteGroup").val(profile.website);
                $("#pro_search_txtHandPhoneGroup").val(profile.handPhone);
                $("#pro_search_txtVipReasonGroup").val(profile.vipReason);
                $("#pro_search_txtAcctContact").val(profile.acctContact);
                $("#pro_search_txtHistoryGroup").prop("checked", profile.history === true);
                $("#pro_search_txtNotesGroup").val(profile.description);

                // TomSelect Group
                if ($('#pro_search_txtCountryGroup')[0]?.tomselect) $('#pro_search_txtCountryGroup')[0].tomselect.setValue(profile.countryID);
                if ($('#pro_search_txtStateGroup')[0]?.tomselect) $('#pro_search_txtStateGroup')[0].tomselect.setValue(profile.stateID);
                if ($('#pro_search_txtLanguageGroup')[0]?.tomselect) $('#pro_search_txtLanguageGroup')[0].tomselect.setValue(profile.languageID);
                if ($('#pro_search_txtCurrencyGroup')[0]?.tomselect) $('#pro_search_txtCurrencyGroup')[0].tomselect.setValue(profile.currencyID);
                if ($('#pro_search_txtVIPGroup')[0]?.tomselect) $('#pro_search_txtVIPGroup')[0].tomselect.setValue(profile.vipid);
                $("#pro_search_txtCityGroup").val(profile.city);

                $('#modalProfileGroup').modal('show');
                $('#pro_search_changeTypeGR').hide();
            }
            // ==========================================
            // CASE 5: CONTACT
            // ==========================================
            else if (profile.type == 5) {
                $("#pro_search_idContact").val(profile.id);
                $("#pro_search_txtCodeContact").val(profile.code);
                $("#pro_search_txtFullNameContact").val(profile.account);
                $("#pro_search_txtFirstNameContact").val(profile.firstname);
                $("#pro_search_txtLastContact").val(profile.lastName);
                $("#pro_search_txtMiddleNameContact").val(profile.middleName);
                $("#pro_search_txtPositionContact").val(profile.position);
                $("#pro_search_txtDeptContact").val(profile.department);
                $("#pro_search_txtSalulationContact").val(profile.salutation);
                $("#pro_search_txtAddressContact").val(profile.address);
                $("#pro_search_txtHomeAddressContact").val(profile.homeAddress);
                $("#pro_search_txtPostalCodeContact").val(profile.postalCode);
                $("#pro_search_txtARContact").val(profile.arNo);
                $("#pro_search_txtTelephoneContact").val(profile.telephone);
                $("#pro_search_txtFaxContact").val(profile.fax);
                $("#pro_search_txtEmailContact").val(profile.email);
                $("#pro_search_txtWebsiteContact").val(profile.website);
                $("#pro_search_txtHandPhoneContact").val(profile.handPhone);
                $("#pro_search_txtActiveContact").prop("checked", profile.active === true);

                if (profile.dateOfBirth) {
                    $("#pro_search_txtDobContact").val(profile.dateOfBirth);
                    $("#pro_search_txtCheckboxDobContact").prop("checked", true);
                } else {
                    $("#pro_search_txtDobContact").val("");
                    $("#pro_search_txtCheckboxDobContact").prop("checked", false);
                }

                // TomSelect Contact
                if ($('#pro_search_txtLanguageContact')[0]?.tomselect) $('#pro_search_txtLanguageContact')[0].tomselect.setValue(profile.languageID);
                if ($('#pro_search_txtTitleContact')[0]?.tomselect) $('#pro_search_txtTitleContact')[0].tomselect.setValue(profile.titleID);
                if ($('#pro_search_txtCityContact')[0]?.tomselect) $('#pro_search_txtCityContact')[0].tomselect.setValue(profile.cityID);
                if ($('#pro_search_txtCountryContact')[0]?.tomselect) $('#pro_search_txtCountryContact')[0].tomselect.setValue(profile.countryID);
                if ($('#pro_search_txtStateContact')[0]?.tomselect) $('#pro_search_txtStateContact')[0].tomselect.setValue(profile.stateID);
                if ($('#pro_search_txtOwnerContact')[0]?.tomselect) $('#pro_search_txtOwnerContact')[0].tomselect.setValue(profile.ownerID);
                if ($('#pro_search_txtTerritoryContact')[0]?.tomselect) $('#pro_search_txtTerritoryContact')[0].tomselect.setValue(profile.territoryID);

                $('#modalProfileContact').modal('show');
                $('#pro_search_changeTypeCON').hide();
            }
        },

        initializeDataGridHistory: function (data) {
            const columnWidth = 150;

            const columns = [
                { dataField: 'ConfirmationNo', caption: 'Conf.No', visible: true, width: columnWidth },
                { dataField: 'CRSNo', caption: 'CRSNo', visible: true, width: columnWidth },
                { dataField: 'ArrivalDate', caption: 'ArrivalDate', visible: true, width: columnWidth, dataType: "date", format: "dd/MM/yyyy" },
                { dataField: 'DepartureDate', caption: 'DepartureDate', visible: true, width: columnWidth, dataType: "date", format: "dd/MM/yyyy" },
                { dataField: 'RoomNo', caption: 'Room', visible: true, width: columnWidth },
                { dataField: 'RoomType', caption: 'Room Type', visible: true, width: columnWidth },
                { dataField: 'Rate', caption: 'Rate', visible: true, width: columnWidth },
                { dataField: 'CurrencyID', caption: 'Currency', visible: true, width: columnWidth },
                { dataField: 'RateCode', caption: 'Rate Code', visible: true, width: columnWidth },
                { dataField: 'NoOfAdult', caption: 'A', visible: true, width: columnWidth },
                { dataField: 'NoOfChild', caption: 'C', visible: true, width: columnWidth },
                { dataField: 'NoOfChild1', caption: 'C1', visible: true, width: columnWidth },
                { dataField: 'NoOfChild2', caption: 'C2', visible: true, width: columnWidth },
                { dataField: 'LastName', caption: 'Guest Name', visible: true, width: columnWidth },
                { dataField: 'BusinessBlockCode', caption: 'Block', visible: true, width: columnWidth },
                { dataField: 'MarketCode', caption: 'Market', visible: true, width: columnWidth },
                { dataField: 'SourceCode', caption: 'Source', visible: true, width: columnWidth },
                { dataField: 'ReservationHolder', caption: 'Reservation Holder', visible: true, width: columnWidth },
                { dataField: 'Status', caption: 'Status', visible: true, width: columnWidth },
                { dataField: 'TotalRevenue', caption: 'Total Rev', visible: true, width: columnWidth },
                { dataField: 'RoomRevenue', caption: 'Room Rev', visible: true, width: columnWidth },
                { dataField: 'FBRevenue', caption: 'F&B Rev', visible: true, width: columnWidth },
                { dataField: 'ExtraRevenue', caption: 'Extra Rev', visible: true, width: columnWidth },
                { dataField: 'NonRevenue', caption: 'Non Rev', visible: true, width: columnWidth },
                { dataField: 'UserInsert', caption: 'Created By', visible: true, width: columnWidth },
                { dataField: 'CreateDate', caption: 'Created On', visible: true, width: columnWidth },
                { dataField: 'UserUpdate', caption: 'Updated By', visible: true, width: columnWidth },
                { dataField: 'UpdateDate', caption: 'Update On', visible: true, width: columnWidth },
            ];

            $("#pro_search_gridContainerHistory").dxDataGrid({
                dataSource: data,
                columns: columns,
                allowColumnResizing: true,
                columnAutoWidth: true,
                showBorders: false,
                selection: {
                    mode: "multiple",
                    showCheckBoxesMode: "none"
                },
                paging: { pageSize: 15 },
                pager: {
                    visible: true,
                    allowedPageSizes: [15, 20, 'all'],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true,
                },
                scrolling: {
                    rowRenderingMode: 'virtual',
                    showScrollbar: "always"
                },
                onRowClick: function (e) {
                    console.log("History ID clicked:", e.data.id);
                }
            });
        }
    };
</script>
