@{
  
}
<style>

</style>

<div class="modal fade" id="allot_type_modal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content modal-full-height">
            <div class="modal-header bg-light py-2">
                <h5 class="modal-title">Allotment Type</h5>
            </div>

            <div class="modal-body d-flex flex-column" style="height: calc(100vh - 120px);">
                <div class="py-2">
                    <button id="allot_type_btnView" class="mui-button mui-button-search"> View</button>
                    <button id="allot_type_btnNew" class="mui-button mui-button-new"> New</button>
                    <button id="allot_type_btnEdit" class="mui-button mui-button-edit"> Edit</button>
                    <button id="allot_type_btnDelete" class="mui-button mui-button-delete"> Delete</button>
                    <button id="allot_type_btnExportExcel" class="mui-button mui-button-export"> Excel</button>
                    <button class="mui-button mui-button-new" data-bs-dismiss="modal"> Close </button>
                </div>
                <div class="mui-card mb-2 bg-light border-0 d-flex flex-column flex-grow-1 overflow-hidden">
                    <div class="p-2 flex-shrink-0">
                        <div class="d-flex align-items-center gap-3">
                            <div class="d-flex align-items-center me-4">
                                <label for="allot_type_codeInput" class="me-2 mb-0">Code:</label>
                                <input type="text" id="allot_type_codeInput" class="form-control form-control-sm w-auto" />
                            </div>
                            <div class="d-flex align-items-center me-4">
                                <label for="allot_type_nameInput" class="me-2 mb-0">Name:</label>
                                <input type="text" id="allot_type_nameInput" class="form-control form-control-sm w-auto" />
                            </div>
                            <div class="d-flex align-items-center me-3">
                                <div class="form-check d-flex align-items-center gap-2">
                                    <input class="form-check-input" type="checkbox" id="allot_type_chkshowInactive">
                                    <label class="form-check-label mb-0" for="allot_type_chkshowInactive">Show Inactive</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="gridContainer mt-2 d-flex flex-column flex-grow-1" style="min-height: 0;">
                        <div id="allot_type_grid"></div>

                        <div id="allot_type_loadingSpinner" style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                        z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                        height: 100%;display: flex;align-items: center;justify-content: center;">
                            <div class="spinner-border text-primary" role="status"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="allot_type_itemModal" tabindex="-1" data-bs-backdrop="static" aria-labelledby="allot_type_itemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="allot_type_itemModalLabel">New Item</h5>
            </div>
            <div class="modal-footer justify-content-start">
                <button type="button" id="allot_type_btnSaveItem" class="mui-button mui-button-save"> Save</button>
                <button type="button" data-bs-dismiss="modal" class="mui-button mui-button-close"> Close</button>
            </div>
            <div class="modal-body">
                <form id="allot_type_formContainer">
                    <div class="container-fluid">
                        <div class="row mb-3 align-items-center">
                            <label for="allot_type_txtcode" class="col-sm-3 col-form-label">Code</label>
                            <div class="col-sm-5">
                                <input type="text" id="allot_type_txtcode" name="code" class="form-control form-control-sm" />
                                <div class="invalid-feedback"></div>
                            </div>
                            <div class="col-sm-4 d-flex align-items-center">
                                <div class="form-check mb-0">
                                    <input type="checkbox" id="allot_type_inactive" name="inactive" class="form-check-input" />
                                    <label for="allot_type_inactive" class="form-check-label text-danger">Inactive</label>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3 align-items-center">
                            <label for="allot_type_txtname" class="col-sm-3 col-form-label">Name</label>
                            <div class="col-sm-9">
                                <input type="text" id="allot_type_txtname" name="name" class="form-control form-control-sm" />
                                <div class="invalid-feedback"></div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label for="allot_type_txtdescription" class="col-sm-3 col-form-label">Description</label>
                            <div class="col-sm-9">
                                <textarea id="allot_type_txtdescription" name="txtdescription" class="form-control" rows="4" style="height:100px"></textarea>
                            </div>
                        </div>

                        <input type="hidden" id="allot_type_id" name="id" value="0" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    var allot_type_Module = {
        selectedRowData: null,

        init: function () {
            this.initEvents();
            this.initDOMEvents();

            this.reloadData();
        },

        initEvents: function () {
            window.openModalAllotType = () => {
                $('#allot_type_modal').modal('show');
                this.reloadData();
            };
            // Xử lý xóa lỗi validation khi nhập liệu
            $("#allot_type_formContainer").on("input change", "input, select, textarea", function () {
                if ($(this).hasClass("is-invalid")) {
                    $(this).removeClass("is-invalid");
                    $(this).next(".invalid-feedback").text("");
                }
            });

            // Reset validation khi đóng modal
            $('#allot_type_itemModal').on('hidden.bs.modal', function () {
                if (typeof applyValidationErrors === "function") {
                    applyValidationErrors([], "#allot_type_formContainer");
                }
            });
        },

        initDOMEvents: function () {
            $("#allot_type_btnView").on("click", () => this.reloadData());
            $("#allot_type_btnNew").on("click", () => this.openNewModal());
            $("#allot_type_btnEdit").on("click", () => this.openEditModal());
            $("#allot_type_btnSaveItem").on("click", () => this.saveItem());
            $("#allot_type_btnDelete").on("click", () => this.deleteItem());
            $("#allot_type_btnExportExcel").on("click", () => this.exportExcel());
        },

        reloadData: function () {
            $("#allot_type_loadingSpinner").show();
            $("#allot_type_grid").css("opacity", "0.5");

            $.ajax({
                url: "/Allotment/GetAllotmentType",
                type: "GET",
                cache: false,
                data: {
                    code: $("#allot_type_codeInput").val(),
                    name: $("#allot_type_nameInput").val(),
                    inactive: $("#allot_type_chkshowInactive").prop("checked") ? 1 : 0
                },
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                success: (data) => {
                    this.renderGrid(data);
                    $("#allot_type_loadingSpinner").hide();
                    $("#allot_type_grid").css("opacity", "1");
                },
                error: (xhr) => {
                    $("#allot_type_loadingSpinner").hide();
                    $("#allot_type_grid").css("opacity", "1");
                    if (typeof showToast === "function") showToast("Error", "Unable to load data", false);
                }
            });
        },

        renderGrid: function (data) {
            $("#allot_type_grid").dxDataGrid({
                dataSource: data,
                height: "100%",
                width: "100%",
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                hoverStateEnabled: true,
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "code", caption: "Code", width: "10%" },
                    { dataField: "name", caption: "Name", width: "20%" },
                    { dataField: "description", caption: "Description", width: "30%" },
                    {
                        dataField: "inactive",
                        caption: "Inactive",
                        width: "6%",
                        cellTemplate: function (container, options) {
                            let checked = options.value == 1;
                            $("<div>").dxCheckBox({ value: checked, readOnly: true }).css("transform", "scale(0.8)").appendTo(container);
                        }
                    },
                    { dataField: "createdBy", caption: "Created By", width: "8%" },
                    { dataField: "createdDate", caption: "Created Date", dataType: "date", width: "9%" },
                    { dataField: "updatedBy", caption: "Updated By", width: "8%" },
                    { dataField: "updatedDate", caption: "Updated Date", dataType: "date", width: "9%" },
                ],
                filterRow: { visible: true, applyFilter: "auto" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, 100],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: { mode: "standard", showScrollbar: "always" },
                onSelectionChanged: (e) => {
                    this.selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
                }
            });
        },

        openNewModal: function () {
            $("#allot_type_formContainer")[0].reset();
            $("#allot_type_id").val("0");
            $("#allot_type_itemModalLabel").text("Add Allotment Type");
            $("#allot_type_itemModal").modal("show");
        },

        openEditModal: function () {
            if (!this.selectedRowData) {
                if (typeof showToast === "function") showToast("Warning", "Please select a line to edit.", true);
                return;
            }
            const data = this.selectedRowData;
            $("#allot_type_id").val(data.id);
            $("#allot_type_txtcode").val(data.code);
            $("#allot_type_txtname").val(data.name);
            $("#allot_type_txtdescription").val(data.description);
            $("#allot_type_inactive").prop("checked", data.inactive);

            $("#allot_type_itemModalLabel").text("Update Allotment Type");
            $("#allot_type_itemModal").modal("show");
        },

        saveItem: function () {
            const id = parseInt($("#allot_type_id").val()) || 0;
            let loginName = (localStorage.getItem("Loginname") || "").trim().replace(/^"(.*)"$/, '$1');

            const model = {
                ID: id,
                Code: $("#allot_type_txtcode").val(),
                Name: $("#allot_type_txtname").val(),
                Description: $("#allot_type_txtdescription").val(),
                Inactive: $("#allot_type_inactive").prop("checked"),
                CreatedBy: loginName,
                UpdatedBy: loginName
            };

            $.ajax({
                url: "/Allotment/AllotmentTypeSave",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(model),
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                beforeSend: () => {
                    $("#allot_type_loadingSpinner").show();
                },
                success: (res) => {
                    $("#allot_type_loadingSpinner").hide();
                    if (res.success) {
                        if (typeof showToast === "function") showToast("Success", res.message, true);
                        $("#allot_type_itemModal").modal("hide");
                        this.reloadData();
                    } else {
                        if (res.errors && res.errors.length > 0) {
                            if (typeof applyValidationErrors === "function") applyValidationErrors(res.errors, "#allot_type_formContainer");
                            let generalError = res.errors.find(x => x.field === "general");
                            let toastMsg = generalError ? generalError.message : "Please check input fields.";
                            if (typeof showToast === "function") showToast("Warning", toastMsg, false);
                        } else {
                            if (typeof showToast === "function") showToast("Error", res.message || "Save failed", false);
                        }
                    }
                },
                error: () => {
                    $("#allot_type_loadingSpinner").hide();
                    if (typeof showToast === "function") showToast("Error", "Request error!", false);
                }
            });
        },

        deleteItem: function () {
            if (!this.selectedRowData || this.selectedRowData.id === 0) {
                if (typeof showToast === "function") showToast('Warning', "Please select a line to delete.", true);
                return;
            }
            if (!confirm("Are you sure you want to delete this record? This action cannot be undone.")) {
                return;
            }
            $.ajax({
                url: `/Allotment/DeleteAllotmentType/` + this.selectedRowData.id,
                type: "POST",
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                success: (result) => {
                    if (result.success) {
                        this.reloadData();
                        if (typeof showToast === "function") showToast("Success", "Delete Successfully!", true);
                    } else {
                        if (typeof showToast === "function") showToast("Error", result.message, false);
                    }
                },
                error: () => {
                    if (typeof showToast === "function") showToast("Error", "Delete failed!", false);
                },
            });
        },

        exportExcel: function () {
            const grid = $("#allot_type_grid").dxDataGrid("instance");
            if (!grid) return;

            const workbook = new ExcelJS.Workbook();
            const companyName = localStorage.getItem("CompanyName") || "System";
            const worksheet = workbook.addWorksheet("Sheet 1");

            worksheet.addRow([companyName]);
            worksheet.mergeCells('A1:D1');
            worksheet.getRow(1).font = { bold: true };

            const exportDate = new Date().toLocaleString("vi-VN");
            worksheet.addRow(['', '', '', exportDate]);
            worksheet.getRow(2).alignment = { horizontal: 'right' };

            worksheet.addRow([]);
            worksheet.addRow([]);

            const reportRow = worksheet.addRow(['Allotment Type Report']);
            worksheet.mergeCells('A5:D5');
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { horizontal: 'center' };

            worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(() => {
                workbook.xlsx.writeBuffer().then((buffer) => {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "AllotmentType.xlsx");
                });
            });
        }
    };

    $(document).ready(function () {
        allot_type_Module.init();
    });
</script>
