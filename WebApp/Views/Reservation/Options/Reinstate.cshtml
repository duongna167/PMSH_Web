<style>
    .confirm-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.4);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .confirm-box {
        background: white;
        padding: 30px;
        border-radius: 12px;
        width: 400px;
        max-width: 90%;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        animation: fadeIn 0.3s ease;
        text-align: center;
    }

        .confirm-box h2 {
            margin: 0 0 10px;
            font-size: 20px;
            color: #333;
        }

        .confirm-box p {
            font-size: 16px;
            color: #666;
            margin: 10px 0 25px;
        }

    .confirm-buttons {
        display: flex;
        justify-content: center;
        gap: 15px;
    }

    .btn {
        padding: 10px 20px;
        border: none;
        border-radius: 6px;
        font-size: 14px;
        cursor: pointer;
        transition: 0.3s ease;
    }

    .btn-confirm {
        background-color: #28a745;
        color: white;
    }

    .btn-cancel {
        background-color: #dc3545;
        color: white;
    }

    .btn:hover {
        opacity: 0.9;
    }


</style>
<div id="confirmBoxReinstate" class="confirm-overlay">
    <div class="confirm-box">
        <h2>Confirmation Action</h2>
        <p>Are you sure you want to reinstate this booking?</p>
        <div class="confirm-buttons">
            <button class="mui-button mui-button-search" onclick="onConfirmReinstate()">OK</button>
            <button class="mui-button mui-button-clear" onclick="closeConfirmReinstate()">Cancel</button>
        </div>
    </div>
</div>
<script>
    function openConfirmReinstate() {
        if(idReservation == 0){
            showToast('Warning', 'Please choose booking', false);
            return;
        }
        // Khớp RESV_STATUS / reservation.Status trong DB: chỉ Cancel(3), CheckedOut(2), CheckedIn(1) mới reinstate được.
        var rs = NaN;
        if (typeof reservationStatus !== 'undefined' && reservationStatus !== null && reservationStatus !== '') {
            rs = parseInt(reservationStatus, 10);
        }
        if (isNaN(rs) && typeof statusID !== 'undefined') {
            rs = parseInt(statusID, 10);
        }
        var allowed = !isNaN(rs) && (rs === 1 || rs === 2 || rs === 3);
        if (!allowed && typeof status === 'string' && status) {
            var t = status.toUpperCase().replace(/\s+/g, ' ').trim();
            allowed = (t === 'CHECKED IN' || t === 'CHECKED OUT' || t === 'CANCEL' || t === 'CANCELLED');
        }
        if (!allowed) {
            showToast('Warning', 'This action is not allowed for the current status.', false);
            return;
        }
       document.getElementById("confirmBoxReinstate").style.display = "flex";
    }

    function closeConfirmReinstate() {
       document.getElementById("confirmBoxReinstate").style.display = "none";
    }

    function onConfirmReinstate() {
      closeConfirmReinstate();
         ReinstateReservation();
    }
    function ReinstateReservation() {
        var rawLogin = localStorage.getItem("Loginname");
        var userName = "";
        if (rawLogin) {
            try { userName = String(JSON.parse(rawLogin)); } catch (e) { userName = rawLogin.trim().replace(/^"(.*)"$/, "$1"); }
        }
        var rawUserId = localStorage.getItem("userID");
        var userID = 0;
        if (rawUserId) {
            try { userID = parseInt(JSON.parse(rawUserId), 10) || 0; } catch (e2) { userID = parseInt(String(rawUserId).replace(/"/g, ""), 10) || 0; }
        }
        if (!userID) {
            showToast('Warning', 'Session user is missing. Please sign in again.', false);
            return;
        }
        var formData = new FormData();
        formData.append('reservationID',idReservation);
        formData.append('userName',userName);
        formData.append('userID',userID);
        formData.append('status',status);

        $.ajax({
            url: '/Reservation/ReinstateReservation',
            type: 'POST',
            processData: false,
            contentType: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            data: formData,
            success: function (data) {
                if (data.code == 0) {
                        if (typeof searchReservation === 'function') searchReservation();
                        showToast('Success', data.msg, true);
                } else {
                        showToast('Error', data.msg, false);
                }

            },
            error: function (xhr, statusText, err) {
                 showToast('Error', err, false);

            }
        });

    }
</script>