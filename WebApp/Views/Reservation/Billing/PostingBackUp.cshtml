    function switchView(viewName) {
        const isMobile = window.innerWidth < 768;

        document.querySelectorAll(".mobile-nav button").forEach((btn) => btn.classList.remove("active"));
        const activeBtn = document.getElementById("nav-" + viewName);
        if(activeBtn) activeBtn.classList.add("active");

        const cols = ["view-trans", "view-group", "view-form"];

        cols.forEach((id) => {
            const el = document.getElementById(id);
            if (isMobile) {
                // Logic cho Mobile: Chỉ hiện 1 cột được chọn
                if (id === "view-" + viewName) {
                    el.classList.add("active-view");
                    el.style.display = "block";
                } else {
                    el.classList.remove("active-view");
                    el.style.display = "none";
                }
            } else {
                // Logic cho Tablet/Desktop: Hiển thị tất cả các cột theo Grid Bootstrap
                el.style.display = "";
                el.classList.remove("active-view");
                if (id === "view-form") el.classList.add("active-view");
            }
        });

        if (viewName === 'form') syncToolbarLogic();

        // Refresh lại Grid để tính toán lại chiều cao khi chuyển view/màn hình
        if (typeof refreshInvoiceGrid === 'function') {
            setTimeout(refreshInvoiceGrid, 200);
        }
    }

    // Thêm sự kiện lắng nghe khi resize trình duyệt
    window.addEventListener('resize', function() {
        const isMobile = window.innerWidth < 768;
        if (!isMobile) {
            // Tự động khôi phục hiển thị các cột nếu người dùng xoay ngang tablet hoặc mở rộng trình duyệt
            ["view-trans", "view-group", "view-form"].forEach(id => {
                document.getElementById(id).style.display = "";
            });
        }
    });

    document.addEventListener("keydown", function (event) {
        if (event.key === "F2") {
            event.preventDefault();
            switchView("form");
            bootstrap.Tab.getOrCreateInstance(
                document.querySelector("#detail-tab")
            ).show();
        }

        if (event.key === "F3") {
            event.preventDefault();
            switchView("form");
            bootstrap.Tab.getOrCreateInstance(
                document.querySelector("#invoice-tab")
            ).show();
        }

    });

    // Load Data INTO CBO
    function loadCurrencies() {
        var $selects = $('.currency-select');
        $.ajax({
            url: '/Billing/GetCurrencies',
            type: 'GET',
            success: function (data) {
                if(data.error) return console.error(data.error);
                let html = '<option value="">-- Select --</option>';
                data.forEach(item => { html += `<option value="${item.id}">${item.id}</option>`; });
                $selects.html(html).val('VND');
            }
        });
    }

    var xhrGroup = null;
    function loadGroups() {
        if (xhrGroup) xhrGroup.abort();
        $('#list-group-container').html('<div class="p-2">Loading...</div>');
        xhrGroup = $.ajax({
            url: '/Billing/GetTransactionGroups',
            type: 'GET',
            success: function (data) {
                if (data.error) { alert(data.error); return; }
                let html = '';
                data.forEach(item => {
                    html += `<a href="javascript:void(0)" onclick="loadSubGroups(${item.id}, this)" class="list-group-item list-group-item-action">${item.description}</a>`;
                });
                $('#list-group-container').html(html);
                if (data.length > 0) {
                    $('#list-group-container .list-group-item:first-child').click();
                }
            }
        });
    }

    var xhrSubgroup = null;
    function loadSubGroups(groupId, element) {
        if (xhrSubgroup) xhrSubgroup.abort();

        highlightItem(element, '#list-group-container');
        $('#view-group').data('selected-group-id', groupId);
        $('#list-subgroup-container').html('Loading...');
        $('#list-transaction-container').empty();
        $('#list-article-container').empty();

        xhrSubgroup = $.ajax({
            url: '/Billing/GetTransactionSubGroups',
            type: 'GET',
            data: { groupId: groupId },
            success: function (data) {
                let html = data.length === 0 ? '<div class="p-2 small text-muted">No Data</div>' : '';
                data.forEach(item => {
                    html += `<a href="javascript:void(0)" onclick="loadTransactions(${item.id}, this)" class="list-group-item list-group-item-action">${item.description}</a>`;
                });
                $('#list-subgroup-container').html(html);
                $('.js-search-box[data-target="#list-subgroup-container"]').val('');
                if (data.length > 0) {
                    $('#list-subgroup-container .list-group-item:first-child').trigger('click');
                }
            }
        });
    }

    var xhrTransactions = null;
    function loadTransactions(subGroupId, element) {
        if (xhrTransactions) xhrTransactions.abort();

        highlightItem(element, '#list-subgroup-container');
        let groupId = $('#view-group').data('selected-group-id');
        $('#list-transaction-container').html('<div class="p-2">Loading...</div>');
        $('#list-article-container').empty();

        xhrTransactions = $.ajax({
            url: '/Billing/GetTransactions',
            type: 'GET',
            data: { groupId: groupId, subGroupId: subGroupId },
            success: function (data) {
                let html = data.length === 0 ? '<div class="p-2 text-muted small">No Transactions</div>' : '';
                data.forEach(item => {
                    html += `<a href="javascript:void(0)" onclick="checkAndLoadArticles('${item.code}', '${item.description}', ${item.defaultPrice}, this)" class="list-group-item list-group-item-action">
                                <span class="fw-bold me-2">${item.code}</span> ${item.description}
                             </a>`;
                });
                $('#list-transaction-container').html(html);
                $('.js-search-box[data-target="#list-transaction-container"]').val('');
            }
        });
    }

    function checkAndLoadArticles(transCode, transName, transPrice, element) {
        highlightItem(element, '#list-transaction-container');
        $('#list-article-container').html('<div class="p-2 text-muted">Loading...</div>');

        $.ajax({
            url: '/Billing/GetArticles',
            type: 'GET',
            data: { transactionCode: transCode },
            success: function (data) {
                if (data.length === 0) {
                    $('#list-article-container').html('<div class="p-2 small text-muted">No Articles. Selected Transaction.</div>');
                    // Không có article -> Load TransPrice vào và tính Net
                    fillToForm(transCode, transName, null, null, transPrice, null);
                } else {
                    let html = '';
                    data.forEach(item => {
                        let artPrice = item.defaultPrice || 0;
                        html += `<a href="javascript:void(0)"
                                    onclick="fillToForm('${transCode}', '${transName}', '${item.code}', '${item.description}', ${artPrice}, this)"
                                    class="list-group-item list-group-item-action">
                                    <span class="fw-bold me-2">${item.code}</span>
                                    <span>${item.description}</span>
                                    <span class="float-end small fw-bold">${formatNumberWithComma(artPrice)}</span>
                                 </a>`;
                    });
                    $('#list-article-container').html(html);
                    $('.js-search-box[data-target="#list-article-container"]').val('');
                }
            }
        });
    }

    // --- Hàm bỏ dấu tiếng Việt để tìm kiếm ---
    function removeVietnameseTones(str) {
        str = str.replace(/à|á|ạ|ả|ã|â|ầ|ấ|ậ|ẩ|ẫ|ă|ằ|ắ|ặ|ẳ|ẵ/g, "a");
        str = str.replace(/è|é|ẹ|ẻ|ẽ|ê|ề|ế|ệ|ể|ễ/g, "e");
        str = str.replace(/ì|í|ị|ỉ|ĩ/g, "i");
        str = str.replace(/ò|ó|ọ|ỏ|õ|ô|ồ|ố|ộ|ổ|ỗ|ơ|ờ|ớ|ợ|ở|ỡ/g, "o");
        str = str.replace(/ù|ú|ụ|ủ|ũ|ư|ừ|ứ|ự|ử|ữ/g, "u");
        str = str.replace(/ỳ|ý|ỵ|ỷ|ỹ/g, "y");
        str = str.replace(/đ/g, "d");
        str = str.replace(/À|Á|Ạ|Ả|Ã|Â|Ầ|Ấ|Ậ|Ẩ|Ẫ|Ă|Ằ|Ắ|Ặ|Ẳ|Ẵ/g, "A");
        str = str.replace(/È|É|Ẹ|Ẻ|Ẽ|Ê|Ề|Ế|Ệ|Ể|Ễ/g, "E");
        str = str.replace(/Ì|Í|Ị|Ỉ|Ĩ/g, "I");
        str = str.replace(/Ò|Ó|Ọ|Ỏ|Õ|Ô|Ồ|Ố|Ộ|Ổ|Ỗ|Ơ|Ờ|Ớ|Ợ|Ở|Ỡ/g, "O");
        str = str.replace(/Ù|Ú|Ụ|Ủ|Ũ|Ư|Ừ|Ứ|Ự|Ử|Ữ/g, "U");
        str = str.replace(/Ỳ|Ý|Ỵ|Ỷ|Ỹ/g, "Y");
        str = str.replace(/Đ/g, "D");
        // Một số ký tự đặc biệt
        str = str.replace(/\u0300|\u0301|\u0303|\u0309|\u0323/g, "");
        str = str.replace(/\u02C6|\u0306|\u031B/g, "");
        return str;
    }

    function highlightItem(element, containerId) {
        $(containerId + ' .list-group-item').removeClass('active-item-custom');
        $(element).addClass('active-item-custom');
    }

    // --- RESET FORM KHI ĐÓNG MODAL ---
    $(document).on('shown.bs.tab', 'button[data-bs-toggle="tab"]', function (e) {
        syncToolbarLogic();
        invoiceList = [];
        syncDefaultInvoiceMasterConfig(true);
        resetFormPosting();

        if (typeof refreshInvoiceGrid === 'function') {
            refreshInvoiceGrid();
        }
    });


    // nut add and post
    var invoiceList = [];
    var invoiceMasterCode = "";
    var invoiceMasterDesc = "";

    function syncDefaultInvoiceMasterConfig(forceReset) {
        if (forceReset === true || !invoiceMasterCode) {
            invoiceMasterCode = (typeof defaultInvoiceCode !== 'undefined' ? defaultInvoiceCode : "") || "";
        }

        if (forceReset === true || !invoiceMasterDesc) {
            invoiceMasterDesc = (typeof defaultInvoiceDesc !== 'undefined' ? defaultInvoiceDesc : "") || "";
        }
    }

        // --- NÚT ADD RENDER DATA VÀO INVOICE LIST ---
        $(document).off('click', '#btn-add').on('click', '#btn-add', function() {
            var $activePane = $('#invoice-pane');
            var transCode = $activePane.find('.js-trans-code').val();

            if (!transCode) {
                showToast("Warning","Please select a transaction first!",true);
                return;
            }

            var qty = parseFloat($activePane.find('.js-input-qty').val()) || 0;
            var price = parseNumberWithComma($activePane.find('.js-input-price-net').val());

            // Tính toán amount hiển thị
            var rawTotal = qty * price;
            var pctVal = 0;
            var serviceType = '';
            var finalTotal = rawTotal;

            if ($activePane.find('.js-chk-express').is(':checked')) {
                pctVal = parseFloat($activePane.find('.js-input-express-pct').val()) || 0;
                serviceType = 'EXP';
                finalTotal += rawTotal * (pctVal / 100);
            }
            else if ($activePane.find('.js-chk-discount').is(':checked')) {
                pctVal = parseFloat($activePane.find('.js-input-discount-pct').val()) || 0;
                serviceType = 'DIS';
                finalTotal -= rawTotal * (pctVal / 100);
            }

            var itemObj = {
                id: Date.now(),
                code: transCode,
                articleCode: $activePane.find('.js-art-code').val() || "",
                description: $activePane.find('.js-art-desc').val() || $activePane.find('.js-trans-desc').val(),
                amountBeforeTax: parseNumberWithComma($activePane.find('.js-amount-net').val()),
                quantity: qty,
                price: price,
                serviceType: serviceType,
                servicePct: pctVal,
                amount: finalTotal,
                reference: $activePane.find('.js-ref-main').val(),
                supplement: $activePane.find('.js-sup-folio').val() || "",
                remark: $activePane.find('.js-invoice-desc').val(),
                checkNo: $activePane.find('.js-invoice-checkNo').val()
            };

            invoiceList.push(itemObj);
            // Thêm hiệu ứng thông báo nhỏ hoặc cuộn xuống cuối
                showToast("Success", "Item added to list", true);

                // Tùy chọn: Tự động cuộn xuống phần Footer để xem danh sách
                $('.form-body-scroll').animate({
                    scrollTop: $('.form-footer-fixed').offset().top
                }, 500);
            refreshInvoiceGrid();
            resetFormKeepInvoiceInfo();
        });

    // ---. HÀM RESET FORM NHƯNG GIỮ INPUT FIELD INVOICE DESC (CHO NÚT ADD) ---
    function resetFormKeepInvoiceInfo() {
        var $activePane = $('#invoice-pane');

        var currentInvoiceDesc = $activePane.find('.js-invoice-desc').val();

        resetFormPosting();   

        // Giữ lại thông tin Invoice Description
        $activePane.find('.js-invoice-desc').val(currentInvoiceDesc);

        $activePane.find('.js-trans-code').focus();
    }

        // ---  HÀM POSTING SERVICE  ---
        function PostingService() {
            const loginUser = parseInt(localStorage.getItem("userID")) || 0;
            const loginName = (localStorage.getItem("Loginname") || "").trim().replace(/^"(.*)"$/, '$1');
            const shiftID = parseInt(localStorage.getItem("shiftID")) || 0;

            var $activePane = $('.tab-pane.active');
            var activeTabId = $activePane.attr('id');

            // Lấy FolioNo từ Select tương ứng của Tab (1, 2... hoặc -1, -2...)
            var folioNoElement = (activeTabId === 'detail-pane') ? '#selectFolioDetail' : '#selectFolioInvoice';
            var selectedFolioNo = parseInt($(folioNoElement).val());

            if (isNaN(selectedFolioNo)) {
                showToast('Error', "Please select a Folio/Window No!", false);
                return;
            }

            var payload = {
                folioNo: selectedFolioNo,
                currentFolioID: folioNoID,
                targetFolioID: getSelectedPostingFolioId(folioNoElement),
                masterCode: (activeTabId === 'invoice-pane') ? invoiceMasterCode : "",
                masterDescription: (activeTabId === 'invoice-pane') ? $activePane.find('.js-invoice-desc').val() : "",
                masterReference: (activeTabId === 'invoice-pane') ? $activePane.find('.js-invoice-ref').val() : "",
                masterSupplement: (activeTabId === 'invoice-pane') ? $activePane.find('.js-invoice-supp').val() : "",
                masterCheckNo: (activeTabId === 'invoice-pane') ? $activePane.find('.js-invoice-checkNo').val() : "",
                details: []
            };

            if (activeTabId === 'detail-pane') {
                // --- LOGIC POST DETAIL (F2) ---
                var tCode = $activePane.find('.js-trans-code').val();
                if (!tCode) { showToast("Warning", "No transaction selected!", true); return; }

                var qty = parseFloat($activePane.find('.js-input-qty').val()) || 0;
                var priceNet = parseNumberWithComma($activePane.find('.js-input-price-net').val());
                var amountNet = parseNumberWithComma($activePane.find('.js-amount-net').val());
                var amountGross = parseNumberWithComma($activePane.find('.js-amount-gross').val());
                    payload.details.push({
                    UserID: loginUser, UserName: loginName, ShiftID: shiftID,
                    CashierNo: loginName,
                    ReservationID: parseInt(idReservation),
                    OriginReservationID: parseInt(idReservation),

                    RoomType: roomType, RoomID: parseInt(roomID),

                    TransactionCode: tCode,
                    Description: $activePane.find('.js-trans-desc').val(),
                    ArticleCode: $activePane.find('.js-art-code').val(),

                    Quantity: qty, Price: priceNet, Amount: amountGross,
                    AmountGross: amountGross,
                    AmountBeforeTax: amountNet,
                    CurrencyID: $activePane.find('.currency-select').val(),
                    Reference: $activePane.find('.js-ref-main').val(),
                    Supplement: $activePane.find('.js-sup-folio').val(),
                    PostType: 2, // Post Detail,
                    UserInsertID: loginUser,
                    UserUpdateID: loginUser
                });
            }
            else if (activeTabId === 'invoice-pane') {
                // --- LOGIC POST INVOICE (F3) ---
                if (invoiceList.length === 0) {
                    showToast("Warning", "Invoice list is empty! Please 'Add' items first.", true);
                    return;
                }

                syncDefaultInvoiceMasterConfig();
                if (!invoiceMasterCode) {
                    showToast('Error', "Default invoice code is not configured!", false);
                    return;
                }

                payload.masterCode = invoiceMasterCode;
                payload.masterDescription = $activePane.find('.js-invoice-desc').val() || invoiceMasterDesc;

                invoiceList.forEach(function(item) {
                    payload.details.push({
                        UserID: loginUser, UserName: loginName, ShiftID: shiftID,
                        CashierNo: loginName,
                        ReservationID: parseInt(idReservation), RoomType: roomType, RoomID: parseInt(roomID),

                        TransactionCode: item.code,
                        Description: item.description,
                        ArticleCode: item.articleCode,
                        Quantity: item.quantity, Price: item.price, Amount: item.amount,
                        AmountGross: item.amount,
                        AmountBeforeTax: item.amountBeforeTax,
                        CurrencyID: $activePane.find('.currency-select').val(),
                        Reference: item.reference,
                        CheckNo: item.checkNo,
                        Supplement: $activePane.find('.js-invoice-supp').val(), 
                        PostType: 3, // Post Invoice
                        UserInsertID: loginUser,
                        UserUpdateID: loginUser
                    });
                });
            }

            submitToDB(payload);
        }

        // Hàm confirm post (api)
        function submitToDB(payload) {
            $.ajax({
                url: '/Billing/PostingSave',
                type: 'POST',
                contentType: 'application/json',
                showLoading: true,
                data: JSON.stringify(payload),
                success: function (res) {
                    if (res.success) {
                        showToast("Success", "Posted Successfully! Invoice No: " + res.invoiceNo, true);

                        // Reset dữ liệu
                        invoiceList = [];
                        syncDefaultInvoiceMasterConfig(true);
                        resetFormPosting();
                        $('#modalPosting').modal('hide');
                        if (res.folioId) {
                            folioNoID = res.folioId;
                        }
                        if (typeof GetBalanceVND === 'function') {
                            GetBalanceVND(idReservation);
                        }

                        // Reload lại dữ liệu Billing theo Folio vừa post
                        if (typeof filterByFolioNo === 'function') {
                            // Nếu là master (số âm) thì truyền realFolioNo, còn không truyền chính nó
                            getFolioNo();
                        } else {
                            searchFolioDetail(0);
                        }
                    } else {
                        showToast('Error', res.message || "Posting Failed", false);
                    }
                },
                error: function (xhr) {
                    var msg = (xhr.responseJSON && xhr.responseJSON.message)
                        ? xhr.responseJSON.message
                        : "Network error or Internal Server Error";

                    showToast('Error', "System Error: " + msg, false);
                },
                complete: function(){
                    $("#posting_loadingSpinnerRateCode").hide();
                }
            });
        }

        // ---: Khởi tạo grid F3 invoice list---
        function initInvoiceFooterGrid() {
            var $gridContainer = $("#gridInvoiceFooter");

            if (!$gridContainer.data("dxDataGrid")) {
                $gridContainer.dxDataGrid({
                    dataSource: invoiceList,
                    keyExpr: "id",
                    height: "100%",
                    width: "100%",
                    showBorders: true,
                    showRowLines: true,
                    rowAlternationEnabled: true,
                    columnAutoWidth: false,
                    scrolling: {
                        mode: "standard",
                        useNative: true
                    },
                    paging: { enabled: false },
                    loadPanel: { enabled: false },
                    columns: [
                        { dataField: "code", caption: "Code", width: 40, cssClass: "fw-bold" },
                        {
                            dataField: "description", caption: "Description", minWidth: 110,
                            cellTemplate: function(container, options) {
                                $("<div>").addClass("text-truncate").attr("title", options.value).text(options.value).appendTo(container);
                            }
                        },
                        { dataField: "quantity", caption: "Qty", width: 30 },
                        {
                            dataField: "price", caption: "Price", width: 100,
                            format: { type: "fixedPoint", precision: 0 }
                        },
                        {
                            dataField: "amount", caption: "Total", width: 100,
                            cssClass: "fw-bold",
                            format: { type: "fixedPoint", precision: 0 }
                        },
                        { dataField: "reference", caption: "Ref", width: 100 },
                        {
                            type: "buttons",
                            width: 30,
                            buttons: [{
                                hint: "Delete",
                                icon: "trash",
                                onClick: function(e) {
                                    removeInvoiceItem(e.row.data.id);
                                }
                            }]
                        }
                    ],
                    onContentReady: function(e) {
                        updateFooterTotal();
                    }
                });
            }
        }

        // thao tác F3 invoice list
        function refreshInvoiceGrid() {
            var $gridContainer = $("#gridInvoiceFooter");
            if ($gridContainer.length === 0) return;

            var dataGridInstance = $gridContainer.data("dxDataGrid");

            if (dataGridInstance) {
                dataGridInstance.option("dataSource", invoiceList);

                //Sử dụng requestAnimationFrame để đảm bảo DOM đã render xong chiều cao mới
                window.requestAnimationFrame(function() {
                    dataGridInstance.updateDimensions();
                });
            } else {
                initInvoiceFooterGrid();
            }
            updateFooterTotal();
        }

        function removeInvoiceItem(id) {
            invoiceList = invoiceList.filter(item => item.id !== id);
            refreshInvoiceGrid();
        }

        function clearInvoiceList() {
            invoiceList = [];
            syncDefaultInvoiceMasterConfig(true);

            refreshInvoiceGrid();
        }

        function updateFooterTotal() {
            var total = invoiceList.reduce((sum, item) => sum + item.amount, 0);
            $('.js-total-footer').text(formatNumberWithComma(total));
        }
        //end thao tác F3 invoice list

        function resetAllPostingData() {
            isReset = true;
            isSilentReset = true;

            $('#modalPosting').find('input').val('');
            $('#modalPosting').find('.js-input-qty').val('1');
            $('#modalPosting').find('.js-input-price, .js-input-price-net, .js-amount-gross, .js-amount-net').val('0,00');

            $('.js-chk-express, .js-chk-discount').prop('checked', false);
            $('.express-box input[type="text"], .express-box input[type="radio"]').prop('disabled', true);

            $('#list-group-container').empty().html('<div class="p-2 text-muted">Loading...</div>');
            $('#list-subgroup-container').empty();
            $('#list-transaction-container').empty();
            $('#list-article-container').empty();

            $('.list-group-item').removeClass('active-item-custom');

            if (typeof invoiceList !== 'undefined') invoiceList = [];
            syncDefaultInvoiceMasterConfig(true);

            var gridFooter = $("#gridInvoiceFooter").data("dxDataGrid");
            if (gridFooter) gridFooter.option("dataSource", []);

            switchView('group');

            setTimeout(() => {
                isReset = false;
                isSilentReset = false;
            }, 200);
        }

        function formatCurrencyLive(input) {
            if (isComposing) return;

            let value = (input.value || '').replace(/\s/g, '').replace(/[^\d.,]/g, '');
            if (!value) {
                input.value = '';
                return;
            }

            const lastComma = value.lastIndexOf(',');
            const lastDot = value.lastIndexOf('.');
            const separatorIndex = Math.max(lastComma, lastDot);
            const hasTrailingSeparator = separatorIndex === value.length - 1;

            let integerRaw = separatorIndex >= 0 ? value.substring(0, separatorIndex) : value;
            let decimalRaw = separatorIndex >= 0 ? value.substring(separatorIndex + 1) : '';

            integerRaw = integerRaw.replace(/[^\d]/g, '');
            decimalRaw = decimalRaw.replace(/[^\d]/g, '').slice(0, 2);

            if (!integerRaw) {
                integerRaw = '0';
            }

            let formatted = new Intl.NumberFormat('vi-VN').format(parseInt(integerRaw, 10));

            if (separatorIndex >= 0) {
                formatted += ',';
                if (decimalRaw !== '') {
                    formatted += decimalRaw;
                } else if (!hasTrailingSeparator) {
                    formatted = formatted.slice(0, -1);
                }
            }

            input.value = formatted;
        }
       
        function toggleServiceLock(serviceType, isChecked) {
            var $pane = $('.tab-pane.active');
            var $expressBox = $pane.find('.js-chk-express').closest('.express-box');
            var $discountBox = $pane.find('.js-chk-discount').closest('.express-box');

            if (isChecked) {
                if (serviceType === 'EXP') {
                    // Tích Express -> Khóa hoàn toàn vùng Discount
                    $pane.find('.js-chk-discount').prop('checked', false).prop('disabled', true);
                    toggleInputs($discountBox, false);
                } else {
                    // Tích Discount -> Khóa hoàn toàn vùng Express
                    $pane.find('.js-chk-express').prop('checked', false).prop('disabled', true);
                    toggleInputs($expressBox, false);
                }
            } else {
                // Bỏ tích -> Mở khóa cho cả 2 để chọn lại
                $pane.find('.js-chk-express, .js-chk-discount').prop('disabled', false);
            }
        }
