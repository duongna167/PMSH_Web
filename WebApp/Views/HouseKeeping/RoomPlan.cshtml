<div id="loadingSpinner"
     style="display:none;
            position:fixed;
            top:50%;
            left:50%;
            transform:translate(-50%, -50%);
            z-index:1000;
            text-align:center;">
    
    <i class="fa-solid fa-spinner fa-spin" style="font-size:36px;"></i>
    <div style="margin-top:8px; font-size:14px; font-weight:500;">
        Please wait...
    </div>
</div>

<script>


    $(document).ready(function () {
        getBusinessDate();
        initTomSelect(".tomselect-custom");
        // Khi nhấn nút Filter
        $('#toggleFilterBtn').on('click', function (e) {
            e.stopPropagation();

            // Gắn filterPopup ngay sau nút
            $(this).after($('#filterPopup'));

            // Toggle hiển thị
            $('#filterPopup').toggle();
        });

        // Click ra ngoài sẽ đóng popup và overlay
        $(document).on('click', function (e) {

            const $popup = $('#filterPopup');
            const $button = $('#toggleFilterBtn');

            if (
                !$popup.is(e.target) && $popup.has(e.target).length === 0 &&
                !$button.is(e.target) && $button.has(e.target).length === 0
            ) {
                $popup.hide();
                $('#overlay').hide();
            }
        });
        let currentScaleX = 1.0;      // Zoom ngang mặc định 100%
        const step = 0.1;             // Mỗi lần zoom ±10%
        const minScaleX = 0.5;        // Tối thiểu 50%
        const maxScaleX = 2.0;        // Tối đa 200%

        function applyHorizontalZoom() {
            $('#schedulerContainer').css('transform', 'scaleX(' + currentScaleX + ')');
        }

        $('#zoom-in').on('click', function () {
            if (currentScaleX < maxScaleX) {
                currentScaleX += step;
                applyHorizontalZoom();
            }
        });

        $('#zoom-out').on('click', function () {
            if (currentScaleX > minScaleX) {
                currentScaleX -= step;
                applyHorizontalZoom();
            }
        });

        $('input[name="masterlliouppop"]').on('change', function () {
            if ($(this).is(':checked')) {
                $("#btnPrint").trigger("click");
            }
        });
        document.getElementById("reportTitle").innerText = 'Room Plan';
         initTomSelect(".tomselect-custom");
         const DAY_RANGE = 30;

        const parseDate = (val) => {
            if (!val) return null;
            return new Date(val + 'T00:00:00');
        };

        const formatDate = (d) => d.toISOString().split('T')[0];

        $('#fromDate').on('change', function () {
            const fromDate = parseDate(this.value);
            if (!fromDate) return;

            const toDate = new Date(fromDate);
            toDate.setDate(toDate.getDate() + DAY_RANGE);

            $('#toDate').val(formatDate(toDate));
        });

        $('#toDate').on('change', function () {
            const toDate = parseDate(this.value);  
            if (!toDate) return;

            const fromDate = new Date(toDate);
            fromDate.setDate(fromDate.getDate() - DAY_RANGE);

            $('#fromDate').val(formatDate(fromDate));
        });
    });

    function getBusinessDate() {
        return $.ajax({
            url: '/Reservation/GetBusinessDate',
            type: 'get',
            dataType: 'json',
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {

                const baseDateStr = result.split('T')[0]; // YYYY-MM-DD

                const baseDate = new Date(baseDateStr);
                const toDate = new Date(baseDate);
                toDate.setDate(toDate.getDate() + 30);

                // format YYYY-MM-DD
                const formatDate = (d) => d.toISOString().split('T')[0];

                $('#fromDate').val(formatDate(baseDate));
                $('#toDate').val(formatDate(toDate));
                $("#btnPrint").trigger("click");
            },
            error: function (xhr, statusText, err) {
                if (xhr.status == 401) {
                    sessionTimeout();
                }
            }
        });
    }
  
        function parseVNDateOnly(str) {
        if (!str) return null;

        // "23/03/2025 00:00:00" → "23/03/2025"
        const datePart = str.split(" ")[0];
        const [dd, MM, yyyy] = datePart.split("/").map(Number);

        if (!dd || !MM || !yyyy) return null;

        return new Date(yyyy, MM - 1, dd); // 00:00:00
    }


    $(document).off("click", "#btnPrint").on("click", "#btnPrint", function () {
        $("#loadingSpinner").show();
        const owner = $("#viewBy").val();
        let orderbyroom = $("input[name='masterlliouppop']:checked").val() || "";
        $.ajax({
            url: '/HouseKeeping/RoomPlanData',
            type: 'GET',
            data: {
                fromDate: $("#fromDate").val(),
                toDate: $("#toDate").val(),
                orderbyroom: orderbyroom, // sẽ là "1" hoặc "0"
                owner: owner
            },
            traditional: true,
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (data) {

                // console.log(data);
                // initializeRoomPlanGrid(data);

                const fromDate = $("#fromDate").val();
                const toDate = $("#toDate").val();
                initializeRoomScheduler(data, fromDate, toDate);

                $("#loadingSpinner").hide();
            }

            ,


            error: function () {
                alert("Không thể tải báo cáo.");
                $("#loadingSpinner").hide();
            }
        });
    });
    let roomNorl, roomtypeid, idReservationrl, roomIDrl;
    let originalAppointmentData = null;

    function initializeRoomScheduler(schedulerData, fromDate, toDate) {

        if (!schedulerData || !schedulerData.length) return;

        /* =======================
         * DATE RANGE
         * ======================= */
        const from = new Date(fromDate);
        from.setHours(0, 0, 0, 0);

        const to = new Date(toDate);
        to.setHours(0, 0, 0, 0);

        const daysToShow =
            Math.ceil((to - from) / (1000 * 60 * 60 * 24)) + 1;

        /* =======================
         * ROOM GROUPS
         * ======================= */
        const roomGroups = [
            ...new Map(
                schedulerData
                    .filter(d => d.roomID && d.roomNo && d.roomNo.trim() !== "")
                    .map(d => [
                        d.roomID.toString(),
                        { id: d.roomID.toString(), text: d.roomNo.trim() }
                    ])
            ).values()
        ];

        const validRoomIDs = new Set(roomGroups.map(r => r.id));

        /* =======================
         * ROOM INFO MAP
         * ======================= */
        const roomInfoMap = Object.create(null);

        for (let i = 0, l = schedulerData.length; i < l; i++) {
            const d = schedulerData[i];
            const id = d.roomID;
            if (!id || roomInfoMap[id]) continue;

            roomInfoMap[id] = {
                roomNo: d.roomNo,
                roomNumber: d.roomNumber,
                roomTypeCode: d.roomTypeCode
            };
        }


        /* =======================
         * APPOINTMENTS
         * ======================= */
        const appointments = schedulerData
            .filter(d => {
                const a = parseVNDateOnly(d.arrivalDate);
                const dep = parseVNDateOnly(d.departureDate);

                return (
                    d.roomID &&
                    validRoomIDs.has(d.roomID.toString()) &&
                    a && dep &&
                    a <= to && dep >= from
                );
            })
            .map(d => {
                const a = parseVNDateOnly(d.arrivalDate);
                const dep = parseVNDateOnly(d.departureDate);

                return {
                    text: d.lastName || "",
                    startDate: a < from ? from : a,
                    endDate: dep > to ? to : dep,
                    roomID: d.roomID.toString(),

                    type: d.type || "",
                    reservationStatus: d.reservationStatus,
                    reservationID:
                        !d.reservationID || String(d.reservationID) === "0"
                            ? d.oooid
                            : d.reservationID,

                    roomTypeCode: d.roomTypeCode || "",
                    oooStatus: d.oooStatus || "",
                    roomNumber: d.roomNumber || "",

                    tooltipData: {
                        company: d.company,
                        agent: d.agent,
                        paymentMethod: d.paymentMethod,
                        comment: d.comment,
                        confirmationNo: d.confirmationNo,
                        code: d.code
                    }
                };
            });

        /* =======================
         * INIT SCHEDULER
         * ======================= */
        $("#schedulerContainer").dxScheduler({
            dataSource: appointments,

            views: [{
                type: "timelineDay",
                intervalCount: daysToShow,
                startDate: from
            }],

            currentView: "timelineDay",
            currentDate: from,

            startDayHour: 0,
            endDayHour: 24,
            cellDuration: 1440,

            groups: ["roomID"],
            crossScrollingEnabled: true,

            resources: [{
                fieldExpr: "roomID",
                dataSource: roomGroups,
                allowMultiple: false
            }],

            /* =======================
             * ROOM LABEL (GIỮ NGUYÊN)
             * ======================= */
            dataCellTemplate(cellData, _, cellElement) {
                const cellDate = new Date(cellData.startDate);
                cellDate.setHours(0, 0, 0, 0);

                if (cellDate.getTime() !== from.getTime()) return;

                const roomInfo = roomInfoMap[cellData.groups.roomID];
                if (!roomInfo) return;

                cellElement.append(`
                    <div class="room-label">
                        <div class="room-no">${roomInfo.roomNumber}</div>
                        <div class="room-type">-${roomInfo.roomTypeCode || ""}</div>
                    </div>
                `);
            },

            /* =======================
             * APPOINTMENT RENDER
             * (GIỮ LOGIC CŨ 100%)
             * ======================= */
            onAppointmentRendered: function (e) {

                const el = $(e.appointmentElement);
                const data = e.appointmentData;
                const tooltipData = data.tooltipData || {};

                /* ===== TITLE ===== */
                let titleText = data.text || "";
                if (data.type === "OOOS") {
                    titleText = `${tooltipData.code || "Code"} (Out of Order)`;
                }

                let titleEl = el.find(".dx-scheduler-appointment-title");
                if (!titleEl.length) {
                    titleEl = $('<div class="dx-scheduler-appointment-title"></div>');
                    el.append(titleEl);
                }
                titleEl.text(titleText).css("display", "block");

                /* ===== TOOLTIP ===== */
                el.attr("title", [
                    `Company: ${tooltipData.company || ""}`,
                    `Agent: ${tooltipData.agent || ""}`,
                    `PaymentMethod: ${tooltipData.paymentMethod || ""}`,
                    `Comment: ${tooltipData.comment || ""}`,
                    `ConfirmationNo: ${tooltipData.confirmationNo || ""}`
                ].join("\n"));

                /* ===== COLOR LOGIC (NGUYÊN BẢN) ===== */
                if (data.type === "Reservation") {
                    const resvStatus = String(data.reservationStatus);
                    switch (resvStatus) {
                        case "0":
                        case "5":
                        case "8":
                            el.addClass("resv-pending"); break;
                        case "1":
                            el.addClass("resv-checkin"); break;
                        case "2":
                            el.addClass("resv-checkout"); break;
                        case "6":
                            el.addClass("resv-dueout"); break;
                        default:
                            el.addClass("resv-checkin");
                    }
                } else if (data.type === "OOOS") {
                    const oooStatus = String(data.oooStatus || "");
                    if (oooStatus === "1") {
                        el.addClass("ooo-order");
                    } else if (oooStatus === "2") {
                        el.addClass("ooo-service");
                    } else {
                        el.addClass("ooo-default");
                    }
                }

                /* ===== POSITION LOGIC (NGUYÊN BẢN) ===== */
                const start = new Date(data.startDate); start.setHours(0, 0, 0, 0);
                const end = new Date(data.endDate); end.setHours(0, 0, 0, 0);

                if (from >= start && from <= end) {
                    el.css({
                        position: "absolute",
                        left: "100px",
                        marginTop: "4px"
                    });
                }

                /* ===== TRANSLATE Y (NGUYÊN BẢN – KHÔNG REGEX) ===== */
                const style = el[0].style.transform;
                if (style && style.indexOf("translate") !== -1) {
                    const m = style.match(/translate\(([-\d.]+)px,\s*([-\d.]+)px\)/);
                    if (m) {
                        const x = m[1];
                        const y = parseFloat(m[2]) - 30;
                        el[0].style.transform = `translate(${x}px, ${y}px)`;
                    }
                }
            }
        });
    }


    function goUpdate(idReservationrl, startDate, endDate, roomNorl, roomtypeid, roomIDrl) {
         var modal = $('#newReservationModal');

        // Luôn hiển thị loading
        modal.find('.modal-body').html(`
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-3">Loading reservation...</p>
            </div>
        `);

        modal.modal('show');
        $.ajax({
            url: '/Reservation/EncryptId',
            type: 'POST',
            data: { id: idReservationrl },
            success: function (response) {
                if (response.success) {
                    var start = formatDate(startDate);
                    var end = formatDate(endDate);
                    var data = start + "|" + end + "|" + roomNorl + "|" + roomtypeid + "|" + idReservationrl;


                    localStorage.setItem("ReservationRoomPlan", data);
                    // chỉ encode cái encryptedId
                    // window.location.href = '/Reservation/NewReservation?key=' + encodeURIComponent(response.encryptedId);
                     $.ajax({
                        url: '/Reservation/NewReservation',
                        type: 'GET',
                        data: { key: response.encryptedId },
                        cache: false,
                        success: function (html) {
                            modal.find('.modal-body').html(html);
                           
                        },
                        error: function () {
                            modal.find('.modal-body').html(`
                                <div class="alert alert-danger m-4">
                                    <strong>Lỗi!</strong> Không thể tải thông tin đặt chỗ.
                                </div>
                            `);
                        }
                    });
                }
            }
        });
    }


    function goReview(idReservationrl) {
