<!-- Modal search profile-->
<div class="modal fade modal-xl" id="modalProfile" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
     aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="staticBackdropLabel">Search Profile</h5>
            </div>
            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <button class="mui-button mui-button-new" onclick="initProfileGrid();">Search</button>
                        <button type="button" class="mui-button mui-button-new" onclick="clearSearch()">Clear</button>

                        <button type="button" class="mui-button mui-button-new"
                                onclick="closeModalSearchProfle()">Close</button>

                    </div>
                    <div class="row mt-1">

                        <!-- Full Name -->
                        <div class="col-12 col-sm-6 col-md-4 col-lg-3 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Full Name
                                </label>
                                <div class="col-12 col-md-8">
                                    <input class="form-control" id="nameProfileSearch" placeholder="Enter name">
                                </div>
                            </div>
                        </div>

                        <!-- First Name -->
                        <div class="col-12 col-sm-6 col-md-4 col-lg-3 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    First Name
                                </label>
                                <div class="col-12 col-md-8">
                                    <input class="form-control" id="firstNameProfileSearch"
                                           placeholder="Enter first name">
                                </div>
                            </div>
                        </div>

                        <!-- View By -->
                        <div class="col-12 col-sm-6 col-md-4 col-lg-3 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    View By
                                </label>
                                <div class="col-12 col-md-8">

                                    <select id="viewByProfileSearch">
                                        @*         <option selected value="3">Individual</option> *@
                                        <option value="1">Travel Agent</option>
                                        <option value="2">Company</option>
                                        <option value="3">Source</option>
                                        <option value="0">Individual</option>
                                        <option value="4">Group</option>
                                        <option value="5">Contact</option>
                                        <option value="" selected>View by All</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- City -->
                        <div class="col-12 col-sm-6 col-md-4 col-lg-3 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    City
                                </label>
                                <div class="col-12 col-md-8">
                                    <select id="cityProfileSearch" asp-items="ViewBag.cboCity">
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Key word -->
                        <div class="col-12 col-sm-6 col-md-4 col-lg-3 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Key word
                                </label>
                                <div class="col-12 col-md-8">
                                    <input class="form-control" id="keywordProfileSearch">
                                </div>
                            </div>
                        </div>

                        <!-- Code -->
                        <div class="col-12 col-sm-6 col-md-4 col-lg-3 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Code
                                </label>
                                <div class="col-12 col-md-8">
                                    <input class="form-control" id="codeProfileSearch">
                                </div>
                            </div>
                        </div>

                        <!-- Property -->
                        <div class="col-12 col-sm-6 col-md-4 col-lg-3 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Property
                                </label>
                                <div class="col-12 col-md-8">
                                    <select id="propertyProfileSearch" disabled>
                                        <option selected>PMSh TheArena</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Sale in charge -->
                        <div class="col-12 col-sm-6 col-md-4 col-lg-3 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-5 col-form-label text-md-end">
                                    Sale in charge
                                </label>
                                <div class="col-12 col-md-6 d-flex align-items-center">
                                    <input type="checkbox">
                                </div>
                            </div>
                        </div>

                    </div>

                </div>


                <div class="mui-card">
                    <div id="gridContainerSearchProfile" class="mt-2 gridContainer"></div>
                </div>
            </div>

        </div>
    </div>
</div>
<script>
    /* =========================
     *  MODAL
     * ========================= */
    function openModalSearchProfile(type) {
        openProfileModal('normal', type);
    }

    function openModalSearchProfileInAllotment() {
        openProfileModal('allotment');
    }

    function openProfileModal(mode, type) {
        $('#viewByProfileSearch').val(type);
        initProfileGrid(mode);
        $('#modalProfile').modal('show');
    }

    function closeModalSearchProfle() {
        clearSearch();
        $('#modalProfile').modal('hide');
    }

    function clearSearch() {
        $('#nameProfileSearch, #firstNameProfileSearch, #keywordProfileSearch, #codeProfileSearch').val('');
        $('#cityProfileSearch').val(0);
        $('#sale').prop('checked', false);
    }

    /* =========================
     *  GRID
     * ========================= */
    function initProfileGrid(mode) {
        $("#gridContainerSearchProfile").dxDataGrid({
            dataSource: {
                load: function (loadOptions) {
                    return loadProfileData(loadOptions);
                }
            },
            height: 500,
            remoteOperations: { paging: true, filtering: true },
            columns: getProfileColumns(),
            paging: { pageSize: 15 },
            pager: {
                visible: true,
                allowedPageSizes: [15, 20, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            filterRow: { visible: true, applyFilter: "auto" },
            selection: { mode: "single" },
            onRowDblClick: function (e) {
                handleProfileSelect(e.data.id, mode);
            }
        });
    }

    function loadProfileData(loadOptions) {
        var d = $.Deferred();

        $.ajax({
            url: '/Profile/GetAllProfiles2',
            type: 'GET',
            dataType: 'json',
            data: buildSearchParams(loadOptions),
            headers: {
                "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val()
            },
            success: function (res) {
                d.resolve(res.data, { totalCount: res.totalCount });
            },
            error: function (xhr) {
                xhr.status === 401 ? sessionTimeout() :
                    informBox(TOAST_STATUS.DANGER, "Lỗi tải danh sách Profile");
                d.reject();
            }
        });

        return d.promise();
    }

    function buildSearchParams(loadOptions) {
        return {
            code: $('#codeProfileSearch').val(),
            account: $('#nameProfileSearch').val(),
            firstName: $('#firstNameProfileSearch').val(),
            keyWord: $('#keywordProfileSearch').val(),
            city: $('#cityProfileSearch').val(),
            type: $('#viewByProfileSearch').val(),
            showSaleInCharge: $('#sale').is(':checked'),
            page: loadOptions.skip / loadOptions.take + 1,
            pageSize: loadOptions.take
        };
    }

    function getProfileColumns() {
        return [
            { dataField: "id", visible: false },
            { dataField: "code", caption: "Code", width: 100 },
            { dataField: "account", caption: "Account", width: 300 },
            { dataField: "taxCode", caption: "Tax Code", width: 150 },
            { dataField: "city", caption: "City", width: 150 },
            { dataField: "nationality", caption: "Nat", width: 150 },
            { dataField: "address", caption: "Address", width: 150 },
            { dataField: "homeAddress", caption: "Business Address", width: 150 },
            { dataField: "company", caption: "Company", width: 150 },
            { dataField: "handPhone", caption: "HandPhone", width: 150 },
            { dataField: "telephone", caption: "Telephone", width: 150 },
            { dataField: "email", caption: "Email", width: 150 },
            { dataField: "website", caption: "Website", width: 150 },
            { dataField: "aRNo", caption: "ARNo", width: 150 },
            { dataField: "postalCode", caption: "Postal Code", width: 150 },
            { dataField: "keyword", caption: "Keyword", width: 150 },
            { dataField: "description", caption: "Description", width: 150 },
            { dataField: "personInChargeID", caption: "Sale In Charge", width: 150 }
        ];
    }

    /* =========================
     *  SELECT PROFILE
     * ========================= */
    function handleProfileSelect(profileId, mode) {
        if (mode === 'allotment') {
            getInfoByProfileIDInAllotment(profileId);
        } else {
            getInfoByProfileID(profileId);
        }
        $('#modalProfile').modal('hide');
        $('#txtItemInventory').prop('disabled', false);
    }

    /* =========================
     *  GET PROFILE INFO
     * ========================= */
    function getInfoByProfileID(id) {
        $.getJSON('/Reservation/GetInfoProfile', { profileID: id }, function (r) {
            $('#txtID').val(r.id);
            $('#nameProfileSearch, #txtName').val(r.account);
            $('#firstNameProfileSearch, #txtFirstName').val(r.firstname);
            $('#txtPhone').val(r.handPhone);
            $('#txtEmail').val(r.email);
            $("#txtTitle").val(r.titleID);
            $('#txtPassport').val(r.passPort || r.passport || '');
            $('#txtIdentityCard').val(r.identityCard || r.identityCard || '');
            $('#txtAddress').val(r.address);
            $('#txtCity').val(r.city);
            $('#txtDob').val(r.dateOfBirth?.split('T')[0]);
            $('#txtNationality').val(r.nationalityID);
            $('#txtVIP').val(r.vipID);
            $('#txtMemberType').val(r.memberType);
            $('#txtPrefRoom').val(r.prefRoom);
            let lastStay = '';

            if (r.lastRoom || r.lastvisit) {
                let formattedDate = '';

                if (r.lastvisit) {
                    const d = r.lastvisit.split('T')[0]; // 2025-06-25
                    const parts = d.split('-');          // [2025, 06, 25]
                    if (parts.length === 3) {
                        formattedDate = `${parts[2]}-${parts[1]}-${parts[0].slice(-2)}`; // 25-06-25
                    }
                }

                lastStay = `R.${r.lastRoom || ''}${formattedDate ? ' - ' + formattedDate : ''}`;
            }

            $('#txtLastStay').val(lastStay);
        });
    }

    function getInfoByProfileIDInAllotment(id) {
        $.getJSON('/Reservation/GetInfoProfile', { profileID: id }, function (r) {
            $('#profileAllotmentSearch').val(r.account);
            $('#IDprofileAllotmentSearch').val(r.id);
        });
    }
</script>
