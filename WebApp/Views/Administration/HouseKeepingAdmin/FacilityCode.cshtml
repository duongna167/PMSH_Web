@{
    var facCategory = ViewBag.FacilityCategory;
}


<!-- =========================
     MAIN MODAL (modal-xl)
     ========================= -->
<div class="modal fade" id="faCo_modalMain" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Facility Code</h5>
            </div>

            <div class="modal-body">

                <!-- ERP Search Filter -->
                <div class="search-filter">
                    <!-- Toolbar -->
                    <div>
                        <button id="faCo_btnView" type="button" class="mui-button mui-button-search">View</button>
                        <button id="faCo_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="faCo_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="faCo_btnDelete" type="button" class="mui-button mui-button-delete">Delete</button>
                        <button id="faCo_btnExportExcel" type="button" class="mui-button mui-button-export">Excel</button>
                        <button id="faCo_btnClose" type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                    </div>

                    <div class="row g-2 mt-1">

                        <div class="col-12 col-lg-4">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end"
                                       for="faCo_codeInput">Code</label>
                                <div class="col-md-8">
                                    <input type="text"
                                           id="faCo_codeInput"
                                           name="faCo_codeInput"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-4">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end"
                                       for="faCo_nameInput">Description</label>
                                <div class="col-md-8">
                                    <input type="text"
                                           id="faCo_nameInput"
                                           name="faCo_nameInput"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-4">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-5 col-form-label col-form-label-sm text-md-end" for="faCo_chkshowInactive">Show Inactive</label>
                                <div class="col-md-7">
                                    <div class="form-check d-flex align-items-center gap-2">
                                        <input 
                                            type="checkbox"
                                            id="faCo_chkshowInactive"
                                            name="faCo_chkshowInactive">
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Grid -->
                <div class="mui-card">
                    <div id="faCo_gridContainer" class="gridContainer"></div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- =========================
     EDIT / NEW MODAL (modal-xl)
     ========================= -->
<div class="modal fade" id="faCo_modalEdit" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="faCo_itemModalLabel">Facility Code</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">
                    <button type="button" id="faCo_btnSaveItem" class="mui-button mui-button-save">Save</button>
                    <button type="button" data-bs-dismiss="modal" class="mui-button mui-button-close">Close</button>
                </div>

                <form id="faCo_formContainer" novalidate>
                    <div class="p-2">

                        <div class="row g-2">

                            <div class="col-12 col-lg-8">
                                <div class="row g-2 align-items-center">
                                    <label for="faCo_code" class="col-md-3 col-lg-4 me-3 col-form-label col-form-label-sm text-md-end">Code</label>
                                    <div class="col-md-9 col-lg-7">
                                        <input type="text"
                                               id="faCo_code"
                                               name="code"
                                               class="form-control form-control-sm" />
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-lg-4">
                                <div class="row g-2 align-items-center">
                                    <div class="col-md-12 d-flex align-items-center">
                                        <input type="checkbox"
                                               id="faCo_inactive"
                                               name="faCo_inactive"
                                               class="me-2" />
                                        <label for="faCo_inactive" class="form-check-label text-danger">Inactive</label>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="row g-2 mt-1">
                            <div class="col-12">
                                <div class="row g-2 align-items-center">
                                    <label class="col-md-3 col-lg-3 col-form-label col-form-label-sm text-md-end"
                                           for="faCo_facilityCategoryID">Facility Category</label>
                                    <div class="col-lg-9">
                                        <select id="faCo_facilityCategoryID"
                                                name="facilityCategoryID"
                                                class="tomselect-custom">
                                            <option value="">--Select Facility Category--</option>
                                            @foreach (var sg in facCategory)
                                            {
                                                <option value="@sg.ID">@sg.Name</option>
                                            }
                                        </select>
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-2 mt-1">
                            <div class="col-12 col-lg-6">
                                <div class="row g-2 align-items-center">
                                    <label for="faCo_sequence" class="col-lg-6 col-form-label col-form-label-sm text-md-end">Sequence</label>
                                    <div class="col-lg-6">
                                        <input type="number"
                                               id="faCo_sequence"
                                               name="faCo_sequence"
                                               class="form-control form-control-sm text-end"
                                               placeholder="0" />
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-2 mt-1">
                            <div class="col-12">
                                <div class="row g-2 align-items-start">
                                    <label for="faCo_description" class="col-md-3 col-form-label col-form-label-sm text-md-end">Description</label>
                                    <div class="col-md-9">
                                        <textarea id="faCo_description"
                                                  name="faCo_description"
                                                  class="form-control form-control-sm"
                                                  rows="4"
                                                  style="height: 100px;"></textarea>
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <input type="hidden" id="faCo_id" name="faCo_id" value="0" />
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

<div id="faCo_loadingSpinner"
    style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
    z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
    height: 100%;display: flex;align-items: center;justify-content: center;">
    <div class="spinner-border text-primary"></div>
</div>

<script>
    var faCo_Module = (function () {
        "use strict";

        const SEL = {
            modalMain: "#faCo_modalMain",
            modalEdit: "#faCo_modalEdit",
            spinner: "#faCo_loadingSpinner",

            btnView: "#faCo_btnView",
            btnNew: "#faCo_btnNew",
            btnEdit: "#faCo_btnEdit",
            btnDelete: "#faCo_btnDelete",
            btnExportExcel: "#faCo_btnExportExcel",

            codeInput: "#faCo_codeInput",
            nameInput: "#faCo_nameInput",
            chkshowInactive: "#faCo_chkshowInactive",

            grid: "#faCo_gridContainer",

            form: "#faCo_formContainer",
            modalLabel: "#faCo_itemModalLabel",
            btnSaveItem: "#faCo_btnSaveItem",

            id: "#faCo_id",
            code: "#faCo_code",
            facilityCategoryID: "#faCo_facilityCategoryID",
            sequence: "#faCo_sequence",
            description: "#faCo_description",
            inactive: "#faCo_inactive"
        };

        let _gridInstance = null;
        let _selectedRowData = null;
        let _bound = false;

        function showLoading(show) {
            if (show) $(SEL.spinner).show();
            else $(SEL.spinner).hide();
        }

        function csrfHeaders() {
            return {
                "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
            };
        }

        function resetValidation() {
            if (typeof applyValidationErrors === "function") {
                applyValidationErrors([], SEL.form);
            }
            $(`${SEL.form} .form-control, ${SEL.form} .form-select`).removeClass("is-invalid");
            $(`${SEL.form} .invalid-feedback`).text("");
        }

        function clearForm() {
            $(SEL.form)[0].reset();
            resetValidation();
            $(SEL.id).val("0");
            clearTomSelect(SEL.facilityCategoryID)
        }

        function disposeGrid() {
            try {
                const inst = $(SEL.grid).dxDataGrid("instance");
                if (inst) inst.dispose();
            } catch (e) { }

            _gridInstance = null;
            _selectedRowData = null;
            $(SEL.grid).empty();
        }

        function fillForm(data) {
            $(SEL.id).val(data.id || 0);
            $(SEL.code).val(data.code || "");
            $(SEL.description).val(data.description || "");
            $(SEL.inactive).prop("checked", !!data.inactive);

            $.get("/HouseKeepingAdmin/GetFacilityCodeById", { id: data.id }, function (res) {
                $(SEL.sequence).val(res.sequence ?? "");
                $(SEL.inactive).prop("checked", res.inactive === 1 || res.inactive === true);
                setTomSelectValue(SEL.facilityCategoryID,res.facilityCategoryID ?? "")
            });
        }

        function getSaveModel() {
            const id = parseInt($(SEL.id).val(), 10) || 0;
            const loginName = (localStorage.getItem("Loginname") || "").trim().replace(/^"(.*)"$/, "$1");

            return {
                ID: id,
                Code: $(SEL.code).val(),
                Sequence: parseInt($(SEL.sequence).val(), 10) || 0,
                Description: $(SEL.description).val(),
                Inactive: $(SEL.inactive).prop("checked"),
                FacilityCategoryID: parseInt($(SEL.facilityCategoryID).val(), 10) || 0,
                CreatedBy: loginName,
                UpdatedBy: loginName
            };
        }

        function initGrid(data) {
            disposeGrid();

            _gridInstance = $(SEL.grid).dxDataGrid({
                dataSource: data || [],
                width: "100%",
                showBorders: true,
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                hoverStateEnabled: true,

                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "code", caption: "Code", width: "100px" },
                    { dataField: "description", caption: "Description", minWidth: 120, cssClass: "col-description"},
                    {
                        dataField: "inactive",
                        caption: "Inactive",
                        width: "60px",
                        cellTemplate: function (container, options) {
                            $("<div>")
                                .dxCheckBox({
                                    value: !!options.value,
                                    readOnly: true
                                })
                                .css("transform", "scale(0.8)")
                                .appendTo(container);
                        }
                    },
                    { dataField: "createdBy", caption: "Created By", width: "80px" },
                    {
                        dataField: "createdDate",
                        caption: "Crea.Date",
                        dataType: "date",
                        format: "dd/MM/yyyy",
                        width: "80"
                    },
                    { dataField: "updatedBy", caption: "Updated By", width: "80px" },
                    {
                        dataField: "updatedDate",
                        caption: "Upd.Date",
                        dataType: "date",
                        format: "dd/MM/yyyy",
                        width: "80"
                    }
                ],

                filterRow: { visible: true, applyFilter: "auto" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: {
                    mode: "standard",
                    showScrollbar: "always"
                },

                onSelectionChanged: function (e) {
                    _selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
                }
            }).dxDataGrid("instance");
        }

        function loadGridData() {
            showLoading(true);

            $.ajax({
                url: "/HouseKeepingAdmin/FacilityCodeData",
                type: "GET",
                cache: false,
                data: {
                    code: $(SEL.codeInput).val(),
                    description: $(SEL.nameInput).val(),
                    inactive: $(SEL.chkshowInactive).prop("checked") ? 1 : 0
                },
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (data) {
                    initGrid(data);
                    showLoading(false);
                },
                error: function () {
                    showLoading(false);
                    showToast("Error", "Unable to load data", false);
                }
            });
        }

        function openNew() {
            clearForm();
            $(SEL.modalLabel).text("Add Facility Code");
            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).show();
        }

        function openEdit() {
            if (!_selectedRowData) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }

            clearForm();
            fillForm(_selectedRowData);
            $(SEL.modalLabel).text("Update Facility Code");
            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).show();
        }

        function save() {
            const model = getSaveModel();

            $.ajax({
                url: "/HouseKeepingAdmin/FacilityCodeSave",
                type: "POST",
                contentType: "application/json",
                cache: false,
                data: JSON.stringify(model),
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (res) {
                    if (res.success) {
                        showToast("Success", res.message, true);
                        bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).hide();
                        loadGridData();
                    } else {
                        if (res.errors && res.errors.length > 0) {
                            applyValidationErrors(res.errors, SEL.form);
                            const genErr = res.errors.find(x => x.field === "general");
                            if (genErr) showToast("Warning", genErr.message, false);
                        } else {
                            showToast("Error", res.message || "Save failed", false);
                        }
                    }
                },
                error: function () {
                    showToast("Error", "Request error!", false);
                    bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).hide();
                }
            });
        }

        function removeSelected() {
            if (!_selectedRowData || _selectedRowData.id === 0) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }

            if (!confirm("Are you sure you want to delete this record? This action cannot be undone.")) {
                return;
            }

            $.ajax({
                url: "/HouseKeepingAdmin/FacilityCodeDelete/" + _selectedRowData.id,
                type: "POST",
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (result) {
                    if (result.success) {
                        loadGridData();
                        showToast("Success", "Delete Successfully!", true);
                    } else {
                        showToast("Error", result.message, false);
                    }
                },
                error: function () {
                    showToast("Error", "Delete failed!", false);
                }
            });
        }

        function exportExcel() {
            const grid = $(SEL.grid).dxDataGrid("instance");
            if (!grid) {
                showToast("Error", "No grid data to export.", false);
                return;
            }

            const workbook = new ExcelJS.Workbook();
            const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const worksheet = workbook.addWorksheet("Sheet 1");

            worksheet.addRow([companyName]);
            worksheet.mergeCells("A1:D1");
            worksheet.getRow(1).font = { bold: true };
            worksheet.getRow(1).alignment = { vertical: "middle", horizontal: "left" };

            const now = new Date();
            const exportDate = now.toLocaleString("vi-VN");
            worksheet.addRow(["", "", "", exportDate]);
            worksheet.mergeCells("D2:D2");
            worksheet.getRow(2).alignment = { vertical: "middle", horizontal: "right" };

            worksheet.addRow([]);
            worksheet.addRow([]);

            const reportRow = worksheet.addRow(["Facility Code"]);
            worksheet.mergeCells("A5:D5");
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { vertical: "middle", horizontal: "center" };

            worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const lastRow = worksheet.lastRow.number + 2;
                worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
                worksheet.getCell(`A${lastRow}`).alignment = { horizontal: "center" };
                worksheet.getCell(`A${lastRow}`).font = { italic: true };

                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "FacilityCode.xlsx");
                });
            });
        }

        function bindEventsOnce() {
            if (_bound) return;
            _bound = true;
            initTomSelect(".tomselect-custom");
            $(document)
                .off("click.faCo", SEL.btnView).on("click.faCo", SEL.btnView, loadGridData)
                .off("click.faCo", SEL.btnNew).on("click.faCo", SEL.btnNew, openNew)
                .off("click.faCo", SEL.btnEdit).on("click.faCo", SEL.btnEdit, openEdit)
                .off("click.faCo", SEL.btnDelete).on("click.faCo", SEL.btnDelete, removeSelected)
                .off("click.faCo", SEL.btnExportExcel).on("click.faCo", SEL.btnExportExcel, exportExcel)
                .off("click.faCo", SEL.btnSaveItem).on("click.faCo", SEL.btnSaveItem, save);

            $(document)
                .off("input.faCo change.faCo", `${SEL.form} input, ${SEL.form} select, ${SEL.form} textarea`)
                .on("input.faCo change.faCo", `${SEL.form} input, ${SEL.form} select, ${SEL.form} textarea`, function () {
                    if ($(this).hasClass("is-invalid")) {
                        $(this).removeClass("is-invalid");
                        $(this).next(".invalid-feedback").text("");
                    }
                });

            $(SEL.modalEdit)
                .off("shown.bs.modal.faCo")
                .on("shown.bs.modal.faCo", function () {
                })
                .off("hidden.bs.modal.faCo")
                .on("hidden.bs.modal.faCo", function () {
                    clearForm();
                });

            $(SEL.modalMain)
                .off("hidden.bs.modal.faCo")
                .on("hidden.bs.modal.faCo", function () {
                    $(SEL.codeInput).val("");
                    $(SEL.nameInput).val("");
                    $(SEL.chkshowInactive).prop("checked", false);

                    disposeGrid();
                    showLoading(false);
                });
        }

        function init() {
            DevExpress.localization.locale("vi");
            bindEventsOnce();
        }

        function open() {
            init();

            const modalEl = document.querySelector(SEL.modalMain);
            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

            $(modalEl).one("shown.bs.modal", function () {
                loadGridData();
            });

            modal.show();
        }

        return { init, open };
    })();

    window.openModalFaCo = function () {
        faCo_Module.open();
    };
</script>