                a11: parseDec(sel.amt11), a11AfterTax: parseDec(sel.amt11Net),
                a12: parseDec(sel.amt12), a12AfterTax: parseDec(sel.amt12Net),
                a13: parseDec(sel.amt13), a13AfterTax: parseDec(sel.amt13Net),
