                        excelCell.font = { bold: true };
                        excelCell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFE0E0E0' } };
                    }

                    // 2. Định dạng hàng "Total Picked Up" màu vàng
                    if (gridCell.rowType === "data" && gridCell.data.RoomType === "Total Picked Up") {
                        excelCell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFFFFF00' } };
                        excelCell.font = { bold: true };
                    }
                }
            }).then(function () {
                // Thêm tiêu đề báo cáo ở dòng 1
                worksheet.mergeCells('A1:E1');
                const titleCell = worksheet.getCell('A1');
                titleCell.value = "ALLOTMENT DETAIL BY STAGE";
                titleCell.font = { bold: true, size: 14 };
                titleCell.alignment = { horizontal: 'left' };

                // Thêm thời gian xuất báo cáo ở dòng 2
                worksheet.mergeCells('A2:E2');
                worksheet.getCell('A2').value = "Export Date: " + timeStr;
                worksheet.getCell('A2').font = { italic: true };

                // Xuất file
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "Allotment_Detail_Stage.xlsx");
                });
            });
        },


