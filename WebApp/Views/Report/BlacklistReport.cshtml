<div class="text-center" id="reportTitle" style="font-size: 20px"></div>
<div class="sticky-header bg-white p-2 shadow-sm z-3">
    <div class="d-flex flex-wrap align-items-center gap-2 mb-1"
        style="border: 1px solid #ced4da; border-radius: 6px; padding: 8px;">
        <!-- From Date -->
        <div class="d-flex align-items-center">
            <label class="me-2 mb-0">From Date:</label>
            <div data-date-input data-format="DD/MM/YYYY" business-date data-name="fromDate">
                <input type="text" class="date-ui form-control form-control-sm"
                       placeholder="dd/mm/yyyy" autocomplete="off" />
            </div>
        </div>

        <!-- To Date -->
        <div class="d-flex align-items-center">
            <label class="me-2 mb-0">To Date:</label>
            <div data-date-input data-format="DD/MM/YYYY" business-date data-name="toDate">
                <input type="text" class="date-ui form-control form-control-sm"
                       placeholder="dd/mm/yyyy" autocomplete="off" />
            </div>
        </div>
    </div>
    <div class="">
        <button id="btnPrint" class="mui-button mui-button-new">View</button>
        <button id="btnExportExcel" class="mui-button mui-button-new" type="button">  Excel</button>
        <button id="btnExportPdf" class="mui-button mui-button-new" type="button">
            PDF</button>
    </div>

</div>

<div class="mui-card">
    @*     <div style="font-size: 20px;" class="mt-1" id="reportTitle"></div> *@
    <div id="gridWrapper" class="mt-2" style="max-height: 500px;">
        <div class="gridContainer mt-2" id="gridContainer"></div>
    </div>
</div>
<div id="loadingSpinner"
    style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:1000;">
    <i class="fa-solid fa-spinner fa-spin"></i>
</div>
<script>
 
    $(document).ready(function () {
        document.getElementById("reportTitle").innerText = '@ViewBag.ReportTitle';
        getBusinessDate();
 



    });
      function getBusinessDate() {
        return $.ajax({
            url: '/Reservation/GetBusinessDate',
            type: 'get',
            dataType: 'json',
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
               const fromDateStr = result.split('T')[0];
                    const fromDate = new Date(fromDateStr);

                    // cộng thêm 13 ngày
                    const toDate = new Date(fromDate);
                    toDate.setDate(toDate.getDate() + 30);

                    // format yyyy-MM-dd
                    const toDateStr = toDate.toISOString().split('T')[0];
                    UI.setHiddenDate("fromDate", fromDateStr);
                    UI.setHiddenDate("toDate", toDateStr);
            },
            error: function (xhr, statusText, err) {
                if (xhr.status == 401) {
                    sessionTimeout();
                }
            }
        });
    }
    $(document).off("click", "#btnPrint").on("click", "#btnPrint", function () {
        $("#loadingSpinner").show();
        $.ajax({
            url: '/Report/BlacklistReporteData',
            type: 'GET',
            data: {
                fromDate: $("#fromDate").val(),
                toDate: $("#toDate").val(),
            },
            traditional: true,
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                // $("#reportViewerContainer").html(result);
                // $("#loadingSpinner").hide();
                console.log(result);
                initializeBlacklistReportGrid(result);
                $("#loadingSpinner").hide();
            },
            error: function () {
                alert("Không thể tải báo cáo.");
                $("#loadingSpinner").hide();
            }
        });
    });

    function initializeBlacklistReportGrid(data) {
        const columnWidth = 180;
        $("#gridContainer").dxDataGrid({
            dataSource: data, height: 500, allowColumnResizing: true,
            columns: [
                {
                    caption: "No.",
                    width: 60,
                    cellTemplate: function (container, options) {
                        container.text(options.rowIndex + 1);
                    }
                },
                { dataField: "account", caption: "Guest Name", width: columnWidth },
                { dataField: "specialUpdateDate", caption: "Date", width: columnWidth - 60, dataType: "date", format: "dd/MM/yyyy" },
                { dataField: "specialUpdateBy", caption: "By user", width: columnWidth - 60 },
                { dataField: "nat", caption: "Nat", width: columnWidth - 60 },
                { dataField: "blackListReason", caption: "BL.Reason", width: columnWidth - 40 },
                { dataField: "passport", caption: "Id/Passport no", width: columnWidth - 60 },

                { dataField: "dateOfBirth", caption: "Nat", width: columnWidth - 60, dataType: "date", format: "dd/MM/yyyy" },
                { dataField: "confirmationNo", caption: "Conf.No", width: columnWidth - 60 },
                { dataField: "roomNo", caption: "Room No", width: columnWidth - 80 },

                { dataField: "arrivalDate", caption: "Arr.Date", width: columnWidth - 60, dataType: "date", format: "dd/MM/yyyy" },
                { dataField: "departureDate", caption: "Dep.Date", width: columnWidth - 60, dataType: "date", format: "dd/MM/yyyy" },
                { dataField: "reservationHolder", caption: "Res.Holder", width: columnWidth },
            ],
            paging: { pageSize: 25 },
            scrolling: {

                useNative: true,
                showScrollbar: "always"
            },
            pager: {
                visible: true,
                allowedPageSizes: [25, 50, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true,
            },
            filterRow: {
                visible: true,
                applyFilter: "auto"
            },
            headerFilter: {
                visible: true
            },
            selection: { mode: "multiple", showCheckBoxesMode: "none" },
            showBorders: true,
            summary: {
                totalItems: [
                    {
                        column: "account", // hoặc bất kỳ cột nào có dữ liệu
                        summaryType: "count",
                        displayFormat: "Blacklist Guest: {0}"
                    }
                ]
            }

        });
    }



    $("#btnExportExcel").click(function () {
        const grid = $("#gridContainer").dxDataGrid("instance"); var selectedReport2 = '@ViewBag.ReportTitle';
        var selectedReport = '@ViewBag.ReportTitle';
        if (!selectedReport) {
            alert("Vui lòng chọn báo cáo trước khi xuất Excel.");
            return;
        }

        const workbook = new ExcelJS.Workbook(); const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
        const worksheet = workbook.addWorksheet("Sheet 1");

        // === Tạo header công ty (dòng 1) ===
        worksheet.addRow([companyName]);
        worksheet.mergeCells('A1:E1');
        worksheet.getRow(1).font = { bold: true };
        worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

        // === Dòng 2: Thời gian xuất (phải) ===
        const now = new Date();
        const exportDate = now.toLocaleString("vi-VN");
        worksheet.addRow(['', '', '', '', ' ' + exportDate]);
        worksheet.mergeCells('E2:H2');
        worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

        // === Dòng 3–4: Trống
        worksheet.addRow([]);
        worksheet.addRow([]);

        // === Dòng 5: Tên báo cáo ở giữa ===
        const reportRow = worksheet.addRow(['', '', selectedReport]);
        worksheet.mergeCells('C5:F5');
        reportRow.font = { bold: true, size: 14 };
        reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

        // === Dòng 6: Trống trước khi xuất dữ liệu
        worksheet.addRow([]);

        // === Export dữ liệu từ DevExtreme (bắt đầu từ dòng 7)
        DevExpress.excelExporter.exportDataGrid({
            component: grid,
            worksheet: worksheet,
            autoFilterEnabled: true,
            topLeftCell: { row: 7, column: 1 } // dữ liệu bắt đầu từ dòng 7
        }).then(function () {
            // Footer
            const lastRow = worksheet.lastRow.number + 2;
            worksheet.mergeCells(`A${lastRow}:F${lastRow}`);
            worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
            worksheet.getCell(`A${lastRow}`).font = { italic: true };

            // Ghi file
            let fileName = selectedReport + ".xlsx";
            workbook.xlsx.writeBuffer().then(function (buffer) {
                saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
            });
        });
    });


    // Nút xuất PDF
    $("#btnExportPdf").click(function () {
        const grid = $("#gridContainer").dxDataGrid("instance");

        // Lấy đối tượng jsPDF từ window
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF({ orientation: "landscape", unit: "pt", format: "A4" });

        const selectedReport = '@ViewBag.ReportTitle';
        const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";

        grid.getDataSource().load().then(data => {
            const columns = grid.getVisibleColumns();

            const head = [columns.map(col => col.caption)];
            const body = data.map(row =>
                columns.map(col =>
                    col.calculateCellValue ? col.calculateCellValue(row) : row[col.dataField]
                )
            );

            doc.setFontSize(14);
            doc.setFont("Helvetica", "bold");
            doc.text(companyName, doc.internal.pageSize.getWidth() / 2, 40, { align: "center" });

            doc.setFontSize(12);
            doc.setFont("Helvetica", "normal");
            doc.text(selectedReport, doc.internal.pageSize.getWidth() / 2, 60, { align: "center" });

            // AutoTable
            doc.autoTable({
                startY: 80,
                head: head,
                body: body,
                styles: { fontSize: 9, cellPadding: 4, lineWidth: 0.5, lineColor: [0, 0, 0] },
                headStyles: { fillColor: [41, 128, 185], textColor: 255, fontStyle: 'bold' },
                alternateRowStyles: { fillColor: [240, 240, 240] },
                margin: { left: 20, right: 20 }
            });

            doc.save(selectedReport + ".pdf");
        });
    });
</script>
