<div class="modal fade modal-xl" id="modalCheckOutAll" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="staticBackdropLabel">Check Out </h5>
                <button type="button" class="btn-close" onclick="closeModalCheckOutAll()"></button>
            </div>
            <div class="modal-body">
                <div style="display:flex;column-gap:12px">
                    <button class="mui-button mui-button-save" onclick="processCheckOutAll()">Process</button>

                    <button class="mui-button mui-button-close" onclick="closeModalCheckOutAll()">Close</button>

                </div>
                <div id="gridContainerCheckOutAll" class="gridContainer mt-2"></div>

            </div>
        </div>
    </div>
</div>
<script>
    /** spReservationSearch thường trả tên cột có khoảng: "Room No", "Reservation Status", "Guest Name"... */
    function checkoutPickField(item, keys) {
        if (!item) return undefined;
        for (var i = 0; i < keys.length; i++) {
            var k = keys[i];
            if (Object.prototype.hasOwnProperty.call(item, k) && item[k] !== undefined && item[k] !== null) {
                return item[k];
            }
        }
        return undefined;
    }

    /** Mã trạng thái reservation (Due Out = 6). Ưu tiên chữ "DUE OUT" trên cột Status (tránh mã số 1 nhưng UI đã Due Out). */
    function checkoutAllRowStatusCode(item) {
        if (!item) return NaN;
        var label = String(checkoutPickField(item, ['Status', 'status']) || '').trim().toUpperCase();
        var roomSt = String(checkoutPickField(item, ['RoomStatus', 'roomStatus', 'Room Status']) || '').trim().toUpperCase();
        if (label.indexOf('DUE OUT') >= 0 || roomSt.indexOf('DUE OUT') >= 0) return 6;

        var raw = checkoutPickField(item, ['ReservationStatus', 'reservationStatus', 'Reservation Status']);
        if (raw !== undefined && String(raw).trim() !== '') {
            var n = parseInt(String(raw).trim(), 10);
            if (!isNaN(n)) return n;
        }
        return NaN;
    }

    function checkoutAllRowBalance(item, field) {
        var alt = field === 'BalanceVND' ? 'balanceVND' : 'balanceUSD';
        var v = checkoutPickField(item, [field, alt]);
        if (v === undefined || v === null || String(v).trim() === '') {
            return 1; // unknown balance — treat as non-zero to block C/O Zero
        }
        if (typeof parseBillingAmount === 'function') {
            var p = parseBillingAmount(v);
            return p === null ? 1 : p;
        }
        var n = Number(v);
        return isNaN(n) ? 1 : n;
    }

    /** Nguồn dòng search reservation: ưu tiên bản full (listData), sau đó dataSource gốc của grid (không phụ thuộc filter DevExtreme). */
    function getSearchReservationRowsForCheckout() {
        var fromWindow = typeof window.listData !== 'undefined' && Array.isArray(window.listData) ? window.listData : null;
        var fromLocal = typeof listData !== 'undefined' && Array.isArray(listData) ? listData : null;
        if (fromWindow && fromWindow.length > 0) return fromWindow;
        if (fromLocal && fromLocal.length > 0) return fromLocal;

        var grid = null;
        try {
            grid = $('#gridContainer').dxDataGrid('instance');
        } catch (e) {
            grid = null;
        }
        if (!grid) return [];

        var raw = grid.option('dataSource');
        if (Array.isArray(raw) && raw.length > 0) return raw;

        try {
            var ds = grid.getDataSource();
            if (ds && typeof ds.items === 'function') {
                var items = ds.items();
                if (Array.isArray(items) && items.length > 0) return items;
            }
        } catch (e2) { }

        return [];
    }

    function finishOpenModalCheckOutAll(type, allData) {
        var filteredData = (allData || []).filter(function(item) {
            return checkoutAllRowStatusCode(item) === 6;
        });

        if (Number(type) === 2) {
            filteredData = filteredData.filter(function(item) {
                return checkoutAllRowBalance(item, 'BalanceVND') === 0 && checkoutAllRowBalance(item, 'BalanceUSD') === 0;
            });
        }

        filteredData = filteredData.map(function(item) {
            var sid = checkoutPickField(item, ['ID', 'id', 'Id']);
            var st = checkoutPickField(item, ['ReservationStatus', 'reservationStatus', 'Reservation Status']);
            var room = checkoutPickField(item, ['RoomNo', 'roomNo', 'Room No', 'Room No.']);
            var name = checkoutPickField(item, ['GuestName', 'guestName', 'Guest Name']);
            var mg = checkoutPickField(item, ['MG', 'mg']);
            return {
                roomNo: room != null ? String(room) : '',
                mg: mg != null ? String(mg) : '',
                id: sid != null ? String(sid) : '',
                name: name != null ? String(name) : '',
                reservationStatus: st != null ? String(st) : '',
                coStatus: '',
                message: ''
            };
        });

        if (filteredData.length === 0) {
            showToast('Warning', 'No DUE OUT bookings for the current filters and date range. Widen dates or clear room/name filters.', false);
        }

        initializeDataGridCheckOutAll(filteredData);
        $('#modalCheckOutAll').modal('show');
    }

    async function openModalCheckOutAll(type) {
        if (Number(reservationStatus) === 2) {
            showToast('Warning', 'This booking has already been checked out.', false);
            return;
        }

        var allData = [];

        // Search Reservation: SP với General (0) không trả Due Out — luôn tải thêm bản Due Out (5) cùng filter để C/O All/Zero có dữ liệu.
        if (typeof window.buildSearchReservation2AjaxData === 'function') {
            try {
                if (window.businessDateReady) {
                    await window.businessDateReady;
                }
            } catch (e) { }

            var payload = window.buildSearchReservation2AjaxData({ searchType: 5 });
            if (payload) {
                allData = await new Promise(function (resolve) {
                    $.ajax({
                        url: '/Reservation/SearchReservation2',
                        type: 'get',
                        dataType: 'json',
                        data: payload,
                        crossDomain: false,
                        headers: { 'X-CSRF-TOKEN-HEADERNAME': jQuery("input[name='__RequestVerificationToken']").val() },
                        success: function (result) {
                            var norm = typeof window.normalizeSearchReservationRows === 'function'
                                ? window.normalizeSearchReservationRows(result)
                                : (Array.isArray(result) ? result : (result && result.data) || []);
                            resolve(norm || []);
                        },
                        error: function () {
                            resolve([]);
                        }
                    });
                });
            }
        }

        if (!allData.length) {
            allData = getSearchReservationRowsForCheckout();
        }

        finishOpenModalCheckOutAll(type, allData);
    }
    window.openModalCheckOutAll = openModalCheckOutAll;
    function processCheckOutAll(){
        var grid = $("#gridContainerCheckOutAll").dxDataGrid("instance");
        const userName = JSON.parse(localStorage.getItem("Loginname"));
        const userID = JSON.parse(localStorage.getItem("userID"));
        var dataSource = grid.getDataSource();
        var filteredData = dataSource.items();

        $.ajax({
            url: '/Reservation/CheckOutAll',
            type: 'POST',

            // headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            data: {
                listItem: filteredData,
                userID: userID,
                userName: userName
            },
            success: function (data) {
                if (data.code == 0) {
                    initializeDataGridCheckOutAll(data.data);
                    $('#searchType').val(1);
                    searchReservation();
                    showToast('Success', data.msg, true);
                } else if (data.code == 2) {
                    initializeDataGridCheckOutAll(data.data);
                    $('#searchType').val(1);
                    searchReservation();
                    showToast('Warning', data.msg, false);
                } else {
                    if (data.data) {
                        initializeDataGridCheckOutAll(data.data);
                    }
                    showToast('Error', data.msg, false);
                }

            },
            error: function (xhr, statusText, err) {

            }
        });
    }
    function closeModalCheckOutAll(){
        $('#modalCheckOutAll').modal('hide');

    }
    function initializeDataGridCheckOutAll(data) {
        const limitedData = Array.isArray(data) ? data.slice(0, 100) : [];
        var $host = $('#gridContainerCheckOutAll');
        // Khởi tạo lặp lại trên cùng DOM: phải dispose instance cũ, nếu không grid giữ datasource rỗng / không vẽ.
        try {
            var prev = $host.dxDataGrid('instance');
            if (prev) prev.dispose();
        } catch (e) { }

        $host.dxDataGrid({
            dataSource: limitedData,
            allowColumnResizing: true,
            columnAutoWidth: true,
            columnMinWidth: 90,
            paging: {
                enabled: true, // Bật phân trang
                pageSize: 15 // Mỗi trang 15 bản ghi
            },
            pager: {
                visible: true,
                allowedPageSizes: [15, 20, 30], // Chỉ các kích thước trang cố định
                showPageSizeSelector: true,
                showInfo: true, // Hiển thị thông tin phân trang
                showNavigationButtons: true
            },
            scrolling: {
                mode: 'standard', // Thay 'virtual' bằng 'standard' để kiểm tra
                showScrollbar: 'always',
                useNative: false
            },
            filterRow: {
                visible: true,
                applyFilter: "auto"
            },
            selection: {
                mode: "single"
            },
            columns: [
                { dataField: "roomNo", caption: "Room No" },
                { dataField: "mg", caption: "MG" },
                { dataField: "id", visible: false }, // Ẩn cột ID
                { dataField: "name", caption: "Guest Name" },
                { dataField: "reservationStatus", visible: false }, // Ẩn cột ReservationStatus
                { dataField: "coStatus", caption: "CO Status" },
                { dataField: "message", caption: "Message" }
            ]
        });
    }
    /** Single C/O and C/O All / Zero: enabled only for DUE OUT (6); disabled when checked out (2) or other statuses (from grid / after successful C/O). */
    function updateSingleCheckoutButtonState(status) {
        const s = status === undefined || status === null ? NaN : Number(status);
        const canCheckout = s === 2 ;
        const apply = function (selector) {
            $(selector).each(function () {
                const $el = $(this);
                if (!canCheckout) {
                    $el.removeClass('checkout-disabled').removeAttr('aria-disabled')
                        .css({ opacity: '', pointerEvents: '', cursor: '' });

                } else {
                    $el.addClass('checkout-disabled').attr('aria-disabled', 'true')
                        .css({ opacity: '0.5', pointerEvents: 'none', cursor: 'not-allowed' });
                }

                    const $checkoutBtn = $('a').filter(function () {
                        return $(this).text().trim() === 'Check out';
                    });
                      
                    if (status == 1) {

                        $checkoutBtn.addClass('checkout-disabled')
                            .attr('aria-disabled', 'true')
                            .css({
                                opacity: '0.5',
                                pointerEvents: 'none',
                                cursor: 'not-allowed'
                            });
                    } else {
                       
                    }
            });
        };
        apply('.js-checkout-single');
        apply('.js-checkout-bulk');
    }
    window.updateSingleCheckoutButtonState = updateSingleCheckoutButtonState;

    function openModalCheckOut(){
        if(idReservation == 0){
            showToast('Warning', "Please choose booking", false);
            return;
        }
        if (Number(reservationStatus) === 2) {
            showToast('Warning', 'This booking has already been checked out.', false);
            return;
        }
        if(reservationStatus != 6){
            showToast('Warning', "Please choose booking has status DUE OUT", false);
            return;
        }
        const userName = JSON.parse(localStorage.getItem("Loginname"));
        const userID = JSON.parse(localStorage.getItem("userID"));
        $.ajax({
            url: '/Reservation/CheckOut',
            type: 'POST',

            // headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            data: {
                userID: userID,
                userName: userName,
                reservationID: idReservation
            },
            success: function (data) {
                if (data.code == 0) {
                    reservationStatus = 2;
                    statusID = 2;
                    if (typeof window.updateSingleCheckoutButtonState === 'function') {
                        window.updateSingleCheckoutButtonState(2);
                    }
                    // $('#searchType').val(1);
                    searchReservation();
                    showToast('Success', data.msg, true);
                } else {
                    showToast('Error', data.msg, false);
                }

            },
            error: function (xhr, statusText, err) {

            }
        });
    }
</script>
