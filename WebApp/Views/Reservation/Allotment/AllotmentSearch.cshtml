@{

}

<style>
    #allot_trans_cutoffDateInput:disabled,
    #allot_trans_cutoffDayInput:disabled {
        background-color: #f5f5f5;
        cursor: not-allowed;
    }

    .btn-modal-detail {
        width: 28px;
        height: 28px;
        border: 1px solid rgba(0,0,0,0.5);
        background: #ffffff;
        color: #222;
        font-size: 16px;
        font-weight: 600;
        line-height: 1;
        border-radius: 4px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.15s ease;
    }

        /* Hover */
        .btn-modal-detail:hover {
            background: #f0f0f0;
            border-color: rgba(0,0,0,0.7);
        }

        /* Active (khi nhấn) */
        .btn-modal-detail:active {
            background: #e0e0e0;
            transform: scale(0.95);
        }

        /* Focus */
        .btn-modal-detail:focus {
            outline: none;
            box-shadow: 0 0 0 2px rgba(0,0,0,0.1);
        }
    /* Cố định chiều cao hàng trên Desktop để có scroll riêng từng bảng */
    @@media (min-width: 768px) {
        .row-top-grids {
            height: 300px !important;
            flex-shrink: 0;
        }

        .row-bottom-resv {
            flex-grow: 1;
            min-height: 0;
        }
    }

    /* Responsive cho Mobile */
    @@media (max-width: 767px) {
        .modal-body {
            height: auto !important;
            overflow-y: auto !important;
        }

        .row-top-grids, .row-bottom-resv {
            height: auto !important;
            display: block !important;
        }

            .row-top-grids > div, .row-bottom-resv > div {
                height: 350px !important; /* Cố định chiều cao mỗi bảng trên mobile để Grid không bị mất scroll */
                margin-bottom: 25px;
            }

        .grid-wrapper {
            height: 100% !important;
        }
    }

    /* Đẩy lề phải cho cột Total để không bị giáp lề */
    .grid-column-total {
        padding-right: 15px !important;
        font-weight: bold;
        color: #000;
    }

    /* Đảm bảo toàn bộ các ô căn lề phải có khoảng cách an toàn */
    .dx-datagrid-rowsview .dx-row > td {
        padding-right: 8px !important;
    }

    .dx-loadpanel-content {
        background: transparent !important;
        box-shadow: none !important;
        border: none !important;
    }

    .dx-overlay-shader {
        background: rgba(255,255,255,0.55) !important;
    }

    .custom-loader-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Tiêu đề bảng */
    .table-header-custom {
        font-size: 14px;
        font-weight: bold;
        color: #000;
        border-bottom: 2px solid #009444;
        padding-bottom: 5px;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* Hàng chứa bảng Reservation bên dưới sẽ tự chiếm phần còn lại */
    .row-bottom-resv {
        flex-grow: 1;
        min-height: 0;
    }

    .grid-wrapper {
        display: flex;
        flex-direction: column;
        height: 100%;
        min-height: 0; /* Quan trọng để flexbox tính toán đúng */
        position: relative;
    }

    /* Đảm bảo bản thân component Grid chiếm trọn wrapper */
    #allot_search_gridAllotInfor,
    #allot_search_gridAllotDetail,
    #allot_search_gridReservation {
        flex-grow: 1;
        height: 100% !important;
        width: 100% !important;
    }

    /* Loại bỏ lề mặc định của container-fluid bên trong body modal nếu cần */
    .modal-body .container-fluid {
        display: flex;
        flex-direction: column;
    }
</style>

<div class="modal fade" id="allot_search_modal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-light py-2">
                <h5 class="modal-title">Allotment Search</h5>
            </div>

            <div class="modal-body d-flex flex-column" style="height: calc(100vh - 120px);">
                <div class="py-2">
                    <button id="allot_search_btnView" class="mui-button mui-button-view">View</button>
                    <button id="allot_search_btnNew" class="mui-button mui-button-new">New</button>
                    <button id="allot_search_btnEdit" class="mui-button mui-button-edit">Edit</button>
                    <button id="allot_search_btnDelete" class="mui-button mui-button-delete">Delete</button>

                    <div class="mui-dropdown" id="transferDropdown">
                        <button class="mui-button mui-button-advance dropdown-toggle">
                            Transfer
                        </button>

                        <div class="mui-dropdown-menu">
                            <button id="allot_search_btnFromAllotment" class="mui-button mui-button-advance dropdown-item">
                                From Allotment
                            </button>
                            <button id="allot_search_btnFromInventory" class="mui-button mui-button-advance dropdown-item">
                                From Inventory
                            </button>
                        </div>
                    </div>

                    <button id="allot_search_btnDetail" class="mui-button mui-button-new">Detail</button>
                    <button id="allot_search_btnTransHistory" class="mui-button mui-button-new">Trans.History</button>
                    <button id="allot_search_btnExportExcel" class="mui-button mui-button-export">Excel</button>
                    <button class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                </div>
                <div class="mui-card mb-2 bg-light border-0 d-flex flex-column flex-grow-1 overflow-hidden">

                    <div class="p-2 flex-shrink-0">
                        <div class="row g-3 align-items-center flex-wrap">

                            <div class="col-auto d-flex align-items-center">
                                <label class="fw-bold small me-2 mb-0">Code</label>
                                <input type="text" id="allot_search_code" class="form-control form-control-sm" style="width: 150px;" placeholder="Enter code...">
                            </div>

                            <div class="col-auto d-flex align-items-center">
                                <label class="fw-bold small me-2 mb-0">Market</label>
                                <div style="width: 120px;">
                                    <select id="allot_search_market" class="tomselect-custom w-100">
                                        @foreach (var z in ViewBag.MarketList)
                                        {
                                            <option value="@z.ID">@z.Code</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="col-auto d-flex align-items-center">
                                <label class="fw-bold small me-2 mb-0">All.Type</label>
                                <div style="width: 100px;">
                                    <select id="allot_search_type" class="tomselect-custom w-100">
                                        @foreach (var g in ViewBag.AllotTypeList)
                                        {
                                            <option value="@g.ID">@g.Code</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="col-auto d-flex align-items-center">
                                <label class="fw-bold small me-2 mb-0">Profile</label>
                                <div class="d-flex gap-1">
                                    <input id="allot_search_profileId" type="hidden" />
                                    <input id="allot_search_profileName" class="form-control form-control-sm" style="width: 130px;" placeholder="" />
                                    <button onclick="allot_search_Module.openProSearchModal()" class="" data-tooltip="Search Profile">
                                        <i class="fa-solid fa-arrow-down text-dark"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="col-auto d-flex align-items-center">
                                <label class="fw-bold small me-2 mb-0">Zone</label>
                                <div style="width: 120px;">
                                    <select id="allot_search_zone" class="tomselect-custom w-100" multiple>
                                        @foreach (var z in ViewBag.ZoneList)
                                        {
                                            <option value="@z.Code">@z.Code</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="col-auto d-flex align-items-center">
                                <input class="" type="checkbox" id="allot_search_default">
                                <label class="form-check-label small ms-1" for="allot_search_default" style="font-size: 11px;">Default</label>
                            </div>

                            <div class="col-auto d-flex align-items-center">
                                <input class="" type="checkbox" id="allot_search_history">
                                <label class="form-check-label small ms-1" for="allot_search_history" style="font-size: 11px;">Show history</label>
                            </div>
                        </div>

                    </div>

                    <div class="gridContainer flex-grow-1 d-flex flex-column position-relative py-2">
                        <div class="container-fluid px-0 h-100 d-flex flex-column">

                            <div class="row g-3 mb-3 row-top-grids">
                                <div class="col-md-6 d-flex flex-column h-100">
                                    <div class="table-header-custom flex-shrink-0">Allotment Information</div>
                                    <div class="grid-wrapper">
                                        <div id="allot_search_gridAllotInfor"></div> 
                                    </div>
                                </div>

                                <div class="col-md-6 d-flex flex-column h-100">
                                    <div class="table-header-custom flex-shrink-0">Allotment Detail</div>
                                    <div class="grid-wrapper">
                                        <div id="allot_search_gridAllotDetail"></div> 
                                    </div>
                                </div>
                            </div>

                            <div class="row row-bottom-resv">
                                <div class="col-12 d-flex flex-column h-100">
                                    <div class="table-header-custom flex-shrink-0">Reservation</div>
                                    <div class="grid-wrapper">
                                        <div id="allot_search_gridReservation"></div> 
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Popup for New Item -->
<div class="modal fade managed-modal" id="allot_setup_itemModal" tabindex="-1" data-bs-backdrop="static" aria-labelledby="allot_setup_label" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="allot_setup_label">Allotment Setup</h5>
            </div>

            <div class="modal-body">

                <!-- Action -->
                <div class="py-2">
                    <button id="allot_setup_btnSaveItem" class="mui-button mui-button-save">Save</button>
                    <button data-bs-dismiss="modal" class="mui-button mui-button-close">Close</button>

                </div>

                <form id="allot_setup_formContainer">
                    <div class="container-fluid px-2">

                        <input type="hidden" id="allot_setup_id" name="id" value="0" />

                        <div class="row g-2">

                            <div class="col-12 col-lg-9">

                                <!-- Code -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-semibold mb-1 mb-md-0 text-end">
                                        Code <span class="text-danger">*</span>
                                    </div>
                                    <div class="col-12 col-md-8 text-start">
                                        <input type="text"
                                               id="allot_setup_code"
                                               name="allot_setup_code"
                                               class="form-control form-control-sm" />
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>

                                <!-- Name -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-bold mb-1 mb-md-0 text-end">
                                        Name
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <input type="text"
                                               id="allot_setup_name"
                                               name="allot_setup_name"
                                               class="form-control form-control-sm" />
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>

                                <!-- Profile -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-semibold mb-1 mb-md-0 text-end">
                                        Profile <span class="text-danger">*</span>
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <div class="input-group input-group-sm">
                                            <input id="allot_setup_profileID" type="hidden" />
                                            <input id="allot_setup_profileName"
                                                   class="form-control"
                                                   placeholder="..."
                                                   readonly />
                                            <button class="btn btn-outline-secondary"
                                                    type="button"
                                                    onclick="allot_search_Module.openProAllotModal()"
                                                    data-tooltip="Search Profile">
                                                <i class="fa-solid fa-arrow-down text-dark"></i>
                                            </button>
                                        </div>
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>

                                <!-- Market -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-bold mb-1 mb-md-0 text-end">
                                        Market
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <select id="allot_setup_marketID"
                                                name="allot_setup_marketID"
                                                class="tomselect-custom w-100">
                                            @foreach (var u in ViewBag.MarketList)
                                            {
                                                <option value="@u.ID">@u.Code - @u.Name</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <!-- Allotment Type -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-semibold mb-1 mb-md-0 text-end">
                                        All.Type <span class="text-danger">*</span>
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <select id="allot_setup_type"
                                                name="allot_setup_type"
                                                class="tomselect-custom w-100">
                                            @foreach (var u in ViewBag.AllotTypeList)
                                            {
                                                <option value="@u.ID">@u.Code - @u.Name</option>
                                            }
                                        </select>
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>

                            </div>

                        </div>
                    </div>
                </form>

            </div>

        </div>
    </div>
</div>

<!-- Modal Detail by Stage -->
<div class="modal fade managed-modal" id="allot_detail_modal" tabindex="-1" data-bs-backdrop="static" aria-labelledby="allot_detail_label" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2 bg-light">
                <h5 class="modal-title" id="allot_detail_label" style="font-size: 14px;">Allotment Detail by Stage</h5>
            </div>

            <div class="modal-body d-flex flex-column" style="height: 500px;">
                <div class="py-2 d-flex align-items-center gap-2 border-bottom mb-2">
                    <button id="allot_detail_btnSearchDetail" class="mui-button mui-button-view">Search</button>
                    <button id="allot_detail_btnExport" class="mui-button mui-button-export">Export</button>
                    <button data-bs-dismiss="modal" class="mui-button mui-button-close">Close</button>
                </div>

                <div class="grid-wrapper gridContainer flex-grow-1">
                    <div id="allot_detail_gridAllotDetailByStage"></div>
                </div>

                <div class="py-2 d-flex align-items-center gap-3 border-top mt-2">
                    <div class="d-flex align-items-center gap-1">
                        <button class="btn-modal-detail" onclick="allot_search_Module.changeDetailDate(-1)">-</button>
                        <div data-date-input data-format="DD/MM/YYYY" data-name="allot_detail_searchDate">
                            <input type="text" class="date-ui form-control form-control-sm" style="width: 120px;">
                        </div>
                        <button class="btn-modal-detail" onclick="allot_search_Module.changeDetailDate(1)">+</button>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <label class="small fw-bold mb-0">Display No of Days</label>
                        <select id="allot_detail_noOfDays" class="form-select form-select-sm" style="width: 70px;">
                            <option value="10">10</option>
                            <option value="15">15</option>
                            <option value="20" selected>20</option>
                            <option value="30">30</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal transfer -->
<div class="modal fade managed-modal" id="allot_transfer_modal" tabindex="-1" data-bs-backdrop="static" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-1 bg-light">
                <h6 class="modal-title">Allotment Transfer</h6>
            </div>
            <div class="modal-body">
                <div class="py-2 mb-3">
                    <button type="button" id="allot_trans_btnOK" class="mui-button mui-button-save">OK</button>
                    <button type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                </div>

                <form id="allot_transfer_formContainer">
                    <div class="row g-3">
                        <div class="col-md-6 border-end">
                            <h6 class="small fw-bold">Allotment Information</h6>

                            <div class="mb-2 d-flex align-items-start gap-2">
                                <label class="small fw-bold flex-shrink-0 mt-1" style="width: 60px;">From</label>
                                <div class="flex-grow-1" style="min-width: 0;">
                                    <select id="allot_trans_fromID" class="tomselect-custom"></select>
                                    <div class="invalid-feedback"></div>
                                </div>
                                <div class="form-check flex-shrink-0 ms-1 mt-1">
                                    <input class="me-1" type="checkbox" id="allot_trans_chkInventory" disabled>
                                    <label class="form-check-label small" for="allot_trans_chkInventory">Inventory</label>
                                </div>
                            </div>

                            <div class="mb-2 d-flex align-items-center" style="padding-left: 68px;">
                                <label id="allot_trans_allotName" class="small text-muted text-truncate w-100"></label>
                            </div>

                            <div class="mb-2 d-flex align-items-start gap-2">
                                <label class="small fw-bold flex-shrink-0 mt-1" style="width: 60px;">To</label>
                                <div class="flex-grow-1" style="min-width: 0;">
                                    <select id="allot_trans_toID" class="tomselect-custom"></select>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>

                            <div class="mb-2 d-flex align-items-start gap-2">
                                <label class="small fw-bold flex-shrink-0 mt-1" style="width: 60px;">Stage</label>
                                <div class="flex-grow-1" style="min-width: 0;">
                                    <select id="allot_trans_stageID" class="tomselect-custom"></select>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>

                            <div class="mb-2 d-flex align-items-start gap-2">
                                <label class="small fw-bold flex-shrink-0 mt-1" style="width: 60px;">Cut off</label>
                                <div class="d-flex flex-column gap-2 flex-grow-1">
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="radio" name="cutoffType" id="allot_trans_cutoffDate" value="date">
                                        <label for="allot_trans_cutoffDate" class="small mb-0" style="width: 80px;">Cut off date</label>
                                        <div class="flex-grow-1">
                                            <div data-date-input data-format="DD/MM/YYYY" data-name="allot_trans_cutoffDateInput" style="width:130px;">
                                                <input type="text" class="date-ui form-control form-control-sm">
                                            </div>
                                            <div class="invalid-feedback"></div>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="radio" name="cutoffType" id="allot_trans_cutoffDay" value="day" checked>
                                        <label for="allot_trans_cutoffDay" class="small mb-0" style="width: 80px;">Cut off day</label>
                                        <div class="flex-grow-1">
                                            <input type="number" id="allot_trans_cutoffDayInput" class="form-control form-control-sm" style="width:80px;">
                                            <div class="invalid-feedback"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <h6 class="small fw-bold">Transfer</h6>

                            <div class="row g-2 mb-2 align-items-end">
                                <div class="col-5">
                                    <label class="small fw-bold">From Date</label>
                                    <div data-date-input data-format="DD/MM/YYYY" business-date data-name="allot_trans_fromDate">
                                        <input type="text" class="date-ui form-control form-control-sm">
                                    </div>
                                    <div class="invalid-feedback"></div>
                                </div>
                                <div class="col-2 px-1">
                                    <input type="number" id="allot_trans_count" class="form-control form-control-sm text-center" value="1" min="1" style="padding: 0.25rem 0.1rem;">
                                </div>
                                <div class="col-5">
                                    <label class="small fw-bold">To Date</label>
                                    <div data-date-input data-format="DD/MM/YYYY" data-name="allot_trans_toDate">
                                        <input type="text" class="date-ui form-control form-control-sm">
                                    </div>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>

                            <div class="mb-2">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="small fw-bold" style="width: 80px;">Room Type</label>
                                    <div class="flex-grow-1">
                                        <select id="allot_trans_roomTypeID" class="tomselect-custom w-100"></select>
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-2">
                                <div class="d-flex align-items-start gap-2">
                                    <label class="small fw-bold mt-1" style="width: 80px;">Quantity</label>

                                    <div class="d-flex flex-grow-1 gap-2">
                                        <div class="flex-grow-1">
                                            <input type="text" id="allot_trans_qty" class="form-control form-control-sm" value="1">
                                        </div>

                                    </div>
                                    <button type="button" id="allot_trans_btnInput" class="mui-button mui-button-export flex-shrink-0">Input</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>

                <div class="gridContainer mt-3 border-top pt-2 flex-grow-1" style="min-height: 200px;">
                    <div id="allot_trans_grid"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal transfer history-->
<div class="modal fade managed-modal" id="allot_transHis_modal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-light py-2">
                <h5 class="modal-title">Allotment Transfer History</h5>
            </div>

            <div class="modal-body d-flex flex-column" style="height: calc(100vh - 120px);">
                <div class="py-2">
                    <button id="allot_transHis_btnView" class="mui-button mui-button-view">View</button>
                    <button id="allot_transHis_btnExportExcel" class="mui-button mui-button-export">Excel</button>
                    <button class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                </div>
                <div class="mui-card mb-2 bg-light border-0 d-flex flex-column flex-grow-1 overflow-hidden" id="allot_transHis_formContainer">
                    <div class="p-2 flex-shrink-0">
                        <div class="row g-3 align-items-center">
                            <div class="col-auto d-flex align-items-center gap-2">
                                <label class="fw-bold small mb-0">From</label>
                                <div data-date-input data-format="DD/MM/YYYY" data-name="allot_transHis_fromDate">
                                    <input type="text" class="date-ui form-control form-control-sm" style="width:115px;">
                                </div>
                                <input type="checkbox" id="allot_transHis_chkFrom" checked />
                                <label class="fw-bold small mb-0">To</label>
                                <div data-date-input data-format="DD/MM/YYYY" data-name="allot_transHis_toDate">
                                    <input type="text" class="date-ui form-control form-control-sm" style="width:115px;">
                                </div>
                                <input type="checkbox" id="allot_transHis_chkTo" checked />

                            </div>

                            <div class="col-auto d-flex align-items-center gap-1">
                                <label class="small fw-bold" style="width: 70px;">Room Type</label>
                                <div style="width: 150px;">
                                    <select id="allot_transHis_roomType" class="tomselect-custom"></select>
                                </div>
                            </div>

                            <div class="col-auto d-flex align-items-center gap-1">
                                <label class="small fw-bold">From Allot.</label>
                                <div style="width: 180px;">
                                    <select id="allot_transHis_fromID" class="tomselect-custom"></select>
                                </div>
                            </div>

                            <div class="col-auto d-flex align-items-center gap-1">
                                <label class="small fw-bold">To Allot.</label>
                                <div style="width: 180px;">
                                    <select id="allot_transHis_toID" class="tomselect-custom"></select>
                                </div>
