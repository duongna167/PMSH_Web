@{
    var listCurr = ViewBag.CurrencyList;
}

<!-- =========================
     MAIN MODAL (modal-xl)
     ========================= -->
<div class="modal fade" id="drs_modalMain" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Deposit Rules Search</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">
                    <!-- Toolbar -->
                    <div>
                        <button id="drs_btnSearch" type="button" class="mui-button mui-button-search">View</button>
                        <button id="drs_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="drs_btnUpdate" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="drs_btnDelete" type="button" class="mui-button mui-button-delete">Delete</button>
                        <button id="drs_btnExportExcel" type="button" class="mui-button mui-button-export">Excel</button>
                        <button id="drs_btnClose" type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                    </div>

                    <!-- ERP Search Filter -->
                    <div class="row g-2 mt-1">

                        <div class="col-12 col-md-6 col-lg-4">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end"
                                       for="drs_codeInput">Deposit Code</label>
                                <div class="col-md-8">
                                    <input type="text" id="drs_codeInput" name="drs_codeInput"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end"
                                       for="drs_descriptionInput">Description</label>
                                <div class="col-md-8">
                                    <input type="text" id="drs_descriptionInput" name="drs_descriptionInput"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Grid -->
                <div class="mui-card">
                    <div id="drs_gridContainer" class="gridContainer"></div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- =========================
     EDIT / NEW MODAL (modal-xl)
     ========================= -->
<div class="modal fade" id="drs_itemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="drs_itemModalLabel">New/Edit Item</h5>
            </div>

            <div class="modal-body mb-2">
                <div class="search-filter">
                    <button type="button" id="drs_btnSaveItem" class="mui-button mui-button-save">Save</button>
                    <button type="button" id="drs_btnClosePopup" data-bs-dismiss="modal" class="mui-button mui-button-close">Close</button>
                </div>

                <form id="drs_formContainer" novalidate>

                    <div class="row g-2 mt-1">
                        <div class="col-11">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end"
                                        for="drs_txtCode">Deposit Rule Code</label>
                                <div class="col-md-8">
                                    <input type="text" id="drs_txtCode" name="code"
                                            class="form-control form-control-sm" />
                                    <div class="invalid-feedback">Code is required.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-2 mt-1">
                        <div class="col-11">
                            <div class="row g-2">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end"
                                        for="drs_txtDescription">Description</label>
                                <div class="col-md-8">
                                    <textarea id="drs_txtDescription" name="des"
                                                class="form-control form-control-sm"
                                                rows="4"></textarea>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-2 mt-1">
                        <div class="col-11">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-2 col-form-label col-form-label-sm text-md-end">Type:</label>
                                <div class="col-md-10">
                                    <div class="d-flex flex-wrap gap-3">
                                        <div class="form-check">
                                            <input type="radio"
                                                    name="drs_type" id="drs_typeFlat" value="0" checked>
                                            <label class="form-check-label" for="drs_typeFlat">Flat</label>
                                        </div>
                                        <div class="form-check">
                                            <input type="radio"
                                                    name="drs_type" id="drs_typePercentage" value="1">
                                            <label class="form-check-label" for="drs_typePercentage">Percentage</label>
                                        </div>
                                        <div class="form-check">
                                            <input type="radio"
                                                    name="drs_type" id="drs_typeNights" value="2">
                                            <label class="form-check-label" for="drs_typeNights">Nights</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-2 mt-1">
                        <div class="col-11">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end"
                                        for="drs_depositAmount">Deposit Amount</label>
                                <div class="col-md-8">
                                    <input type="text" id="drs_depositAmount" name="amountValue"
                                            class="form-control form-control-sm text-end" />
                                    <div class="invalid-feedback">Amount must be valid number &gt; 0.</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-11" id="drs_divCurrency">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end"
                                        for="drs_currencyID">Currency</label>
                                <div class="col-md-8">
                                    <select id="drs_currencyID" name="currencyID" class="tomselect-custom">
                                        <option value="">-- Select Currency --</option>
                                        @foreach (var item in listCurr)
                                        {
                                            <option value="@item.ID">@item.ID</option>
                                        }
                                    </select>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row g-2 mt-1">
                        <div class="col-11">
                            <div class="row g-2 align-items-center">
                                <div class="col-md-2"></div>
                                <div class="col-md-10">
                                    <div class="form-check">
                                        <label for="drs_inActive" class="form-check-label text-danger me-1">Inactive</label>
                                        <input type="checkbox" id="drs_inActive" name="drs_inActive" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-2 mt-1">
                        <div class="col-12">
                            <div class="row g-2">
                                <label class="col-md-2 col-form-label col-form-label-sm text-md-end">Conditions:</label>
                                <div class="col-md-10">
                                    <div class="row g-2">
                                        <div class="col-12 col-md-4">
                                            <label class="form-label form-label-sm mb-1" for="drs_daysBeforeArrival">Days before Arr.</label>
                                            <input type="text" id="drs_daysBeforeArrival" name="dayBA"
                                                    class="form-control form-control-sm text-end" />
                                            <div class="invalid-feedback">Must be number ≥ 0.</div> 
                                        </div>

                                        <div class="col-12 col-md-4">
                                            <label class="form-label form-label-sm mb-1" for="drs_daysAfterBooking">Days after Bkg.</label>
                                            <input type="text" id="drs_daysAfterBooking" name="dayAB"
                                                    class="form-control form-control-sm text-end" />
                                            <div class="invalid-feedback">Must be number ≥ 0.</div>
                                        </div>

                                        <div class="col-12 col-md-4">
                                            <label class="form-label form-label-sm mb-1" for="drs_sequence">Sequence</label>
                                            <input type="text" id="drs_sequence" name="seq"
                                                    class="form-control form-control-sm text-end" />
                                            <div class="invalid-feedback">Invalid number.</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="drs_id" name="drs_id" value="0" />
                </form>
            </div>

        </div>
    </div>
</div>

<div id="drs_loadingSpinner"
    style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
    z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
    height: 100%;display: flex;align-items: center;justify-content: center;">
    <div class="spinner-border text-primary"></div>
</div>

<script>
    var drs_Module = (function () {
        "use strict";

        const SEL = {
            modalMain: "#drs_modalMain",
            modalEdit: "#drs_itemModal",
            spinner: "#drs_loadingSpinner",

            btnSearch: "#drs_btnSearch",
            btnNew: "#drs_btnNew",
            btnUpdate: "#drs_btnUpdate",
            btnDelete: "#drs_btnDelete",
            btnExportExcel: "#drs_btnExportExcel",

            codeInput: "#drs_codeInput",
            descriptionInput: "#drs_descriptionInput",

            grid: "#drs_gridContainer",

            form: "#drs_formContainer",
            modalLabel: "#drs_itemModalLabel",
            btnSaveItem: "#drs_btnSaveItem",

            id: "#drs_id",
            txtCode: "#drs_txtCode",
            txtDescription: "#drs_txtDescription",

            typeFlat: "#drs_typeFlat",
            typePercentage: "#drs_typePercentage",
            typeNights: "#drs_typeNights",
            typeRadio: "input[name='drs_type']",

            depositAmount: "#drs_depositAmount",
            currencyID: "#drs_currencyID",
            divCurrency: "#drs_divCurrency",

            daysBeforeArrival: "#drs_daysBeforeArrival",
            daysAfterBooking: "#drs_daysAfterBooking",
            sequence: "#drs_sequence",
            inActive: "#drs_inActive"
        };

        let _gridInstance = null;
        let _selectedRowData = null;
        let _bound = false;

        function showLoading(show) {
            if (show) $(SEL.spinner).show();
            else $(SEL.spinner).hide();
        }

        function csrfHeaders() {
            return {
                "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
            };
        }

        function clearForm() {
            $(SEL.form)[0].reset();
            applyValidationErrors([], SEL.modalEdit);
            $(SEL.id).val("0");
            $(SEL.txtCode).prop("disabled", false);
            $(SEL.typeFlat).prop("checked", true);
            toggleCurrency();
        }

        function toggleCurrency() {
            const typeVal = $(SEL.typeRadio + ":checked").val();
            if (typeVal === "0") {
                $(SEL.divCurrency).removeClass("d-none");
            } else {
                $(SEL.divCurrency).addClass("d-none");
                $(SEL.currencyID).removeClass("is-invalid");
            }
        }

        function disposeGrid() {
            try {
                const inst = $(SEL.grid).dxDataGrid("instance");
                if (inst) inst.dispose();
            } catch (e) { }

            _gridInstance = null;
            _selectedRowData = null;
            $(SEL.grid).empty();
        }

        function mapTypeStringToInt(typeStr) {
            switch (typeStr) {
                case "Flat": return 0;
                case "Percentage": return 1;
                case "Nights": return 2;
                default: return 0;
            }
        }

        function initGrid(data) {
            disposeGrid();

            const listUser = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.UsersList ?? new List<object>()));

            _gridInstance = $(SEL.grid).dxDataGrid({
                dataSource: data || [],
                width: "100%",
                showBorders: true,
                columnAutoWidth: false,
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                hoverStateEnabled: true,

                columns: [
                    { dataField: "id", caption: "ID", visible: false },
                    { dataField: "code", caption: "Code", width: "100" },
                    { dataField: "description", caption: "Description", minWidth: "120",cssClass: "col-description"},
                    { dataField: "type", caption: "Type", width: "100" },
                    { dataField: "amountValue", caption: "Amount", format: "#,##0", width: "80" },
                    { dataField: "currencyID", caption: "$", width: "50" },
                    { dataField: "daysBeforeArrival", caption: "Bef. Arr. Days", width: "100" },
                    { dataField: "daysAfterBooking", caption: "Aft. Book. Days", width: "100" },
                    {
                        dataField: "userInsertID",
                        caption: "Create By",
                        width: "80",
                        lookup: {
                            dataSource: listUser,
                            valueExpr: "ID",
                            displayExpr: "LoginName"
                        }
                    },
                    { dataField: "createDate", caption: "Cre.Date", dataType: "date", format: "dd/MM/yyyy", width: "80" },
                    {
                        dataField: "userUpdateID",
                        caption: "Update By",
                        width: "80",
                        lookup: {
                            dataSource: listUser,
                            valueExpr: "ID",
                            displayExpr: "LoginName"
                        }
                    },
                    { dataField: "updateDate", caption: "Upd.Date", dataType: "date", format: "dd/MM/yyyy", width: "80" }
                ],

                filterRow: { visible: true, applyFilter: "auto" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: {
                    mode: "standard",
                    showScrollbar: "always"
                },

                onSelectionChanged: function (e) {
                    _selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
                }
            }).dxDataGrid("instance");
        }

        function search() {
            showLoading(true);

            $.ajax({
                url: "/Administration/GetDepositRule/",
                type: "GET",
                cache: false,
                data: {
                    code: $(SEL.codeInput).val(),
                    description: $(SEL.descriptionInput).val()
                },
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (data) {
                    initGrid(data);
                    showLoading(false);
                },
                error: function () {
                    showLoading(false);
                    showToast("Error", "Không thể tải dữ liệu", false);
                }
            });
        }

        function openNew() {
            clearForm();
            $(SEL.modalLabel).text("Add Deposit Rules Search");
            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).show();
        }

        function fillEditForm(data) {
            applyValidationErrors([], SEL.modalEdit);

            $(SEL.id).val(data.id);
            $(SEL.txtCode).val(data.code).prop("disabled", true);
            $(SEL.txtDescription).val(data.description || "");

            const typeInt = mapTypeStringToInt(data.type);
            if (typeInt === 0) $(SEL.typeFlat).prop("checked", true);
            if (typeInt === 1) $(SEL.typePercentage).prop("checked", true);
            if (typeInt === 2) $(SEL.typeNights).prop("checked", true);

            $(SEL.depositAmount).val(data.amountValue);
            setTomSelectValue(SEL.currencyID,data.currencyID || "")
            $(SEL.daysBeforeArrival).val(data.daysBeforeArrival);
            $(SEL.daysAfterBooking).val(data.daysAfterBooking);

            toggleCurrency();

            $.get("/Administration/GetDepositRuleById", { id: data.id }, function (res) {
                $(SEL.inActive).prop("checked", res.inactive === 1 || res.inactive === true);
                $(SEL.sequence).val(res.sequence);
            });

            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).show();
        }

        function openEdit() {
            if (!_selectedRowData || _selectedRowData.id === 0) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }

            $(SEL.modalLabel).text("Edit Deposit Rules Search");
            fillEditForm(_selectedRowData);
        }

        function save() {
            const id = parseInt($(SEL.id).val(), 10) || 0;
            const loginUser = parseInt(localStorage.getItem("userID"), 10) || 0;

            const currentType = $(SEL.typeRadio + ":checked").val();
            const currencyValue = currentType == "0" ? $(SEL.currencyID).val() : "";
            const amountVal = parseFloat($(SEL.depositAmount).val()) || 0;
            const daysBefore = parseInt($(SEL.daysBeforeArrival).val(), 10) || 0;
            const daysAfter = parseInt($(SEL.daysAfterBooking).val(), 10) || 0;
            const seq = parseInt($(SEL.sequence).val(), 10) || 0;

            const model = {
                ID: id,
                Code: $(SEL.txtCode).val(),
                Description: $(SEL.txtDescription).val(),
                AmountValue: amountVal,
                Type: currentType,
                CurrencyID: currencyValue,
                DaysBeforeArrival: daysBefore,
                DaysAfterBooking: daysAfter,
                Sequence: seq,
                Inactive: $(SEL.inActive).prop("checked"),
                UserInsertID: loginUser,
                UserUpdateID: loginUser
            };

            showLoading(true);

            $.ajax({
                url: "/Administration/DepositRuleSave",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(model),
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (res) {
                    showLoading(false);

                    if (res.success) {
                        showToast("Success", res.message, true);
                        bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).hide();
                        search();
                    } else {
                        if (res.errors && res.errors.length > 0) {
                            applyValidationErrors(res.errors, SEL.form);
                            const generalError = res.errors.find(x => x.field === "general");
                            const toastMessage = generalError ? generalError.message : "Please check input fields.";
                            showToast("Warning", toastMessage, false);
                        } else {
                            showToast("Error", res.message || "Save failed", false);
                        }
                    }
                },
                error: function (xhr, status, error) {
                    showLoading(false);
                    showToast("Error", error || "Request failed", false);
                }
            });
        }

        function removeSelected() {
            if (!_selectedRowData || _selectedRowData.id === 0) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }
            console.log('_selectedRowData',_selectedRowData);
            
            if (!confirm("Are you sure you want to delete this record? This action cannot be undone.")) {
                return;
            }

            showLoading(true);

            $.ajax({
                url: "/Administration/DepositRuleDelete/" + _selectedRowData.id,
                type: "POST",
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (result) {
                    showLoading(false);

                    if (result.success) {
                        search();
                        showToast("Success", `Successfully Delete Deposit Rule Code : ${_selectedRowData.code}!`, true);
                    } else {
                        showToast("Error", result.message, false);
                    }
                },
                error: function () {
                    showLoading(false);
                    showToast("Error", "Delete failed!", false);
                }
            });
        }

        function exportExcel() {
            const grid = $(SEL.grid).dxDataGrid("instance");
            if (!grid) {
                showToast("Error", "No grid data to export.", false);
                return;
            }

            const workbook = new ExcelJS.Workbook();
            const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const worksheet = workbook.addWorksheet("Sheet 1");

            worksheet.addRow([companyName]);
            worksheet.mergeCells("A1:D1");
            worksheet.getRow(1).font = { bold: true };
            worksheet.getRow(1).alignment = { vertical: "middle", horizontal: "left" };

            const now = new Date();
            const exportDate = now.toLocaleString("vi-VN");
            worksheet.addRow(["", "", "", exportDate]);
            worksheet.mergeCells("D2:D2");
            worksheet.getRow(2).alignment = { vertical: "middle", horizontal: "right" };

            worksheet.addRow([]);
            worksheet.addRow([]);

            const reportRow = worksheet.addRow(["Deposit Rules Search"]);
            worksheet.mergeCells("A5:D5");
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { vertical: "middle", horizontal: "center" };

            worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const lastRow = worksheet.lastRow.number + 2;
                worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
                worksheet.getCell(`A${lastRow}`).alignment = { horizontal: "center" };
                worksheet.getCell(`A${lastRow}`).font = { italic: true };

                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "DepositRulesSearch.xlsx");
                });
            });
        }

        function bindEventsOnce() {
            if (_bound) return;
            _bound = true;
            initTomSelect("#drs_currencyID");


            $(document)
                .off("click.drs", SEL.btnSearch).on("click.drs", SEL.btnSearch, search)
                .off("click.drs", SEL.btnNew).on("click.drs", SEL.btnNew, openNew)
                .off("click.drs", SEL.btnUpdate).on("click.drs", SEL.btnUpdate, openEdit)
                .off("click.drs", SEL.btnDelete).on("click.drs", SEL.btnDelete, removeSelected)
                .off("click.drs", SEL.btnExportExcel).on("click.drs", SEL.btnExportExcel, exportExcel)
                .off("click.drs", SEL.btnSaveItem).on("click.drs", SEL.btnSaveItem, save);

            $(document)
                .off("input.drs change.drs", `${SEL.form} input, ${SEL.form} select, ${SEL.form} textarea`)
                .on("input.drs change.drs", `${SEL.form} input, ${SEL.form} select, ${SEL.form} textarea`, function () {
                    if ($(this).hasClass("is-invalid")) {
                        $(this).removeClass("is-invalid");
                        $(this).next(".invalid-feedback").text("");
                    }
                });

            $(document)
                .off("change.drs", SEL.typeRadio)
                .on("change.drs", SEL.typeRadio, function () {
                    toggleCurrency();
                    $(SEL.currencyID).removeClass("is-invalid");
                });

            $(SEL.modalEdit)
                .off("shown.bs.modal.drs")
                .on("shown.bs.modal.drs", function () {
                })
                .off("hidden.bs.modal.drs")
                .on("hidden.bs.modal.drs", function () {
                    clearForm();
                    showLoading(false);
                });

            $(SEL.modalMain)
                .off("hidden.bs.modal.drs")
                .on("hidden.bs.modal.drs", function () {
                    $(SEL.codeInput).val("");
                    $(SEL.descriptionInput).val("");

                    disposeGrid();
                    showLoading(false);
                });
        }

        function init() {
            bindEventsOnce();
        }

        function open() {
            init();

            const modalEl = document.querySelector(SEL.modalMain);
            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

            $(modalEl).one("shown.bs.modal", function () {
                search();
            });

            modal.show();
        }

        return { init, open };
    })();

    window.openModalDrs = function () {
        drs_Module.open();
    };
</script>