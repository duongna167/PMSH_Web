        // thao tác F3 invoice list
        function refreshInvoiceGrid() {
            var $gridContainer = $("#gridInvoiceFooter");
            if ($gridContainer.length === 0) return;

            var dataGridInstance = $gridContainer.data("dxDataGrid");

            if (dataGridInstance) {
                dataGridInstance.option("dataSource", invoiceList);

                //Sử dụng requestAnimationFrame để đảm bảo DOM đã render xong chiều cao mới
                window.requestAnimationFrame(function() {
                    dataGridInstance.updateDimensions();
                });
            } else {
                initInvoiceFooterGrid();
            }
            updateFooterTotal();
        }

        function removeInvoiceItem(id) {
            invoiceList = invoiceList.filter(item => item.id !== id);
            refreshInvoiceGrid();
        }

        function clearInvoiceList() {
            invoiceList = [];
            refreshInvoiceGrid();
        }

        function updateFooterTotal() {
            var total = invoiceList.reduce((sum, item) => sum + item.amount, 0);
            $('.js-total-footer').text(formatNumberWithComma(total));
        }
        //end thao tác F3 invoice list

        function resetAllPostingData() {
            isReset = true;
            isSilentReset = true;

            // Reset toàn bộ input trong modal
            $('#modalPosting').find('input').val('');

            // Gọi reset logic chung cho tab đang active (để đưa Percent về 10 và radio về 10)
            resetFormPosting();

            // Reset các danh sách bên trái
            $('#list-group-container').empty().html('<div class="p-2 text-muted">Loading...</div>');
            $('#list-subgroup-container').empty();
            $('#list-transaction-container').empty();
            $('#list-article-container').empty();

            $('.list-group-item').removeClass('active-item-custom');

            // Clear danh sách Invoice tạm thời (F3)
            if (typeof invoiceList !== 'undefined') invoiceList = [];
            var gridFooter = $("#gridInvoiceFooter").data("dxDataGrid");
            if (gridFooter) gridFooter.option("dataSource", []);

            // Quay về view Group (cho mobile)
            switchView('group');

            setTimeout(() => {
                isReset = false;
                isSilentReset = false;
            }, 200);
        }

        function formatCurrencyLive(input) {
            if (isComposing) return;

            let value = input.value;

            let isNegative = value.startsWith('-');

            // giữ lại số + dấu ,
            let clean = value.replace(/[^\d,]/g, '');

            // chỉ cho 1 dấu ,
            let parts = clean.split(',');
            if (parts.length > 2) {
                clean = parts[0] + ',' + parts.slice(1).join('');
            }

            let [intPart, decPart] = clean.split(',');

            if (!intPart) intPart = '0';

            let formattedInt = new Intl.NumberFormat('vi-VN').format(Number(intPart));

            let result = formattedInt;

            if (decPart !== undefined) {
                result += ',' + decPart.slice(0, 2); 
            }

            if (isNegative) result = '-' + result;

            input.value = result;
        }

        function calculateLineTotalPMS({
            qty = 1,
            price = 0,
            taxRate = 0,
            isExpress = false,
            pctExpress = 0,
            isDiscount = false,
            pctDiscount = 0
        }) {
            let base = qty * price;

            let expressAmount = 0;
            if (isExpress && pctExpress > 0) {
                expressAmount = base * (pctExpress / 100);
            }

            let discountAmount = 0;
            if (isDiscount && pctDiscount > 0) {
                discountAmount = base * (pctDiscount / 100); // tính trên base
            }

            let net = base + expressAmount - discountAmount;

            let tax = net * (taxRate / 100);
            let gross = net + tax;

            return { net, tax, gross };
        }

        function buildRefAndSuppl($pane) {
            let $refInput = $pane.find('.js-ref-main');

            let baseRef = $refInput.data("base-ref") || "";

            let parts = [];

            let isExpress = $pane.find('.js-chk-express').is(':checked');
            let pctExpress = parseFloat($pane.find('.js-input-express-pct').val()) || 0;

            let isDiscount = $pane.find('.js-chk-discount').is(':checked');
            let pctDiscount = parseFloat($pane.find('.js-input-discount-pct').val()) || 0;

            if (isExpress && pctExpress > 0) {
                parts.push(`EX-${pctExpress}%`);
            }

            if (isDiscount && pctDiscount > 0) {
                parts.push(`DIS-${pctDiscount}%`);
            }

            let finalRef = baseRef;

            if (parts.length > 0) {
                finalRef = (baseRef ? baseRef + " | " : "") + parts.join(" | ");
            }

            $refInput.val(finalRef);

            return {
                reference: finalRef,
                supplement: parts.join(" | ")
            };
        }
</script>
