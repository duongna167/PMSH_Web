    function resetFormPosting() {
        let $pane = $('.tab-pane.active');
        if ($pane.length === 0) return;

        isReset = true;
        isSilentReset = true;

        // Reset các trường text cơ bản
        $pane.find('input')
            .not('.js-invoice-desc, .js-invoice-ref, .js-invoice-supp, .js-invoice-checkNo, .js-chk-express, .js-chk-discount')
            .val('');

        // Giá trị mặc định
        $pane.find('.js-input-qty').val('1');
        $pane.find('.js-input-price, .js-input-price-net').val('0,00');
        $pane.find('.js-amount-gross, .js-amount-net').val('0,00');

        // Reset Express/Discount về 10.00 và Disable
        $pane.find('.js-chk-express, .js-chk-discount').prop('checked', false);

        // Mặc định cho Express là 50%
        $pane.find('.js-input-express-pct').val('50.00');
        $pane.find('.js-express-radio[value="50"]').prop('checked', true);

        // Mặc định cho Discount là 10%
        $pane.find('.js-input-discount-pct').val('10.00');
        $pane.find('.js-discount-radio[value="10"]').prop('checked', true);

        // chỉ disable radio + input %, KHÔNG disable checkbox
        $pane.find('.express-box input[type="radio"]').prop('disabled', true);
        $pane.find('.express-box input[type="text"]').prop('disabled', true);

        // enable checkbox
        $pane.find('.js-chk-express, .js-chk-discount').prop('disabled', false);

        // Tích chọn radio 10% mặc định
        $pane.find('input[type="radio"][value="10"]').prop('checked', true);

        $pane.find('.js-ref-main').data("base-ref", "");
        $pane.find('.js-ref-main').val("");

        isReset = false;
        isSilentReset = false;
    }

