<!-- Main Modal -->
<div class="modal fade" id="marketType_mainModal" tabindex="-1" aria-labelledby="marketType_mainModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="marketType_mainModalLabel">Market Type</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <button id="marketType_btnView" type="button" class="mui-button mui-button-search">View</button>
                        <button id="marketType_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="marketType_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="marketType_btnDelete" type="button" class="mui-button mui-button-delete">Delete</button>
                        <button id="marketType_btnExportExcel" type="button" class="mui-button mui-button-export">Excel</button>
                        <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal" aria-label="Close">Close</button>
                    </div>

                    <div class="row g-2 mt-1">
                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label for="marketType_filterCode" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Code
                                </label>
                                <div class="col-md-8">
                                    <input id="marketType_filterCode"
                                           name="marketType_filterCode"
                                           type="text"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label for="marketType_filterName" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Name
                                </label>
                                <div class="col-md-8">
                                    <input id="marketType_filterName"
                                           name="marketType_filterName"
                                           type="text"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Status
                                </label>
                                <div class="col-md-8">
                                    <div class="d-flex align-items-center h-100">
                                        <div class="form-check d-flex align-items-center gap-2">
                                            <span class="status-color-box color-clean-uncheck"></span>
                                            <input type="checkbox" id="marketType_chkShowInactive" name="marketType_chkShowInactive">
                                            <label class="form-check-label" for="marketType_chkShowInactive">Show Inactive</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mui-card mt-1">
                    <div id="marketType_gridContainer" class="gridContainer"></div>
                </div>

                <div id="marketType_loadingSpinner"
                     style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                     z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                     height: 100%;display: flex;align-items: center;justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="marketType_itemModal" tabindex="-1" aria-labelledby="marketType_itemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="marketType_itemModalLabel">Add MarketType</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <button type="button" id="marketType_btnSave" class="mui-button mui-button-new">Save</button>
                    <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>

                <form id="marketType_formContainer">
                    <div class="row g-2 mt-1 mb-2">
                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label for="marketType_code" class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Code
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <input id="marketType_code"
                                           name="marketType_code"
                                           type="text"
                                           class="form-control form-control-sm" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Status
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <div class="form-check d-inline-flex align-items-center gap-2">
                                        <input id="marketType_inactive"
                                               name="marketType_inactive"
                                               type="checkbox" />
                                        <label for="marketType_inactive" class="form-check-label text-danger">
                                            Inactive
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="marketType_name" class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Name
                                </label>
                                <div class="col-md-10">
                                    <input id="marketType_name"
                                           name="marketType_name"
                                           type="text"
                                           class="form-control form-control-sm" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="marketType_description" class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Description
                                </label>
                                <div class="col-md-10">
                                    <textarea id="marketType_description"
                                              name="marketType_description"
                                              rows="4"
                                              class="form-control form-control-sm"
                                              style="height:100px;"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="marketType_id" name="marketType_id" value="0" />
                </form>
            </div>

        </div>
    </div>
</div>

<script>
    var marketType_Module = (() => {
        let marketType_selectedRowData = null;

        const marketType_selectors = {
            mainModal: "#marketType_mainModal",
            itemModal: "#marketType_itemModal",
            form: "#marketType_formContainer",
            grid: "#marketType_gridContainer",
            loading: "#marketType_loadingSpinner",

            filterCode: "#marketType_filterCode",
            filterName: "#marketType_filterName",
            chkShowInactive: "#marketType_chkShowInactive",

            btnView: "#marketType_btnView",
            btnNew: "#marketType_btnNew",
            btnEdit: "#marketType_btnEdit",
            btnDelete: "#marketType_btnDelete",
            btnExportExcel: "#marketType_btnExportExcel",
            btnSave: "#marketType_btnSave",

            modalLabel: "#marketType_itemModalLabel",

            id: "#marketType_id",
            code: "#marketType_code",
            name: "#marketType_name",
            description: "#marketType_description",
            inactive: "#marketType_inactive"
        };

        function marketType_init() {
            marketType_bindEvents();
            marketType_resetForm();
            marketType_loadGrid([]);
            marketType_loadData();
        }

        function marketType_bindEvents() {
            $(document)
                .off("input change", `${marketType_selectors.form} input, ${marketType_selectors.form} select, ${marketType_selectors.form} textarea`)
                .on("input change", `${marketType_selectors.form} input, ${marketType_selectors.form} select, ${marketType_selectors.form} textarea`, function () {
                    if ($(this).hasClass("is-invalid")) {
                        $(this).removeClass("is-invalid");
                        $(this).next(".invalid-feedback").text("");
                    }
                });

            $(marketType_selectors.itemModal)
                .off("hidden.bs.modal")
                .on("hidden.bs.modal", function () {
                    applyValidationErrors([], marketType_selectors.form);
                });

            $(document)
                .off("click", marketType_selectors.btnView)
                .on("click", marketType_selectors.btnView, function () {
                    marketType_loadData();
                });

            $(document)
                .off("click", marketType_selectors.btnNew)
                .on("click", marketType_selectors.btnNew, function () {
                    marketType_openAddModal();
                });

            $(document)
                .off("click", marketType_selectors.btnEdit)
                .on("click", marketType_selectors.btnEdit, function () {
                    marketType_openEditModal();
                });

            $(document)
                .off("click", marketType_selectors.btnSave)
                .on("click", marketType_selectors.btnSave, function () {
                    marketType_save();
                });

            $(document)
                .off("click", marketType_selectors.btnDelete)
                .on("click", marketType_selectors.btnDelete, function () {
                    marketType_delete();
                });

            $(document)
                .off("click", marketType_selectors.btnExportExcel)
                .on("click", marketType_selectors.btnExportExcel, function () {
                    marketType_exportExcel();
                });
        }

        function marketType_resetForm() {
            const marketType_form = $(marketType_selectors.form)[0];
            if (marketType_form) {
                marketType_form.reset();
            }

            $(marketType_selectors.id).val("0");
            $(marketType_selectors.modalLabel).text("Add MarketType");
        }

        function marketType_openAddModal() {
            marketType_resetForm();
            $(marketType_selectors.modalLabel).text("Add MarketType");
            $(marketType_selectors.itemModal).modal("show");
        }

        function marketType_openEditModal() {
            if (!marketType_selectedRowData) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }

            marketType_fillForm(marketType_selectedRowData);
            $(marketType_selectors.modalLabel).text("Update MarketType");
            $(marketType_selectors.itemModal).modal("show");
        }

        function marketType_fillForm(marketType_data) {
            $(marketType_selectors.id).val(marketType_data.id);
            $(marketType_selectors.code).val(marketType_data.code);
            $(marketType_selectors.name).val(marketType_data.name);
            $(marketType_selectors.description).val(marketType_data.description);
            $(marketType_selectors.inactive).prop("checked", marketType_data.inactive);
        }

        function marketType_getSearchModel() {
            return {
                code: $(marketType_selectors.filterCode).val(),
                name: $(marketType_selectors.filterName).val(),
                inactive: $(marketType_selectors.chkShowInactive).prop("checked") ? 1 : 0
            };
        }

        function marketType_getSaveModel() {
            const marketType_id = parseInt($(marketType_selectors.id).val()) || 0;
            let marketType_loginName = (localStorage.getItem("Loginname") || "")
                .trim()
                .replace(/^"(.*)"$/, "$1");
            const marketType_loginUser = parseInt(localStorage.getItem("userID")) || 0;

            return {
                ID: marketType_id,
                Code: $(marketType_selectors.code).val(),
                Name: $(marketType_selectors.name).val(),
                Description: $(marketType_selectors.description).val(),
                Inactive: $(marketType_selectors.inactive).prop("checked"),
                CreatedBy: marketType_loginName,
                UpdatedBy: marketType_loginName,
                UserInsertID: marketType_loginUser,
                UserUpdateID: marketType_loginUser
            };
        }

        function marketType_showLoading() {
            $(marketType_selectors.loading).show();
        }

        function marketType_hideLoading() {
            $(marketType_selectors.loading).hide();
        }

        function marketType_loadData() {
            marketType_showLoading();

            $.ajax({
                url: "/Administration/GetMarketType",
                type: "GET",
                cache: false,
                data: marketType_getSearchModel(),
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (marketType_data) {
                    marketType_loadGrid(marketType_data || []);
                    marketType_hideLoading();
                },
                error: function () {
                    showToast("Error", "Unable to load data", false);
                    marketType_hideLoading();
                }
            });
        }

        function marketType_loadGrid(marketType_data) {
            $(marketType_selectors.grid).dxDataGrid({
                dataSource: marketType_data,
                width: "100%",
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                hoverStateEnabled: true,
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "code", caption: "Code", width: "100" },
                    { dataField: "name", caption: "Name", width: "150" },
                    { dataField: "description", caption: "Description", minWidth: 120, cssClass: "col-description" },
                    { dataField: "inactive", caption: "Inactive", width: "60",
                        cellTemplate: function (container, options) {
                            $("<div>")
                                .dxCheckBox({
                                    value: options.value == 1 || options.value === true,
                                    readOnly: true
                                })
                                .css("transform", "scale(0.8)")
                                .appendTo(container);
                        }
                    },
                    { dataField: "createdBy", caption: "Created By", width: "80" },
                    { dataField: "createdDate", caption: "Cre.Date", dataType: "date", width: "80" },
                    { dataField: "updatedBy", caption: "Updated By", width: "80" },
                    { dataField: "updatedDate", caption: "Upd.Date", dataType: "date", width: "80" }
                ],
                filterRow: { visible: true, applyFilter: "auto" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: { mode: "standard", showScrollbar: "always" },
                onSelectionChanged: function (e) {
                    marketType_selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
                }
            });
        }

        function marketType_save() {
            const marketType_model = marketType_getSaveModel();

            $.ajax({
                url: "/Administration/MarketTypeSave",
                type: "POST",
                contentType: "application/json",
                cache: false,
                data: JSON.stringify(marketType_model),
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (marketType_res) {
                    if (marketType_res.success) {
                        showToast("Success", marketType_res.message, true);
                        $(marketType_selectors.itemModal).modal("hide");
                        marketType_loadData();
                    } else {
                        if (marketType_res.errors && marketType_res.errors.length > 0) {
                            applyValidationErrors(marketType_res.errors, marketType_selectors.form);

                            let marketType_generalError = marketType_res.errors.find(x => x.field === "general");
                            let marketType_toastMessage = marketType_generalError ? marketType_generalError.message : "Please check input fields.";

                            showToast("Warning", marketType_toastMessage, false);
                        } else {
                            showToast("Error", marketType_res.message || "Save failed", false);
                        }
                    }
                },
                error: function () {
                    showToast("Error", "Request error!", false);
                    $(marketType_selectors.itemModal).modal("hide");
                }
            });
        }

        function marketType_delete() {
            if (!marketType_selectedRowData || marketType_selectedRowData.id === 0) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }

            if (!confirm("Are you sure you want to delete this record? This action cannot be undone.")) {
                return;
            }

            $.ajax({
                url: `/Administration/DeleteMarketType/` + marketType_selectedRowData.id,
                type: "POST",
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (marketType_result) {
                    if (marketType_result.success) {
                        marketType_loadData();
                        showToast("Success", "Delete Successfully!", true);
                    } else {
                        showToast("Error", marketType_result.message, false);
                    }
                },
                error: function () {
                    console.log("delete " + marketType_selectedRowData.id);
                    showToast("Error", "Delete failed!", false);
                    $("#loadingSpinner").hide();
                }
            });
        }

        function marketType_exportExcel() {
            const marketType_grid = $(marketType_selectors.grid).dxDataGrid("instance");

            const marketType_workbook = new ExcelJS.Workbook();
            const marketType_companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const marketType_worksheet = marketType_workbook.addWorksheet("Sheet 1");

            marketType_worksheet.addRow([marketType_companyName]);
            marketType_worksheet.mergeCells("A1:D1");
            marketType_worksheet.getRow(1).font = { bold: true };
            marketType_worksheet.getRow(1).alignment = { vertical: "middle", horizontal: "left" };

            const marketType_now = new Date();
            const marketType_exportDate = marketType_now.toLocaleString("vi-VN");
            marketType_worksheet.addRow(["", "", "", marketType_exportDate]);
            marketType_worksheet.mergeCells("D2:D2");
            marketType_worksheet.getRow(2).alignment = { vertical: "middle", horizontal: "right" };

            marketType_worksheet.addRow([]);
            marketType_worksheet.addRow([]);

            const marketType_reportRow = marketType_worksheet.addRow(["Market Type"]);
            marketType_worksheet.mergeCells("A5:D5");
            marketType_reportRow.font = { bold: true, size: 14 };
            marketType_reportRow.alignment = { vertical: "middle", horizontal: "center" };

            marketType_worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: marketType_grid,
                worksheet: marketType_worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const marketType_lastRow = marketType_worksheet.lastRow.number + 2;
                marketType_worksheet.mergeCells(`A${marketType_lastRow}:D${marketType_lastRow}`);
                marketType_worksheet.getCell(`A${marketType_lastRow}`).alignment = { horizontal: "center" };
                marketType_worksheet.getCell(`A${marketType_lastRow}`).font = { italic: true };

                let marketType_fileName = "MarketType.xlsx";
                marketType_workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), marketType_fileName);
                });
            });
        }

        return {
            init: marketType_init,
            loadData: marketType_loadData,
            openAddModal: marketType_openAddModal,
            openEditModal: marketType_openEditModal
        };
    })();

    window.openModalMarketType = function () {
        const modalEl = document.querySelector("#marketType_mainModal");
        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

        $(modalEl).one("shown.bs.modal", function () {
            marketType_Module.init();
        });
        modal.show();
    };
</script>