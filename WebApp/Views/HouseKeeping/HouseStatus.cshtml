                            <div class="form-row">
                                <label class="col-label">Individuals</label>
                                <input id="individualsRoom" type="text" class="col-val" disabled>
                                <input id="individualsPerson" type="text" class="col-val" disabled>
                                <input id="individualsVip" type="text" class="col-val" disabled>
                            </div>

                            <div class="form-row">
                                <label class="col-label">Groups</label>
                                <input id="groupRoom" type="text" class="col-val" disabled>
                                <input id="groupPerson" type="text" class="col-val" disabled>
                                <input id="groupVip" type="text" class="col-val" disabled>
                            </div>

                            <div class="form-row">
                                <label class="col-label">Comp & HU</label>
                                <input id="compGroup" type="text" class="col-val" disabled>
                                <input id="compPerson" type="text" class="col-val" disabled>
                                <input id="compVip" type="text" class="col-val" disabled>
                            </div>

                            <hr class="my-1">

                            <div class="form-row">
                                <label class="col-label fw-bold">Room Revenue</label>
                                <input id="roomRevennue" type="text" style="width: 133px;" disabled>
                            </div>
                            <div class="form-row">
                                <label class="col-label fw-bold">AVG Rate</label>
                                <input id="roomAVG" type="text" style="width: 133px;" disabled>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<div id="popupLogGrid"
     style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 20px; border-radius: 10px; z-index: 1100; box-shadow: 0 0 10px rgba(0,0,0,0.3); width: fit-content; max-width: 90vw; max-height: 600px; overflow-y: auto;">
    <div class="d-flex justify-content-start mb-2">
        <button id="btnExportExcel" class="mui-button mui-button-export" type="button"> Excel</button>
        <button onclick="$('#popupLogGrid').hide()" class="mui-button mui-button-close ms-2">Close</button>
    </div>
    <div id="logGridContainer" class="gridContainer mt-2"></div>
</div>

<div id="loadingSpinnerHouseStatus"
     style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:1200;">
    <i class="fa-solid fa-spinner fa-spin" style="font-size: 35px; color: #3b9ac6;"></i>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script>
    var getHouseStatusToken = function() {
        // Ưu tiên lấy token nằm trong modalHouseStatus, nếu không có mới tìm toàn trang
        var token = $('#modalHouseStatus input[name="__RequestVerificationToken"]').val();
        if (!token) {
            token = $('input[name="__RequestVerificationToken"]').val();
        }
        return token;
    };

    // Hàm format số tiền/số liệu Việt Nam
    var hs_formatVN = (val, fraction = 0) => {
        return (val || 0).toLocaleString('vi-VN', { maximumFractionDigits: fraction });
    };

    function initHouseStatusData() {
        console.log("House Status Initialized");

        hs_getBusinessDate();

        hs_bindHouseStatusEvents();
    }

    // Hàm gọi AJAX chung (để tái sử dụng)
    var hs_callAjax  = (url, data) => {
        return $.ajax({
            url: url,
            type: 'GET',
            data: data,
            cache: false, 
            headers: { "X-CSRF-TOKEN-HEADERNAME": getHouseStatusToken() }
        });
    };

    $(document).ready(function () {
        initHouseStatusData();
    });

    function hs_bindHouseStatusEvents() {
        // Xử lý sự kiện click icon lấy chi tiết
        $(document).off("click", ".ellipsis-icon").on("click", ".ellipsis-icon", function () {
                            var inputId = $(this).closest(".form-row").find("input").attr("id");

                            hs_callAjax ('/HouseKeeping/DataHSdetail', {
                                datebunisess: $("#datebunisess").val(),
                                roomtype: $("#roomtype").val(),
                                zone: $("#zone").val(),
                                inputId: inputId,
                            }).done(result => {
                                if (Array.isArray(result)) {
                                    initializeLogStatusGrid(result, inputId);
                                    $("#popupLogGrid").show();
                                } else {
                                    alert("Dữ liệu không đúng định dạng!");
                                }
                            });
                        });

        // Xử lý nút View dữ liệu tổng quát
        $(document).off("click", "#btnViewHS").on("click", "#btnViewHS", function () {
                            var $spinner = $("#loadingSpinnerHouseStatus");
                            $spinner.show();

                            hs_callAjax ('/HouseKeeping/HouseStatusData', {
                                datebunisess: $("#datebunisess").val(),
                                roomtype: $("#roomtype").val(),
                                zone: $("#zone").val(),
                            }).done(result => {
                                // --- 1. Thực hiện các tính toán logic (Giữ nguyên logic cũ) ---
                                var totalRoom = parseInt(result.totalPhysicalRoom[0]?.totalPhysicalRoom) || 0;
                                var outOfOrder = parseInt(result.outOfOrder[0]?.outOfOrder) || 0;
                                var roomToSell = totalRoom - outOfOrder;

                                var stayOverRoom = parseInt(result.stayOver[0]?.totalRooms) || 0;
                                var depExpRoom = parseInt(result.departureExpected[0]?.totalRooms) || 0;
                                var occupancyRoom = stayOverRoom + depExpRoom;
                                var occupancyPercent = roomToSell > 0 ? ((occupancyRoom * 100) / roomToSell) : 0;

                                var maxaccRoom = parseInt(result.endOfDayMaxOccTonight[0]?.totalRooms) || 0;
                                var maxOccPercent = roomToSell > 0 ? ((maxaccRoom * 100) / roomToSell) : 0;

                                var amount = parseFloat(result.endOfDayRoomRevenue[0]?.amount) || 0;
                                var avgRate = maxaccRoom > 0 ? (amount / maxaccRoom) : 0;

                                var vIns = parseInt(result.hkInspected[0]?.vacant) || 0;
                                var oIns = parseInt(result.hkInspected[0]?.occ) || 0;
                                var vHk = parseInt(result.hkClean[0]?.vacant) || 0;
                                var oHk = parseInt(result.hkClean[0]?.occ) || 0;
                                var vHkD = parseInt(result.hkDirty[0]?.vacant) || 0;
                                var oHkD = parseInt(result.hkDirty[0]?.occ) || 0;
                                var txtDO = result.roomzone?.length || 0;

                                // --- 2. Ánh xạ dữ liệu vào Form (Mapping để tối ưu dòng code) ---
                                var dataMap = {
                                    '#totalRoom': totalRoom,
                                    '#outOfOrder': outOfOrder,
                                    '#roomToSell': roomToSell,
                                    '#outOfService': result.outOfService[0]?.outOfService,
                                    '#occupancyRoom': occupancyRoom,
                                    '#occupancyPercent': occupancyPercent.toFixed(2),
                                    '#minAvail': roomToSell - maxaccRoom,
                                    '#occupancyPersons': (parseInt(result.stayOver[0]?.totalPersons) || 0) + (parseInt(result.departureExpected[0]?.totalPersons) || 0),
                                    '#occupancyvVip': result.arrivalActualVIP[0]?.vip,
                                    '#maxaccRoom': maxaccRoom,
                                    '#maxpercentonight': maxOccPercent.toFixed(2),
                                    '#maxaccPerson': result.endOfDayMaxOccTonight[0]?.totalPersons,
                                    '#maxaccVip': result.endOfDayMaxOccTonightVIP[0]?.vip,
                                    '#individualsRoom': result.endOfDayIndividual[0]?.totalRooms,
                                    '#individualsPerson': result.endOfDayIndividual[0]?.totalPersons,
                                    '#individualsVip': result.endOfDayIndividualVIP[0]?.vip,
                                    '#groupRoom': result.endOfDayGroupAndBlock[0]?.totalRooms,
                                    '#groupPerson': result.endOfDayGroupAndBlock[0]?.totalPersons,
                                    '#groupVip': result.endOfDayGroupAndBlockVIP[0]?.vip,
                                    '#compGroup': result.endOfDayCHU[0]?.totalRooms,
                                    '#compPerson': result.endOfDayCHU[0]?.totalPersons,
                                    '#compVip': result.endOfDayCHUVIP[0]?.vip,
                                    '#roomRevennue': hs_formatVN(amount),
                                    '#roomAVG': avgRate > 0 ? hs_formatVN(avgRate) : '0.000',
                                    '#stayoverRoom': result.stayOver[0]?.totalRooms,
                                    '#stayoverPerson': result.stayOver[0]?.totalPersons,
                                    '#stayoverVip': result.stayOverVIP[0]?.vip,
                                    '#depExpectedRoom': result.departureExpected[0]?.totalRooms,
                                    '#depExpectedPerson': result.departureExpected[0]?.totalPersons,
                                    '#depExpectedVip': result.departureExpectedVIP[0]?.vip,
                                    '#actualRoom': result.departureActual[0]?.totalRooms,
                                    '#actualPerson': result.departureActual[0]?.totalPersons,
                                    '#actualVip': result.departureActualVIP[0]?.vip,
                                    '#arrivalExpectedRoom': result.arrivalExpected[0]?.totalRooms,
                                    '#arrivalExpectedPerson': result.arrivalExpected[0]?.totalPersons,
                                    '#arrivalExpectedVip': result.arrivalExpectedVIP[0]?.vip,
                                    '#arrivalActualRoom': result.arrivalActual[0]?.totalRooms,
                                    '#arrivalActualPerson': result.arrivalActual[0]?.totalPersons,
                                    '#arrivalActualVip': result.arrivalActualVIP[0]?.vip,
                                    '#extendedStaysRoom': result.extendedStay[0]?.totalRooms,
                                    '#extendedStaysPerson': result.extendedStay[0]?.totalPersons,
                                    '#extendedStaysVip': result.extendedStayVIP[0]?.vip,
                                    '#earlyDeparturesRoom': result.earlyDeparture[0]?.totalRooms,
                                    '#earlyDeparturesPerson': result.earlyDeparture[0]?.totalPersons,
                                    '#earlyDeparturesVip': result.earlyDepartureVIP[0]?.vip,
                                    '#dayUseRoom': result.dayUseRoom[0]?.totalRooms,
                                    '#dayUsePerson': result.dayUseRoom[0]?.totalPersons,
                                    '#dayUseVip': result.dayUseRoomVIP[0]?.vip,
                                    '#walkinRoom': result.walkInRoom[0]?.totalRooms,
                                    '#walkinPerson': result.walkInRoom[0]?.totalPersons,
                                    '#walkinVip': result.wakeInRoomVIP[0]?.vip,
                                    '#cleanVacant': vIns,
                                    '#cleanOccupied': oIns,
                                    '#cleanTotal': vIns + oIns,
                                    '#cleannonVacant': vHk,
                                    '#cleannonOccupied': oHk,
                                    '#cleannonTotal': vHk + oHk,
                                    '#dirtyVacant': vHkD,
                                    '#dirtyOccupied': oHkD,
                                    '#dirtyTotal': vHkD + oHkD,
                                    '#doeoutOccupied': txtDO,
                                    '#totalVacant': vIns + vHk + vHkD,
                                    '#totalOccupied': oIns + oHk + oHkD + txtDO,
                                    '#outoforderVacant': result.hkOutOfOrder[0]?.vacant,
                                    '#outofserviveVacant': result.hkOutOfService[0]?.vacant,
                                    '#outofserviveOccupied': result.hkOutOfService[0]?.occ
                                };

                                // Thực hiện gán hàng loạt
                                $.each(dataMap, (selector, value) => {
                                    $(selector).val(value);
                                });

                            }).fail(() => {
                                alert("Error loading House Status Data");
                            }).always(() => {
                                $spinner.hide();
                            });
                        });

        $(document).off("click", "#btnExecutePrint").on("click", "#btnExecutePrint", function () {
            var modalElement = document.querySelector("#modalHouseStatus .modal-content");
            var isSaveFile = document.getElementById("radioSave").checked;
            $("#loadingSpinnerHouseStatus").show();
            html2canvas(modalElement, {
                scale: 2,
                useCORS: true,
                logging: false,
                backgroundColor: "#f0f2f5"
            }).then(canvas => {
                var imageData = canvas.toDataURL("image/png");
                if (isSaveFile) {
                    var link = document.createElement('a');
                    link.href = imageData;
                    link.download = `HouseStatus_${new Date().getTime()}.png`;
                    link.click();
                } else {
                    var printWindow = window.open('', '_blank');
                    printWindow.document.write(`
                        <html>
                        <head><title>Print House Status</title></head>
                        <body style="margin:0; display:flex; justify-content:center;">
                        <img src="${imageData}" style="max-width:100%;">
                        <script>window.onload = function() { window.print(); window.close(); }<\/script>
                        </body>
                        </html>
                    `);
                    printWindow.document.close();
                }
                $("#loadingSpinnerHouseStatus").hide();
            }).catch(err => {
                console.error("Snapshot error:", err);
                $("#loadingSpinnerHouseStatus").hide();
            });
        });

        $("#btnExportExcel").click(function () {
                            var grid = $("#logGridContainer").dxDataGrid("instance");
                            var selectedReport = 'Detail House Status';
                            if (!selectedReport) {
                                alert("Vui lòng chọn báo cáo trước khi xuất Excel.");
                                return;
                            }

                            var workbook = new ExcelJS.Workbook(); var companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
                            var worksheet = workbook.addWorksheet("Sheet 1");

                            // === Tạo header công ty (dòng 1) ===
                            worksheet.addRow([companyName]);
                            worksheet.mergeCells('A1:E1');
                            worksheet.getRow(1).font = { bold: true };
                            worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

                            // === Dòng 2: Thời gian xuất (phải) ===
                            var now = new Date();
                            var exportDate = now.toLocaleString("vi-VN");
                            worksheet.addRow(['', '', '', '', ' ' + exportDate]);
                            worksheet.mergeCells('E2:H2');
                            worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

                            // === Dòng 3–4: Trống
                            worksheet.addRow([]);
                            worksheet.addRow([]);

                            // === Dòng 5: Tên báo cáo ở giữa ===
                            var reportRow = worksheet.addRow(['', '', selectedReport]);
                            worksheet.mergeCells('C5:F5');
                            reportRow.font = { bold: true, size: 14 };
                            reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

                            // === Dòng 6: Trống trước khi xuất dữ liệu
                            worksheet.addRow([]);

                            // === Export dữ liệu từ DevExtreme (bắt đầu từ dòng 7)
                            DevExpress.excelExporter.exportDataGrid({
                                component: grid,
                                worksheet: worksheet,
                                autoFilterEnabled: true,
                                topLeftCell: { row: 7, column: 1 } // dữ liệu bắt đầu từ dòng 7
                            }).then(function () {
                                // Footer
                                var lastRow = worksheet.lastRow.number + 2;

                                worksheet.mergeCells(`A${lastRow}:F${lastRow}`);
                                worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
                                worksheet.getCell(`A${lastRow}`).font = { italic: true };

                                // Ghi file
                                let fileName = selectedReport + ".xlsx";
                                workbook.xlsx.writeBuffer().then(function (buffer) {
                                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
                                });
                            });
        });
    }

    function hs_getBusinessDate() {
        $.ajax({
            url: '/Reservation/GetBusinessDate',
            type: 'get',
            dataType: 'json',
            crossDomain: false,
            // Sửa: Lấy token từ hàm helper
            headers: { "X-CSRF-TOKEN-HEADERNAME": getHouseStatusToken() },
            success: function (result) {
                if(result && result.indexOf('T') > -1) {
                    $('#datebunisess').val(result.split('T')[0]);
                } else {
                    var now = new Date();
                    var day = ("0" + now.getDate()).slice(-2);
                    var month = ("0" + (now.getMonth() + 1)).slice(-2);
                    $('#datebunisess').val(now.getFullYear()+"-"+(month)+"-"+(day));
                }

                $("#btnViewHS").trigger("click");
            },
            error: function (xhr) {
                if (xhr.status == 401) {
                    alert("Session expired");
                }
            }
        });
    }

    // Cấu hình Grid
    var GRID_CONFIGS = {
            outOfService: [
                { dataField: "roomName", caption: "Room Name", width: "30%" },
                { dataField: "roomType", caption: "Room Type", width: "30%" },
                { dataField: "direction", caption: "Direction", width: "40%" }
            ],
            outOfOrder: [
                { dataField: "roomName", caption: "Room Name", width: "30%" },
                { dataField: "roomType", caption: "Room Type", width: "30%" },
                { dataField: "fromDate", caption: "From Date", dataType: "date", format: "dd/MM/yyyy" },
                { dataField: "toDate", caption: "To Date", dataType: "date", format: "dd/MM/yyyy" }
            ],
            // Các nhóm dùng chung cột Reservation
            reservationGroup: [
                { dataField: "reservationNumber", caption: "Reservation Number", width: "10%" },
                { dataField: "roomNo", caption: "Room No", width: "10%" },
                { dataField: "roomType", caption: "Room Type", width: "20%" },
                { dataField: "guest", caption: "Guest", width: "20%" },
                { dataField: "arrivalDate", caption: "Arrival Date", dataType: "date", format: "dd/MM/yyyy" },
                { dataField: "departureDate", caption: "Departure Date", dataType: "date", format: "dd/MM/yyyy" }
            ],
            // Các nhóm dùng chung cột Housekeeping
            hkGroup: [
                { dataField: "roomName", caption: "Room Name", width: "20%" },
                { dataField: "roomType", caption: "Room Type", width: "20%" },
                { dataField: "zone", caption: "Zone", width: "60%" }
            ]
        };
    
    function initializeLogStatusGrid(data, inputId) {
    let columns = [];
        // Logic chọn bộ cột dựa trên ID
        var resIds = ["stayoverRoom", "depExpectedRoom", "actualRoom", "arrivalExpectedRoom", "arrivalActualRoom",
        "extendedStaysRoom", "earlyDeparturesRoom", "dayUseRoom", "walkinRoom", "doeoutOccupied"];

        if (GRID_CONFIGS[inputId]) {
            columns = GRID_CONFIGS[inputId];
        } else if (resIds.includes(inputId)) {
            columns = GRID_CONFIGS.reservationGroup;
        } else {
            columns = GRID_CONFIGS.hkGroup;
        }

        $("#logGridContainer").dxDataGrid({
            dataSource: data,
            allowColumnResizing: true,
            columnAutoWidth: true,
            showBorders: true,
            height: 500,
            columns: columns,
            paging: { pageSize: 25 },
            scrolling: { useNative: true, showScrollbar: "always" },
            pager: {
                visible: true,
                allowedPageSizes: [25, 50, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            filterRow: { visible: true, applyFilter: "auto" },
            headerFilter: { visible: true },
            onRowPrepared: function (e) {
                if (e.rowType === "data" && e.data?.isTotal) {
                    e.rowElement.css({ "font-weight": "bold", "background-color": "#f6f6f6" });
                }
            }
        });
    }
        
</script>
