<div class="modal fade modal-xl" id="modalMembership" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
     aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="staticBackdropLabel">Memberships</h5>
                <button type="button" class="btn-close" onclick="closeModalMembership()"></button>
            </div>
            <div class="modal-body">
                <div class="mt-2">
                    <button class="mui-button mui-button-new" onclick="GetMembership();"> Search</button>
                    <button class="mui-button mui-button-new" onclick="openModalNewMembership('New')">New</button>
                    <button class="mui-button mui-button-new" onclick="openModalNewMembership('Edit')">Edit</button>
                    <button class="mui-button mui-button-new" onclick="deleteNewMembership();"> Delete</button>
                    <button class="mui-button mui-button-new" onclick="closeModalMembership();"> Close</button>
                </div>
                <div class="row mt-2">
                    <div class="form-group-new-reservation col-md-3 ">
                        <label>Member Name</label>
                        <div class="row" style="margin-left:1px;margin-right:2px">
                            <input id="pro_search_memberName" class="form-control form-control-sm" />
                        </div>
                    </div>
                    <div class="form-group-new-reservation col-md-6 mt-1" style="display:flex">
                        <div style="margin-left:1px;margin-right:2px">
                            <input type="checkbox" id="pro_search_showActive">
                        </div>
                        <label>Show active</label>
                    </div>
                </div>

                <div class="mui-card mt-2">
                    <div id="pro_search_gridContainerSearchMembership" class="mt-2 gridContainer"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade modal" id="modalNewMembership" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
     aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="staticBackdropLabel">New Membership</h5>
                <button type="button" class="btn-close" onclick="closeModalNewMembership()"></button>
            </div>
            <div class="modal-body">
                <div class="mt-2">
                    <button class="mui-button mui-button-new" onclick="SaveMemberShip();"> OK</button>
                    <button class="mui-button mui-button-new" onclick="closeModalNewMembership()">Close</button>
                </div>
                <div class="row mt-2">
                    <div class="form-group-new-reservation ">
                        <label>Member Name</label>
                        <div class="row" style="margin-left:1px;margin-right:2px">
                            <input id="pro_search_memberNameAdd" class="form-control form-control-sm" />
                            <input id="pro_search_memberNameProfile" style="display:none" />
                        </div>
                    </div>
                    <div class="form-group-new-reservation ">
                        <label>Type</label>
                        <div class="row" style="margin-left:1px;margin-right:2px">
                            <select id="pro_search_memberTypeAdd" class="form-select form-select-sm" asp-items="ViewBag.cboMemberType">
                            </select>
                        </div>
                    </div>
                    <div class="form-group-new-reservation  ">
                        <label>Name on Card</label>
                        <div class="row" style="margin-left:1px;margin-right:2px">
                            <input id="pro_search_nameOnCardAdd" class="form-control form-control-sm" />
                        </div>
                    </div>
                    <div class="form-group-new-reservation  ">
                        <label>Card Number</label>
                        <div class="row" style="margin-left:1px;margin-right:2px">
                            <input id="pro_search_cardNumberAdd" class="form-control form-control-sm" />
                        </div>
                    </div>
                    <div class="form-group-new-reservation  ">
                        <label>Expire Date</label>
                        <div class="row" style="margin-left:1px;margin-right:2px">
                            <input id="pro_search_expireDateAdd" type="date" class="form-control form-control-sm" />
                        </div>
                    </div>
                    <div class="form-group-new-reservation  ">
                        <label>Sequence</label>
                        <div class="row" style="margin-left:1px;margin-right:2px">
                            <input id="pro_search_sequenceAdd" class="form-control form-control-sm" />
                        </div>
                    </div>

                    <div class="form-group-new-reservation  ">
                        <label>Description</label>
                        <div class="row" style="margin-left:1px;margin-right:2px">
                            <input id="pro_search_descriptionAdd" class="form-control form-control-sm" />
                        </div>
                    </div>
                    <div class="form-group-new-reservation   mt-1" style="display:flex">
                        <div style="margin-left:1px;margin-right:2px">
                            <input type="checkbox" id="pro_search_inactiveAdd">
                        </div>
                        <label>Inactive</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    
    var pro_search_membershipID = pro_search_membershipID || "";

    function openModalMembership() {
        GetMembership();
        $('#modalMembership').modal('show');
        $('#pro_search_memberName').val(pro_search_Module.profileName);
    }

    function closeModalMembership() {
        $('#pro_search_memberName').val('');
        $('#modalMembership').modal('hide');
    }

    function GetMembership() {
        let pro_search_showActive = $('#pro_search_showActive').is(':checked') ? '' : '0';
        $.ajax({
            url: '/Profile/SearchProfileMembership',
            type: 'GET',
            data: {
                profileID: pro_search_Module.profileID,
                inactive: pro_search_showActive
            },
            success: function (pro_search_data) {
                initializeDataGridMembership(pro_search_data);
            },
            error: function () {
                alert('Error retrieving membership data.');
            }
        });
    }

    function initializeDataGridMembership(pro_search_gridData) {
        $("#pro_search_gridContainerSearchMembership").dxDataGrid({
            dataSource: pro_search_gridData,
            allowColumnResizing: true,
            columns: [
                { dataField: "ID", caption: "ID", visible: false },
                { dataField: "Sequence", caption: "Seq" },
                { dataField: "MemberType", caption: "Type" },
                { dataField: "MemberNo", caption: "Card Number" },
                { dataField: "Expiry", caption: "Expiration Date" },
                { dataField: "MemberTypeName", caption: "Card on Name" },
                { dataField: "Description", caption: "Description" },
                { dataField: "Inactive", caption: "Inactive" },
                { dataField: "CreatedBy", caption: "Created By" },
                { dataField: "CreatedDate", caption: "Created Date", dataType: "date", format: "dd/MM/yyyy" },
                { dataField: "UpdatedBy", caption: "Updated By" },
                { dataField: "UpdatedDate", caption: "Updated Date", dataType: "date", format: "dd/MM/yyyy" },
            ],
            paging: { pageSize: 15 },
            scrolling: { rowRenderingMode: 'virtual' },
            pager: {
                visible: true,
                allowedPageSizes: [15, 20, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true,
            },
            selection: {
                mode: "multiple",
                showCheckBoxesMode: "none"
            },
            showBorders: false,
            onRowClick: function (e) {
                pro_search_membershipID = e.data.ID;
            }
        });
    }

    function openModalNewMembership(pro_search_action) {
        if (pro_search_action === 'New') {
            resetFormMembershipAdd();
            $('#modalNewMembership').modal('show');
        }

        if (pro_search_action === 'Edit') {
            var pro_search_grid = $("#pro_search_gridContainerSearchMembership").dxDataGrid("instance");
            var pro_search_selectedRowsData = pro_search_grid.getSelectedRowsData();

            if (!pro_search_selectedRowsData || pro_search_selectedRowsData.length !== 1) {
                showToast('Error', "Please select exactly one record to edit.", false);
                return;
            }

            var pro_search_idToEdit = pro_search_selectedRowsData[0].ID;
            pro_search_membershipID = pro_search_idToEdit;
            resetFormMembershipAdd();
            GetMembershipByID(pro_search_idToEdit);
            $('#modalNewMembership').modal('show');
        }
    }

    function resetFormMembershipAdd() {
        $('#pro_search_memberNameAdd').val(pro_search_Module.profileName);
        $('#pro_search_memberNameProfile').val(pro_search_Module.profileID);
        $('#pro_search_memberTypeAdd').val(0);
        $('#pro_search_nameOnCardAdd').val('');
        $('#pro_search_cardNumberAdd').val('');
        const pro_search_today = new Date().toISOString().split('T')[0];
        $('#pro_search_expireDateAdd').val(pro_search_today);
        $('#pro_search_sequenceAdd').val('');
        $('#pro_search_descriptionAdd').val('');
        $('#pro_search_inactiveAdd').prop('checked', false);
    }

    function closeModalNewMembership() {
        $('#modalNewMembership').modal('hide');
    }

    $('#pro_search_memberTypeAdd').off('change').on('change', function () {
        let pro_search_typeId = $(this).val();
        if (pro_search_typeId != 0) {
            GetMemberTypeByID(pro_search_typeId);
        }
    });

    function GetMembershipByID(pro_search_targetId) {
        $.ajax({
            url: '/Profile/GetMembershipByID',
            type: 'GET',
            data: { id: pro_search_targetId },
            success: function (pro_search_data) {
                $('#pro_search_memberTypeAdd').val(pro_search_data.memberTypeID);
                GetMemberTypeByID(pro_search_data.memberTypeID);
                $('#pro_search_cardNumberAdd').val(pro_search_data.memberNo);
                $("#pro_search_sequenceAdd").val(pro_search_data.sequence);
                if (pro_search_data.expiry) {
                    $("#pro_search_expireDateAdd").val(pro_search_data.expiry.split('T')[0]);
                }
                $("#pro_search_descriptionAdd").val(pro_search_data.description);
                $('#pro_search_inactiveAdd').prop('checked', pro_search_data.inActive == 1);
            },
            error: function () {
                alert('Error retrieving membership data.');
            }
        });
    }

    function GetMemberTypeByID(pro_search_typeId) {
        $.ajax({
            url: '/Profile/GetMemberTypeByID',
            type: 'GET',
            data: { id: pro_search_typeId },
            success: function (pro_search_data) {
                $('#pro_search_nameOnCardAdd').val(pro_search_data.name);
            },
            error: function () {
                alert('Error retrieving member type data.');
            }
        });
    }

    function deleteNewMembership() {
        var pro_search_grid = $("#pro_search_gridContainerSearchMembership").dxDataGrid("instance");
        var pro_search_selectedRowsData = pro_search_grid.getSelectedRowsData();

        if (!pro_search_selectedRowsData || pro_search_selectedRowsData.length !== 1) {
            showToast('Error', "Please select exactly one record to delete.", false);
            return;
        }
        var pro_search_mId = pro_search_selectedRowsData[0].ID;
        if (!confirm("Are you sure you want to delete this member card?")) return;

        $.ajax({
            url: '/Profile/DeleteNewMembership',
            type: 'GET',
            data: { id: pro_search_mId },
            success: function (pro_search_data) {
                if (pro_search_data.code == 0) {
                    showToast('Success', pro_search_data.msg, true);
                    GetMembership();
                } else {
                    showToast('Error', pro_search_data.msg, false);
                }
            },
            error: function () {
                alert('Error deleting membership data.');
            }
        });
    }

    function SaveMemberShip() {
        var pro_search_formData = new FormData();
        const pro_search_userName = JSON.parse(localStorage.getItem("Loginname"));

        pro_search_formData.append('ID', pro_search_membershipID);
        pro_search_formData.append('profileID', $('#pro_search_memberNameProfile').val());
        pro_search_formData.append('userName', pro_search_userName);
        pro_search_formData.append('memberNo', $('#pro_search_cardNumberAdd').val());
        pro_search_formData.append('memberTypeID', $('#pro_search_memberTypeAdd').val());
        pro_search_formData.append('description', $('#pro_search_descriptionAdd').val());
        pro_search_formData.append('expiry', $('#pro_search_expireDateAdd').val());
        pro_search_formData.append('sequence', $("#pro_search_sequenceAdd").val());
        pro_search_formData.append('inactive', $('#pro_search_inactiveAdd').is(':checked') ? 1 : 0);

        $.ajax({
            url: '/Profile/SaveMembership',
            type: 'POST',
            processData: false,
            contentType: false,
            data: pro_search_formData,
            success: function (pro_search_result) {
                if (pro_search_result.code == 0) {
                    GetMembership();
                    showToast('Success', pro_search_result.msg, true);
                    closeModalNewMembership();
                    pro_search_membershipID = "";
                } else {
                    showToast('Error', pro_search_result.msg, false);
                }
            }
        });
    }
</script>
