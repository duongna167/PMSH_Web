    // Set va;ue tomselect
    function setTomSelectValue(selector, value, text = null) {
        const ts = tomSelectInstances[selector];
        if (!ts) return;

        if (value === null || value === undefined || value === '' || value == 0) {
            ts.clear();
            return;
        }

        // Nếu option chưa tồn tại → add
        if (!ts.options[value]) {
            ts.addOption({
                value: value,
                text: text ?? value
            });
        }

        ts.setValue(value, true);
    }

