<div class="modal fade" id="lanG_mainModal" tabindex="-1" aria-labelledby="lanG_mainModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="lanG_mainModalLabel">Language</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <button id="lanG_btnView" type="button" class="mui-button mui-button-search">View</button>
                        <button id="lanG_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="lanG_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="lanG_btnDelete" type="button" class="mui-button mui-button-delete">Delete</button>
                        <button id="lanG_btnExportExcel" type="button" class="mui-button mui-button-export">Excel</button>
                       <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal" aria-label="Close">Close</button>
                    </div>

                    <form id="lanG_searchForm">
                        <div class="row g-2 mt-1">
                            <div class="col-12 col-md-4 col-lg-3">
                                <div class="row g-2 align-items-center">
                                    <label for="lanG_codeSearch" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                        Code
                                    </label>
                                    <div class="col-md-8">
                                        <input id="lanG_codeSearch"
                                               name="lanG_codeSearch"
                                               type="text"
                                               class="form-control form-control-sm">
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-md-4 col-lg-3">
                                <div class="row g-2 align-items-center">
                                    <label for="lanG_nameSearch" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                        Name
                                    </label>
                                    <div class="col-md-8">
                                        <input id="lanG_nameSearch"
                                               name="lanG_nameSearch"
                                               type="text"
                                               class="form-control form-control-sm">
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-md-4 col-lg-3">
                                <div class="row g-2 align-items-center">
                                    <label for="lanG_showInactive" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                        Status
                                    </label>
                                    <div class="col-md-8">
                                        <div class="d-flex align-items-center h-100">
                                            <div class="form-check d-flex align-items-center gap-2">
                                                <span class="status-color-box color-clean-uncheck"></span>
                                                <input id="lanG_showInactive"
                                                       name="lanG_showInactive"
                                                       type="checkbox">
                                                <label class="form-check-label" for="lanG_showInactive">Show Inactive</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="mui-card mt-1">
                    <div id="lanG_gridContainer" class="gridContainer"></div>
                </div>

                <div id="lanG_loadingSpinner" 
                    style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                    z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                    height: 100%;display: flex;align-items: center;justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="lanG_itemModal" tabindex="-1" aria-labelledby="lanG_itemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="lanG_itemModalLabel">Language</h5>
            </div>

            <div class="search-filter">
                <button type="button" id="lanG_btnSave" class="mui-button mui-button-save">Save</button>
                <button type="button" data-bs-dismiss="modal" class="mui-button mui-button-close">Close</button>
            </div>

            <div class="modal-body">
                <form id="lanG_form">
                    <div class="row g-2 mt-1 mb-2">
                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label for="lanG_code" class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Code
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <input id="lanG_code"
                                            name="lanG_code"
                                            type="text"
                                            class="form-control form-control-sm">
                                    <div class="invalid-feedback" id="lanG_codeError"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label for="lanG_inactive" class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Status
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <div class="form-check d-flex align-items-center gap-2">
                                        <input id="lanG_inactive"
                                                name="lanG_inactive"
                                                type="checkbox">
                                        <label for="lanG_inactive" class="form-check-label text-danger">Inactive</label>
                                    </div>
                                    <div class="invalid-feedback" id="lanG_inactiveError"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2 align-items-center">
                                <label for="lanG_name" class="col-md-2 col-lg-2 col-form-label col-form-label-sm text-md-end">
                                    Name
                                </label>
                                <div class="col-md-10 col-lg-10">
                                    <input id="lanG_name"
                                            name="lanG_name"
                                            type="text"
                                            class="form-control form-control-sm">
                                    <div class="invalid-feedback" id="lanG_nameError"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="lanG_description" class="col-md-2 col-lg-2 col-form-label col-form-label-sm text-md-end">
                                    Description
                                </label>
                                <div class="col-md-10 col-lg-10">
                                    <textarea id="lanG_description"
                                                name="lanG_description"
                                                class="form-control form-control-sm"
                                                rows="5"
                                                style="height:100px"></textarea>
                                    <div class="invalid-feedback" id="lanG_descriptionError"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="lanG_id" name="lanG_id" value="0" />
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    DevExpress.localization.locale("vi");

    const lanG_Module = (function () {
        let selectedRowData = null;

        const selectors = {
            mainModal: "#lanG_mainModal",
            itemModal: "#lanG_itemModal",
            form: "#lanG_form",
            searchForm: "#lanG_searchForm",
            grid: "#lanG_gridContainer",
            loading: "#lanG_loadingSpinner",
            itemModalLabel: "#lanG_itemModalLabel",

            btnView: "#lanG_btnView",
            btnNew: "#lanG_btnNew",
            btnEdit: "#lanG_btnEdit",
            btnDelete: "#lanG_btnDelete",
            btnSave: "#lanG_btnSave",
            btnExportExcel: "#lanG_btnExportExcel",

            codeSearch: "#lanG_codeSearch",
            nameSearch: "#lanG_nameSearch",
            showInactive: "#lanG_showInactive",

            id: "#lanG_id",
            code: "#lanG_code",
            name: "#lanG_name",
            description: "#lanG_description",
            inactive: "#lanG_inactive"
        };

        const endpoints = {
            getList: "/Administration/GetLanguage",
            save: "/Administration/LanguageSave",
            delete: "/Administration/DeleteLanguage/"
        };

        function init() {
            bindEvents();
            loadGrid();
        }

        function bindEvents() {
            $(selectors.btnView).off("click").on("click", loadGrid);
            $(selectors.btnNew).off("click").on("click", openAddModal);
            $(selectors.btnEdit).off("click").on("click", openEditModal);
            $(selectors.btnDelete).off("click").on("click", deleteRecord);
            $(selectors.btnSave).off("click").on("click", saveRecord);
            $(selectors.btnExportExcel).off("click").on("click", exportExcel);

            $(selectors.form).off("input change", "input, select, textarea").on("input change", "input, select, textarea", function () {
                clearFieldError(this);
            });

            $(selectors.itemModal).off("hidden.bs.modal").on("hidden.bs.modal", function () {
                resetForm();
                applyValidationErrors([], selectors.form);
            });
        }

        function openAddModal() {
            resetForm();
            $(selectors.id).val("0");
            $(selectors.itemModalLabel).text("Add Language");
            $(selectors.itemModal).modal("show");
        }

        function openEditModal() {
            if (!selectedRowData) {
                showToast("Warning", "Please select a row first!", false);
                return;
            }

            resetForm();
            fillForm(selectedRowData);
            $(selectors.itemModalLabel).text("Update Language");
            $(selectors.itemModal).modal("show");
        }

        function fillForm(data) {
            $(selectors.id).val(data.id || 0);
            $(selectors.code).val(data.code ?? "");
            $(selectors.name).val(data.name ?? "");
            $(selectors.description).val(data.description ?? "");
            $(selectors.inactive).prop("checked", !!data.inactive);
        }

        function resetForm() {
            $(selectors.form)[0].reset();
            $(selectors.id).val("0");
            applyValidationErrors([], selectors.form);
        }

        function loadGrid() {
            $(selectors.loading).show();

            $.ajax({
                url: endpoints.getList,
                type: "GET",
                cache: false,
                data: {
                    code: $(selectors.codeSearch).val(),
                    name: $(selectors.nameSearch).val(),
                    inactive: $(selectors.showInactive).prop("checked") ? 1 : 0
                },
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val()
                },
                success: function (data) {
                    renderGrid(data || []);
                },
                error: function () {
                    showToast("Error", "Unable to load data", false);
                },
                complete: function () {
                    $(selectors.loading).hide();
                }
            });
        }

        function renderGrid(data) {
            $(selectors.grid).dxDataGrid({
                dataSource: data,
                keyExpr: "id",
                height: 500,
                width: "100%",
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                hoverStateEnabled: true,
                filterRow: { visible: true, applyFilter: "auto" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: { mode: "standard", showScrollbar: "always" },
                columns: [
                    { dataField: "id", caption: "ID", visible: false },
                    { dataField: "code", caption: "Code", width: "10%" },
                    { dataField: "name", caption: "Name", width: "20%" },
                    { dataField: "description", caption: "Description", width: "30%" },
                    { dataField: "inactive", caption: "Inactive", width: "6%",
                        cellTemplate: function (container, options) {
                            $("<div>")
                                .dxCheckBox({
                                    value: options.value == 1 || options.value === true,
                                    readOnly: true
                                })
                                .css("transform", "scale(0.8)")
                                .appendTo(container);
                        }
                     },
                    { dataField: "createdBy", caption: "Created By", width: "8%" },
                    { dataField: "createdDate", caption: "Created Date", dataType: "date", width: "9%" },
                    { dataField: "updatedBy", caption: "Updated By", width: "8%" },
                    { dataField: "updatedDate", caption: "Updated Date", dataType: "date", width: "9%" }
                ],
                onSelectionChanged: function (e) {
                    selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
                }
            });
        }

        function saveRecord() {
            const id = parseInt($(selectors.id).val()) || 0;
            const loginName = (localStorage.getItem("Loginname") || "").trim().replace(/^"(.*)"$/, "$1");
            const loginUser = parseInt(localStorage.getItem("userID")) || 0;

            const model = {
                ID: id,
                Code: $(selectors.code).val().trim(),
                Name: $(selectors.name).val().trim(),
                Description: $(selectors.description).val().trim(),
                Inactive: $(selectors.inactive).prop("checked"),
                CreatedBy: loginName,
                UpdatedBy: loginName,
                UserInsertID: loginUser,
                UserUpdateID: loginUser
            };

            $.ajax({
                url: endpoints.save,
                type: "POST",
                contentType: "application/json",
                cache: false,
                data: JSON.stringify(model),
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val()
                },
                success: function (res) {
                    if (res.success) {
                        showToast("Success", res.message, true);
                        $(selectors.itemModal).modal("hide");
                        loadGrid();
                        return;
                    }

                    if (res.errors && res.errors.length > 0) {
                        applyValidationErrors(res.errors, selectors.form);

                        const generalError = res.errors.find(x => x.field === "general");
                        const toastMessage = generalError ? generalError.message : "Please check input fields.";

                        showToast("Warning", toastMessage, false);
                        return;
                    }

                    showToast("Error", res.message || "Save failed", false);
                },
                error: function () {
                    showToast("Error", "Request error!", false);
                }
            });
        }

        function deleteRecord() {
            if (!selectedRowData || selectedRowData.id === 0) {
                showToast("Warning", "Select 1 row, please!", false);
                return;
            }

            if (!confirm("Are you sure you want to delete this record? This action cannot be undone.")) {
                return;
            }

            $.ajax({
                url: endpoints.delete + selectedRowData.id,
                type: "POST",
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val()
                },
                success: function (result) {
                    if (result.success) {
                        selectedRowData = null;
                        showToast("Success", "Delete Successfully!", true);
                        loadGrid();
                    } else {
                        showToast("Error", result.message || "Delete failed!", false);
                    }
                },
                error: function () {
                    showToast("Error", "Delete failed!", false);
                }
            });
        }

        function exportExcel() {
            const grid = $(selectors.grid).dxDataGrid("instance");
            if (!grid) {
                showToast("Warning", "Grid is not ready.", false);
                return;
            }

            const workbook = new ExcelJS.Workbook();
            const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const worksheet = workbook.addWorksheet("Sheet 1");

            worksheet.addRow([companyName]);
            worksheet.mergeCells("A1:D1");
            worksheet.getRow(1).font = { bold: true };
            worksheet.getRow(1).alignment = { vertical: "middle", horizontal: "left" };

            const now = new Date();
            const exportDate = now.toLocaleString("vi-VN");
            worksheet.addRow(["", "", "", exportDate]);
            worksheet.getRow(2).alignment = { vertical: "middle", horizontal: "right" };

            worksheet.addRow([]);
            worksheet.addRow([]);

            const reportRow = worksheet.addRow(["Language"]);
            worksheet.mergeCells("A5:D5");
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { vertical: "middle", horizontal: "center" };

            worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const lastRow = worksheet.lastRow.number + 2;
                worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
                worksheet.getCell(`A${lastRow}`).alignment = { horizontal: "center" };
                worksheet.getCell(`A${lastRow}`).font = { italic: true };

                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(
                        new Blob([buffer], { type: "application/octet-stream" }),
                        "Language.xlsx"
                    );
                });
            });
        }

        function clearFieldError(element) {
            const $element = $(element);

            if ($element.hasClass("is-invalid")) {
                $element.removeClass("is-invalid");
            }

            const $feedback = $element.siblings(".invalid-feedback");
            if ($feedback.length) {
                $feedback.text("");
            }
        }

        return {
            init: init,
            loadGrid: loadGrid,
            openAddModal: openAddModal,
            openEditModal: openEditModal
        };
    })();

    $(document).ready(function () {
        lanG_Module.init();
    });

    window.openModalLanguage = function () {
        $("#lanG_mainModal").modal("show");
        lanG_Module.loadGrid();
    };
</script>