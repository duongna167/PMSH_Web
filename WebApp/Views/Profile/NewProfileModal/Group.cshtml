</div>
<script>
    var pro_gro_Module = {
        init: function () {
            this.initDOMEvents();
            this.initTomSelects();
        },

        initDOMEvents: function () {
            const self = this;

            // Sự kiện nút Save
            $('#gro_btnSave').on('click', function () {
                self.saveProfile();
            });

            // Sự kiện nút Clear
            $('#gro_btnClear').on('click', function () {
                self.clearForm();
            });
        },

        initTomSelects: function () {
            const self = this;

            initTomSelect('.tomselect-custom');

            LoadingGlobal.show();

            const mapCode = (item) => ({
                value: item.id || item.ID,
                text: (item.code || item.Code) + " - " + (item.name || item.Name),
                data: item
            });

            const loadTasks = [
                loadDataToTomSelect("#gro_txtLanguage", "/Profile/GetAllLanguage", mapCode),
                loadDataToTomSelect("#gro_txtCity", "/Profile/GetAllCity", mapCode),
                loadDataToTomSelect("#gro_txtCountry", "/Profile/GetAllCountry", mapCode),

                loadDataToTomSelect("#gro_txtCurrency", "/Profile/GetAllCurrency",(item) => {
                    const id = item.id || item.ID || "";

                    const desc = item.description || item.Description || "";

                    return {
                        value: item.id || item.ID,
                        text: (id && desc) ? `${id} - ${desc}` : (id || desc || "Unknown"),
                        data: item
                    };
                }),

                // loadDataToTomSelect("#gro_txtAccountType", "/Profile/GetAllAccountType", (item) => {
                //     return {
                //         value: item.type || item.Type,
                //         text: item.type || item.Type,
                //         data: item
                //     };
                // }),

                loadDataToTomSelect("#gro_txtVIP", "/Profile/GetAllVIP", mapCode),

                loadDataToTomSelect("#gro_txtState", "/Profile/GetAllState", (item) => {
                    const zip = item.zipCode || item.ZipCode || "";
                    const name = item.stateName || item.StateName || "";
                    return {
                        value: item.id || item.ID,
                        text: (zip && name) ? `${zip} - ${name}` : (zip || name || "Unknown"),
                        data: item
                    };
                })
            ];

            // 4. Ẩn loading sau khi tất cả các API đã hoàn tất
            Promise.all(loadTasks).finally(() => {
                LoadingGlobal.hide();
            });
        },

        getFormData: function () {

            const getTS = (id) => {
                const ts = getTomSelect(id);
                return ts ? ts.getValue() : null;
            };

            const loginUser = parseInt(localStorage.getItem("userID")) || 0;
            const defaultDate = "1900-01-01";

            const data = {
                ID: parseInt($("#gro_id").val()) || 0,
                Type: 4,

                Code: $("#gro_txtCode").val()?.trim() || "",
                Account: $("#gro_txtGroupName").val()?.trim() || "",

                LanguageID: parseInt(getTS("#gro_txtLanguage")) || 0,

                Address: $("#gro_txtAddress").val()?.trim() || "",
                HomeAddress: $("#gro_txtHomeAddress").val()?.trim() || "",

                City: getTS("#gro_txtCity") || "",

                PostalCode: $("#gro_txtPostalCode").val()?.trim() || "",

                CountryID: parseInt(getTS("#gro_txtCountry")) || 0,
                StateID: parseInt(getTS("#gro_txtState")) || 0,

                AcctContact: $("#gro_txtContact").val()?.trim() || "",

                CurrencyID: getTS("#gro_txtCurrency") || "",

                VIPID: parseInt(getTS("#gro_txtVIP")) || 0,
                VIPReason: $("#gro_txtVIPReason").val()?.trim() || "",

                Description: $("#gro_txtNotes").val()?.trim() || "",

                History: $("#gro_chkHistory").is(":checked"),

                Telephone: $("#gro_txtTelephone").val()?.trim() || "",
                Email: $("#gro_txtEmail").val()?.trim() || "",
                Website: $("#gro_txtWebsite").val()?.trim() || "",
                HandPhone: $("#gro_txtHandPhone").val()?.trim() || "",

                // ===== Required DateTime fields in Model =====
                DateOfBirth: defaultDate,
                Lastvisit: defaultDate,
                FirstReservation: defaultDate,
                LastReservation: defaultDate,
                WeddingAnniversary: defaultDate,
                Firstvisit: defaultDate,
                Expiry: defaultDate,
                LastContact: defaultDate,
                SpecialUpdateDate: defaultDate,

                StayNo: 0,
                UserInsertID: loginUser,
                UserUpdateID: loginUser
            };

            return data;
        },

        clearForm: function () {
            const $container = $("#pro_gro_formContainer");
            $container.find('input[type="text"], input[type="hidden"], input[type="email"], textarea').val('');
            $("#gro_chkHistory").prop("checked", false);

            const tsIds = ["#gro_txtLanguage", "#gro_txtCity", "#gro_txtCountry", "#gro_txtState", "#gro_txtCurrency", "#gro_txtAccountType", "#gro_txtVIP"];
            tsIds.forEach(id => {
                const ts = getTomSelect(id);
                if (ts) ts.clear();
            });

            if (window.ValidationAdapter) ValidationAdapter.clear("#pro_gro_formContainer");
            $("#gro_txtCode").focus();
        },

        saveProfile: function () {
            const data = this.getFormData();
            LoadingGlobal.show();

            $.ajax({
                url: '/Profile/SaveProfile',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {
                    LoadingGlobal.hide();
                    if (res.success) {
                        showToast("Success", res.message || 'Profile saved successfully!', true);
                        const modalEl = document.getElementById('modalGroup');
                        if (modalEl) {
                            const modalInstance = bootstrap.Modal.getInstance(modalEl);
                            if (modalInstance) modalInstance.hide();
                        }

                        if ($("#pro_search_btnSearch").length) {
                            $("#pro_search_btnSearch").trigger("click");
                        }
                    } else {
                        if (res.errors && res.errors.length > 0) {
                            ValidationAdapter.apply(res.errors, "#pro_gro_formContainer");

                            showToast("Error",'Please check the highlighted fields.', false);
                        } else {
                            showToast("Error",res.message || 'An error occurred', false);
                        }
                    }
                },
                error: function () {
                    LoadingGlobal.hide();
                    showToast("Error", 'System error', false);
                }
            });
        },

        fillForm: function (data) {

            if (!data) return;

            const setTS = (id, value) => {
                const ts = getTomSelect(id);
                if (ts) {
                    ts.setValue(value || "");
                }
            };

            $("#gro_id").val(data.id || 0);

            $("#gro_txtCode").val(data.code || "");
            $("#gro_txtGroupName").val(data.account || "");

            setTS("#gro_txtLanguage", data.languageID);

            $("#gro_txtAddress").val(data.address || "");
            $("#gro_txtHomeAddress").val(data.homeAddress || "");

            setTS("#gro_txtCity", data.city);

            $("#gro_txtPostalCode").val(data.postalCode || "");

            setTS("#gro_txtCountry", data.countryID);
            setTS("#gro_txtState", data.stateID);

            $("#gro_txtContact").val(data.acctContact || "");

            setTS("#gro_txtCurrency", data.currencyID);

            setTS("#gro_txtVIP", data.vipID);

            $("#gro_txtVIPReason").val(data.vipReason || "");

            $("#gro_txtNotes").val(data.description || "");

            $("#gro_chkHistory").prop("checked", data.history === true);

            $("#gro_txtTelephone").val(data.telephone || "");
            $("#gro_txtEmail").val(data.email || "");
            $("#gro_txtWebsite").val(data.website || "");
            $("#gro_txtHandPhone").val(data.handPhone || "");

        },

        loadProfileByID: function (id) {
            const self = this;
            LoadingGlobal.show();
            $.ajax({
                url: '/Profile/GetProfileByID/',
                type: 'GET',
                data: { id: id },
                success: function (res) {
                    LoadingGlobal.hide();
                    if (res.code === 0) {
                        self.fillForm(res.profile);
                    } else {
                        showToast("Error", res.msg, false);
                    }
                },
                error: function () {
                    LoadingGlobal.hide();
                    showToast("Error", "Cannot load profile", false);
                }
            });
        }
    };

    window.initGroupModal = function() {
        if (window.pro_gro_Module) {
            window.pro_gro_Module.init();
        }
    }

</script>
