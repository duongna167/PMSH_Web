@using DevExpress.XtraReports.UI

@{
    var listfloor = ViewBag.FloorList;
    var listrl = ViewBag.RoomClassList;
    var listroom = ViewBag.RoomList;
    var listzo = ViewBag.ZoneList;
}
<style>
    .filter-box {
        border-radius: 6px;
        padding: 8px 10px;
        background: #fff;
    }

    /* Mỗi cụm label + control */
    .filter-item {
        display: flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
    }

    /* Label gọn */
    .filter-item>label {
        margin: 0;
        font-weight: 500;
    }

    /* Group checkbox Show */
    .show-group {
        gap: 12px;
    }

    /* Checkbox gọn hàng */
    .show-group .form-check {
        display: flex;
        align-items: center;
        margin: 0;
    }

    .show-group .form-check-label {
        margin-left: 4px;
        padding-top: 0;
        cursor: pointer;
    }
</style>
<div class="text-center" id="reportTitle" style="font-size: 20px">Room Discrepancy</div>
<div class="search-filter">
    <div class="">
        <button id="btnPrint" class="mui-button mui-button-new">View</button>
        <button id=" btnSave" class="mui-button mui-button-new" type="button"> Save</button>

    </div>
    <div class="filter-box d-flex flex-wrap align-items-center gap-3 mb-1">

        <div class="filter-item">
            <label>Floor:</label>
            <select id="floor" class="form-control form-control-sm w-auto">
                <option value="">-- All --</option>
                @foreach (var u in ViewBag.FloorList)
                {
                    <option value="@u.Code">@u.Code</option>
                }
            </select>
        </div>

        <div class="filter-item">
            <label>Room:</label>
            <select id="room" class="tomselect-custom" multiple style="width:200px">
                @foreach (var g in ViewBag.RoomList)
                {
                    <option value="@g.RoomNo">@g.RoomNo - @g.RoomName</option>
                }
            </select>
        </div>

        <div class="filter-item">
            <label>Zone:</label>
            <select id="zone" class="tomselect-custom" multiple style="width:200px">
                @foreach (var sg in ViewBag.ZoneList)
                {
                    <option value="@sg.ID">@sg.Code</option>
                }
            </select>
        </div>

        <div class="filter-item">
            <label>Room Class:</label>
            <select id="roomClass" class="tomselect-custom" multiple style="width:220px">
                @foreach (var tr in ViewBag.RoomClassList)
                {
                    <option value="@tr.ID">@tr.Code - @tr.Description</option>
                }
            </select>
        </div>

        <div class="filter-item show-group">
            <label>Show:</label>

            <div class="form-check">
                <input type="checkbox" id="sleeps" checked>
                <label class="form-check-label " for="sleeps">Sleeps</label>
            </div>

            <div class="form-check">
                <input type="checkbox" id="skips" checked>
                <label class="form-check-label " for="skips">Skips</label>
            </div>

            <div class="form-check">
                <input type="checkbox" id="personsDiscrepancy" checked>
                <label class="form-check-label " for="personsDiscrepancy">
                    Persons Discrepancy
                </label>
            </div>
        </div>

    </div>

</div>

<div class="mui-card">

    <div id="gridContainer" class="gridContainer"></div>
</div>
<div id="loadingSpinner"
    style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:1000;">
    <i class="fa-solid fa-spinner fa-spin"></i>
</div>
<script>
    $(document).ready(function () {
        initTomSelect(".tomselect-custom");
        $("#btnPrint").trigger("click");
    });

    $(document).off("click", "#btnPrint").on("click", "#btnPrint", function () {
        $("#loadingSpinner").show();

        $.ajax({
            url: '/RoomManagement/GetDiscrepancy',
            type: 'GET',
            data: {
                sleep: $("#sleeps").is(":checked") ? 1 : 0,
                skip: $("#skips").is(":checked") ? 1 : 0,
                person: $("#personsDiscrepancy").is(":checked") ? 1 : 0,
                floor: $("#floor").val(),
                room: $("#room").val(),
                zone: $("#zone").val(),
                roomClass: $("#roomClass").val(),
            },
            success: function (data) {
                console.log(data);
                loadDiscrepancyGrid(data);
                $("#loadingSpinner").hide();
            },
            error: function () {
                alert("Không thể tải dữ liệu");
                $("#loadingSpinner").hide();
            }
        });
    });
    // Map numeric ↔ tên hiển thị
    const hkStatusMap = { 0: "Vacant", 1: "Occupied" };
    const hkStatusMapReverse = { "Vacant": 0, "Occupied": 1 };

    function loadDiscrepancyGrid(data) {
        // Map dữ liệu DB (string) sang số
        data.forEach(item => {
            item.hkStatusId = hkStatusMapReverse[item.hkStatus] ?? null;
        });

        $("#gridContainer").dxDataGrid({
            dataSource: data,
            keyExpr: "id",
            allowColumnResizing: true,
            selection: { mode: "single" }, // chỉ chọn 1 dòng
            editing: { mode: "batch", allowUpdating: true },
            height: 500,
            columns: [
                { dataField: "id", caption: "ID", visible: false },
                { dataField: "roomNo", caption: "Room No", allowEditing: false },
                {
                    dataField: "hkStatusId",
                    caption: "HK Status",
                    lookup: {
                        dataSource: [
                            { id: 0, name: "Vacant" },
                            { id: 1, name: "Occupied" }
                        ],
                        valueExpr: "id",
                        displayExpr: "name"
                    },
                    cellTemplate: function (cellElement, cellInfo) {

                        cellElement
                            .addClass("dx-editor-cell")
                            .attr("tabindex", 0);

                        $("<div>").dxSelectBox({
                            dataSource: [
                                { id: 0, name: "Vacant" },
                                { id: 1, name: "Occupied" }
                            ],
                            valueExpr: "id",
                            displayExpr: "name",
                            value: cellInfo.value,
                            buttons: ["dropDown"],
                            width: "100%",
                            onValueChanged(e) {
                                cellInfo.component.cellValue(
                                    cellInfo.rowIndex,
                                    "hkStatusId",
                                    e.value
                                );
                            }
                        }).appendTo(cellElement);
                    }
                },
                { dataField: "roomStatus", caption: "Room Status", allowEditing: false },
                { dataField: "foStatus", caption: "FO Status", allowEditing: false },
                { dataField: "hkPersons", caption: "HK Persons", allowEditing: false },
                { dataField: "foPersons", caption: "FO Persons", allowEditing: false },
                { dataField: "discrepancy", caption: "Discrepancy", allowEditing: false }
            ],
            scrolling: {
                mode: "standard", // Không dùng virtual để footer hiển thị đúng
                showScrollbar: "always",
                scrollByContent: true
            },
            paging: {
                pageSize: 50
            },
            pager: {
                visible: true,
                allowedPageSizes: [50, 100, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            filterRow: {
                visible: true,
                applyFilter: "auto"
            },
            toolbar: {
                visible: false
            },
            onCellPrepared: function (e) {
                if (e.rowType === "data" && e.column.dataField === "roomStatus") {
                    const status = (e.value || "").toLowerCase();

                    if (status.includes("dirty")) {
                        e.cellElement.css("background-color", "Red"); // d? nh?t
                        e.cellElement.css("color", "white");
                    } else if (status.includes("pickup")) {
                        e.cellElement.css("background-color", "#f740f4"); // tím nh?t
                    } else if (status.includes("clean non-checked")) {
                        e.cellElement.css("background-color", "#1bdff5"); // xanh nu?c bi?n nh?t
                    } else if (status.includes("out of order")) {
                        e.cellElement.css("background-color", "#cf159a"); // h?ng
                        e.cellElement.css("color", "white");
                    } else if (status.includes("clean")) {
                        e.cellElement.css("background-color", "green"); // xanh lá
                        e.cellElement.css("color", "white"); // ch? tr?ng cho d? nhìn
                    }
                }
            },
            onSaving: function (e) {
                const editRows = e.changes;
                console.log('edtRows', editRows);
                if (editRows.length < 1) {
                    showToast("Warning", "There are no changes to save.", false);
                    return;
                }
                var userId = localStorage.getItem("userID");
                const payload = editRows
                    .filter(c => c.type === "update")
                    .map(c => ({
                        roomIds: c.key,
                        newHKFOStatus: c.data.hkStatusId,
                        updateByID: userId
                    }))
                    .filter(p => p.newHKFOStatus !== undefined);
                console.log('payload', payload);
                $.ajax({
                    url: '/UpdateHKFOStatus',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(payload),
                    success: function (res) {
                        if (res.success) {
                            const skippedText = res.skipped && res.skipped.length > 0 ? res.skipped.join(", ") : "no";
                            showToast("Success", `Update success ${res.updated} room(s), skipped room(s): ${skippedText}`, true);
                            grid.refresh();
                        } else {
                            showToast('Error: ', res.message, false);
                        }
                    },
                    error: function (xhr, status, error) {
                        // Nếu có mảng errors thì hiển thị từng cái
                        if (Array.isArray(xhr.responseJSON?.errors)) {
                            xhr.responseJSON.errors.forEach((err, index) => {
                                setTimeout(() => {
                                    showToast("Error", err, false);
                                }, index * 1000); // delay 300ms mỗi toast
                            });
                        }

                    }

                });



            }
        });
    }

    $('#btnSave').click(function () {
        var grid = $("#gridContainer").dxDataGrid("instance");
        //    var selectedRow = grid.getSelectedRowsData()[0]; // chỉ lấy 1 phòng
        grid.saveEditData();

        @* if (!selectedRow) {
            alert('Vui lòng chọn 1 phòng.');
            return;
        } *@

            @* var payload = {
            roomNo: selectedRow.roomNo,      // **string, không phải mảng**
            newHKFOStatus: selectedRow.hkStatusId
        }; *@

            @* console.log("Payload gửi lên server:", payload); *@
    });








</script>
