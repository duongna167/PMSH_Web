@using DevExpress.XtraReports.UI
@{
    var selectedReport = @ViewBag.ReportHeader;
    var crrlist = ViewBag.CurrencyList;
}

<link href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>

<div class="text-center" id="reportTitle" style="font-size: 20px">Exchange Rate</div>

<div class="search-filter mb-1">
    <div class="">
        <button id="btnNew" class="mui-button mui-button-new"> New</button>
        <button id="btnEdit" class="mui-button mui-button-new"> Edit</button>
        <button id="btnDelete" class="mui-button mui-button-new"> Delete</button>
        <button id="btnExportExcel" class="mui-button mui-button-new" type="button"> Excel</button>
    </div>
</div>

<div class="mui-card">
    <div id="gridWrapper">
        <div id="gridContainer" class="gridContainer"></div>
    </div>
</div>

<div class="modal fade" id="editorModal" tabindex="-1" aria-labelledby="editorModalLabel" aria-hidden="true"
    data-bs-backdrop="static">
    <div class="modal-dialog modal-lg  modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editorModalLabel">Exchange Rate</h5>
            </div>
            <div class="modal-body">
                <form id="exchangeRateForm">
                    <!-- Buttons -->
                    <div class="d-flex justify-content-start gap-2 mb-1">
                        <button type="button" class="mui-button mui-button-new" id="btnModalSave">Save</button>
                        <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                    </div>
                    <input type="hidden" id="ID" name="ID" />

                    <div class="row  align-items-center mb-1">
                        <div class="col-md-6">
                            <div class="row align-items-center">
                                <label class="col-sm-4 col-form-label text-sm-end">Date:</label>
                                <div class="col-sm-8">
                                    <div data-date-input data-format="DD/MM/YYYY" business-date data-name="DateTime">
                                        <input type="text" class="date-ui form-control" placeholder="dd/mm/yyyy"
                                            autocomplete="off" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="row align-items-center">
                                <label class="col-sm-4 col-form-label text-sm-end">From Curr:</label>
                                <div class="col-sm-8">
                                    <select id="FromCurrencyID" name="FromCurrencyID"
                                        class="form-select form-select-sm">
                                        <option value="">---Select---</option>
                                        @foreach (var crr in ViewBag.CurrencyList)
                                        {
                                            <option value="@crr.ID">@crr.ID - @crr.Description</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="row align-items-center">
                                <label class="col-sm-4 col-form-label text-sm-end">To Curr:</label>
                                <div class="col-sm-8">
                                    <select id="ToCurrencyIDSelect" class="form-select form-select-sm" disabled>
                                        @foreach (var crr in crrlist)
                                        {
                                            if (crr.ID == "VND")
                                            {
                                                <option value="@crr.ID" selected>@crr.ID -
                                                    @crr.Description</option>
                                            }
                                        }
                                    </select>
                                    <input type="hidden" id="ToCurrencyID" name="ToCurrencyID" value="VND" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-1">
                        <div class="col-md-6">
                            <div class="row align-items-center">
                                <label class="col-sm-4 col-form-label text-sm-end fw-bold">Buy Rate:</label>
                                <div class="col-sm-8">
                                    <input type="number" id="ExChangeRate" value="0" name="ExChangeRate"
                                        class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="row align-items-center">
                                <label class="col-sm-4 col-form-label text-sm-end fw-bold">Sell Rate:</label>
                                <div class="col-sm-8">
                                    <input type="number" id="ExChangeRateSell" value="0" name="ExChangeRateSell"
                                        class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row ">
                        <div class="col-lg-4">
                            <div class="border-start border-end">
                                <div class="text-center  fw-bold d-block">MAX</div>
                                <div>
                                    <label class="col-5 col-form-label text-sm-end fw-bold">Denomination</label>
                                    <input type="number" id="DenominationMax" value="0" name="DenominationMax"
                                        class="form-control-sm col-6" />
                                </div>
                                <div>
                                    <label class="col-5 col-form-label text-sm-end fw-bold">Rate</label>
                                    <input type="number" id="ExChangeRateMax" value="0" name="ExChangeRateMax"
                                        class="form-control-sm col-6" />
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="border-start border-end">
                                <div class="text-center  fw-bold d-block">MEDIUM</div>
                                <div>
                                    <label class="col-5 col-form-label text-sm-end fw-bold">Denomination</label>
                                    <input type="number" id="DenominationMedium" value="0" name="DenominationMedium"
                                        class="form-control-sm col-6" />
                                </div>
                                <div>
                                    <label class="col-5 col-form-label text-sm-end fw-bold">Rate</label>
                                    <input type="number" id="ExChangeRateMedium" value="0" name="ExChangeRateMedium"
                                        class="form-control-sm col-6" />
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="border-start border-end">
                                <div class="text-center  fw-bold d-block">MIN</div>
                                <div>
                                    <label class="col-5 col-form-label text-sm-end fw-bold">Denomination</label>
                                    <input type="number" id="DenominationMin" value="0" name="DenominationMin"
                                        class="form-control-sm col-6" />
                                </div>
                                <div>
                                    <label class="col-5 col-form-label text-sm-end fw-bold">Rate</label>
                                    <input type="number" id="ExChangeRateMin" value="0" name="ExChangeRateMin"
                                        class="form-control-sm col-6" />
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="loadingSpinner"
    style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:1000;">
    <i class="fa-solid fa-spinner fa-spin"></i>
</div>

<script>
    let selectedRowData = null;

    DevExpress.localization.locale("vi");

    $(document).ready(function () {
    });

    // --- REFACTORED: New Button ---
    // Opens the modal in "Insert" mode
    $("#btnNew").click(function () {
        // Reset form
        $("#exchangeRateForm")[0].reset();
        $("#ID").val(""); // Ensure ID is empty for Insert
        reloadBusinessDate();        // Set Modal Title and Show
        $("#editorModalLabel").text("New Exchange Rate");
        $("#editorModal").modal("show");
    });

    // --- REFACTORED: Edit Button ---
    // Opens the modal in "Update" mode with data pre-filled
    $("#btnEdit").click(function () {
        if (!selectedRowData) {
            alert("Please select a row first!");
            return;
        }

        // Map selected row data to form (Existing Logic Preserved)
        $("#ID").val(selectedRowData.id);
        $("#DateTime").val(selectedRowData.dateTime.split("T")[0]);
        $("#FromCurrencyID").val(selectedRowData.fromCurrencyID);
        $("#ToCurrencyID").val(selectedRowData.toCurrencyID);
        $("#ExChangeRate").val(selectedRowData.buyRate);
        $("#ExChangeRateSell").val(selectedRowData.sellRate);
        $("#ExChangeRateMax").val(selectedRowData.exChangeRateMax);
        $("#DenominationMax").val(selectedRowData.denominationMax);
        $("#ExChangeRateMedium").val(selectedRowData.exChangeRateMedium);
        $("#DenominationMedium").val(selectedRowData.denominationMedium);
        $("#ExChangeRateMin").val(selectedRowData.exChangeRateMin);
        $("#DenominationMin").val(selectedRowData.denominationMin);

        // Set Modal Title and Show
        $("#editorModalLabel").text("Edit Exchange Rate");
        $("#editorModal").modal("show");
    });

    // --- REFACTORED: Save Button (Inside Modal) ---
    // Reuse existing logic, but now closes modal on success
    $("#btnModalSave").click(function () {
        let id = $("#ID").val();
        let data = $("#exchangeRateForm").serialize();

        console.log("Serialized Data:", data);

        if (!id) {
            // === Insert Logic ===
            $.post("/Cashiering/Insert", data, function (res) {
                console.log("Insert Response:", res);
                DevExpress.ui.notify("Inserted new ID: " + res.id, "success", 2000);

                // Refresh Grid
                $("#gridContainer").dxDataGrid("instance").refresh();

                // Close Modal
                $("#editorModal").modal("hide");

            }).fail(function (xhr) {
                console.error("Insert error:", xhr.responseText);
                DevExpress.ui.notify("Insert failed!", "error", 2000);
            });
        } else {
            // === Update Logic ===
            $.post("/Cashiering/Update", data, function (res) {
                console.log("Update Response:", res);
                DevExpress.ui.notify("Updated ID: " + res.id, "success", 2000);

                // Refresh Grid
                $("#gridContainer").dxDataGrid("instance").refresh();

                // Close Modal
                $("#editorModal").modal("hide");

            }).fail(function (xhr) {
                console.error("Update error:", xhr.responseText);
                DevExpress.ui.notify("Update failed!", "error", 2000);
            });
        }
    });

    // --- NEW: Modal Hidden Event ---
    // Ensures clean state if user closes modal via X or backdrop
    $("#editorModal").on('hidden.bs.modal', function () {
        $("#exchangeRateForm")[0].reset();
        $("#ID").val("");
        // Reset date to today
        $("#DateTime").val(formatDate(new Date()));
    });

    // --- REUSED: Delete Logic (Unchanged) ---
    $("#btnDelete").click(function () {
        if (!selectedRowData) {
            showToast("Warning", "Please select a row first!", false);
            return;
        }

        if (!confirm("Are you sure you want to delete this record?")) return;

        $.post("/Cashiering/Delete", { id: selectedRowData.id }, function (res) {
            if (res.deleted > 0) {
                showToast("Success", "Deleted successfully", true);
                $("#gridContainer").dxDataGrid("instance").refresh();
                selectedRowData = null;
            } else {
                DevExpress.ui.notify("Delete failed!", "error", 2000);
            }
        }).fail(function (xhr) {
            console.error("Delete error:", xhr.responseText);
            DevExpress.ui.notify("Delete error!", "error", 2000);
        });
    });

    // --- REUSED: Grid Configuration (Unchanged) ---
    $(function () {
        $("#gridContainer").dxDataGrid({
            dataSource: new DevExpress.data.DataSource({
                load: function () {
                    return $.ajax({
                        url: "/Cashiering/GetExchangeRate",
                        type: "GET",
                        dataType: "json"
                    }).then(res => {
                        console.log("ExchangeRates:", res);
                        return res;
                    });
                }
            }),
            keyExpr: "ID",
            showBorders: true,
            height: "500px",
            selection: { mode: "single" },
            paging: { pageSize: 20 },
            pager: {
                showPageSizeSelector: true,
                allowedPageSizes: [20, 50, 100],
                showInfo: true
            },
            columnAutoWidth: false,   // BẮT BUỘC
            filterRow: { visible: true },
            columns: [
                { dataField: "dateTime", caption: "Date Time", dataType: "datetime", format: "dd/MM/yyyy" },
                { dataField: "fromCurrencyID", caption: "From Curr.", width: 80 },
                { dataField: "toCurrencyID", caption: "To Curr.", width: 70 },
                { dataField: "buyRate", caption: "Buy Rate", dataType: "number", format: "#,##0.00", width: 80 },
                { dataField: "sellRate", caption: "Sell Rate", dataType: "number", format: "#,##0.00", width: 80 },
                { dataField: "exChangeRateMax", caption: "Buy Rate Max", dataType: "number", format: "#,##0.00", width: 120 },
                { dataField: "denominationMax", caption: "Deno. Max", dataType: "number", width: 80 },
                { dataField: "exChangeRateMedium", caption: "Buy Rate Medium", dataType: "number", format: "#,##0.00", width: 120 },
                { dataField: "denominationMedium", caption: "Deno. Medium", dataType: "number", width: 90 },
                { dataField: "exChangeRateMin", caption: "Buy Rate Min", dataType: "number", format: "#,##0.00", width: 120 },
                { dataField: "denominationMin", caption: "Deno. Min", dataType: "number", width: 80 },
                { dataField: "createBy", caption: "Created By", width: 80 },
                { dataField: "createDate", caption: "Created Date", dataType: "date", format: "dd/MM/yyyy" },
                { dataField: "updateBy", caption: "Updated By", width: 80 },
                { dataField: "updateDate", caption: "Updated Date", dataType: "date", format: "dd/MM/yyyy" }
            ],
            scrolling: {
                mode: "standard",
                showScrollbar: "always",
                scrollByContent: true
            },
            paging: {
                pageSize: 50
            },
            pager: {
                visible: true,
                allowedPageSizes: [50, 100, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            filterRow: {
                visible: true,
                applyFilter: "auto"
            },
            onSelectionChanged: function (e) {
                if (e.selectedRowsData.length > 0) {
                    selectedRowData = e.selectedRowsData[0];
                    console.log("Selected Row:", selectedRowData);
                } else {
                    selectedRowData = null;
                }
            }
        });
    });

    // --- REUSED: Excel Export (Unchanged) ---
    $("#btnExportExcel").click(function () {
        const grid = $("#gridContainer").dxDataGrid("instance");
        const workbook = new ExcelJS.Workbook();
        const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
        const worksheet = workbook.addWorksheet("Sheet 1");

        worksheet.addRow([companyName]);
        worksheet.mergeCells('A1:D1');
        worksheet.getRow(1).font = { bold: true };
        worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

        const now = new Date();
        const exportDate = now.toLocaleString("vi-VN");
        worksheet.addRow(['', '', '', exportDate]);
        worksheet.mergeCells('D2:D2');
        worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

        worksheet.addRow([]);
        worksheet.addRow([]);

        const reportRow = worksheet.addRow(['Exchange Rate']);
        worksheet.mergeCells('A5:O5');
        reportRow.font = { bold: true, size: 14 };
        reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

        worksheet.addRow([]);

        DevExpress.excelExporter.exportDataGrid({
            component: grid,
            worksheet: worksheet,
            autoFilterEnabled: true,
            topLeftCell: { row: 7, column: 1 }
        }).then(function () {
            const lastRow = worksheet.lastRow.number + 2;
            worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
            worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
            worksheet.getCell(`A${lastRow}`).font = { italic: true };

            let fileName = "Exchange Rate.xlsx";

            workbook.xlsx.writeBuffer().then(function (buffer) {
                saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
            });
        });
    });
</script>
