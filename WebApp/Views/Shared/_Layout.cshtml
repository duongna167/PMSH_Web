<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    DevExpress.localization.locale("vi");
    document.addEventListener('DOMContentLoaded', function () {
        const isDesktop = () => window.innerWidth >= 992;
        const BOTTOM_THRESHOLD = 40; // px

        // ===============================
        //  SUBMENU (CẤP 2) 
        // ===============================
        document.querySelectorAll('.dropdown-submenu').forEach(item => {
            const submenu = item.querySelector('.dropdown-submenu-content');
            if (!submenu) return;
            let subHideTimeout = null;

            item.addEventListener('mouseenter', () => {
                if (!isDesktop()) return;
                clearTimeout(subHideTimeout);

                const toggle = item.querySelector('.dropdown-submenu-toggle');
                const rect = toggle.getBoundingClientRect();

                const viewportHeight = window.innerHeight;

                submenu.style.position = 'fixed';
                submenu.style.display = 'block';

                const submenuHeight = submenu.scrollHeight;
                const spaceAbove = rect.top;

                const style = window.getComputedStyle(toggle);
                const paddingTop = parseFloat(style.paddingTop);
                const borderTop = parseFloat(style.borderTopWidth) || 0;

                const subStyle = window.getComputedStyle(submenu);
                const subBorder = parseFloat(subStyle.borderTopWidth) || 0;

                let topPos = rect.top - subBorder;

                // Khoảng trống bên dưới
                const spaceBelow = viewportHeight - rect.bottom;

                // Nếu gần đáy màn hình → dịch lên nhẹ cho đẹp
                if (spaceBelow < submenuHeight + BOTTOM_THRESHOLD) {
                    const overflow = submenuHeight - spaceBelow;
                    topPos -= Math.min(overflow * 0.4, 24); // chỉ kéo lên 40%, tối đa 24px
                }

                // Chặn cứng không vượt màn hình
                topPos = Math.min(
                    Math.max(10, topPos),
                    viewportHeight - submenuHeight - 10
                );

                submenu.style.top = topPos + 'px';


                // Giới hạn chiều cao + scroll
                const maxHeight = Math.max(spaceBelow, spaceAbove) - 10;
                submenu.style.maxHeight = maxHeight + 'px';
                submenu.style.overflowY = 'auto';

                // Ngang trái / phải
                let leftPos = rect.right;
                if (rect.right + submenu.offsetWidth > window.innerWidth) {
                    leftPos = rect.left - submenu.offsetWidth;
                }
                submenu.style.left = leftPos + 'px';

                requestAnimationFrame(() => submenu.classList.add('menu-open'));
            });

            item.addEventListener('mouseleave', () => {
                if (!isDesktop()) return;
                subHideTimeout = setTimeout(() => {
                    if (!submenu.matches(':hover')) {
                        submenu.classList.remove('menu-open');
                        submenu.style.display = 'none';
                    }
                }, 200);
            });

            // Giữ menu mở khi chuột đang ở trong menu con
            submenu.addEventListener('mouseenter', () => {
                clearTimeout(subHideTimeout);
            });

            submenu.addEventListener('mouseleave', () => {
                if (!isDesktop()) return;
                subHideTimeout = setTimeout(() => {
                    if (!item.matches(':hover')) {
                        submenu.classList.remove('menu-open');
                        submenu.style.display = 'none';
                    }
                }, 200);
            });
        });

        // ===============================
        //: MENU CẤP 1 
        // ===============================
        document.querySelectorAll('.nav-item').forEach(item => {
            const dropdown = item.querySelector('.dropdown-menu-custom');
            if (!dropdown) return;
            let showTimeout, hideTimeout;

            item.addEventListener('mouseenter', () => {
                if (!isDesktop()) return;
                clearTimeout(hideTimeout);
                showTimeout = setTimeout(() => {
                    if (!item.matches(':hover')) return;
                    const rect = item.getBoundingClientRect();
                    dropdown.style.position = 'fixed';
                    dropdown.style.top = rect.bottom + 'px';
                    dropdown.style.left = rect.left + 'px';
                    dropdown.style.display = 'block';
                    requestAnimationFrame(() => dropdown.classList.add('menu-open'));
                }, 100);
            });

            item.addEventListener('mouseleave', () => {
                if (!isDesktop()) return;
                clearTimeout(showTimeout);
                hideTimeout = setTimeout(() => {
                    if (!dropdown.matches(':hover')) {
                        dropdown.classList.remove('menu-open');
                        setTimeout(() => { if (!dropdown.classList.contains('menu-open')) dropdown.style.display = 'none'; }, 200);
                    }
                }, 200);
            });

            dropdown.addEventListener('mouseleave', () => {
                if (!isDesktop()) return;
                hideTimeout = setTimeout(() => {
                    if (!item.matches(':hover')) {
                        dropdown.classList.remove('menu-open');
                        setTimeout(() => { if (!dropdown.classList.contains('menu-open')) dropdown.style.display = 'none'; }, 200);
                    }
                }, 200);
            });
        });

        // ===============================
        //  MOBILE: CLICK
        // ===============================
        // Xử lý Menu Cấp 1
        document.querySelectorAll('.nav-item > .nav-link').forEach(link => {
            link.addEventListener('click', function (e) {
                if (isDesktop()) return;
                const dropdown = this.nextElementSibling;
                if (dropdown && dropdown.classList.contains('dropdown-menu-custom')) {
                    e.preventDefault(); e.stopPropagation();
                    const isOpen = dropdown.style.display === 'block';
                    // Đóng tất cả
                    document.querySelectorAll('.dropdown-menu-custom').forEach(m => {
                        m.style.display = 'none'; m.classList.remove('menu-open');
                    });
                    // Mở cái hiện tại
                    if (!isOpen) {
                        dropdown.style.display = 'block';
                        dropdown.style.position = 'static'; // Mobile không dùng fixed
                        dropdown.classList.add('menu-open');
                    }
                }
            });
        });

        // Xử lý Menu Cấp 2 (Submenu)
        document.querySelectorAll('.dropdown-submenu-toggle').forEach(toggle => {
            toggle.addEventListener('click', function (e) {
                if (isDesktop()) return;
                e.preventDefault(); e.stopPropagation();
                const parent = this.parentElement;
                const submenu = this.nextElementSibling;
                parent.classList.toggle('active');
                if (submenu) {
                    submenu.style.display = parent.classList.contains('active') ? 'block' : 'none';
                    submenu.style.position = 'static';
                    submenu.classList.toggle('menu-open', parent.classList.contains('active'));
                }
            });
        });

        // Xử lý scroll: Đóng menu desktop khi cuộn chuột để tránh menu bay lung tung
        window.addEventListener('scroll', () => {
            if (isDesktop()) {
                document.querySelectorAll('.menu-open').forEach(el => {
                    el.classList.remove('menu-open');
                    el.style.display = 'none';
                });
            }
        });
    });

