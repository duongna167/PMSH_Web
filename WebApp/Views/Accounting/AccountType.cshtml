@using DevExpress.XtraReports.UI


@{
    var selectedReport = @ViewBag.ReportHeader;

    var currencylist = ViewBag.CurrencyList;
}

<style>

</style>
<div class="text-center" id="reportTitle" style="font-size: 20px">Account Type</div>
<div class="sticky-header bg-white p-2 shadow-sm z-3">
    <div class="">
        <button id="btnPrint" class="mui-button mui-button-new"> View</button>
        <button id="btnNew" class="mui-button mui-button-new"> New</button>
        <button id="btnUpdate" class="mui-button mui-button-edit">  Edit</button>
        <button id="btnDelete" class="mui-button button-report-delete"> 
            Delete</button>
        <button id="btnExportExcel" class="mui-button mui-button-export" type="button"> Excel</button>
    </div>
</div>
<div class="mui-card">
    <div id="gridContainer" class="gridContainer mt-2"></div>
</div>

<div class="modal fade" id="itemModal" tabindex="-1" data-bs-backdrop="static" aria-labelledby="itemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header">
                <h5 class="modal-title" id="itemModalLabel">AR Account Type</h5>
            </div>
            <!-- FOOTER -->
            <div class="modal-footer justify-content-start py-2">
                <div>
                    <button id="btnOkAuto" class="mui-button mui-button-advance" type="button"> Ok</button>
                    <button id="btnSaveAuto" class="mui-button mui-button-new" type="button"> Save</button>
                    <button type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">
                        Close
                    </button>
                </div>
            </div>
            <!-- BODY -->
            <div class="modal-body p-4">
                <form id="formContainer">
                    <input type="hidden" id="id" name="id" value="0" />

                    <div class="container-fluid">
                        <div class="mb-4">
                            <h6 class="fw-bold mb-3 border-bottom pb-2">
                                Info
                            </h6>

                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold" for="typeacc">Type</label>
                                    <input type="text" id="typeacc" name="typeacc" class="form-control form-control-sm" />
                                </div>

                                <div class="col-md-8">
                                    <label class="form-label small fw-bold" for="descriptionaccty">Description</label>
                                    <input type="text" id="descriptionaccty" name="descriptionaccty" class="form-control form-control-sm" />
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label small fw-bold">Credit Limit</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" id="creditLimit" name="creditLimit" class="form-control" />
                                        <select id="currencyacc" name="" class="form-select w-auto flex-grow-0" style="min-width: 80px;">
                                            @foreach (var item in currencylist)
                                            {
                                                <option value="@item.ID" selected="@(item.ID == "VND" ? "selected" : null)">@item.ID</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label small fw-bold" for="statementmode">Statement Mode</label>
                                    <select id="statementmode" name="statementmode" class="form-select form-select-sm">
                                        <option value="Individual Open Items">Individual Open Items</option>
                                        <option value="Balance Brought Forward">Balance Brought Forward</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label small fw-bold" for="remindercycle">Reminder Cycle</label>
                                    <select id="remindercycle" name="remindercycle" class="form-select form-select-sm">
                                        <option value="End of Month">End of Month</option>
                                        <option value="Days">Days</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="mb-2">
                            <h6 class="fw-bold mb-3 border-bottom pb-2">
                                Finance Charges
                            </h6>

                            <div class="row g-3 align-items-end">
                                <div class="col-md-3">
                                    <label class="form-label small fw-bold" for="dayofmonth">Day of Month</label>
                                    <input type="number" id="dayofmonth" name="dayofmonth" class="form-control form-control-sm" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Charge Calculation</label>
                                    <div class="d-flex align-items-center bg-light p-1 rounded border" style="min-height: 38px;">
                                        <div class="form-check form-check-inline d-flex align-items-center mb-0 ms-2">
                                            <input class="form-check-input mt-0" type="checkbox" id="amount" name="includeOptionsTurndown" value="amount">
                                            <label class="form-check-label small ms-2" for="amount">Amount</label>
                                        </div>

                                        <div class="form-check form-check-inline d-flex align-items-center mb-0">
                                            <input class="form-check-input mt-0" type="checkbox" id="percentage" name="includeOptionsTurndown" value="percentage">
                                            <label class="form-check-label small ms-2" for="percentage">Percentage</label>
                                        </div>

                                        <input type="number" id="amountorPercentage" name="amountorPercentage"
                                               class="form-control form-control-sm ms-auto me-1" style="width: 80px;" />
                                    </div>
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label small fw-bold" for="dayolderthan">Days Older Than</label>
                                    <input type="number" id="dayolderthan" name="dayolderthan" class="form-control form-control-sm" />
                                </div>

                                <div class="col-12">
                                    <div class="form-check d-flex align-items-center mt-2">
                                        <input class="form-check-input mt-0" type="checkbox" id="includeUnallocated" name="includeOptions" value="1">

                                        <label class="form-check-label small fw-bold text-secondary ms-2 mb-0" for="includeUnallocated">
                                            Include Unallocated Payments
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>


<div id="loadingSpinner"
    style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:1000;">
    <i class="fa-solid fa-spinner fa-spin"></i>
</div>

<script>

    $(document).ready(function () {
        $("#btnPrint").trigger("click");

    });
    function clearAccountTypeForm() {
        // Xóa giá trị của input text/number
        $("#typeacc").val("");
        $("#descriptionaccty").val("");
        $("#creditLimit").val("");
        $("#dayofmonth").val("");
        $("#amountorPercentage").val("");
        $("#dayolderthan").val("");

        // Reset select
        $("#currencyacc").val("");
        $("#statementmode").val("Individual Open Items");
        $("#remindercycle").val("End of Month");

        // Bỏ check checkbox
        $("#amount").prop("checked", false);
        $("#percentage").prop("checked", false);
        $("#includeUnallocated").prop("checked", false);
    }

    $(document).off("click", "#btnPrint").on("click", "#btnPrint", function () {
        $("#loadingSpinner").show();
        $.ajax({
            url: '/Accounting/AccountTypeData',
            type: 'GET',
            data: {

            },
            traditional: true,
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                // $("#reportViewerContainer").html(result);
                // $("#loadingSpinner").hide();
                console.log(result);
                initializeAccountTypeGrid(result);
                $("#loadingSpinner").hide();
            },
            error: function () {
                alert("Không th? t?i báo cáo.");
                $("#loadingSpinner").hide();
            }
        });
    });
    var selectedRowData = null;
        function initializeAccountTypeGrid(data) {
        $("#gridContainer").dxDataGrid({
            dataSource: data,
            showBorders: true,
            height: 500,
            selection: { mode: "single" },
            allowColumnResizing: true, // Cho phép người dùng chỉnh lại nếu cần
            columnAutoWidth: false,
            wordWrapEnabled: true, // Tự động xuống dòng nếu tiêu đề dài
            columns: [
                { dataField: "id", caption: "ID", visible: false },
                { dataField: "type", caption: "Type", width: 100, fixed: true }, // Cố định cột quan trọng
                { dataField: "description", caption: "Description", minWidth: 200 }, // Để cột này tự co giãn theo diện tích còn lại

                // Nhóm tài chính
                { dataField: "creditLimit", caption: "Credit Limit", dataType: "number", format: "#,##0", width: 110 },
                { dataField: "currencyID", caption: "Curr.", width: 60 }, // Viết tắt Currency

                // Nhóm cấu hình
                { dataField: "statementMode", caption: "Stmt. Mode", width: 130 }, // Viết tắt Statement
                { dataField: "reminderCycle", caption: "Remind Cycle", width: 110 },
                { dataField: "dayOfMonth", caption: "Day/Month", dataType: "number", width: 80},

                // Nhóm phí
                { dataField: "percentage", caption: "%", dataType: "number", format: "percent", width: 70},
                { dataField: "amount", caption: "Charge Amt", dataType: "number", format: "#,##0", width: 100 },
                { dataField: "dayOrderThan", caption: "Days > Than", dataType: "number", width: 100 },

                {
                    dataField: "includePayment",
                    caption: "Incl. Pay",
                    alignment: "center",
                    width: 85,
                    cellTemplate: function (container, options) {
                        let checked = options.value == 1;
                        container.addClass("d-flex justify-content-center align-items-center");
                        $("<div>")
                            .dxCheckBox({
                                value: checked,
                                readOnly: true
                            })
                            .css("transform", "scale(0.8)")
                            .appendTo(container);
                    }
                },

                // Nhóm thông tin hệ thống (Thu hẹp vì ít quan trọng hơn)
                { dataField: "userInsert", caption: "User Ins", width: 100},
                { dataField: "createdDate", caption: "Created Date", dataType: "date", format: "dd/MM/yyyy", width: 110 },
                { dataField: "userUpdate", caption: "User Update", width: 100 },
                { dataField: "updatedDate", caption: "Updated Date", dataType: "date", format: "dd/MM/yyyy", width: 110 }
            ],
            scrolling: {
                mode: "standard",
                showScrollbar: "always",
            },
            paging: { pageSize: 50 },
            pager: {
                visible: true,
                allowedPageSizes: [50, 100, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            filterRow: {
                visible: true,
                applyFilter: "auto"
            },
            onRowClick: function (e) {
                selectedRowData = e.data;
            }
        });
    }

    $(document).off("click", "#btnOkAuto").on("click", "#btnOkAuto", function () {
        var values = $("input[name='includeOptionsTurndown']:checked").map(function () {
            return this.value;
        }).get();

        $("#loadingSpinner").show();
        let loginName = (localStorage.getItem("Loginname") || "")
            .trim()
            .replace(/^"(.*)"$/, '$1');
        const loginUser = parseInt(localStorage.getItem("userID")) || 0;
        $.ajax({
            url: '/Accounting/AccountTypeSave',
            type: 'POST',
            data: {
                typeacc: $("#typeacc").val(),
                descriptionaccty: $("#descriptionaccty").val(),
                creditLimit: $("#creditLimit").val(),
                currencyacc: $("#currencyacc").val(),
                statementmode: $("#statementmode").val(),
                remindercycle: $("#remindercycle").val(),
                dayofmonth: $("#dayofmonth").val(),
                check: values,
                dayolderthan: $("#dayolderthan").val(),
                amountorPercentage: $("#amountorPercentage").val(),
                includePayment: $("#includeUnallocated").is(":checked"),
                id: $("#id").val(),
                user: loginName
            },
            traditional: true,
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                if (result.success) {
                    showToast('Success', result.message, true);
                    $("#btnPrint").trigger("click");
                    clearAccountTypeForm();
                } else {
                    showToast('Error', 'Please select a Task Code before saving.', false);
                }

            },
            error: function () {
                alert("Không th? t?i báo cáo.");
                $("#loadingSpinner").hide();
            }
        });
    });


    $(document).off("click", "#btnDelete").on("click", "#btnDelete", function () {
        if (!selectedRowData) {
            showToast("Warning","Please select a line to delete.", false);
            return;
        }

        if (!confirm("Are you sure you want to delete this record?")) {
            return; 
        }

        $.ajax({
            url: '/Accounting/AccountTypeDelete',
            type: 'POST',
            data: {
                id: selectedRowData.id


            },
            traditional: true,
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                if (result.success) {
                    showToast('Success', result.message, true);
                    $("#btnPrint").trigger("click");
                } else {
                    showToast('Error', 'Please select a Task Code before saving.', false);
                }

            },
            error: function () {
                alert("Không th? t?i báo cáo.");
                $("#loadingSpinner").hide();
            }
        });


    });

    $(document).off("click", "#btnUpdate").on("click", "#btnUpdate", function () {
        if (!selectedRowData) {
            showToast("Warning","Please select a line to edit.", false);
            return;
        }

        // Gán giá trị từ row vào form
        $("#idcaacountype").val(selectedRowData.id);
        $("#typeacc").val(selectedRowData.type);
        $("#descriptionaccty").val(selectedRowData.description);
        $("#creditLimit").val(selectedRowData.creditLimit);
        $("#currencyacc").val(selectedRowData.currencyID);

        $("#statementmode").val(selectedRowData.statementMode);
        $("#remindercycle").val(selectedRowData.reminderCycle);

        $("#dayofmonth").val(selectedRowData.dayOfMonth);
        $("#dayolderthan").val(selectedRowData.dayOrderThan);

        // Amount / Percentage
        if (selectedRowData.amount > 0) {
            $("#amount").prop("checked", true);
            $("#amountorPercentage").val(selectedRowData.amount);
        } else {
            $("#amount").prop("checked", false);
        }

        if (selectedRowData.percentage > 0) {
            $("#percentage").prop("checked", true);
            $("#amountorPercentage").val(selectedRowData.percentage);
        } else {
            $("#percentage").prop("checked", false);
        }

        // Include Payment (checkbox)
        if (selectedRowData.includePayment == 1) {
            $("#includeUnallocated").prop("checked", true);
        } else {
            $("#includeUnallocated").prop("checked", false);
        }
        $("#itemModalLabel").text("Update AR Account Type");

        // Hiển thị popup
        $("#itemModal").modal("show");

    });


    $(document).off("click", "#btnSaveAuto").on("click", "#btnSaveAuto", function () {
        var values = $("input[name='includeOptionsTurndown']:checked").map(function () {
            return this.value;
        }).get();

        $("#loadingSpinner").show();
        $.ajax({
            url: '/Accounting/AccountTypeSave',
            type: 'POST',
            data: {
                typeacc: $("#typeacc").val(),
                descriptionaccty: $("#descriptionaccty").val(),
                creditLimit: $("#creditLimit").val(),
                currencyacc: $("#currencyacc").val(),
                statementmode: $("#statementmode").val(),
                remindercycle: $("#remindercycle").val(),
                dayofmonth: $("#dayofmonth").val(),
                check: values,
                dayolderthan: $("#dayolderthan").val(),
                amountorPercentage: $("#amountorPercentage").val(),
                includePayment: $("#includeUnallocated").is(":checked"),
                id: $("#id").val(),
                user: localStorage.getItem("Loginname")

            },
            traditional: true,
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                if (result.success) {
                    showToast('Success', result.message, true);
                    clearAccountTypeForm();
                    $("#loadingSpinner").hide();
                } else {
                    showToast('Error', 'Please select a Task Code before saving.', false);
                }

            },
            error: function () {
                alert("Không th? t?i báo cáo.");
                $("#loadingSpinner").hide();
            }
        });
    });


    $("#btnNew").on("click", function () {
        $("#formContainer")[0].reset();
        $("#id").val("0");
        $("#itemModalLabel").text("Add AR Account Type");

        $("#itemModal").modal("show");
    });

    $("#btnExportExcel").click(function () {
        const grid = $("#gridContainer").dxDataGrid("instance");  

        const workbook = new ExcelJS.Workbook();
        const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
        const worksheet = workbook.addWorksheet("Sheet 1");

        // === Dòng 1: Tên công ty (merge theo 4 cột) ===
        worksheet.addRow([companyName]);
        worksheet.mergeCells('A1:D1');
        worksheet.getRow(1).font = { bold: true };
        worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

        // === Dòng 2: Ngày giờ xuất (bên phải) ===
        const now = new Date();
        const exportDate = now.toLocaleString("vi-VN");
        worksheet.addRow(['', '', '', exportDate]);
        worksheet.mergeCells('D2:D2');  // cột D thôi
        worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

        // === Dòng 3–4: trống
        worksheet.addRow([]);
        worksheet.addRow([]);

        // === Dòng 5: Tiêu đề báo cáo (ở giữa) ===
        const reportRow = worksheet.addRow(['AR Accounting Type']);
        worksheet.mergeCells('A5:D5');
        reportRow.font = { bold: true, size: 14 };
        reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

        // === Dòng 6: trống
        worksheet.addRow([]);

        // === Xuất dữ liệu grid bắt đầu từ dòng 7 ===
        DevExpress.excelExporter.exportDataGrid({
            component: grid,
            worksheet: worksheet,
            autoFilterEnabled: true,
            topLeftCell: { row: 7, column: 1 }
        }).then(function () {
            // Footer (sau cùng)
            const lastRow = worksheet.lastRow.number + 2;
            worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
            worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
            worksheet.getCell(`A${lastRow}`).font = { italic: true };

            // Ghi file
            let fileName = "ARAccountType.xlsx";
            workbook.xlsx.writeBuffer().then(function (buffer) {
                saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
            });
        });
    });
</script>
