<script>
    $(document).ready(async function () {
        window.tomSelectInstances = window.tomSelectInstances || {};
        await setSelectIndividual();
        await blindValue();
    });

    // const tomSelectInstances = {};
    async function setSelectIndividual() {
        const configs = [
            "#pro_search_select-beast-empty",
            "#pro_search_txtLanguageIndividual",
            "#pro_search_txtTitleIndividual",
            "#pro_search_txtNationalityIndividual",
            "#pro_search_txtCountryIndividual",
            "#pro_search_txtStateIndividual",
            "#pro_search_txtCityIndividual",
            "#pro_search_txtVIPIndividual",
        ];

        for (const id of configs) {
            const el = document.querySelector(id);
            if (!el) continue;

            if (tomSelectInstances[id]) {
                tomSelectInstances[id].destroy();
            }

            tomSelectInstances[id] = new TomSelect(el, {
                valueField: 'value',
                labelField: 'text',
                searchField: 'text',
                create: false,
                allowEmptyOption: true,
                plugins: ['clear_button']
            });
        }
    }

    $(document).on('keydown', '#pro_search_nameIndividual, #pro_search_firstNameIndividual_Search', async function (e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            await blindValue();
        }
    });

    // Blacklist Logic
    $('#pro_search_blackListIndividual').on('change', function () {
        const isChecked = this.checked;
        $('#pro_search_blackListReasonIndividual').prop('disabled', !isChecked).toggleClass('is-invalid', false);
        if (isChecked) { $('#pro_search_blackListReasonIndividual').css({ 'background-color': 'black', 'color': 'white' }); }
        else { $('#pro_search_blackListReasonIndividual').css({ 'background-color': '', 'color': '' }); }
    });

    $('#pro_search_txtCheckboxDobIndividual').on('change', function () {
        const isChecked = $(this).is(':checked');
        const $wrapper = $('[data-name="pro_search_txtDobIndividual"]');
        $wrapper.find('input').prop('disabled', isChecked);
    });

    // --- UI HELPERS ---
    function openModalSearch() {
        $('#pro_search_modalIndividualSearch').modal('show');
    }

    function closeModalSearch() {
        clearIndividualSearchModal();
        $('#pro_search_modalIndividualSearch').modal('hide');
    }

    //Fill dữ liệu cho Individual
    function selectGroup(selectedRowData) {
        if (!selectedRowData) return;
        console.log('selectedRowData:', selectedRowData);

        $('#pro_search_idIndividual').val(selectedRowData.id ?? '');

        // ===== BASIC INFO =====
        $('#pro_search_txtCodeIndividual').val(selectedRowData.code ?? '');
        $('#pro_search_txtFullNameIndividual').val(selectedRowData.account ?? '');
        $('#pro_search_txtFirstNameIndividual').val(selectedRowData.firstname ?? '');
        $('#pro_search_txtLastNameIndividual').val(selectedRowData.lastName ?? '');
        $('#pro_search_txtMiddleNameIndividual').val(selectedRowData.middleName ?? '');

        // ===== TOMSELECT =====
        setTomSelectValue('#pro_search_txtLanguageIndividual',
            selectedRowData.languageID,
            selectedRowData.languageName
        );

        setTomSelectValue('#pro_search_txtTitleIndividual',
            selectedRowData.titleID,
            selectedRowData.titleName
        );

        setTomSelectValue('#pro_search_txtNationalityIndividual',
            selectedRowData.nationalityID,
            selectedRowData.nationalityName
        );

        setTomSelectValue('#pro_search_txtCountryIndividual',
            selectedRowData.countryID,
            selectedRowData.countryName
        );

        setTomSelectValue('#pro_search_txtStateIndividual',
            selectedRowData.stateID,
            selectedRowData.stateName
        );

        setTomSelectValue('#pro_search_txtCityIndividual',
            selectedRowData.cityID,
            selectedRowData.cityName
        );

        setTomSelectValue('#pro_search_txtVIPIndividual',
            selectedRowData.vipid,
            selectedRowData.vipName
        );

        // ===== TEXT FIELDS =====
        $('#pro_search_txtPostalIndividual').val(selectedRowData.postalCode ?? '');
        $('#pro_search_txtReligionIndividual').val(selectedRowData.religion ?? '');
        $('#pro_search_txtNationIndividual').val(selectedRowData.nation ?? '');
        $('#pro_search_txtPurposeIndividual').val(selectedRowData.purposeOfStay ?? '');

        $('#pro_search_txtAddressIndividual').val(selectedRowData.address ?? '');
        $('#pro_search_txtBusAddressIndividual').val(selectedRowData.homeAddress ?? '');

        $('#pro_search_txtTelephoneIndividual').val(selectedRowData.telephone ?? '');
        $('#pro_search_txtHandPhoneIndividual').val(selectedRowData.handPhone ?? '');
        $('#pro_search_txtFaxIndividual').val(selectedRowData.fax ?? '');
        $('#pro_search_txtEmailIndividual').val(selectedRowData.email ?? '');
        $('#pro_search_txtWebsiteIndividual').val(selectedRowData.website ?? '');

        $('#pro_search_txtCompany2Individual').val(selectedRowData.company ?? '');
        $('#pro_search_txtBusinessTitleIndividual').val(selectedRowData.businessTitle ?? '');
        $('#pro_search_txtCompanyIndividual').val(selectedRowData.company ?? '');

        $('#pro_search_txtTaxIndividual').val(selectedRowData.taxCode ?? '');
        $('#pro_search_txtPassportIndividual').val(selectedRowData.passPort ?? '');
        $('#pro_search_txtCardIndividual').val(selectedRowData.identityCard ?? '');

        $('#pro_search_txtSalutationIndividual').val(selectedRowData.salutation ?? '');
        $('#pro_search_txtReasonIndividual').val(selectedRowData.vipReason ?? '');

        // ===== DOB =====
        var dobValue = selectedRowData.dateOfBirth;

        if (dobValue) {
            UI.setHiddenDate("pro_search_txtDobIndividual", dobValue);
            $('#pro_search_txtCheckboxDobIndividual').prop('checked', false);
            $('[data-name="pro_search_txtDobIndividual"]').find('input').prop('disabled', false);

        } else {
            UI.setHiddenDate("pro_search_txtDobIndividual", "1900-01-01");
            $('[data-name="pro_search_txtDobIndividual"]').find('input').prop('disabled', false);
        }

        // ===== STATUS =====
        $('#pro_search_txtActiveIndividual').prop('checked', !!selectedRowData.active);
        $('#pro_search_txtContactIndividual').prop('checked', !!selectedRowData.contact);

        $('#pro_search_txtKeywordIndividual').val(selectedRowData.keyword ?? '');
        $('#pro_search_txtNoteIndividual').val(selectedRowData.description ?? '');

        // ===== BLACKLIST =====
        $('#pro_search_blackListIndividual').prop('checked', !!selectedRowData.isBlackList);
        $('#pro_search_blackListReasonIndividual')
            .val(selectedRowData.blackListReason ?? '')
            .prop('disabled', !selectedRowData.isBlackList);

        closeModalSearch();
    }

    async function selectIndividual(id) {
        try {
            $("#pro_search_loadingSpinner").show();
            const res = await $.ajax({ url: 'FindIndividualByID/', method: "GET", data: { id: id } });
            if (!res?.success) { showToast('Error', res?.message || 'Failed.', false); return; }
            const pkg = res.data;
            selectGroup(pkg);
            $("#pro_search_loadingSpinner").hide();
        } catch (error) { console.error(error); $("#pro_search_loadingSpinner").hide(); }
    }

    async function initializeProfileIndividualGrid(data) {
        $("#pro_search_profileIndividualGrid").dxDataGrid({
            dataSource: data || [],
            showBorders: true,
            selection: { mode: "single" },
            paging: { pageSize: 20 },
            height: "300px",
            pager: { showPageSizeSelector: true, allowedPageSizes: [5, 10, 20], showInfo: true },
            filterRow: { visible: true },
            columns: [{ dataField: "id", caption: "ID", visible: false }, { dataField: "name", caption: "Name" }],
            scrolling: { mode: "standard", showScrollbar: "always", scrollByContent: true },
            onRowClick: async function (e) {
                const selectedRowId = e.data.id;
                await selectIndividual(selectedRowId);
            },
            noDataText: "No records to display"
        });
    }

    async function getProfileIndividualSreach(value) {
        try {
            $("#pro_search_loadingSpinner").show();
            const res = await $.ajax({ url: '/ProfileIndividualSreach/', method: "GET", data: { LastName: value.name, FirstName: value.firstName } });
            if (!res?.success) { showToast('Error', res?.message || 'Failed.', false); return; }
            initializeProfileIndividualGrid(res.data);
            $("#pro_search_loadingSpinner").hide();
        } catch (error) { console.error(error); $("#pro_search_loadingSpinner").hide(); }
    }

    async function blindValue() {
        const searchModel = {
            name: document.getElementById('pro_search_nameIndividual').value.trim(),
            firstName: document.getElementById('pro_search_firstNameIndividual_Search').value.trim()
        };
        await getProfileIndividualSreach(searchModel);
    }

    function bindIndividualSearch() {
        const inputs = ['pro_search_nameIndividual', 'pro_search_firstNameIndividual_Search'];
        inputs.forEach(id => {
            const el = document.getElementById(id);
            if (!el) return;
            el.addEventListener('keydown', async function (event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    await blindValue();
                }
            });
        });
    }

    async function bindIndividualSearchButton() {
        const btn = document.getElementById('pro_search_btnViewIndividual');
        if (btn) {
            btn.addEventListener('click', async function () {
                await blindValue();
            });
        }
    }

    bindIndividualSearch();
    bindIndividualSearchButton();

    function clearIndividualSearchModal() {
        $('#pro_search_nameIndividual').val('');
        $('#pro_search_firstNameIndividual_Search').val('');

        const grid = $('#pro_search_profileIndividualGrid').dxDataGrid('instance');
        if (grid) {
            grid.option('dataSource', []);
            grid.clearSelection();
        }
    }
</script>
