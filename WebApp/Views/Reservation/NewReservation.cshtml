    function focusNewReservationFirstField() {
        function getRoot() {
            var modalBody = document.getElementById('newReservationModalBody');
            if (modalBody) return $(modalBody);
            var layout = document.querySelector('.container-new-reservation');
            if (layout) return $(layout);
            return $('body');
        }
        function attempt() {
            var $root = getRoot();
            var $target = $root.find('#txtName').filter(':visible').first();
            if (!$target.length) {
                $target = $root.find('input:not([type="hidden"]):not([type="button"]):not([type="submit"]):not([type="reset"])')
                    .filter(':visible:not([disabled])').first();
            }
            if (!$target.length) {
                $target = $root.find('select:visible:not([disabled]), textarea:visible:not([disabled])').first();
            }
            if (!$target.length) return false;
            var el = $target[0];
            if (el) {
                el.focus();
                if (el.tagName === 'INPUT' && (!el.type || el.type === 'text' || el.type === 'search')) {
                    try { el.select(); } catch (e) { }
                }
            }
            return true;
        }
        [0, 80, 220].forEach(function (delay) {
            window.setTimeout(attempt, delay);
        });
    }
    window.focusNewReservationFirstField = focusNewReservationFirstField;

