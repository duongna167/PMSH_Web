    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Profile Options</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="toolbar-menu mt-2 row" id="pro_search_functionAndOption">
                    <a href="#" class="font-semibold col-md-6 mb-1" id="pro_search_btnChanges">Changes</a>
                    <a href="#" class="font-semibold col-md-6 mb-1" id="pro_search_btnDelete">Delete</a>
                    <a href="#" class="font-semibold col-md-6 mb-1" id="pro_search_btnFuture">Future</a>
                    <a href="#" class="font-semibold col-md-6 mb-1" id="pro_search_btnHistory">History</a>
                    <a href="#" class="font-semibold col-md-6 mb-1" id="pro_search_btnMembership">Memberships</a>
                    <a href="#" class="font-semibold col-md-6 mb-1" id="pro_search_btnMerge">Merge</a>
                    <a href="#" class="font-semibold col-md-6 mb-1" id="pro_search_btnNegRate">Neg.Rates</a>
                    <a href="#" class="font-semibold col-md-6 mb-1" id="pro_search_btnProfileUpdate">Profile Update</a>
                    @* <a href="#" class="font-semibold col-md-6 mb-1" id="pro_search_btnRelationship">Relationships</a> *@
