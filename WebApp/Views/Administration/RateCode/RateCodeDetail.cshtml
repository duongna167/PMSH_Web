<script>
    var rtCD_Module = (function () {

        let mainModal = null;
        let upsertModal = null;

        let gridRateCodes = null;
        let gridGrouped = null;
        let gridDetails = null;

        let selectedRateCodesRow = null;   // from left grid
        let selectedGroupedRow = null;     // from grouped grid
        let selectedDetailId = null;       // from bottom grid selection

        const sel = {
            modalMain: "#rtCD_modalMain",
            modalUpsert: "#rtCD_modalUpsert",

            btnView: "#rtCD_btnView",
            btnNew: "#rtCD_btnNew",
            btnEdit: "#rtCD_btnEdit",
            btnDelete: "#rtCD_btnDelete",
            btnExportExcel: "#rtCD_btnExportExcel",
            btnClose: "#rtCD_btnClose",

            code: "#rtCD_code",
            category: "#rtCD_category",
            typeDate: "#rtCD_typeDate",
            fromDateUi: "#rtCD_fromDateUi",
            toDateUi: "#rtCD_toDateUi",

            gridRateCodes: "#rtCD_gridRateCodes",
            gridGrouped: "#rtCD_gridRateDetailsGrouped",
            gridDetails: "#rtCD_gridDetails",

            loading: "#rtCD_loadingSpinner",

            form: "#rtCD_form",
            upsertTitle: "#rtCD_upsertTitle",
            btnSave: "#rtCD_btnSave",
            btnSaveClose: "#rtCD_btnSaveClose",

            modalDetailId: "#rtCD_modalDetailId",
            txtRateCode: "#rtCD_txtRateCode",
            selRoomType: "#rtCD_selRoomType",
            txtBeginDate: "#rtCD_txtBeginDate",
            txtEndDate: "#rtCD_txtEndDate",
            selTransaction: "#rtCD_selTransaction",
            selPackage: "#rtCD_selPackage",
            txtCurrency: "#rtCD_txtCurrency",
            txtMinLOS: "#rtCD_txtMinLOS",
            txtMaxLOS: "#rtCD_txtMaxLOS",
            txtAmount: "#rtCD_txtAmount",
            txtPercentage: "#rtCD_txtPercentage",
            txtDescription: "#rtCD_txtDescription",
            chkActive: "#rtCD_chkActive"
        };

        function init() {
            mainModal = bootstrap.Modal.getOrCreateInstance(document.querySelector(sel.modalMain), { backdrop: "static" });
            upsertModal = bootstrap.Modal.getOrCreateInstance(document.querySelector(sel.modalUpsert), { backdrop: "static" });

            $(sel.modalMain).off("shown.bs.modal.rtCD").on("shown.bs.modal.rtCD", async function () {
                bindEvents();

                // Init selects + date inputs (reuse your shared helpers if present)
                try { if (typeof window.initTomSelect === "function") window.initTomSelect(".tomselect-custom"); } catch { }
                try { if (typeof window.initDateInputs === "function") await window.initDateInputs(); } catch { }

                await reloadAll(isInitial = true);
            });

            $(sel.modalMain).off("hidden.bs.modal.rtCD").on("hidden.bs.modal.rtCD", function () {
                cleanup();
            });

            $(sel.modalUpsert).off("hidden.bs.modal.rtCD").on("hidden.bs.modal.rtCD", function () {
                clearForm();
                if (typeof window.applyValidationErrors === "function") applyValidationErrors([], sel.form);
            });
        }

        function open() {
            mainModal.show();
        }

        function bindEvents() {
            $(document).off("click.rtCD", sel.btnView).on("click.rtCD", sel.btnView, function () {
                reloadAll(false);
            });

            $(document).off("click.rtCD", sel.btnNew).on("click.rtCD", sel.btnNew, function () {
                openNew();
            });

            $(document).off("click.rtCD", sel.btnEdit).on("click.rtCD", sel.btnEdit, function () {
                openEdit();
            });

            $(document).off("click.rtCD", sel.btnDelete).on("click.rtCD", sel.btnDelete, function () {
                doDelete();
            });

            $(document).off("click.rtCD", sel.btnExportExcel).on("click.rtCD", sel.btnExportExcel, function () {
                exportExcel();
            });

            $(document).off("click.rtCD", sel.btnClose).on("click.rtCD", sel.btnClose, function () {
                mainModal.hide();
            });

            $(document).off("click.rtCD", sel.btnSave).on("click.rtCD", sel.btnSave, function () {
                save(false);
            });

            $(document).off("click.rtCD", sel.btnSaveClose).on("click.rtCD", sel.btnSaveClose, function () {
                save(true);
            });
        }

        function cleanup() {
            $(document).off(".rtCD");
            destroyGrid(sel.gridRateCodes, gridRateCodes); gridRateCodes = null;
            destroyGrid(sel.gridGrouped, gridGrouped); gridGrouped = null;
            destroyGrid(sel.gridDetails, gridDetails); gridDetails = null;

            selectedRateCodesRow = null;
            selectedGroupedRow = null;
            selectedDetailId = null;
        }

        function showLoading(on) {
            if (on) $(sel.loading).show(); else $(sel.loading).hide();
        }

        // --------- API ---------
        async function apiGetAllRateCodeDetail() {
            return $.ajax({
                url: "/Administration/RateCode/GetAllRateCodeDetail",
                type: "GET",
                data: {
                    rateCode: $(sel.code).val(),
                    rateCategory: $(sel.category).val(),
                    typeOfDate: $(sel.typeDate).val(),
                    fromDate: $("#rtCD_fromDate").val() || $(sel.fromDateUi).val(), // allow hidden ISO if you use DateInput
                    toDate: $("#rtCD_toDate").val() || $(sel.toDateUi).val()
                },
                traditional: true,
                crossDomain: false,
                headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() }
            });
        }

        async function apiRateCodeGroupDataByID(rateCodeID) {
            return $.ajax({
                url: "/Administration/RateCode/RateCodeGroupDataByID",
                type: "GET",
                data: { rateCodeID: rateCodeID }
            });
        }

        async function apiGetDetails(groupRow) {
            return $.ajax({
                url: "/Administration/RateCode/GetDetails",
                type: "GET",
                data: {
                    RateCodeID: groupRow.rateCodeID,
                    BeginDate: groupRow.beginDate,
                    EndDate: groupRow.endDate,
                    RoomType: groupRow.roomType,
                    TransCode: groupRow.transaction,
                    CurrencyID: groupRow.curr,
                    PackageID: groupRow.packageID,
                    A1: groupRow.a1,
                    A2: groupRow.a2,
                    A3: groupRow.a3,
                    A4: groupRow.a4,
                    A5: groupRow.a5,
                    A6: groupRow.a6,
                    C1: groupRow.c1,
                    C2: groupRow.c2,
                    C3: groupRow.c3,
                    MinLOS: groupRow.minLOS,
                    MaxLOS: groupRow.maxLOS,
                    MinRoom: groupRow.minNoOfRoom,
                    MaxRoom: groupRow.maxNoOfRoom
                },
                traditional: true,
                crossDomain: false,
                headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() }
            });
        }

        // --------- LOAD ---------
        async function reloadAll(isInitial = false) {
            try {
                showLoading(true);

                // Optional: wait for business date if your DateInput sets hidden ISO fields
                // If you want strict ISO, you can adapt to your `waitForBusinessDate` helpers.
                if (isInitial) {
                    try {
                        if (typeof window.waitForBusinessDate === "function") {
                            // if your date inputs are named rtCD_fromDate/rtCD_toDate
                            await waitForBusinessDate("rtCD_fromDate", 10000);
                            await waitForBusinessDate("rtCD_toDate", 10000);
                        }
                    } catch { }
                }

                const rateCodes = await apiGetAllRateCodeDetail();

                if (!Array.isArray(rateCodes) || !rateCodes.length) {
                    renderAllGrids([], [], []);
                    showToast("Warning", "No Rate Code data found.", false);
                    return;
                }

                // default pick first row's idRateCode (kept behavior)
                const firstRateCodeID = rateCodes[0].idRateCode;
                const grouped = await apiRateCodeGroupDataByID(firstRateCodeID);

                const firstGroupRow = Array.isArray(grouped) && grouped.length ? grouped[0] : null;
                const details = firstGroupRow ? await apiGetDetails(firstGroupRow) : [];

                renderAllGrids(rateCodes, grouped || [], details || []);

            } catch (err) {
                console.error(err);
                renderAllGrids([], [], []);
                showToast("Error", "The report could not be loaded.", false);
            } finally {
                showLoading(false);
            }
        }

        // --------- GRID HELPERS ---------
        function destroyGrid(containerSelector, instance) {
            try {
                if (instance) instance.dispose();
            } catch { }
            $(containerSelector).empty();
        }

        function renderAllGrids(rateCodes, grouped, details) {
            renderRateCodes(rateCodes);
            renderGrouped(grouped);
            renderDetails(details);
        }

        function renderRateCodes(data) {
            destroyGrid(sel.gridRateCodes, gridRateCodes);

            gridRateCodes = $(sel.gridRateCodes).dxDataGrid({
                dataSource: data,
                showBorders: true,
                width: "100%",
                height: "100%",
                selection: { mode: "single" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    showPageSizeSelector: true,
                    allowedPageSizes: [20, 50, 100, "all"],
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: { visible: true, applyFilter: "auto" },
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "rateCode", caption: "Rate Code", minWidth: 120,cssClass: "col-description" },
                    { dataField: "rateCategory", caption: "Rate Category", width: 140 },
                    { dataField: "beginDate", caption: "Begin Date", dataType: "date", format: "dd/MM/yyyy", width: 80 },
                    { dataField: "endDate", caption: "End Date", dataType: "date", format: "dd/MM/yyyy", width: 80 }
                ],
                onSelectionChanged: async function (e) {
                    const row = e.selectedRowsData[0] || null;
                    selectedRateCodesRow = row;

                    if (!row?.idRateCode) return;

                    try {
                        showLoading(true);
                        const newGrouped = await apiRateCodeGroupDataByID(row.idRateCode);
                        if (gridGrouped) gridGrouped.option("dataSource", newGrouped || []);

                        const firstGroup = Array.isArray(newGrouped) && newGrouped.length ? newGrouped[0] : null;
                        const newDetails = firstGroup ? await apiGetDetails(firstGroup) : [];
                        if (gridDetails) gridDetails.option("dataSource", newDetails || []);

                        selectedGroupedRow = firstGroup || null;
                        selectedDetailId = null;
                    } catch (err) {
                        console.error(err);
                        showToast("Error", "Unable to load group/details.", false);
                    } finally {
                        showLoading(false);
                    }
                }
            }).dxDataGrid("instance");
        }

        function renderGrouped(data) {
            destroyGrid(sel.gridGrouped, gridGrouped);

            gridGrouped = $(sel.gridGrouped).dxDataGrid({
                dataSource: data,
                showBorders: true,
                width: "100%",
                height: "100%",
                selection: { mode: "single" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    showPageSizeSelector: true,
                    allowedPageSizes: [20, 50, 100, "all"],
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: { visible: true, applyFilter: "auto" },
                columns: [
                    { dataField: "code", caption: "Code", minWidth: 120,cssClass: "col-description" },
                    { dataField: "roomType", caption: "Room Type", width: 120 },
                    { dataField: "transaction", caption: "Transaction", width: 110 },
                    { dataField: "package", caption: "Package", width: 110 },
                    { dataField: "beginDate", caption: "Begin Date", dataType: "date", format: "dd/MM/yyyy", width: 80 },
                    { dataField: "endDate", caption: "End Date", dataType: "date", format: "dd/MM/yyyy", width: 80 },
                    { dataField: "curr", caption: "Curr.", width: 50 }
                ],
                onSelectionChanged: async function (e) {
                    const row = e.selectedRowsData[0] || null;
                    selectedGroupedRow = row;

                    if (!row) return;

                    try {
                        showLoading(true);
                        const newDetails = await apiGetDetails(row);
                        if (gridDetails) gridDetails.option("dataSource", newDetails || []);
                        selectedDetailId = null;
                    } catch (err) {
                        console.error(err);
                        showToast("Error", "Unable to load details.", false);
                    } finally {
                        showLoading(false);
                    }
                }
            }).dxDataGrid("instance");
        }

        function renderDetails(data) {
            destroyGrid(sel.gridDetails, gridDetails);

            gridDetails = $(sel.gridDetails).dxDataGrid({
                dataSource: data,
                showBorders: true,
                width: "100%",
                height: "100%",
                selection: { mode: "single" },
                paging: { pageSize: 10 },
                pager: {
                    visible: true,
                    showPageSizeSelector: true,
                    allowedPageSizes: [10, 20, 50, 100, "all"],
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: { visible: true, applyFilter: "auto" },
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "roomTypeID", visible: false },
                    { dataField: "rateCode", caption: "Code", width: 100 },
                    { dataField: "roomType", caption: "Room Type", width: 120 },
                    { dataField: "rateDate", caption: "Date", dataType: "date", format: "dd/MM/yyyy", width: 120 },
                    { dataField: "transactionCode", caption: "Transaction", width: 120 },
                    { dataField: "currencyID", caption: "Curr.", width: 80 },
                    { dataField: "a1AfterTax", caption: "A1 Net", width: 110, dataType: "number", format: "#,##0" },
                    { dataField: "a2AfterTax", caption: "A2 Net", width: 110, dataType: "number", format: "#,##0" },
                    { dataField: "a3AfterTax", caption: "A3 Net", width: 110, dataType: "number", format: "#,##0" },
                    { dataField: "a4AfterTax", caption: "A4 Net", width: 110, dataType: "number", format: "#,##0" },
                    { dataField: "a5AfterTax", caption: "A5 Net", width: 110, dataType: "number", format: "#,##0" },
                    { dataField: "a6AfterTax", caption: "A6 Net", width: 110, dataType: "number", format: "#,##0" },
                    { dataField: "c1AfterTax", caption: "C1 Net", width: 110, dataType: "number", format: "#,##0" },
                    { dataField: "c2AfterTax", caption: "C2 Net", width: 110, dataType: "number", format: "#,##0" },
                    { dataField: "c3AfterTax", caption: "C3 Net", width: 110, dataType: "number", format: "#,##0" },
                    { dataField: "adultExtraTax", caption: "Adult Extra", width: 120, dataType: "number", format: "#,##0" }
                ],
                onSelectionChanged: function (e) {
                    const row = e.selectedRowsData[0] || null;
                    selectedDetailId = row?.id || null;
                }
            }).dxDataGrid("instance");
        }

        // --------- UPSERT ---------
        function clearForm() {
            $(sel.modalDetailId).val(0);
            $(sel.txtRateCode).val("").prop("disabled", false);
            $(sel.selRoomType).val("");
            $(sel.txtBeginDate).val("");
            $(sel.txtEndDate).val("");
            $(sel.selTransaction).val("");
            $(sel.selPackage).val("");
            $(sel.txtCurrency).val("VND");
            $(sel.txtMinLOS).val("");
            $(sel.txtMaxLOS).val("");
            $(sel.txtAmount).val("");
            $(sel.txtPercentage).val("");
            $(sel.txtDescription).val("");
            $(sel.chkActive).prop("checked", false);
        }

        function openNew() {
            clearForm();
            if (typeof window.applyValidationErrors === "function") applyValidationErrors([], sel.form);
            $(sel.upsertTitle).text("New Rate Code Detail");
            upsertModal.show();
        }

        function openEdit() {
            if (!selectedGroupedRow) {
                showToast("Warning", "Please select 1 row in 'Rate Details Grouped' to edit.", false);
                return;
            }

            const id = selectedGroupedRow.id;
            if (!id) {
                showToast("Warning", "Selected row has no id.", false);
                return;
            }

            if (typeof window.applyValidationErrors === "function") applyValidationErrors([], sel.form);
            showLoading(true);

            $.ajax({
                url: "/Administration/RateCode/GetRateCodeDetailByID",
                type: "GET",
                data: { id: id },
                success: function (res) {
                    if (!res?.success) {
                        showToast("Error", res?.message || "Failed to load data", false);
                        return;
                    }

                    const d = res.data;
                    clearForm();

                    $(sel.modalDetailId).val(d.id);
                    $(sel.txtRateCode).val(d.rateCode).prop("disabled", true);
                    $(sel.selRoomType).val(d.roomTypeID || "");
                    $(sel.txtBeginDate).val(d.beginDate ? d.beginDate.split("T")[0] : "");
                    $(sel.txtEndDate).val(d.endDate ? d.endDate.split("T")[0] : "");
                    $(sel.selTransaction).val(d.transactionID || "");
                    $(sel.selPackage).val(d.packageID || "");
                    $(sel.txtCurrency).val(d.currency || "VND");
                    $(sel.txtMinLOS).val(d.minLOS ?? "");
                    $(sel.txtMaxLOS).val(d.maxLOS ?? "");
                    $(sel.txtAmount).val(d.amount ?? "");
                    $(sel.txtPercentage).val(d.percentage ?? "");
                    $(sel.txtDescription).val(d.description ?? "");
                    $(sel.chkActive).prop("checked", d.active === true);

                    $(sel.upsertTitle).text("Edit Rate Code Detail");
                    upsertModal.show();
                },
                error: function () {
                    showToast("Error", "Failed to load data.", false);
                },
                complete: function () {
                    showLoading(false);
                }
            });
        }

        function validatePayload(p) {
            if (!p.rateCode) return "Rate Code is required";
            if (!p.beginDate) return "Begin Date is required";
            if (!p.endDate) return "End Date is required";
            return null;
        }

        function buildPayload() {
            return {
                id: parseInt($(sel.modalDetailId).val()) || 0,
                rateCode: $(sel.txtRateCode).val(),
                roomTypeID: parseInt($(sel.selRoomType).val()) || 0,
                beginDate: $(sel.txtBeginDate).val(),
                endDate: $(sel.txtEndDate).val(),
                transactionID: parseInt($(sel.selTransaction).val()) || 0,
                packageID: parseInt($(sel.selPackage).val()) || 0,
                currency: $(sel.txtCurrency).val(),
                minLOS: parseInt($(sel.txtMinLOS).val()) || 0,
                maxLOS: parseInt($(sel.txtMaxLOS).val()) || 0,
                amount: parseFloat($(sel.txtAmount).val()) || 0,
                percentage: parseFloat($(sel.txtPercentage).val()) || 0,
                description: $(sel.txtDescription).val(),
                active: $(sel.chkActive).is(":checked"),
                userID: parseInt(localStorage.getItem("userID")) || 0
            };
        }

        function save(closeAfter) {
            showToast("Error", "Chức năng đang hoàn thiện :14/3/2026", false);
            return;
            const payload = buildPayload();
            const err = validatePayload(payload);

            if (err) {
                showToast("Error", err, false);
                return;
            }

            showLoading(true);

            $.ajax({
                url: "/Administration/RateCode/SaveRateCodeDetail",
                type: "POST",
                contentType: "application/x-www-form-urlencoded; charset=UTF-8",
                data: $.param(payload),
                success: function (res) {
                    if (res?.success) {
                        showToast("Success", res.message || "Saved successfully", true);
                        if (closeAfter) upsertModal.hide();
                        reloadAll(false);
                    } else {
                        showToast("Error", res?.message || "Validation failed", false);
                    }
                },
                error: function (xhr) {
                    const errs = xhr.responseJSON?.errors;
                    if (Array.isArray(errs) && errs.length) {
                        errs.forEach((m, i) => setTimeout(() => showToast("Error", m, false), i * 600));
                    } else {
                        showToast("Error", xhr.responseJSON?.message || "An error occurred while saving", false);
                    }
                },
                complete: function () {
                    showLoading(false);
                }
            });
        }

        // --------- DELETE / EXPORT ---------
        function doDelete() {
            showToast("Error", "Chức năng đang hoàn thiện :14/3/2026", false);
            return;
            if (!selectedGroupedRow?.id) {
                showToast("Error", "Please select a row in 'Rate Details Grouped' to delete.", false);
                return;
            }
            if (!confirm("Are you sure you want to delete this record?")) return;

            showLoading(true);

            $.ajax({
                url: "/Administration/RateCode/DeleteRateCodeDetail",
                type: "POST",
                data: { id: selectedGroupedRow.id },
                traditional: true,
                crossDomain: false,
                headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() },
                success: function (result) {
                    if (result?.success) {
                        showToast("Success", result.message || "Deleted successfully", true);
                        reloadAll(false);
                    } else {
                        showToast("Error", result?.message || "Delete failed", false);
                    }
                },
                error: function () {
                    showToast("Error", "Unable to delete record", false);
                },
                complete: function () {
                    showLoading(false);
                }
            });
        }

        function exportExcel() {
            if (!selectedGroupedRow?.id) {
                showToast("Error", "Please select a row in 'Rate Details Grouped' to export.", false);
                return;
            }
            window.location.href = "/Administration/RateCode/ExportRateCodeDetail?id=" + selectedGroupedRow.id;
        }

        return { init, open };

    })();

    // Option A global entry
    window.openModalRtCD = function () {
        rtCD_Module.open();
    };

    $(document).ready(function () {
        rtCD_Module.init();
        // auto-open if desired:
        // window.openModalRtCD();
    });
</script>