                                break;
                            case "Dirty":
                                colorClass = "color-dirty";
                                break;
                            case "Out Of Order":
                                colorClass = "color-outoforder";
                                break;
                            case "Pickup":
                                colorClass = "color-pickup";
                                break;
                            case "Clean":
                                colorClass = "color-clean";
                                break;
                            case "Out Of Services":
                                colorClass = "color-outofservices";
                                break;
                            default:
                                colorClass = "";
                        }

                        $(container)
                            .addClass(colorClass)
                            .css({
                                "text-align": "center",
                                "color": "#000" // màu chữ
                            });
                    }
                },
