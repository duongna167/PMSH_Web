@using DevExpress.XtraReports.UI

@{
    var selectedReport = @ViewBag.ReportHeader;
    var listroom = ViewBag.RoomList;
    var listrclass = ViewBag.RoomClassList;
    var listzone = ViewBag.ZoneList;
    var listcmt = ViewBag.CommentList;
    var rooms = ViewBag.AvailableRooms;
}

<style>

</style>

<div class="modal fade" id="ooos_modal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content modal-full-height">
            <div class="modal-header bg-light py-2">
                <h5 class="modal-title">Out of Order and Service</h5>
            </div>

            <div class="modal-body d-flex flex-column" style="height: calc(100vh - 120px);">
                <div class="py-2">
                    <button id="ooos_btnView" class="mui-button mui-button-view">View</button>
                    <button id="ooos_btnNew" class="mui-button mui-button-new">New</button>
                    <button id="ooos_btnEdit" class="mui-button mui-button-edit">Edit</button>
                    <button id="ooos_btnDelete" class="mui-button mui-button-delete">Delete</button>
                    <button id="ooos_btnHistory" class="mui-button mui-button-new">History</button>
                    <button id="ooos_btnExportExcel" class="mui-button mui-button-export">Excel</button>
                    <button class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                </div>
                <div class="mui-card mb-2 bg-light border-0 d-flex flex-column flex-grow-1 overflow-hidden">

                    <div class="p-2 flex-shrink-0">
                        <div class="row g-2 align-items-center ooos-filter">

                            <!-- Date -->
                            <div class="col-xl-3 col-lg-4 col-md-6">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="mb-0 fw-semibold">Date:</label>
                                    <div class="d-flex gap-1 flex-grow-1">
                                        <div data-date-input data-format="DD/MM/YYYY" business-date data-name="ooos_fromDate">
                                            <input type="text" class="date-ui form-control form-control-sm" placeholder="From">
                                        </div>
                                        <div data-date-input data-format="DD/MM/YYYY" business-date data-name="ooos_toDate">
                                            <input type="text" class="date-ui form-control form-control-sm" placeholder="To">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Room -->
                            <div class="col-xl-3 col-lg-4 col-md-6">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="mb-0 fw-semibold">Room:</label>
                                    <select id="ooos_room" class="tomselect-custom flex-grow-1" multiple>
                                        @foreach (var u in ViewBag.RoomList)
                                        {
                                            <option value="@u.RoomNo">@u.RoomNo</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <!-- Class -->
                            <div class="col-xl-2 col-lg-2 col-md-4">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="mb-0 fw-semibold">Class:</label>
                                    <select id="ooos_roomClass" class="tomselect-custom flex-grow-1">
                                        @foreach (var g in ViewBag.RoomClassList)
                                        {
                                            <option value="@g.ID">@g.Code</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <!-- Zone -->
                            <div class="col-xl-2 col-lg-2 col-md-4">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="mb-0 fw-semibold">Zone:</label>
                                    <select id="ooos_zone" class="tomselect-custom flex-grow-1" multiple>
                                        @foreach (var z in ViewBag.ZoneList)
                                        {
                                            <option value="@z.Code">@z.Code</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <!-- Type -->
                            <div class="col-xl-2 col-lg-4 col-md-4">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="mb-0 fw-semibold">Type:</label>
                                    <div class="d-flex gap-2 border rounded px-2 py-1 bg-white">
                                        <label class="mb-0">
                                            <input type="checkbox" id="ooos_outofOrder" checked> OOO
                                        </label>
                                        <label class="mb-0">
                                            <input type="checkbox" id="ooos_outofService" checked> OOS
                                        </label>
                                    </div>
                                </div>
                            </div>

                        </div>

                    </div>

                    <div class="gridContainer mt-2 d-flex flex-column flex-grow-1 overflow-auto">
                        <div id="ooos_gridContainer"></div>

                        <div id="loadingSpinnerRateCode" style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                        z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                        height: 100%;display: flex;align-items: center;justify-content: center;">
                            <div class="spinner-border text-primary" role="status"></div>
                        </div>
                    </div>

                </div>
            </div>
        </div>  
    </div>
</div>

<!-- Modal Popup for New Item -->
<div class="modal fade" id="ooos_itemModal" tabindex="-1" data-bs-backdrop="static" aria-labelledby="itemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="ooos_itemModalLabel">Out of order/service management</h5>
            </div>

            <div class="modal-body">

                <!-- Action -->
                <div class="py-2 d-flex gap-2 flex-column flex-sm-row">
                    <button type="button"
                            id="ooos_btnSaveItem"
                            class="mui-button mui-button-new w-sm-auto">
                        Save
                    </button>
                    <button type="button"
                            class="mui-button mui-button-new w-sm-auto"
                            data-bs-dismiss="modal">
                        Close
                    </button>
                </div>

                <form id="ooos_formContainer">
                    <div class="container-fluid px-2">

                        <input type="hidden" id="ooos_id" name="id" value="0" />

                        <div class="row g-4">

                            <!-- LEFT COLUMN -->
                            <div class="col-12 col-lg-7">

                                <!-- Type -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-bold mb-1 mb-md-0">
                                        Type
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <div class="d-flex gap-4">
                                            <div class="form-check m-0">
                                                <input type="radio" name="oooOrS" id="ooos_ooo" value="1">
                                                <label class="form-check-label">OOO</label>
                                            </div>
                                            <div class="form-check m-0">
                                                <input type="radio" name="oooOrS" id="ooos_oos" value="2" checked>
                                                <label class="form-check-label">OOS</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Return Status -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-bold mb-1 mb-md-0">
                                        Return Status
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <select id="ooos_rtStatus"
                                                name="rtStatus"
                                                class="tomselect-custom w-100">
                                            <option value="2">Dirty</option>
                                            <option value="1">Clean Non-Checked</option>
                                            <option value="3">Pickup</option>
                                            <option value="4">Clean</option>
                                        </select>
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>

                                <!-- Reason -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-bold mb-1 mb-md-0">
                                        Reason
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <select id="ooos_comment"
                                                name="comment"
                                                class="tomselect-custom w-100">
                                            @foreach (var dpm in ViewBag.CommentList)
                                            {
                                                <option value="@dpm.ID" data-desc="@dpm.Description">@dpm.Code - @dpm.Description</option>
                                            }
                                        </select>
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>

                                <!-- Reason Note -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-bold mb-1 mb-md-0">
                                        Reason Note
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <input type="text"
                                               id="ooos_txtReasonDesc"
                                               name="txtReasonDesc"
                                               class="form-control form-control-sm" />
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>

                                <!-- Room Select -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-bold mb-1 mb-md-0">
                                        Room Select
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <select id="ooos_roomSelect"
                                                name="roomSelect"
                                                class="tomselect-custom w-100"
                                                multiple>
                                            @foreach (var u in ViewBag.RoomList)
                                            {
                                                <option value="@u.ID">@u.RoomNo</option>
                                            }
                                        </select>
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>

                            </div>

                            <!-- RIGHT COLUMN -->
                            <div class="col-12 col-lg-5">

                                <!-- From -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-bold mb-1 mb-md-0">
                                        From
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <div data-date-input
                                             data-format="DD/MM/YYYY"
                                             business-date
                                             data-name="ooos_itemFromDate"
                                             name="itemFromDate">
                                            <input type="text"
                                                   class="date-ui form-control form-control-sm"
                                                   placeholder="dd/MM/yyyy" />
                                        </div>
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>

                                <!-- To -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-bold mb-1 mb-md-0">
                                        To
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <div data-date-input
                                             data-format="DD/MM/YYYY"
                                             business-date
                                             data-name="ooos_itemToDate"
                                             name="itemToDate">
                                            <input type="text"
                                                   class="date-ui form-control form-control-sm"
                                                   placeholder="dd/MM/yyyy" />
                                        </div>
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>

                            </div>

                        </div>
                    </div>
                </form>

            </div>

        </div>
    </div>
</div>

<!-- History Modal -->
<div class="modal fade" id="ooos_historyModal" tabindex="-1" data-bs-backdrop="static" aria-labelledby="historyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <!-- rộng hơn để chứa grid -->
        <div class="modal-content modal-full-height d-flex flex-column">
            <div class="modal-header">
                <h5 class="modal-title" id="ooos_historyModalLabel">Room Change History</h5>
            </div>

            <div class="modal-body d-flex flex-column overflow-hidden">
                <div class="item-modal-actions py-2">
                    <button class="mui-button mui-button-new" id="ooos_btnHistorySearch">Search</button>
                    <button class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">

                    <div class="d-flex align-items-center me-2">
                        <label class="me-2 mb-0">Room:</label>
                        <input type="text" id="ooos_historyRoom" class="form-control form-control-sm w-auto" />
                    </div>
                    <div class="d-flex align-items-center me-2">
                        <label class="me-2 mb-0">User Name:</label>
                        <input type="text" id="ooos_historyUser" class="form-control form-control-sm w-auto" />
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <div data-date-input data-format="DD/MM/YYYY" business-date
                             data-name="ooos_historyFromDate" style="width: 130px;">
                            <input type="text" class="date-ui form-control form-control-sm"
                                   placeholder="dd/mm/yyyy" autocomplete="off" />
                        </div>
                        <div data-date-input data-format="DD/MM/YYYY" business-date
                             data-name="ooos_historyToDate" style="width: 130px;">
                            <input type="text" class="date-ui form-control form-control-sm"
                                   placeholder="dd/mm/yyyy" autocomplete="off" />
                        </div>
                    </div>

                </div>

                <div class="gridContainer mt-2  flex-grow-1 overflow-hidden">
                    <div id="ooos_historyGrid"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="loadingSpinner" style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:1000;">
    <i class="fa-solid fa-spinner fa-spin"></i>
</div>
<script>
        
    var ooos_Module = {
        selectedRowData: null,

        baseGridOptions: {
            height: "100%",
            width: "100%",
            showBorders: true,
            hoverStateEnabled: true,
            wordWrapEnabled: true,
            allowColumnResizing: true,
            columnResizingMode: "widget",
            columnAutoWidth: true,
            selection: { mode: "single" },
            scrolling: {
                mode: "standard",
                showScrollbar: "always",
                useNative: true
            },
            paging: { pageSize: 20 },
            pager: {
                visible: true,
                allowedPageSizes: [20, 50, 100],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            filterRow: { visible: true, applyFilter: "auto" }
        },

        initGrid: function (containerId, options) {
            const fullOptions = $.extend(true, {}, this.baseGridOptions, options);
            return $(containerId).dxDataGrid(fullOptions);
        },

        init: function () {
            this.initEvents();
            this.intitDOMEvents();
        },

        initEvents: function () {
            const self = this;

            window.openModalOOOS = function () {
                initTomSelect(".tomselect-custom");
                self.reloadGrid();

                // handler close modal
                $('#ooos_modal').on('hidden.bs.modal', function () {
                    self.disposeGrid("#ooos_gridContainer");
                    clearMultipleTomSelect(["#ooos_room", "#ooos_roomClass", "#ooos_zone"]);
                    reloadBusinessDate();
                    self.selectedRowData = null;
                });

                $('#ooos_itemModal').on('hidden.bs.modal', function () {
                    ValidationAdapter.clear("#ooos_formContainer");
                    clearMultipleTomSelect(["#ooos_roomSelect", "#ooos_comment"]);
                    reloadBusinessDate();
                });

                $('#ooos_historyModal').on('hidden.bs.modal', function () {
                    self.disposeGrid("#ooos_historyGrid");
                    reloadBusinessDate();
                    self.selectedRowData = null;
                });

                // events input
                $("#ooos_formContainer").on("input", "input, textarea", function () {
                    if ($(this).hasClass("is-invalid")) {
                        ValidationAdapter.clearField(this);
                    }
                });

                // event tomselect
                $("#ooos_formContainer").on("change", "select.tomselect-custom", function () {
                    if (this.tomselect) {
                        ValidationAdapter.clearField(this);
                    }
                });

                // Tự động điền note khi chọn Reason
                $(document).on("change", "#ooos_comment", function () {
                    const ts = this.tomselect;
                    if (!ts) return;

                    const value = ts.getValue();
                    const option = ts.options[value];

                    $("#ooos_txtReasonDesc").val(option?.desc || "");
                });

            };

        },

        intitDOMEvents: function () {
            const self = this;
            $("#ooos_btnView").on("click", () => self.reloadGrid());
            $("#ooos_btnNew").on("click", () => self.openNewModal());
            $("#ooos_btnEdit").on("click", () => self.openEditModal());
            $("#ooos_btnSaveItem").on("click", () => self.saveBusinessBlock());
            $("#ooos_btnDelete").on("click", () => self.confirmDelete());
            $("#ooos_btnExportExcel").on("click", () => self.exportToExcel());
            $("#ooos_btnHistory").on("click", () => self.openModalHistory());
            $("#ooos_btnHistorySearch").on("click", () => self.fetchHistoryData());
        },

        reloadGrid: function () {
            const self = this;
            const filterData = {
                status: self.getStatusValue(),
                roomNo: (getTomSelectData("#ooos_room") || []).map(x => x.value).join(","),
                roomClassID: getTomSelectData("#ooos_roomClass")?.value,
                fromDate: $("#ooos_fromDate").val() || dateSystem ,
                toDate: $("#ooos_toDate").val() || dateSystem,
                zone: (getTomSelectData("#ooos_zone") || []).map(x => x.value).join(",")
            };
            $("#loadingSpinnerRateCode").show();
            $.ajax({
                url: '/RoomManagement/GetOOOSload',
                type: 'GET',
                data: filterData,
                success: function (data) {
                    self.renderMainGrid(data);
                    $("#loadingSpinnerRateCode").hide();
                },
                error: function (xhr, status, error) {
                    showToast("Error", "Unable to load data", false);
                    $("#loadingSpinnerRateCode").hide();
                }
            });
        },

        renderMainGrid: function (data) {
            const self = this;
            self.initGrid("#ooos_gridContainer",{
                dataSource: data,
                columns: [
                    { dataField: "id", visible:false},
                    { dataField: "roomID", visible:false},
                    { dataField: "reasonID", visible:false},
                    { dataField: "code", caption: "Code", width: 90 },
                    { dataField: "roomNo", caption: "Room No", alignment: "right" , width: 60 },
                    { dataField: "roomType", caption: "Room Type", width: 70 },
                    { dataField: "floor", caption: "Floor", alignment: "right",width: 50 },
                    { dataField: "zone", caption: "Zone", width: 50 },
                    { dataField: "fromDate", caption: "From Date", width: 80, dataType: "date", format: "dd/MM/yyyy" },
                    { dataField: "toDate", caption: "To Date", width: 80, dataType: "date", format: "dd/MM/yyyy" },
                    { dataField: "noOfNights", caption: "Nights", width: 50 },
                    { dataField: "reason", caption: "Reason", width: 150 },
                    { dataField: "status", caption: "Status", width: 50 },
                    { dataField: "userCreate", caption: "User Create", width: 100 },
                    { dataField: "createdDate", caption: "Create Date", width: 80, dataType: "date", format: "dd/MM/yyyy" },
                    { dataField: "userUpdate", caption: "User Update", width: 100 },
                    { dataField: "updatedDate", caption: "Update Date", width: 80, dataType: "date", format: "dd/MM/yyyy" }
                ],
                summary: {
                    totalItems: [
                        // CODE column → hiện chữ Total
                        {
                            column: "code",
                            summaryType: "count",
                            displayFormat: "Total room",
                            alignment: "left"
                        },

                        // ROOM NO → đếm số phòng
                        {
                            column: "roomNo",
                            summaryType: "count",
                            displayFormat: "{0}",
                            alignment: "right"
                        },

                        // NIGHTS → giữ cách tính custom
                        {
                            showInColumn: "reason",
                            summaryType: "custom",
                            name: "TotalNights",
                            displayFormat: "Total Nights: {0}",
                            alignment: "right"
                        }
                    ],

                    calculateCustomSummary: function (options) {
                        if (options.name === "TotalNights") {
                            if (options.summaryProcess === "start")
                                options.totalValue = 0;

                            if (options.summaryProcess === "calculate")
                                options.totalValue += (options.value.noOfNights || 0);
                        }
                    }
                },

                onSelectionChanged: function (e) {
                    self.selectedRowData = e.selectedRowsData[0] || null;
                }
            });

        },

        fetchHistoryData: function () {
            const self = this;

            $("#loadingSpinner").show();

            $.ajax({
                url: "/RoomManagement/GetRoomStatusHistoryOOO",
                type: "GET",
                data: {
                    roomNo: $("#ooos_historyRoom").val(),
                    userName: $("#ooos_historyUser").val(),
                    fromDate: $("#ooos_historyFromDate").val() || dateSystem,
                    toDate: $("#ooos_historyToDate").val() || dateSystem
                },
                success: function (data) {
                    self.renderHistoryGrid(data);
                    $("#loadingSpinner").hide();
                },
                error: function () {
                    showToast("Error", "Lỗi khi load dữ liệu history", false);
                    $("#loadingSpinner").hide();
                }
            });
        },

        renderHistoryGrid: function (data) {
            const self = this;

            self.initGrid("#ooos_historyGrid", {
                dataSource: data,
                columns: [
                    { dataField: "roomNo", caption: "Room No", width: "10%" },
                    { dataField: "action", caption: "Action", width: "10%" },
                    { dataField: "oldValue", caption: "Old Value", width: "30%" },
                    { dataField: "newValue", caption: "New Value", width: "30%" },
                    { dataField: "userName", caption: "User", width: "10%" },
                    { dataField: "changeDate", caption: "Date", dataType: "date", format: "dd/MM/yyyy HH:mm" }
                ]
            });
        },

        openNewModal: function () {
            $("#ooos_itemModal").modal("show");
            initDateInputs();
            $("#ooos_id").val(0);
            $("#ooos_itemModalLabel").text("New Out of Order/Service");
            clearMultipleTomSelect(["#ooos_roomSelect", "#ooos_comment"]);
        },

        openEditModal: function (){
            const self = this;
            initDateInputs();
            if (!self.selectedRowData) {
                showToast("Warning", "Please select a row first!", false);
                return;
            }
            $("#ooos_itemModalLabel").text("Update Out of Order/Service");
            self.fillEditForm(self.selectedRowData);

            $("#ooos_itemModal").modal("show");
        },

        openModalHistory: function () {
            const self = this;
            initDateInputs();

            $("#ooos_historyModal").modal("show");

            self.fetchHistoryData();
        },

        fillEditForm: function (data) {
            $("#ooos_id").val(data.id);
            const statusVal = data.status === "OOO" ? "1" : "2";
            $(`input[name='oooOrS'][value='${statusVal}']`).prop("checked", true);

            setTomSelectValue("#ooos_roomSelect", data.roomID);
            setTomSelectValue("#ooos_rtStatus", data.returnStatusID);
            setTomSelectValue("#ooos_comment", data.reasonID);
            $("#ooos_txtReasonDesc").val(data.reason || "");

            UI.setHiddenDate("ooos_itemFromDate", data.fromDate);
            UI.setHiddenDate("ooos_itemToDate", data.toDate);

        },

        saveBusinessBlock: function () {
            const self = this;

            const loginName = (localStorage.getItem("Loginname") || "")
            .trim()
            .replace(/^"(.*)"$/, '$1');
            const loginUser = parseInt(localStorage.getItem("userID")) || 0;

            const roomSelectData = getTomSelectData("#ooos_roomSelect") || [];

            if (!roomSelectData.length) {
                ValidationAdapter.apply([
                    { field: "roomSelect", message: "Haven't selected a room yet!" }
                ], "#ooos_formContainer");

                showToast("Warning", "Check for incorrect input fields.", false);
                return;
            }
                
            const payload = roomSelectData.map(r => ({
                id: parseInt($("#ooos_id").val() || 0),

                fromDateOOO: $("#ooos_itemFromDate").val() || dateSystem,
                toDateOOO: $("#ooos_itemToDate").val() || dateSystem,

                reasonID: parseInt(toBackendValue(getTomSelectData("#ooos_comment"), "value") || 0),
                reasonNote: $("#ooos_txtReasonDesc").val() || "",

                roomID: parseInt(r.value),
                roomNo: r.text,

                UserInsertID: loginUser,
                UserUpdateID: loginUser,
                ReturnStatus: parseInt(toBackendValue(getTomSelectData("#ooos_rtStatus"), "value") || 0),
                OOOStatus: parseInt($("input[name='oooOrS']:checked").val() || 0),
                CutOffDate: $("#ooos_itemFromDate").val() || dateSystem
            }));

            $.ajax({
                url: "/RoomManagement/SaveBusinessBlock",
                method: "POST",
                contentType: "application/json",
                data: JSON.stringify(payload),
                success: function (res) {
                    if (res.success) {
                        showToast("Success", res.message, true);
                        $("#ooos_itemModal").modal("hide");
                        self.reloadGrid();
                    } else {

                        // nếu có validation errors
                        if (res.errors && res.errors.length > 0) {
                            ValidationAdapter.apply(res.errors, "#ooos_formContainer");
                            showToast("Warning", "Check for incorrect input fields.", false);
                        }
                        else {
                            // nếu là lỗi exception
                            showToast("Error", res.message || "Something went wrong.", false);
                        }
                    }
                },
                error: function () {
                    showToast("Error", "Server error occurred.", false);
                }
            });
        },

        confirmDelete: function() {
            const self = this;
            if (!self.selectedRowData) {
                showToast("Warning","Please select a line to delete.", false);
                return;
            }

            if (!confirm("Are you sure you want to delete this record? This action cannot be undone.")) {
                return;
           }
           $.ajax({
               url: `/RoomManagement/DeleteBusinessBlock/`+ self.selectedRowData.id,
               type: "POST",
               traditional: true,
               crossDomain: false,
               headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
               success: function(result){
                    if(result.success){
                        self.reloadGrid();
                        showToast("Success","Delete Successfully!",true);
                    } else {
                        self.reloadGrid();
                        showToast("Error",result.message,false);
                    }
               },
               error: function(){
                    showToast("Error","Delete failed!" ,false);
               },
           });
        },

        exportToExcel: function () {
            const grid = $("#ooos_gridContainer").dxDataGrid("instance");
            if (!grid) {
                showToast("Warning", "No data to export!", false);
                return;
            }
            const workbook = new ExcelJS.Workbook();
            const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const worksheet = workbook.addWorksheet("Sheet 1");

            // === Dòng 1: Tên công ty (merge theo 4 cột) ===
            worksheet.addRow([companyName]);
            worksheet.mergeCells('A1:D1');
            worksheet.getRow(1).font = { bold: true };
            worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

            // === Dòng 2: Ngày giờ xuất (Sửa lỗi hiển thị ở đây) ===
            const now = new Date();
            const exportDateStr = "Export Date: " + now.toLocaleString("vi-VN");
            const row2 = worksheet.getRow(2);
            row2.getCell(1).value = exportDateStr; // Gán vào ô đầu tiên của vùng merge (A2)
            worksheet.mergeCells('A2:D2');
            row2.alignment = { vertical: 'middle', horizontal: 'left' };
            row2.font = { italic: true };

            // === Dòng 3–4: trống
            worksheet.addRow([]);
            worksheet.addRow([]);

            // === Dòng 5: Tiêu đề báo cáo (ở giữa) ===
            const reportRow = worksheet.addRow(['Out Of Order And Service']);
            worksheet.mergeCells('A5:D5');
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

            // === Dòng 6: trống
            worksheet.addRow([]);

            // === Xuất dữ liệu grid bắt đầu từ dòng 7 ===
            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                // Footer (sau cùng)
                const lastRow = worksheet.lastRow.number + 2;
                worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
                worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
                worksheet.getCell(`A${lastRow}`).font = { italic: true };

                // Ghi file
                let fileName = "OutOfOrderAndService.xlsx";
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
                });
            });
        },

        getStatusValue: function () {
            const isOOO = $('#ooos_outofOrder').is(':checked');
            const isOOS = $('#ooos_outofService').is(':checked');
            if (isOOO && isOOS) return 0;
            return isOOO ? 1 : (isOOS ? 2 : 3);
        },

        disposeGrid: function (containerId) {
            if ($(containerId).data("dxDataGrid")) {
                $(containerId).dxDataGrid("dispose");
                $(containerId).empty();
            }
        },

  
    };

    $(document).ready(function () {
        ooos_Module.init();
    });

</script>
