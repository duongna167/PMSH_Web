        }
        if (reservationStatus == 0 || reservationStatus == 5) {
            $('#modalDepositPayment').modal('show');

        }
        else {
            showToast("Warning", "Please choose booking has status Reservation or Due In", false);
        }
    }
    function closeModalDepositPayment() {
        const arrivalIso = parseReservationDateToIso(arivalDate) || window.dateSystem;
        if (arrivalIso && typeof UI !== 'undefined' && UI.setHiddenDate) {
            UI.setHiddenDate('dateDepositPayment', arrivalIso);
        }
        $('#modalDepositPayment').modal('hide');
        clearDepositPayment();

    }
    function clearDepositPayment() {
        $('#transactionDepositPayment').val(0);
        $('#amountDepositPayment').val('');
        $('#referenceDepositPayment').val('');
        $('#supplementDepositPayment').val('');
        $('#creditCardNoDepositPayment').val('');
        $('#reservationTypeDepositPayment').val(0);

    }
    function getTransactionPayment() {
        $.ajax({
            url: '/Reservation/GetTransactionPayment',
            type: 'get',
            dataType: 'json',

            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                $('#transactionDepositPayment').empty();
                var html = `<option value='0'></option>`;
                if (result.length > 0) {
                    for (var i = 0; i < result.length; i++) {
                        html += `<option value='${result[i].id}'>${result[i].description}</option>`
                    }
                }
                $('#transactionDepositPayment').append(html);
            },
            error: function (xhr, statusText, err) {
                if (xhr.status == 401) {
                    sessionTimeout();
                }
            }
        });
    }


    var depositPaymentSubmitInFlight = false;

    function resetDepositPaymentSubmitState() {
        depositPaymentSubmitInFlight = false;
        $("#btnDepositPaymentOk").prop("disabled", false);
    }

    function SaveDepositPayment() {
        if (depositPaymentSubmitInFlight) {
            return;
        }

        const transCode = $('#transactionDepositPayment').val();
        if (!transCode || transCode === '0') {
            showToast('Warning', 'Please select transaction type.', false);
            return;
        }

        depositPaymentSubmitInFlight = true;
        $("#btnDepositPaymentOk").prop("disabled", true);

        let userID;
        let userName;
        try {
            userID = JSON.parse(localStorage.getItem("userID"));
            userName = JSON.parse(localStorage.getItem("userName"));
        } catch (e) {
            resetDepositPaymentSubmitState();
            showToast('Warning', 'Session invalid. Please sign in again.', false);
            return;
        }

        const shiftID = localStorage.getItem("shiftID");

        var formData = new FormData();

        formData.append('rsvID', idReservation);
        formData.append('dueDate', getHiddenDateValue('dateDepositPayment'));
        formData.append('transCode', transCode);
        formData.append('reference', $('#referenceDepositPayment').val());
        formData.append('supplement', $('#supplementDepositPayment').val());
        formData.append('creditCard', $('#creditCardNoDepositPayment').val());
        formData.append('amount', parseLocalizedNumber($('#amountDepositPayment').val()).toString());
        formData.append('curencyID', $('#currencyDepositPayment').val());
        formData.append('reservationType', $('#reservationTypeDepositPayment').val());
        formData.append('shiftID', shiftID);

        formData.append('userName', userName);
        formData.append('userID', userID);

        $.ajax({
            url: '/Reservation/SaveDepositPayment',
            type: 'POST',
            processData: false,
            contentType: false,
            // headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            data: formData,
            success: function (data) {
                if (data.code == 0) {
                    clearDepositRequest();
                    closeModalDepositPayment();
                    GetDepositRequestByReservationID(idReservation);
                    showToast('Success', data.msg, true);
                } else {
                    showToast('Error', data.msg, false);
                }

            },
            error: function (xhr, statusText, err) {

            },
            complete: function () {
                resetDepositPaymentSubmitState();
            }
        });

    }

    $(document).on("hidden.bs.modal", "#modalDepositPayment", function () {
        resetDepositPaymentSubmitState();
    });
    function PrinReceipt() {

        if (!depoistPaymentID || depoistPaymentID === 0) {
            showToast('Warning', 'No deposit value available for printing.', false);
            return;
        }

        const userName = localStorage.getItem("shiftName");
        $.ajax({
            url: '/Reservation/PrintReceipt',
            type: 'POST',
            data: {
                id: depoistPaymentID,
                userName: userName
            },
            success: function (data) {
                try {
                    // Nếu data có prefix, tách ra phần base64
                    let base64String = data;

                    // Nếu có tiền tố "data:application/pdf;base64," thì tách ra
                    if (base64String.startsWith('data:')) {
                        base64String = base64String.split(',')[1];
                    }

                    // Giải mã base64
                    const byteCharacters = atob(base64String);
                    const byteNumbers = new Array(byteCharacters.length);
                    for (let i = 0; i < byteCharacters.length; i++) {
                        byteNumbers[i] = byteCharacters.charCodeAt(i);
                    }
                    const byteArray = new Uint8Array(byteNumbers);
                    const blob = new Blob([byteArray], { type: 'application/pdf' });
                    console.log(blob);
                    // Tạo URL và mở trong cửa sổ mới
                    const blobUrl = URL.createObjectURL(blob);
                    window.open(blobUrl);
                } catch (e) {
                    console.error("Base64 decode error:", e);
                }
            },
            error: function (xhr, statusText, err) {
                console.error("AJAX error:", err);
            }
        });
    }

    function deleteSelectedDepositRequest() {
        const grid = $("#gridContainerDepositRequest").dxDataGrid("instance");
        if (!grid) {
            showToast('Warning', 'Deposit request grid is not ready.', false);
            return;
        }
        const row = grid.getSelectedRowsData()[0];
        if (!row || !row.rsqID) {
            showToast('Warning', 'Please select a request row to delete.', false);
            return;
        }
        const id = parseInt(row.rsqID, 10) || 0;
        if (!id) {
            showToast('Warning', 'Invalid request id.', false);
            return;
        }
        if (!confirm('Delete selected deposit request?')) return;

        $.ajax({
            url: '/Reservation/DeleteDepositRequest',
            type: 'POST',
            dataType: 'json',
            data: { id: id },
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (res) {
                if (res && res.code === 0) {
                    showToast('Success', res.msg || 'Deleted successfully.', true);
                    GetDepositRequestByReservationID(idReservation);
                } else {
                    showToast('Error', res?.msg || 'Delete failed.', false);
                }
            },
            error: function (xhr) {
                const msg = xhr?.responseJSON?.msg || xhr?.responseJSON?.message || xhr?.statusText || 'Delete failed.';
                showToast('Error', msg, false);
            }
        });
    }
</script>
