                <h5 class="modal-title" id="paymentModalLabel">Deposit Payment</h5>
            </div>

            <div class="modal-body">
                <div class="d-flex gap-2 search-filter">
                    <button type="button" id="btnDepositPaymentOk" class="mui-button mui-button-search" onclick="SaveDepositPayment();">
                        OK
                    </button>
                    <button type="button" class="mui-button mui-button-clear" onclick="closeModalDepositPayment();">
