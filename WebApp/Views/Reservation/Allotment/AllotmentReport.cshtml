@{
    // Cấu trúc Razor
}

<style>

</style>

<div class="modal fade" id="allot_report_modal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-light py-2">
                <h5 class="modal-title">Allotment Report</h5>
            </div>

            <div class="modal-body d-flex flex-column">
                <div class="py-2">
                    <button id="allot_report_btnView" class="mui-button mui-button-search"> View</button>
                    <button id="allot_report_btnExportExcel" class="mui-button mui-button-export"> Excel</button>
                    <button class="mui-button mui-button-new" data-bs-dismiss="modal"> Close </button>
                </div>
                <div class="mui-card mb-2 bg-light border-0 d-flex flex-column flex-grow-1 overflow-hidden">
                    <div class="d-flex flex-column ">
                        <div class="d-flex align-items-center">
                            <div class="row">

                                <div class="col-md-6">

                                    <div class="form-check d-flex align-items-center mb-2">
                                        <input type="checkbox" id="byAllotmentType" name="byAllotment" value="0" class="form-check-input me-2" />
                                        <label class="form-check-label mb-0 text-nowrap" for="byAllotmentType">
                                            By Allotment Type
                                        </label>
                                    </div>

                                    <div class="form-check d-flex align-items-center mb-2">
                                        <input type="checkbox" id="byRoomType" name="byAllotment" value="1" class="form-check-input me-2" />
                                        <label class="form-check-label mb-0 text-nowrap" for="byRoomType">
                                            By Room Type
                                        </label>
                                    </div>

                                    <div class="form-check d-flex align-items-center mb-2">
                                        <input type="checkbox" id="byAllotmentTypeDetail" name="byAllotmentDetail" value="1" class="form-check-input me-2" />
                                        <label class="form-check-label mb-0 text-nowrap" for="byAllotmentTypeDetail">
                                            By Allotment Type Detail
                                        </label>
                                    </div>

                                    <div class="form-check d-flex align-items-center mb-2">
                                        <input type="checkbox" id="byAllotmentandRoomType" name="byAllotmentandRoomType" value="1" class="form-check-input me-2" />
                                        <label class="form-check-label mb-0 text-nowrap" for="byAllotmentandRoomType">
                                            By Allotment Type and Room Type
                                        </label>
                                    </div>

                                </div>

                                <div class="col-md-6">

                                    <div class="form-check d-flex align-items-center mb-2">
                                        <input type="checkbox" id="byAllotmentandRoomTypeGroupbyAll" name="byAllotmentandRoomType" value="1" class="form-check-input me-2" />
                                        <label class="form-check-label mb-0 text-nowrap" for="byAllotmentandRoomTypeGroupbyAll">
                                            By Allotment Type and Room Type Group By Allotment
                                        </label>
                                    </div>

                                    <div class="form-check d-flex align-items-center mb-2">
                                        <input type="checkbox" id="byAllotmentandRoomTypeGroupbyRT" name="byAllotmentandRoomType" value="1" class="form-check-input me-2" />
                                        <label class="form-check-label mb-0 text-nowrap" for="byAllotmentandRoomTypeGroupbyRT">
                                            By Allotment Type and Room Type Group By Room Type
                                        </label>
                                    </div>

                                    <div class="form-check d-flex align-items-center mb-2">
                                        <input type="checkbox" id="byProfile" name="byProfile" value="1" class="form-check-input me-2" />
                                        <label class="form-check-label mb-0 text-nowrap" for="byProfile">
                                            By Profile
                                        </label>
                                    </div>

                                    <div class="form-check d-flex align-items-center mb-2">
                                        <input type="checkbox" id="byRoomtypedetail" name="byRoomtypedetail" value="1" class="form-check-input me-2" />
                                        <label class="form-check-label mb-0 text-nowrap" for="byRoomtypedetail">
                                            By Room Type Detail
                                        </label>
                                    </div>

                                </div>

                            </div>
                        </div>
                    </div>
                   
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="allot_report_itemModal" tabindex="-1" data-bs-backdrop="static" aria-labelledby="allot_report_itemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="allot_report_itemModalLabel">Allotment Report</h5>
            </div>
            <div class="modal-footer justify-content-start">
                <button type="button" id="allot_report_btnItem" class="mui-button mui-button-save">View</button>
                <button type="button" data-bs-dismiss="modal" class="mui-button mui-button-close"> Close</button>
            </div>
            <div class="modal-body">
                <form id="allot_stage_formContainer">
                    <div class="container-fluid">

                        <!-- ✅ Row bao 3 cột -->
                        <div class="row g-2 align-items-end">

                            <!-- Date -->
                            <div class="col-md-4">
                                <div class="row g-1 align-items-center">
                                    <label class="col-md-4 col-form-label">Date</label>
                                    <div class="col-md-8">
                                        <div data-date-input
                                             data-format="DD/MM/YYYY"
                                             data-name="fromDate"
                                             business-date>
                                            <input type="text"
                                                   class="date-ui form-control form-control-sm"
                                                   placeholder="dd/mm/yyyy"
                                                   autocomplete="off" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Display No of Days -->
                            <div class="col-md-4">
                                <div class="row g-1 align-items-center">
                                    <label class="col-md-6 col-form-label">
                                        Display No of Days
                                    </label>
                                    <div class="col-md-6">
                                        <input type="number"
                                               class="form-control form-control-sm"
                                               name="displayDays"
                                               id="displayDays"
                                               value="20" />
                                    </div>
                                </div>
                            </div>

                            <!-- Choose Allotment Type -->
                            <div class="col-md-4">
                                <div class="row g-1 align-items-center">
                                    <label class="col-md-5 col-form-label">
                                        Choose Allotment Type
                                    </label>
                                    <div class="col-md-7">
                                        <select id="allotmentType"
                                                name="allotmentType"
                                                class="form-control form-control-sm">
                                            @foreach (var u in ViewBag.AllottypeList)
                                            {
                                                <option value="@u.ID">@u.Name</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                    <div class="gridContainer mt-2 d-flex flex-column flex-grow-1" style="min-height: 0;">
                        <div id="allot_report_grid"></div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    var allot_report_Module = {
        selectedRowData: null,

        init: function () {
            this.initEvents();
            this.initDOMEvents();
            initDateInputs();
            $("#allot_report_itemModal").modal("hide")

        },

        initEvents: function () {
         
        },

        initDOMEvents: function () {
             const self = this;

            $("#allot_report_btnView").off("click").on("click", function () {
                    $("#allot_report_itemModal").modal("show")
                    self.reloadData();
            });

            $("#allot_report_btnItem").off("click").on("click", function () {
                self.reloadData();
            });

            $("#allot_report_btnExportExcel").off("click").on("click", function () {
                self.exportExcel();
            });

             $(".mui-button-close").off("click").on("click", function () {
                const grid = $("#allot_report_grid").dxDataGrid("instance");

                if (grid) {
                    grid.beginUpdate();

                    grid.option("dataSource", []);
                    grid.option("columns", []);

                    grid.endUpdate();
                    grid.refresh();
                }
            });
            $('.mui-card input[type="checkbox"]')
            .off("change")
            .on("change", function () {
                if ($(this).is(':checked')) {
                    $('.mui-card input[type="checkbox"]')
                        .not(this)
                        .prop('checked', false);
                }
            });
        },      
        reloadData: function () {
          
            $("#allot_stage_loadingSpinner").show();
            $("#allot_stage_grid").css("opacity", "0.5");
         const allotmentType = parseInt($("input[name='byAllotment']:checked").val() ?? 2);
            $.ajax({
                url: "/Allotment/GetAllotmentReport",
                type: "GET",
                cache: false,
                data: {
                    fromDate: $("#fromDate").val(),
                    displayofday: $("#displayDays").val(),
                    byAllotmentType:allotmentType,
                    byAllotmentDetail: $("input[name='byAllotmentDetail']:checked").val(),
                    allotmentType: $("#allotmentType").val(),
                    byAllotmentandRoomType: $("#byAllotmentandRoomType").prop("checked") ? 1 : 0,
                    byAllotmentandRoomTypeGroupbyAll: $("#byAllotmentandRoomTypeGroupbyAll").prop("checked") ? 1 : 0,
                    byAllotmentandRoomTypeGroupbyRT: $("#byAllotmentandRoomTypeGroupbyRT").prop("checked") ? 1 : 0,
                    byProfile: $("#byProfile").prop("checked") ? 1 : 0,
                    byRoomtypedetail: $("#byRoomtypedetail").prop("checked") ? 1 : 0,
                },
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                success: (data) => {
                    console.log(data);
                  
                    this.renderGrid(data,$("#fromDate").val(),allotmentType, $("input[name='byAllotmentDetail']:checked").val(),$("#byAllotmentandRoomType").prop("checked") ? 1 : 0,$("#byAllotmentandRoomTypeGroupbyAll").prop("checked") ? 1 : 0,$("#byAllotmentandRoomTypeGroupbyRT").prop("checked") ? 1 : 0,$("#byProfile").prop("checked") ? 1 : 0,$("#byRoomtypedetail").prop("checked") ? 1 : 0);
                    $("#allot_stage_loadingSpinner").hide();
                    $("#allot_stage_grid").css("opacity", "1");
                },
                error: (xhr) => {
                    $("#allot_stage_loadingSpinner").hide();
                    $("#allot_stage_grid").css("opacity", "1");
                    if (typeof showToast === "function") showToast("Error", "Unable to load data", false);
                }
            });
        },
        generateDateColumns: function (fromDate, toDate) {

            const columns = [];
            const start = new Date(fromDate);
            const end = new Date(toDate);

            start.setHours(0, 0, 0, 0);
            end.setHours(0, 0, 0, 0);

            while (start <= end) {

                const yyyy = start.getFullYear();
                const mm = (start.getMonth() + 1).toString().padStart(2, '0');
                const dd = start.getDate().toString().padStart(2, '0');
                const dateStr = `${yyyy}-${mm}-${dd}`;

                const month = start.toLocaleString('en-US', { month: 'short' });
                const weekday = start.toLocaleString('en-US', { weekday: 'short' });
                const weekNumber = allot_report_Module.getWeekNumber(start);
 
                const captionHtml = `${dd}-${month}<br>${weekday}<br>CW${weekNumber}`;

                columns.push({
                   dataField: dateStr,
                    width: 70,
                    dataType: "number",
                    format: {
                        type: "fixedPoint",
                        precision: 1 // luôn có 1 ch? s? th?p phân
                    },
                    alignment: "center",
                    headerCellTemplate: function (container) {
                        container.html(`<div style="white-space: normal; text-align:center; font-size:11px;">${captionHtml}</div>`);
                    }
                });

                start.setDate(start.getDate() + 1);
            }

            return columns;
        },
        getWeekNumber: function (date) {
            const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
            const dayNum = d.getUTCDay() || 7;
            d.setUTCDate(d.getUTCDate() + 4 - dayNum);
            const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
            return Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
        },
        renderGrid: function (data, fromDateStr,allotmentType,byAllotmentDetail,byAllotmentandRoomType,byAllotmentandRoomTypeGroupbyAll,byAllotmentandRoomTypeGroupbyRT,byProfile,byRoomtypedetail) {
             const columnWidth = 120;
            // Convert string -> Date
            const fromDate = new Date(fromDateStr);
            fromDate.setHours(0, 0, 0, 0);
           
            // toDate = fromDate + 20 ngày
            const toDate = new Date(fromDate);
            toDate.setDate(toDate.getDate() + 20);
         console.log(allotmentType);
            const dateColumns = allot_report_Module.generateDateColumns(fromDate, toDate);

                let columns = [];

                if (Number(allotmentType) === 0 ) {
                    columns.push({
                        dataField: "AllotmentType",
                        caption: "Allotment Type",
                        width: columnWidth + 40,
                        fixed: true
                    });
                } 
                else if (Number(allotmentType) === 1 ) {
                    columns.push({
                        dataField: "RoomType",
                        caption: "Room Type",
                        width: columnWidth + 40,
                        fixed: true
                    });
                }
                else if (Number(byAllotmentDetail) === 1 && Number(byAllotmentandRoomType) === 0 && Number(byAllotmentandRoomTypeGroupbyAll) === 0 && Number(byAllotmentandRoomTypeGroupbyRT) === 0 && Number(byProfile) === 0 && Number(byRoomtypedetail) === 0) {
                    columns.push(
                        {
                            dataField: "AllotmentType",
                            caption: "Allotment Type",
                            width: columnWidth + 40,
                            fixed: true
                        },
                        {
                            dataField: "AllotmentCode",
                            caption: "Allotment Code",
                            width: columnWidth,
                            fixed: true
                        },
                        {
                            dataField: "AccountName",
                            caption: "Account Name",
                            width: columnWidth + 60,
                            fixed: true
                        }
                    );
                }
                else if (  Number(byAllotmentandRoomType) === 1 && Number(byAllotmentandRoomTypeGroupbyAll) === 0 && Number(byAllotmentandRoomTypeGroupbyRT) === 0 && Number(byProfile) === 0 && Number(byRoomtypedetail) === 0) {
                    columns.push({
                        dataField: "RoomType",
                        caption: "Room Type",
                        width: columnWidth + 40,
                        fixed: true
                    });
                }
                else if ( Number(byAllotmentandRoomTypeGroupbyAll) === 1 && Number(byAllotmentandRoomTypeGroupbyRT) === 0 && Number(byProfile) === 0 && Number(byRoomtypedetail) === 0) {
                   columns.push(
                      
                        {
                            dataField: "AllotmentCode",
                            caption: "Allotment Code",
                            width: columnWidth,
                            fixed: true
                        },
                        {
                            dataField: "RoomType",
                            caption: "Room Type",
                            width: columnWidth + 40,
                            fixed: true
                        },
                        {
                            dataField: "AccountName",
                            caption: "Account Name",
                            width: columnWidth + 60,
                            fixed: true
                        }
                   );
                }
                else if ( Number(byAllotmentandRoomTypeGroupbyRT) === 1 && Number(byProfile) === 0 && Number(byRoomtypedetail) === 0) {
                   columns.push(

                        {
                            dataField: "AllotmentCode",
                            caption: "Allotment Code",
                            width: columnWidth,
                            fixed: true
                        },
                        {
                            dataField: "RoomType",
                            caption: "Room Type",
                            width: columnWidth + 40,
                            fixed: true
                        },
                        {
                            dataField: "AccountName",
                            caption: "Account Name",
                            width: columnWidth + 60,
                            fixed: true
                        }
                   );
                }
                 else if ( Number(byProfile) === 1 && Number(byRoomtypedetail) === 0) {
                   columns.push(

                        {
                            dataField: "ProfileCode",
                            caption: "ProfileCode Code",
                            width: columnWidth,
                            fixed: true
                        },
                        {
                            dataField: "Code",
                            caption: "Code",
                            width: columnWidth + 40,
                            fixed: true
                        } 
                   );
                }
                else if (Number(byRoomtypedetail) === 1) {
                   columns.push(

                        {
                            dataField: "AllotmentCode",
                            caption: "Allotment Code",
                            width: columnWidth,
                            fixed: true
                        },
                        {
                            dataField: "RoomType",
                            caption: "Room Type",
                            width: columnWidth + 40,
                            fixed: true
                        },
                        {
                            dataField: "AccountName",
                            caption: "Account Name",
                            width: columnWidth + 60,
                            fixed: true
                        }
                   );
                }
                else {
                    console.warn("Invalid allotmentType value");
                    return;
                };
                columns = [...columns, ...dateColumns];

                let groupingConfig = {};
                let groupPanelConfig = {};

                if (Number(byAllotmentandRoomTypeGroupbyAll) === 1) {

                    const accountColumn = columns.find(c => c.dataField === "AccountName");

                    if (accountColumn) {

                        accountColumn.groupIndex = 0;

                        accountColumn.groupCellTemplate = function (element, info) {
                            element.append(
                                $("<div>").text("Account Name: " + info.value)
                            );
                        };
                    }

                    groupingConfig = {
                        autoExpandAll: true
                    };

                    groupPanelConfig = {
                        visible: false
                    };
                }else  if (Number(byAllotmentandRoomTypeGroupbyRT) === 1) {

                    const accountColumn = columns.find(c => c.dataField === "RoomType");

                    if (accountColumn) {

                        accountColumn.groupIndex = 0;

                        accountColumn.groupCellTemplate = function (element, info) {
                            element.append(
                                $("<div>").text("Room Type: " + info.value)
                            );
                        };
                    }

                    groupingConfig = {
                        autoExpandAll: true
                    };

                    groupPanelConfig = {
                        visible: false
                    };
                }else  if (Number(byRoomtypedetail) === 1) {

                    const accountColumn = columns.find(c => c.dataField === "RoomType");

                    if (accountColumn) {

                        accountColumn.groupIndex = 0;

                        accountColumn.groupCellTemplate = function (element, info) {
                            element.append(
                                $("<div>").text("Room Type: " + info.value)
                            );
                        };
                    }

                    groupingConfig = {
                        autoExpandAll: true
                    };

                    groupPanelConfig = {
                        visible: false
                    };
                }

                    $("#allot_report_grid").dxDataGrid({
                dataSource: data,
                height: "100%",
                width: "100%",
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                hoverStateEnabled: true,
                columns: columns,
                grouping: groupingConfig,
                groupPanel: groupPanelConfig,
                filterRow: { visible: true, applyFilter: "auto" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, 100],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: { mode: "standard", showScrollbar: "always" },
                onSelectionChanged: (e) => {
                    this.selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
                }
            });
        },

        exportExcel: function () {
            const grid = $("#allot_stage_grid").dxDataGrid("instance");
            if (!grid) return;

            const workbook = new ExcelJS.Workbook();
            const companyName = localStorage.getItem("CompanyName") || "System";
            const worksheet = workbook.addWorksheet("Sheet 1");

            worksheet.addRow([companyName]);
            worksheet.mergeCells('A1:D1');
            worksheet.getRow(1).font = { bold: true };

            const exportDate = new Date().toLocaleString("vi-VN");
            worksheet.addRow(['', '', '', exportDate]);
            worksheet.getRow(2).alignment = { horizontal: 'right' };

            worksheet.addRow([]);
            worksheet.addRow([]);

            const reportRow = worksheet.addRow(['Allotment Stage Report']);
            worksheet.mergeCells('A5:D5');
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { horizontal: 'center' };

            worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(() => {
                workbook.xlsx.writeBuffer().then((buffer) => {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "AllotmentStage.xlsx");
                });
            });
        }
    };

    $(document).ready(function () {
        allot_report_Module.init();
    });
</script>
