@using DevExpress.XtraReports.UI

@{
    ViewBag.Title = ViewBag.ReportHeader;
    var zoneList = ViewBag.ZoneList;
    var roomtypeList = ViewBag.RoomTypeList;
    var roomList = ViewBag.RoomList;
}


<!-- =========================
     MAIN MODAL: ROOM STATUS
========================== -->
<div class="modal fade" id="rms_modal" data-bs-backdrop="static" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable modal-4by3">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header bg-light py-2">
                <h5 class="modal-title">Room Status</h5>

            </div>

            <!-- BODY -->
            <div class="search-filter">

                <!-- ACTION BAR -->
                <div>
                    <button id="rms_btnPrint" class="mui-button mui-button-new">View</button>

                    <button id="rms_btnSelectAll" class="mui-button mui-button-new" type="button">Select All</button>
                    <button id="rms_btnClearAll" class="mui-button mui-button-new" type="button">Clear All</button>

                    <button id="rms_btnChangeStatus" class="mui-button mui-button-new" type="button">Chg Status</button>
                    <button id="rms_btnChecklog" class="mui-button mui-button-new" type="button">Ac.Log</button>

                    <button id="rms_btnExportExcel" class="mui-button mui-button-new" type="button">Excel</button>
                    <button id="rms_btnExportPdf" class="mui-button mui-button-new" type="button">PDF</button>

                    <button id="rms_btnUpdatestatus" class="mui-button mui-button-new" type="button">Update</button>

                    <button id="rms_btnFloorplan" class="mui-button mui-button-new" type="button">Floor Plan</button>
                    <button class="mui-button mui-button-new" data-bs-dismiss="modal"aria-label="Close">Close</button>

                </div>
                <!-- CARD = FILTER + GRID -->
                <div class="rms-card mb-2 mt-1">
                    <!-- FILTER PANEL (ERP BS5 layout) -->
                    <div class="mt-1 flex-shrink-0">
                        <div class="row g-2 mt-1 align-items-center">

                            <!-- Room Status -->
                            <div class="col-12">
                                <div class="row g-1 align-items-center">
                                    <label class="col-12 col-md-2 text-md-end mb-0 fw-semibold text-nowrap">
                                        Room Status:
                                    </label>

                                    <div class="col-12 col-md-10">
                                        <div class="d-flex flex-wrap gap-2">

                                            <div class="form-check form-check-inline mb-0">
                                                <input class="rms_include-option"
                                                       type="checkbox"
                                                       id="rms_cleannon"
                                                       checked>
                                                <label class="form-check-label" for="rms_cleannon">Clean Non-Checked</label>
                                            </div>

                                            <div class="form-check form-check-inline mb-0">
                                                <input class="rms_include-option"
                                                       type="checkbox"
                                                       id="rms_clean"
                                                       checked>
                                                <label class="form-check-label" for="rms_clean">Clean</label>
                                            </div>

                                            <div class="form-check form-check-inline mb-0">
                                                <input class="rms_include-option"
                                                       type="checkbox"
                                                       id="rms_dirty"
                                                       checked>
                                                <label class="form-check-label" for="rms_dirty">Dirty</label>
                                            </div>

                                            <div class="form-check form-check-inline mb-0">
                                                <input class="rms_include-option"
                                                       type="checkbox"
                                                       id="rms_pickup"
                                                       checked>
                                                <label class="form-check-label" for="rms_pickup">Pickup</label>
                                            </div>

                                            <div class="form-check form-check-inline mb-0">
                                                <input class="rms_include-option"
                                                       type="checkbox"
                                                       id="rms_oocheck"
                                                       checked>
                                                <label class="form-check-label" for="rms_oocheck">OO</label>
                                            </div>

                                            <div class="form-check form-check-inline mb-0">
                                                <input class="rms_include-option"
                                                       type="checkbox"
                                                       id="rms_oscheck"
                                                       checked>
                                                <label class="form-check-label" for="rms_oscheck">OS</label>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- FO Status -->
                            <div class="col-12">
                                <div class="row g-1 align-items-center">
                                    <label class="col-12 col-md-2 text-md-end mb-0 fw-semibold text-nowrap">
                                        FO Status:
                                    </label>

                                    <div class="col-12 col-md-10">
                                        <div class="d-flex flex-wrap gap-2">

                                            <div class="form-check form-check-inline mb-0">
                                                <input class="rms_include-option"
                                                       type="checkbox"
                                                       id="rms_vacant"
                                                       checked>
                                                <label class="form-check-label" for="rms_vacant">Vacant</label>
                                            </div>

                                            <div class="form-check form-check-inline mb-0">
                                                <input class="rms_include-option"
                                                       type="checkbox"
                                                       id="rms_occupied"
                                                       checked>
                                                <label class="form-check-label" for="rms_occupied">Occupied</label>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Reservation Status -->
                            <div class="col-12">
                                <div class="row g-1 align-items-center">
                                    <label class="col-12 col-md-2 text-md-end mb-0 fw-semibold text-nowrap">
                                        Reservation Status:
                                    </label>

                                    <div class="col-12 col-md-10">
                                        <div class="d-flex flex-wrap gap-2">

                                            <div class="form-check form-check-inline mb-0">
                                                <input class="rms_include-option"
                                                       type="checkbox"
                                                       id="rms_arrivals"
                                                       checked>
                                                <label class="form-check-label" for="rms_arrivals">Arrivals</label>
                                            </div>

                                            <div class="form-check form-check-inline mb-0">
                                                <input class="rms_include-option"
                                                       type="checkbox"
                                                       id="rms_arrived"
                                                       checked>
                                                <label class="form-check-label" for="rms_arrived">Arrived</label>
                                            </div>

                                            <div class="form-check form-check-inline mb-0">
                                                <input class="rms_include-option"
                                                       type="checkbox"
                                                       id="rms_stayover"
                                                       checked>
                                                <label class="form-check-label" for="rms_stayover">Stayover</label>
                                            </div>

                                            <div class="form-check form-check-inline mb-0">
                                                <input class="rms_include-option"
                                                       type="checkbox"
                                                       id="rms_dayuse"
                                                       checked>
                                                <label class="form-check-label" for="rms_dayuse">DayUse</label>
                                            </div>

                                            <div class="form-check form-check-inline mb-0">
                                                <input class="rms_include-option"
                                                       type="checkbox"
                                                       id="rms_dueout"
                                                       checked>
                                                <label class="form-check-label" for="rms_dueout">Due Out</label>
                                            </div>

                                            <div class="form-check form-check-inline mb-0">
                                                <input class="rms_include-option"
                                                       type="checkbox"
                                                       id="rms_departed"
                                                       checked>
                                                <label class="form-check-label" for="rms_departed">Departed</label>
                                            </div>

                                            <div class="form-check form-check-inline mb-0">
                                                <input class="rms_include-option"
                                                       type="checkbox"
                                                       id="rms_notReserved"
                                                       checked>
                                                <label class="form-check-label" for="rms_notReserved">NotReserved</label>
                                            </div>

                                            <div class="form-check form-check-inline mb-0">
                                                <input class="rms_include-option"
                                                       type="checkbox"
                                                       id="rms_departuredarr"
                                                       checked>
                                                <label class="form-check-label" for="rms_departuredarr">Departured/Arrival</label>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Room Type -->
                            <div class="col-12 col-sm-6 col-md-6 col-lg-3">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 text-md-end mb-0 text-nowrap">
                                        Room Type
                                    </label>
                                    <div class="col-8">
                                        <select id="rms_roomtype" class="tomselect-custom" multiple>
                                            @foreach (var item in roomtypeList)
                                            {
                                                <option value="@item.Code">@item.Code</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Zone -->
                            <div class="col-12 col-sm-6 col-md-6 col-lg-3">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 text-md-end mb-0 text-nowrap">
                                        Zone
                                    </label>
                                    <div class="col-8">
                                        <select id="rms_zone" class="tomselect-custom" multiple>
                                            @foreach (var item in zoneList)
                                            {
                                                <option value="@item.Code">@item.Code</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- From Room -->
                            <div class="col-12 col-sm-6 col-md-6 col-lg-3">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 text-md-end mb-0 text-nowrap">
                                        From Room
                                    </label>
                                    <div class="col-8">
                                        <select id="rms_roomfrom" class="tomselect-custom">
                                            <option value=""></option>
                                            @foreach (var item in roomList)
                                            {
                                                <option value="@item.RoomNo">@item.RoomNo</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- To Room -->
                            <div class="col-12 col-sm-6 col-md-6 col-lg-3">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 text-md-end mb-0 text-nowrap">
                                        To Room
                                    </label>
                                    <div class="col-8">
                                        <select id="rms_roomto" class="tomselect-custom">
                                            <option value=""></option>
                                            @foreach (var item in roomList)
                                            {
                                                <option value="@item.RoomNo">@item.RoomNo</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Change Status (inline) -->
                            <div class="col-12">
                                <div class="row g-1 align-items-center">
                                    <label class="col-12 col-md-2 text-md-end mb-0 fw-semibold text-nowrap">
                                        Change Status:
                                    </label>

                                    <div class="col-12 col-md-10">
                                        <div class="d-flex flex-wrap gap-2">

                                            <div class="form-check form-check-inline mb-0">
                                                <input 
                                                       type="checkbox"
                                                       id="rms_cleannonup"
                                                       name="rms_masterllioup">
                                                <label class="form-check-label" for="rms_cleannonup">Clean Non-Checked</label>
                                            </div>

                                            <div class="form-check form-check-inline mb-0">
                                                <input 
                                                       type="checkbox"
                                                       id="rms_dirtyup"
                                                       name="rms_masterllioup">
                                                <label class="form-check-label" for="rms_dirtyup">Dirty</label>
                                            </div>

                                            <div class="form-check form-check-inline mb-0">
                                                <input 
                                                       type="checkbox"
                                                       id="rms_cleanup"
                                                       name="rms_masterllioup"
                                                       checked>
                                                <label class="form-check-label" for="rms_cleanup">Clean</label>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
                <!-- GRID -->
                <div class="mui-card mt-2">
                    <div id="rms_gridContainer" class="gridContainer"></div>
                </div>

                <div id="rms_loadingSpinner" 
                    style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                        z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                        height: 100%;display: flex;align-items: center;justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>                    
        </div>
    </div>
</div>

<!-- =========================
     MODAL: CHANGE STATUS
========================== -->
<div class="modal fade" id="rms_popupChangeStatus" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Change Room Status</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">
                    <button id="rms_btnSavePopup" class="mui-button mui-button-new">Save</button>
                    <button id="rms_btnClearPopup" class="mui-button mui-button-new">Clear</button>
                    <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>

                <div class="mb-3 d-flex align-items-center gap-2">
                    <div class="form-check mb-0">
                        <input type="checkbox" id="rms_checkRoomList" checked>
                    </div>
                    <label class="fw-bold me-2 mb-0" style="min-width:90px;">Room List:</label>
                    <select id="rms_popupRoomList" class="tomselect-custom" multiple>
                        @foreach (var item in roomList)
                        {
                            <option value="@item.ID">@item.RoomNo</option>
                        }
                    </select>
                </div>

                <div class="mb-3 d-flex align-items-center gap-2">
                    <div class="form-check mb-0">
                        <input type="checkbox" id="rms_checkRoomRange">
                    </div>
                    <label class="fw-bold me-2 mb-0" style="min-width:90px;">From Room:</label>

                    <select id="rms_popupRoomFrom" class="form-control form-control-sm" style="width:120px;">
                        <option value=""></option>
                        @foreach (var item in roomList)
                        {
                            <option value="@item.RoomNo">@item.RoomNo</option>
                        }
                    </select>

                    <span class="fw-bold">→ To</span>

                    <select id="rms_popupRoomTo" class="form-control form-control-sm" style="width:120px;">
                        <option value=""></option>
                        @foreach (var item in roomList)
                        {
                            <option value="@item.RoomNo">@item.RoomNo</option>
                        }
                    </select>
                </div>

                <div class="d-flex flex-column mt-2 mb-3">
                    <label class="fw-bold mb-2">Change Status:</label>

                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <div class="form-check me-3">
                            <input type="checkbox" id="rms_cleannonupop" name="rms_masterlliouppop">
                            <label class="form-check-label" for="rms_cleannonupop">Clean Non-Checked</label>
                        </div>

                        <div class="form-check me-3">
                            <input type="checkbox" id="rms_dirtyupop" name="rms_masterlliouppop">
                            <label class="form-check-label" for="rms_dirtyupop">Dirty</label>
                        </div>

                        <div class="form-check me-3">
                            <input type="checkbox" id="rms_cleanupop" name="rms_masterlliouppop">
                            <label class="form-check-label" for="rms_cleanupop">Clean</label>
                        </div>

                        <div class="form-check me-3">
                            <input type="checkbox" id="rms_pickupop" name="rms_masterlliouppop">
                            <label class="form-check-label" for="rms_pickupop">Pickup</label>
                        </div>

                        <div class="form-check me-3">
                            <input type="checkbox" id="rms_dueoutop" name="rms_masterlliouppop">
                            <label class="form-check-label" for="rms_dueoutop">Due Out</label>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- =========================
     MODAL: LOG GRID
========================== -->
<div class="modal fade" id="rms_popupLogGrid" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable modal-4by3">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Room Status History</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">
                    <div>
                        <button id="rms_btnSearchHis" class="mui-button mui-button-new">Search</button>
                        <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>

                    </div>
                    <div class="row g-2 align-items-center mt-1 mb-2">

                        <div class="col-12 col-md-3">
                            <div class="row g-1 align-items-center">
                                <label class="col-2 text-md-end mb-0 text-nowrap">Room</label>
                                <div class="col-9">
                                    <select id="rms_roomstatus" class="tomselect-custom" multiple>
                                        @foreach (var item in roomList)
                                        {
                                            <option value="@item.ID">@item.RoomNo</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-3">
                            <div class="row g-1 align-items-center">
                                <label class="col-4 text-md-end mb-0 text-nowrap">User</label>
                                <div class="col-8">
                                    <input id="rms_username"
                                        type="text"
                                        class="form-control form-control-sm"
                                        placeholder="Enter user name">
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-3">
                            <div class="row g-1 align-items-center">
                                <label class="col-4 text-md-end mb-0 text-nowrap">From</label>
                                <div class="col-8">
                                    <div class="clearable" data-date-input data-format="DD/MM/YYYY" data-name="rms_fromDate" business-date>
                                        <input type="text" class="date-ui form-control form-control-sm" autocomplete="off" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-3">
                            <div class="row g-1 align-items-center">
                                <label class="col-4 text-md-end mb-0 text-nowrap">To</label>
                                <div class="col-8">
                                     <div class="clearable" data-date-input data-format="DD/MM/YYYY" data-name="rms_toDate" business-date>
                                        <input type="text" class="date-ui form-control form-control-sm" autocomplete="off" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="mui-card">
                    <div id="rms_logGridContainer" class="gridContainer mt-2"></div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    var rms_Module = {

        // runtime state
        selectedRoomIds: [],
        grid: null,
        logGrid: null,

        init: function () {
            this.initTomSelects();
            this.initDefaultDates();
            this.bindEvents();

            // initial load
            $("#rms_btnPrint").trigger("click");
        },

        initTomSelects: function () {
            initTomSelect(".tomselect-custom");
            clearMultipleTomSelect(['#rms_roomfrom', '#rms_roomto']);
        },

        initDefaultDates: function () {
            const today = new Date();

            const firstDay = new Date(today);
            firstDay.setDate(today.getDate() - 1);

            const lastDay = new Date(today);

            $('#rms_fromDate').val(this.formatDate(firstDay));
            $('#rms_toDate').val(this.formatDate(lastDay));
        },

        formatDate: function (date) {
            let year = date.getFullYear();
            let month = (date.getMonth() + 1).toString().padStart(2, '0');
            let day = date.getDate().toString().padStart(2, '0');
            return `${year}-${month}-${day}`;
        },

        bindEvents: function () {
            const self = this;

            // single checkbox in group (top)
            $(document).off("change.rms", "input[name='rms_masterllioup']");
            $(document).on("change.rms", "input[name='rms_masterllioup']", function () {
                $("input[name='rms_masterllioup']").not(this).prop("checked", false);
            });

            // single checkbox in group (popup)
            $(document).off("change.rms", "input[name='rms_masterlliouppop']");
            $(document).on("change.rms", "input[name='rms_masterlliouppop']", function () {
                $("input[name='rms_masterlliouppop']").not(this).prop("checked", false);
            });

            // select all / clear all
            $(document).off("click.rms", "#rms_btnSelectAll");
            $(document).on("click.rms", "#rms_btnSelectAll", function () {
                $(".rms_include-option").prop("checked", true);
            });

            $(document).off("click.rms", "#rms_btnClearAll");
            $(document).on("click.rms", "#rms_btnClearAll", function () {
                $(".rms_include-option").prop("checked", false);
            });

            // main actions
            $(document).off("click.rms", "#rms_btnFloorplan");
            $(document).on("click.rms", "#rms_btnFloorplan", function () {
                window.location.href = "/HouseKeeping/FloorPlan";
            });

            $(document).off("click.rms", "#rms_btnChangeStatus");
            $(document).on("click.rms", "#rms_btnChangeStatus", function () {
                $("#rms_popupChangeStatus").modal("show");
            });

            // popup room mode
            $(document).off("change.rms", "#rms_checkRoomList");
            $(document).on("change.rms", "#rms_checkRoomList", function () {
                $("#rms_checkRoomRange").prop("checked", false);
                self.updateRoomInputs();
            });

            $(document).off("change.rms", "#rms_checkRoomRange");
            $(document).on("change.rms", "#rms_checkRoomRange", function () {
                $("#rms_checkRoomList").prop("checked", false);
                self.updateRoomInputs();
            });

            // popup clear
            $(document).off("click.rms", "#rms_btnClearPopup");
            $(document).on("click.rms", "#rms_btnClearPopup", function () {
                $('#rms_popupRoomList').val([]).trigger('change');
                $('#rms_popupRoomFrom').val('');
                $('#rms_popupRoomTo').val('');
                $('#rms_checkRoomList').prop('checked', false);
                $('#rms_checkRoomRange').prop('checked', false);
                self.updateRoomInputs();
            });

            // view
            $(document).off("click.rms", "#rms_btnPrint");
            $(document).on("click.rms", "#rms_btnPrint", function () {
                self.search();
            });

            // update selected rows
            $(document).off("click.rms", "#rms_btnUpdatestatus");
            $(document).on("click.rms", "#rms_btnUpdatestatus", function () {
                if (!self.selectedRoomIds || self.selectedRoomIds.length === 0) {
                    showToast('Warning', 'You must choose at least one room.', false);
                    return;
                }

                if (!confirm("Are you sure you want to change room status?")) return;

                self.updateStatus(self.selectedRoomIds);
            });

            // check log
            $(document).off("click.rms", "#rms_btnChecklog");
            $(document).on("click.rms", "#rms_btnChecklog", function () {
                if (!self.selectedRoomIds || self.selectedRoomIds.length === 0) {
                    showToast('Warning', 'You must choose at least one room.', false);
                    return;
                }

                self.checkLogStatus(self.selectedRoomIds);
            });

            // search history in log modal
            $(document).off("click.rms", "#rms_btnSearchHis");
            $(document).on("click.rms", "#rms_btnSearchHis", function () {
                const roomStatusValue = $('#rms_roomstatus').val();

                if (!roomStatusValue || roomStatusValue.length === 0) {
                    showToast('Warning', 'You must choose at least one room.', false);
                    return;
                }

                self.checkLogStatus(roomStatusValue);
            });

            // save popup
            $(document).off("click.rms", "#rms_btnSavePopup");
            $(document).on("click.rms", "#rms_btnSavePopup", function () {
                self.savePopup();
            });

            // export
            $(document).off("click.rms", "#rms_btnExportExcel");
            $(document).on("click.rms", "#rms_btnExportExcel", function () {
                self.exportExcel();
            });

            $(document).off("click.rms", "#rms_btnExportPdf");
            $(document).on("click.rms", "#rms_btnExportPdf", function () {
                self.exportPdf();
            });
        },

        updateRoomInputs: function () {
            const useList = $('#rms_checkRoomList').is(':checked');

            $('#rms_checkRoomRange').prop('checked', !useList);

            const popupRoomListEl = document.querySelector("#rms_popupRoomList");
            if (popupRoomListEl && popupRoomListEl.tomselect) {
                popupRoomListEl.tomselect.setDisabled(!useList);
            } else {
                $('#rms_popupRoomList').prop('disabled', !useList);
            }

            $('#rms_popupRoomFrom, #rms_popupRoomTo').prop('disabled', useList);
        },

        search: function () {
            const self = this;

            $("#rms_loadingSpinner").show();

            // ROOM STATUS
            let cleannon_room = $("#rms_cleannon").is(":checked") ? 1 : 0;
            let clean = $("#rms_clean").is(":checked") ? 1 : 0;
            let dirty = $("#rms_dirty").is(":checked") ? 1 : 0;
            let pickup = $("#rms_pickup").is(":checked") ? 1 : 0;
            let oocheck = $("#rms_oocheck").is(":checked") ? 1 : 0;
            let oscheck = $("#rms_oscheck").is(":checked") ? 1 : 0;

            // FO STATUS
            let vacant = $("#rms_vacant").is(":checked") ? 1 : 0;
            let occupied = $("#rms_occupied").is(":checked") ? 1 : 0;

            // RESERVATION STATUS
            let arrivals = $("#rms_arrivals").is(":checked") ? 1 : 0;
            let arrived = $("#rms_arrived").is(":checked") ? 1 : 0;
            let stayover = $("#rms_stayover").is(":checked") ? 1 : 0;
            let dayuse = $("#rms_dayuse").is(":checked") ? 1 : 0;
            let dueout = $("#rms_dueout").is(":checked") ? 1 : 0;
            let departed = $("#rms_departed").is(":checked") ? 1 : 0;
            let notReserved = $("#rms_notReserved").is(":checked") ? 1 : 0;
            let departuredarr = $("#rms_departuredarr").is(":checked") ? 1 : 0;

            // ROOM FILTER
            let roomType = $("#rms_roomtype").val();
            let zone = $("#rms_zone").val();
            let roomFrom = $("#rms_roomfrom").val();
            let roomTo = $("#rms_roomto").val();

            $.ajax({
                url: '/HouseKeeping/RoomStatusData',
                type: 'GET',
                data: {
                    cleannon_room: cleannon_room,
                    clean: clean,
                    dirty: dirty,
                    pickup: pickup,
                    oocheck: oocheck,
                    oscheck: oscheck,

                    vacant: vacant,
                    occupied: occupied,

                    arrivals: arrivals,
                    arrived: arrived,
                    stayover: stayover,
                    dayuse: dayuse,
                    dueout: dueout,
                    departed: departed,
                    notReserved: notReserved,
                    departuredarr: departuredarr,

                    roomType: roomType,
                    zone: zone,
                    roomFrom: roomFrom,
                    roomTo: roomTo
                },
                traditional: true,
                crossDomain: false,
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                success: function (result) {
                    self.renderGrid(result);
                    $("#rms_loadingSpinner").hide();
                },
                error: function () {
                    showToast("Error", "Cannot load report.", false);
                    $("#rms_loadingSpinner").hide();
                }
            });
        },

        renderGrid: function (data) {
            const self = this;

            // reset selection
            self.selectedRoomIds = [];

            // dispose old grid
            if ($("#rms_gridContainer").data("dxDataGrid")) {
                $("#rms_gridContainer").dxDataGrid("dispose");
                $("#rms_gridContainer").empty();
            }

            $("#rms_gridContainer").dxDataGrid({
                dataSource: data,
                allowColumnResizing: true,
                height: "100%",
                columnAutoWidth: true,
                showBorders: true,

                columns: [
                    { dataField: "id", caption: "ID", visible: false },
                    { dataField: "roomNumber", caption: "Room No", width: "8%" },
                    { dataField: "roomType", caption: "Room Type", width: "10%" },
                    { dataField: "roomName", caption: "Room Name",  },
                    { dataField: "roomStatus", caption: "Room Status", width: "12%" },
                    { dataField: "foStatus", caption: "FO Status", width: "8%" },
                    { dataField: "floor", caption: "Floor", width: "7%", dataType: "number", format: "#,##0" },
                    { dataField: "roomClass", caption: "Room Class", width: "10%" },
                    { dataField: "reservationStatus", caption: "Resv.Type", width: "10%" },
                    { dataField: "arrival", caption: "Arrivals", width: "10%", dataType: "date", format: "dd/MM/yyyy" }
                ],

                paging: { pageSize: 15 },
                scrolling: { useNative: true, showScrollbar: "always" },
                pager: {
                    visible: true,
                    allowedPageSizes: [15, 50, 'all'],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: { visible: true, applyFilter: "auto" },
                headerFilter: { visible: true },

                selection: { mode: "multiple", showCheckBoxesMode: "none" },

                onCellPrepared: function (e) {
                    if (e.rowType !== "data") return;
                    if (e.column.dataField !== "roomStatus") return;

                    const status = (e.value || "").toLowerCase();

                    if (status.includes("dirty")) {
                        e.cellElement.css({ "background-color": "red", "color": "white" });
                    } else if (status.includes("pickup")) {
                        e.cellElement.css({ "background-color": "#f740f4" });
                    } else if (status.includes("clean non-checked")) {
                        e.cellElement.css({ "background-color": "#1bdff5" });
                    } else if (status.includes("out of order")) {
                        e.cellElement.css({ "background-color": "#cf159a", "color": "white" });
                    } else if (status.includes("clean")) {
                        e.cellElement.css({ "background-color": "green", "color": "white" });
                    }
                },

                onSelectionChanged: function (e) {
                    self.selectedRoomIds = (e.selectedRowsData || [])
                        .map(x => x.id)
                        .filter(x => x !== null && x !== undefined);

                    console.log("Selected IDs:", self.selectedRoomIds);
                }
            });

            self.grid = $("#rms_gridContainer").dxDataGrid("instance");
        },

        updateStatus: function (selectedRoomIds) {
            let status = 0;

            if ($("#rms_cleannonup").is(":checked")) status = 1;
            else if ($("#rms_dirtyup").is(":checked")) status = 2;
            else if ($("#rms_cleanup").is(":checked")) status = 4;

            if (!selectedRoomIds || selectedRoomIds.length === 0) {
                showToast('Warning', 'You must choose at least one room.', false);
                return;
            }

            const loginName = JSON.parse(localStorage.getItem("Loginname"));

            $.ajax({
                url: '/HouseKeeping/UpdateRoomStatus',
                type: 'POST',
                data: { ids: selectedRoomIds, status: status, loginName: loginName },
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: (response) => {
                    if (response.success) {
                        showToast('Success', response.message, true);
                        this.search();
                    } else {
                        showToast('Error', response.message, false);
                    }
                },
                error: function () {
                    showToast("Error", "Update failed.", false);
                }
            });
        },

        checkLogStatus: function (ids) {
            initDateInputs();
            const self = this;

            const fromDate = $('#rms_fromDate').val()||dateSystem;
            const toDate = $('#rms_toDate').val()||dateSystem;
            const username = $('#rms_username').val();

            $.ajax({
                url: '/HouseKeeping/CheckLogStatus',
                type: 'POST',
                data: {
                    id: ids,
                    fromDate: fromDate,
                    toDate: toDate,
                    username: username
                },
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (response) {

                    // if call from main selection -> auto fill roomstatus tomselect
                    if (response.length > 0 && response[0].roomNo) {
                        const ts = $('#rms_roomstatus')[0]?.tomselect;
                        if (ts) {
                            ts.clear(true);
                            ts.setValue(ids, true);
                        }
                    }

                    self.renderLogGrid(response);
                    $("#rms_popupLogGrid").modal('show');
                },
                error: function () {
                    showToast("Error", "Cannot load log.", false);
                }
            });
        },

        renderLogGrid: function (data) {

            if ($("#rms_logGridContainer").data("dxDataGrid")) {
                $("#rms_logGridContainer").dxDataGrid("dispose");
                $("#rms_logGridContainer").empty();
            }

            $("#rms_logGridContainer").dxDataGrid({
                dataSource: data,
                allowColumnResizing: true,
                columnAutoWidth: true,
                showBorders: true,

                columns: [
                    { dataField: "roomNo", caption: "Room No", width: 130 },
                    { dataField: "oldValue", caption: "Old Value", width: 130 },
                    { dataField: "newValue", caption: "New Value", width: 130 },
                    { dataField: "userName", caption: "User Name", width: 130 },
                    { dataField: "action", caption: "Action", width: 130 },
                    { dataField: "computerName", caption: "Computer", width: 130 },
                    { dataField: "changeDate", caption: "Change Date", width: 160, dataType: "date", format: "dd/MM/yyyy" }
                ],

                paging: { pageSize: 25 },
                scrolling: { useNative: true, showScrollbar: "always" },
                pager: {
                    visible: true,
                    allowedPageSizes: [25, 50, 'all'],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: { visible: true, applyFilter: "auto" },
                headerFilter: { visible: true }
            });

            this.logGrid = $("#rms_logGridContainer").dxDataGrid("instance");
        },

        savePopup: function () {
            const self = this;

            $("#rms_loadingSpinner").show();

            // status
            let status = 0;
            if ($("#rms_cleannonupop").is(":checked")) status = 1;
            else if ($("#rms_dirtyupop").is(":checked")) status = 2;
            else if ($("#rms_cleanupop").is(":checked")) status = 4;
            else if ($("#rms_dueoutop").is(":checked")) status = 7;
            else if ($("#rms_pickupop").is(":checked")) status = 3;

            if (status === 0) {
                showToast('Warning', 'Please select a room status.', false);
                $("#rms_loadingSpinner").hide();
                return;
            }

            let isFromTo = 0;
            let roomIds = [];

            if ($("#rms_checkRoomRange").is(":checked")) {
                isFromTo = 1;

                let from = $("#rms_popupRoomFrom").val();
                let to = $("#rms_popupRoomTo").val();

                if (!from || !to) {
                    showToast('Warning', 'Please select both From and To rooms.', false);
                    $("#rms_loadingSpinner").hide();
                    return;
                }

                roomIds = [from, to];

            } else if ($("#rms_checkRoomList").is(":checked")) {
                isFromTo = 0;
                roomIds = $("#rms_popupRoomList").val();

                if (!roomIds || roomIds.length === 0) {
                    showToast('Warning', 'Please select at least one room.', false);
                    $("#rms_loadingSpinner").hide();
                    return;
                }

            } else {
                showToast('Warning', 'Please choose how to select rooms (List or From → To).', false);
                $("#rms_loadingSpinner").hide();
                return;
            }

            const loginName = JSON.parse(localStorage.getItem("Loginname"));

            $.ajax({
                url: '/HouseKeeping/UpdateRoomStatusPopup',
                type: 'POST',
                data: {
                    status: status,
                    roomIds: roomIds,
                    isFromTo: isFromTo,
                    loginName: loginName
                },
                traditional: true,
                crossDomain: false,
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                success: function (response) {
                    if (response.success) {
                        showToast('Success', response.message, true);
                        $("#rms_popupChangeStatus").modal("hide");
                        self.search();
                    } else {
                        showToast('Error', response.message, false);
                    }
                    $("#rms_loadingSpinner").hide();
                },
                error: function () {
                    showToast("Error", "Failed to update room status.", false);
                    $("#rms_loadingSpinner").hide();
                }
            });
        },

        exportExcel: function () {
            const grid = $("#rms_gridContainer").dxDataGrid("instance");
            var selectedReport = '@ViewBag.ReportTitle' || 'Room Status';

            if (!grid) {
                showToast("Warning", "No grid data.", false);
                return;
            }

            const workbook = new ExcelJS.Workbook();
            const worksheet = workbook.addWorksheet("Sheet 1");

            worksheet.addRow(['Công ty Cổ phần Giải pháp Công nghệ CS-Solution']);
            worksheet.mergeCells('A1:E1');
            worksheet.getRow(1).font = { bold: true };
            worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

            const now = new Date();
            const exportDate = now.toLocaleString("vi-VN");
            worksheet.addRow(['', '', '', '', ' ' + exportDate]);
            worksheet.mergeCells('E2:H2');
            worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

            worksheet.addRow([]);
            worksheet.addRow([]);

            const reportRow = worksheet.addRow(['', '', selectedReport]);
            worksheet.mergeCells('C5:F5');
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

            worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const lastRow = worksheet.lastRow.number + 2;
                worksheet.getCell(`A${lastRow}`).value = "--- END  ---";
                worksheet.mergeCells(`A${lastRow}:F${lastRow}`);
                worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
                worksheet.getCell(`A${lastRow}`).font = { italic: true };

                let fileName = selectedReport + ".xlsx";
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
                });
            });
        },

        exportPdf: function () {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();

            DevExpress.pdfExporter.exportDataGrid({
                jsPDFDocument: doc,
                component: $("#rms_gridContainer").dxDataGrid("instance"),
                autoTableOptions: {
                    styles: { cellPadding: 2, fontSize: 8 },
                    margin: { top: 20 }
                }
            }).then(() => {
                doc.save("RoomStatus.pdf");
            });
        },

        destroy: function () {

            // remove event handlers in this namespace
            $(document).off(".rms");

            // dispose grids
            if ($("#rms_gridContainer").data("dxDataGrid")) {
                $("#rms_gridContainer").dxDataGrid("dispose");
                $("#rms_gridContainer").empty();
            }

            if ($("#rms_logGridContainer").data("dxDataGrid")) {
                $("#rms_logGridContainer").dxDataGrid("dispose");
                $("#rms_logGridContainer").empty();
            }

            // destroy tomselects
            $(".tomselect-custom").each(function () {
                if (this.tomselect) this.tomselect.destroy();
            });

            // reset state
            this.selectedRoomIds = [];
            this.grid = null;
            this.logGrid = null;
        }
    };

    // Global entry for ModalManager
    window.openModalRMS = function () {
        $("#rms_modal").modal("show");
        rms_Module.init();
    };

    // Cleanup
    $("#rms_modal").on("hidden.bs.modal", function () {
        rms_Module.destroy();
    });
</script>
