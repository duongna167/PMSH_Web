<div class="modal fade" id="modalAdjustTransaction" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-md">
        <div class="modal-content shadow">
            <div class="modal-header py-2 bg-light">
                <h5 class="modal-title fs-6 fw-bold">Adjustment Transaction</h5>
            </div>

            <div class="p-2 border-bottom d-flex gap-2 bg-light">
                <button type="button" class="mui-button mui-button-save" onclick="PostAdjustTransaction();">
                     Adjust
                </button>
                <button type="button" class="mui-button mui-button-close" onclick="closeModalAdjustTransaction();">
                     Close
                </button>
            </div>

            <div class="modal-body bg-light-gray">
                <div class="card mb-3">
                    <div class="card-header py-1 fw-bold small">Adjust information</div>
                    <div class="card-body p-3">
                        <div class="mb-3">
                            <input type="text" id="transCodeAdjust" class="form-control form-control-sm bg-white" readonly>
                        </div>

                        <div class="row align-items-center mb-2">
                            <div class="col-5">
                                <div class="form-check">
                                    <input class="me-1" type="radio" name="typeAdjustTransPrice" id="amountRadio" value="1" checked onchange="toggleInputs()">
                                    <label class="form-check-label small fw-bold" for="amountRadio">By Amount (++)</label>
                                </div>
                            </div>
                            <div class="col-7">
                                <input type="text" id="amountAdjust" class="form-control form-control-sm text-end amount-input" placeholder="0">
                            </div>
                        </div>

                        <div class="row align-items-center mb-3">
                            <div class="col-5 text-end">
                                <label class="small fw-bold">(net)</label>
                            </div>
                            <div class="col-7">
                                <input type="text" id="amountAdjustNet" class="form-control form-control-sm text-end amount-input fw-bold" placeholder="0">
                            </div>
                        </div>

                        <div class="row align-items-center">
                            <div class="col-5">
                                <div class="form-check">
                                    <input class="me-1" type="radio" name="typeAdjustTransPrice" id="percentRadio" value="2" onchange="toggleInputs()">
                                    <label class="form-check-label small fw-bold" for="percentRadio">By Percentage</label>
                                </div>
                            </div>
                            <div class="col-7">
                                <input type="text" id="percentageAdjust" class="form-control form-control-sm text-end percentage-input" placeholder="0" disabled>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header py-1 fw-bold small">Reason information</div>
                    <div class="card-body p-3">
                        <div class="row mb-2 align-items-center">
                            <label class="col-4 small">RT.Charge</label>
                            <div class="col-8">
                                <input type="text" id="rtChargeAdjust" class="form-control form-control-sm text-end" readonly>
                            </div>
                        </div>
                        <div class="row mb-2">
                            <label class="col-4 small">Reason</label>
                            <div class="col-8">
                                <select id="reasonAdjustTS" class="tomselect-custom"></select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12">
                                <textarea id="memoAdjust" class="form-control form-control-sm mt-1" rows="3" placeholder="Wrong posting..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
        
    // Biến lưu trữ ID dòng đang chọn
    var folioDetailAdjustID = 0;
    var maxAdjustNet = 0;
    var isSilentUpdate = false;

    function formatNumberAdjust(num) {
        if (num === null || num === undefined || isNaN(num) || num === '') return '0,00';
        return parseFloat(num).toLocaleString('vi-VN', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });
    }

    function parseNumberAdjust(str) {
        if (str === null || str === undefined || str === '') return 0;
        if (typeof str === 'number') return str;

        let cleanStr = str.toString().replace(/\./g, '').replace(/,/g, '.');
        let result = parseFloat(cleanStr);
        return isNaN(result) ? 0 : result;
    }

    function forceNegativeValue(inputElement) {
        let valStr = $(inputElement).val();
        if (!valStr || valStr === '0' || valStr === '0,00' || valStr === '-') {
            $(inputElement).val('0,00');
            return 0;
        }

        let valNum = parseNumberAdjust(valStr);

        // Ép thành số âm
        let negativeNum = Math.abs(valNum) * -1;

        $(inputElement).val(formatNumberAdjust(negativeNum)).css('color', 'red');

        return negativeNum;
    }

    // Nhập Net -> Tính ra Gross (Amount ++)
    function adjustCalcGrossFromNet() {
        let tCodeFull = $('#transCodeAdjust').val();
        if (!tCodeFull) return;

        let tCode = tCodeFull.split('-')[0].trim();
        let netVal = parseNumberAdjust($('#amountAdjustNet').val());

        $.ajax({
            url: '/Billing/CalculatePricePlusPlus',
            type: 'GET',
            data: { transactionCode: tCode, netPrice: netVal },
            success: function (res) {
                if (!isNaN(res)) {
                    $('#amountAdjust').val(formatNumberAdjust(res));
                    $('#amountAdjustNet').val(formatNumberAdjust(netVal));
                }
            }
        });
    }
    
    // Nhập Gross (Amount ++) -> Tính ra Net
    function adjustCalcNetFromGross() {
        let tCodeFull = $('#transCodeAdjust').val();
        if (!tCodeFull) return;

        let tCode = tCodeFull.split('-')[0].trim();
        let grossVal = parseNumberAdjust($('#amountAdjust').val());

        $.ajax({
            url: '/Billing/CalculatePriceNet',
            type: 'GET',
            data: { transactionCode: tCode, grossPrice: grossVal },
            success: function (res) {
                if (!isNaN(res)) {
                    $('#amountAdjustNet').val(formatNumberAdjust(res));
                    $('#amountAdjust').val(formatNumberAdjust(grossVal));
                }
            }
        });
    }   

    $(document).ready(function() {
        clearMultipleTomSelect(["#reasonAdjustTS"]);

        $(document).on('blur keypress', '#amountAdjust', function(e) {
            if (e.type === 'keypress' && e.which !== 13) return;
            if (e.type === 'keypress') e.preventDefault();
            if (isSilentUpdate) return;

            let grossVal = forceNegativeValue(this);
            if (grossVal === 0) return;

            let tCode = $('#transCodeAdjust').val().split('-')[0].trim();
            isSilentUpdate = true;

            $.ajax({
                url: '/Billing/CalculatePriceNet',
                type: 'GET',
                data: { transactionCode: tCode, grossPrice: grossVal },
                success: function (res) {
                    $('#amountAdjustNet').val(formatNumberAdjust(res)).css('color', 'red');
                    isSilentUpdate = false;
                },
                error: function() { isSilentUpdate = false; }
            });
        });

        // Khi gõ vào ô Net
        $(document).on('blur keypress', '#amountAdjustNet', function(e) {
            if (e.type === 'keypress' && e.which !== 13) return;
            if (e.type === 'keypress') e.preventDefault();
            if (isSilentUpdate) return;

            let netVal = forceNegativeValue(this);
            if (netVal === 0) return;

            // Validation: Không cho phép Adjust nhiều hơn số tiền gốc 
            if (netVal < maxAdjustNet) {
               showToast('Warning', 'Cannot adjust more than the original amount', false);
               netVal = maxAdjustNet;
               $(this).val(formatNumberAdjust(netVal));
            }

            let tCode = $('#transCodeAdjust').val().split('-')[0].trim();
            isSilentUpdate = true;

            $.ajax({
                url: '/Billing/CalculatePricePlusPlus',
                type: 'GET',
                data: { transactionCode: tCode, netPrice: netVal },
                success: function (res) {
                    $('#amountAdjust').val(formatNumberAdjust(res)).css('color', 'red');
                    isSilentUpdate = false;
                },
                error: function() { isSilentUpdate = false; }
            });
        });

        // Khi gõ vào ô Percentage
        $(document).on('blur keypress', '#percentageAdjust', function(e) {
            if (e.type === 'keypress' && e.which !== 13) return;
            if (e.type === 'keypress') e.preventDefault();

            let pctVal = forceNegativeValue(this);
            if (pctVal < -100) {
                $(this).val('-100,00');
            }
        });


        $(document).on('keypress', '#amountAdjust, #amountAdjustNet, #percentageAdjust', function(e) {
            var charCode = (e.which) ? e.which : e.keyCode;
            // Chỉ cho phép: 48-57 (Số), 44 (Phẩy), 46 (Chấm)
            if ((charCode >= 48 && charCode <= 57) || charCode === 44 || charCode === 46) {
                return true;
            }
            return false;
        });
    });

    function openModalAdjustTransaction(netAmount) {
        localStorage.setItem("currentFromID", "modalAdjustTransaction");
        const crashierLogin = localStorage.getItem("crashierLogin");

        if (crashierLogin == "NotYet") {
            openModalShilftLogin();
            return;
        }

        let initialNet = Math.abs(netAmount) * -1;
        maxAdjustNet = initialNet; 

        $('#amountAdjustNet').val(formatNumberAdjust(initialNet)).css('color', 'blue');
        $('#amountAdjust').val('Loading...').css('color', 'blue');
        $('#percentageAdjust').val('-100'); 
        $('#memoAdjust').val('');

        let tCode = $('#transCodeAdjust').val().split('-')[0].trim();

        $.ajax({
            url: '/Billing/CalculatePricePlusPlus',
            type: 'GET',
            data: { transactionCode: tCode, netPrice: initialNet },
            success: function (res) {
                $('#amountAdjust').val(formatNumberAdjust(res));
                $('#amountAdjust, #amountAdjustNet').css('color', 'red');
            }
        });

        GetReasonAdjustmentTransaction();
        $('#modalAdjustTransaction').modal('show');
        toggleInputs();
    }

    function toggleInputs() {
        const isAmount = $('#amountRadio').is(':checked');
        $('.amount-input').prop('disabled', !isAmount);
        $('.percentage-input').prop('disabled', isAmount);

        if (isAmount) {
            $('.percentage-input').val('0');
            $('#amountAdjust').focus();
        } else {
            $('.amount-input').val('0');
            $('#percentageAdjust').focus();
        }
    }

    function adjustTransaction() {
        var grid = $("#gridContainerBilling").dxDataGrid("instance");
        var selectedRows = grid.getSelectedRowsData();

        if (!selectedRows.length) {
            showToast('Warning', "Please select a service to adjust", false);
            return;
        }

        const data = selectedRows[0];

        $.get('/Billing/CheckAdjustCode', { transactionCode: data.code }, function (result) {
            if (result.code == 1) {
                showToast('Error', result.msg || "This code cannot be adjusted", false);
            } else {
                $('#transCodeAdjust').val(`${data.code} - ${data.description}`);
                $('#rtChargeAdjust').val(roomType || "N/A");

                folioDetailAdjustID = data.id;

                let originalAmount = parseFloat(data.amount) || 0;

                openModalAdjustTransaction(originalAmount);
            }
        });
    }

    function GetReasonAdjustmentTransaction() {
        loadDataToTomSelect('#reasonAdjustTS', '/Billing/GetReasonAdjustmentTransaction', (item) => ({
            value: item.code,                           
            text: item.code + ' - ' + item.description, 
            data: item                                 
        }));
    }
        
    function closeModalAdjustTransaction() {
        $('#modalAdjustTransaction').modal('hide');
    }

    function PostAdjustTransaction() {
        const type = $('input[name="typeAdjustTransPrice"]:checked').val();

        const reasonCode = $('#reasonAdjustTS').val();
        if (!reasonCode) {
            showToast('Error', "Please select a reason for adjustment", false);
            return;
        }

        const adjAmount = parseNumberAdjust($('#amountAdjust').val());
        const adjNet = parseNumberAdjust($('#amountAdjustNet').val());
        const adjPercent = parseNumberAdjust($('#percentageAdjust').val());

        if (type == "1" && adjAmount === 0) {
            showToast('Error', "Adjustment amount must be different from 0", false);
            return;
        }
        if (type == "2" && adjPercent === 0) {
            showToast('Error', "Adjustment percentage must be different from 0", false);
            return;
        }
        if (adjAmount === 0) {
            showToast('Error', "Please enter an amount to adjust", false);
            return;
        }

        const userName = JSON.parse(localStorage.getItem("Loginname"));
        const userID = JSON.parse(localStorage.getItem("userID"));
        const shiftID = localStorage.getItem("shiftID");
        const shiftName = localStorage.getItem("shiftName");

        var formData = new FormData();

        formData.append('rsvID', idReservation);
        formData.append('roomID', roomID);
        formData.append('folioID', folioNoID); // ID của Window hiện tại
        formData.append('folioDetailAdjustID', folioDetailAdjustID); // ID của dòng giao dịch gốc

        formData.append('postType', type);
        formData.append('transCode', $('#transCodeAdjust').val().split('-')[0].trim());
        formData.append('adjustAmount', adjAmount);
        formData.append('adjustNet', adjNet);
        formData.append('percentage', adjPercent);
        formData.append('reference', reasonCode);
        formData.append('memo', $('#memoAdjust').val());

        formData.append('userName', userName);
        formData.append('userID', userID);
        formData.append('shiftID', shiftID);
        formData.append('shiftName', shiftName);

        $.ajax({
            url: '/Billing/PostAdjustmentTransaction',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            beforeSend: function() {
                $(".mui-button-save").prop("disabled", true).text("Processing...");
            },
            success: function (data) {
                if (data.code == 0) {
                    closeModalAdjustTransaction();

                    if (typeof searchFolioDetail === 'function') searchFolioDetail(0);
                    if (typeof GetBalanceVND === 'function') GetBalanceVND(idReservation);

                    showToast('Success', "Adjustment posted successfully!", true);
                } else {
                    showToast('Error', data.msg, false);
                }
            },
            error: function () {
                showToast('Error', "System error occurred", false);
            },
            complete: function() {
                $(".mui-button-save").prop("disabled", false).text("Adjust");
            }
        });
    }
</script>
