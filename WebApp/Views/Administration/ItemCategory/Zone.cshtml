<!-- Main Modal -->
<div class="modal fade"
     id="zone_mainModal"
     tabindex="-1"
     aria-labelledby="zone_mainModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="zone_mainModalLabel">Zone</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <button id="zone_btnView" type="button" class="mui-button mui-button-search">View</button>
                        <button id="zone_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="zone_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="zone_btnDelete" type="button" class="mui-button mui-button-delete">Delete</button>
                        <button id="zone_btnExportExcel" type="button" class="mui-button mui-button-export">Excel</button>
                        <button type="button"
                                class="mui-button mui-button-new"
                                data-bs-dismiss="modal"
                                aria-label="Close">
                            Close
                        </button>
                    </div>

                    <div class="row g-2 mt-1">
                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label for="zone_filterCode"
                                       class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Code
                                </label>
                                <div class="col-md-8">
                                    <input id="zone_filterCode"
                                           name="zone_filterCode"
                                           type="text"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label for="zone_filterName"
                                       class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Name
                                </label>
                                <div class="col-md-8">
                                    <input id="zone_filterName"
                                           name="zone_filterName"
                                           type="text"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Status
                                </label>
                                <div class="col-md-8">
                                    <div class="d-flex align-items-center h-100">
                                        <div class="form-check d-flex align-items-center gap-2">
                                            <span class="status-color-box color-clean-uncheck"></span>
                                            <input type="checkbox"
                                                   id="zone_chkShowInactive"
                                                   name="zone_chkShowInactive" />
                                            <label class="form-check-label" for="zone_chkShowInactive">
                                                Show Inactive
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mui-card mt-1">
                    <div id="zone_gridContainer" class="gridContainer"></div>
                </div>

                <div id="zone_loadingSpinner"
                     style="position: absolute;
                            top: 50%;
                            left: 50%;
                            transform: translate(-50%, -50%);
                            z-index: 999;
                            background: rgba(255, 255, 255, 0.55);
                            backdrop-filter: blur(2px);
                            width: 100%;
                            height: 100%;
                            display: flex;
                            align-items: center;
                            justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade"
     id="zone_itemModal"
     tabindex="-1"
     aria-labelledby="zone_itemModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="zone_itemModalLabel">New Zone</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <button type="button" id="zone_btnSave" class="mui-button mui-button-new">Save</button>
                    <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>

                <form id="zone_formContainer">
                    <div class="row g-2 mt-1 mb-2">
                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label for="zone_code"
                                       class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Code
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <input id="zone_code"
                                           name="zone_code"
                                           type="text"
                                           class="form-control form-control-sm" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Status
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <div class="form-check d-inline-flex align-items-center gap-2">
                                        <input id="zone_inactive"
                                               name="zone_inactive"
                                               type="checkbox" />
                                        <label for="zone_inactive" class="form-check-label text-danger">
                                            Inactive
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="zone_name"
                                       class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Name
                                </label>
                                <div class="col-md-10">
                                    <input id="zone_name"
                                           name="zone_name"
                                           type="text"
                                           class="form-control form-control-sm" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="zone_description"
                                       class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Description
                                </label>
                                <div class="col-md-10">
                                    <textarea id="zone_description"
                                              name="zone_description"
                                              rows="4"
                                              class="form-control form-control-sm"
                                              style="height:100px;"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="zone_id" name="zone_id" value="0" />
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    DevExpress.localization.locale("vi");

    var zone_Module = (() => {
        let zone_selectedRowData = null;

        const zone_selectors = {
            mainModal: "#zone_mainModal",
            itemModal: "#zone_itemModal",
            form: "#zone_formContainer",
            grid: "#zone_gridContainer",
            loading: "#zone_loadingSpinner",
            filterCode: "#zone_filterCode",
            filterName: "#zone_filterName",
            chkShowInactive: "#zone_chkShowInactive",
            btnView: "#zone_btnView",
            btnNew: "#zone_btnNew",
            btnEdit: "#zone_btnEdit",
            btnDelete: "#zone_btnDelete",
            btnExportExcel: "#zone_btnExportExcel",
            btnSave: "#zone_btnSave",
            modalLabel: "#zone_itemModalLabel",
            id: "#zone_id",
            code: "#zone_code",
            name: "#zone_name",
            description: "#zone_description",
            inactive: "#zone_inactive"
        };

        function zone_init() {
            zone_bindEvents();
            zone_resetForm();
            zone_loadGrid([]);
            zone_loadData();
        }

        function zone_bindEvents() {
            $(document)
                .off("input change", `${zone_selectors.form} input, ${zone_selectors.form} select, ${zone_selectors.form} textarea`)
                .on("input change", `${zone_selectors.form} input, ${zone_selectors.form} select, ${zone_selectors.form} textarea`, function () {
                    if ($(this).hasClass("is-invalid")) {
                        $(this).removeClass("is-invalid");
                        $(this).next(".invalid-feedback").text("");
                    }
                });

            $(zone_selectors.itemModal)
                .off("hidden.bs.modal")
                .on("hidden.bs.modal", function () {
                    zone_resetForm();
                    applyValidationErrors([], zone_selectors.form);
                });

            $(document)
                .off("click", zone_selectors.btnView)
                .on("click", zone_selectors.btnView, function () {
                    zone_loadData();
                });

            $(document)
                .off("click", zone_selectors.btnNew)
                .on("click", zone_selectors.btnNew, function () {
                    zone_openAddModal();
                });

            $(document)
                .off("click", zone_selectors.btnEdit)
                .on("click", zone_selectors.btnEdit, function () {
                    zone_openEditModal();
                });

            $(document)
                .off("click", zone_selectors.btnSave)
                .on("click", zone_selectors.btnSave, function () {
                    zone_save();
                });

            $(document)
                .off("click", zone_selectors.btnDelete)
                .on("click", zone_selectors.btnDelete, function () {
                    zone_delete();
                });

            $(document)
                .off("click", zone_selectors.btnExportExcel)
                .on("click", zone_selectors.btnExportExcel, function () {
                    zone_exportExcel();
                });
        }

        function zone_resetForm() {
            const zone_form = $(zone_selectors.form)[0];

            if (zone_form) {
                zone_form.reset();
            }

            $(zone_selectors.id).val("0");
            $(zone_selectors.modalLabel).text("New Zone");
            zone_selectedRowData = null;
        }

        function zone_openAddModal() {
            zone_resetForm();
            $(zone_selectors.modalLabel).text("New Zone");
            $(zone_selectors.itemModal).modal("show");
        }

        function zone_openEditModal() {
            if (!zone_selectedRowData) {
                showToast("Warning", "Please select a row first!", true);
                return;
            }

            zone_fillForm(zone_selectedRowData);
            $(zone_selectors.modalLabel).text("Update Country");
            $(zone_selectors.itemModal).modal("show");
        }

        function zone_fillForm(zone_data) {
            $(zone_selectors.id).val(zone_data.id);
            $(zone_selectors.code).val(zone_data.code);
            $(zone_selectors.name).val(zone_data.name);
            $(zone_selectors.description).val(zone_data.description);
            $(zone_selectors.inactive).prop("checked", zone_data.inactive);
        }

        function zone_getSearchModel() {
            return {
                code: $(zone_selectors.filterCode).val(),
                name: $(zone_selectors.filterName).val(),
                inactive: $(zone_selectors.chkShowInactive).prop("checked") ? 1 : 0
            };
        }

        function zone_getSaveModel() {
            const zone_id = parseInt($(zone_selectors.id).val()) || 0;
            let zone_loginName = (localStorage.getItem("Loginname") || "")
                .trim()
                .replace(/^"(.*)"$/, "$1");
            const zone_loginUser = parseInt(localStorage.getItem("userID")) || 0;

            return {
                ID: zone_id,
                Code: $(zone_selectors.code).val(),
                Name: $(zone_selectors.name).val(),
                Description: $(zone_selectors.description).val(),
                Inactive: $(zone_selectors.inactive).prop("checked"),
                CreatedBy: zone_loginName,
                UpdatedBy: zone_loginName,
                UserInsertID: zone_loginUser,
                UserUpdateID: zone_loginUser
            };
        }

        function zone_showLoading() {
            $(zone_selectors.loading).show();
        }

        function zone_hideLoading() {
            $(zone_selectors.loading).hide();
        }

        function zone_loadData() {
            zone_showLoading();

            $.ajax({
                url: "/Administration/GetZone",
                type: "GET",
                cache: false,
                data: zone_getSearchModel(),
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (zone_data) {
                    zone_loadGrid(zone_data || []);
                    zone_hideLoading();
                },
                error: function () {
                    showToast("Error", "Unable to load data", false);
                    zone_hideLoading();
                }
            });
        }

        function zone_loadGrid(zone_data) {
            $(zone_selectors.grid).dxDataGrid({
                dataSource: zone_data,
                height: 500,
                width: "100%",
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: {
                    mode: "single"
                },
                hoverStateEnabled: true,
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "code", caption: "Code", width: "10%" },
                    { dataField: "name", caption: "Name", width: "20%" },
                    { dataField: "description", caption: "Description", width: "30%" },
                    { dataField: "inactive", caption: "Inactive", width: "6%",
                        cellTemplate: function (container, options) {
                            $("<div>")
                                .dxCheckBox({
                                    value: options.value == 1 || options.value === true,
                                    readOnly: true
                                })
                                .css("transform", "scale(0.8)")
                                .appendTo(container);
                        }
                    },
                    { dataField: "createdBy", caption: "Created By", width: "8%" },
                    { dataField: "createdDate", caption: "Created Date", dataType: "date", width: "9%" },
                    { dataField: "updatedBy", caption: "Updated By", width: "8%" },
                    { dataField: "updatedDate", caption: "Updated Date", dataType: "date", width: "9%" }
                ],
                filterRow: {
                    visible: true,
                    applyFilter: "auto"
                },
                paging: {
                    pageSize: 20
                },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: {
                    mode: "standard",
                    showScrollbar: "always"
                },
                onSelectionChanged: function (e) {
                    zone_selectedRowData = e.selectedRowsData.length > 0
                        ? e.selectedRowsData[0]
                        : null;
                }
            });
        }

        function zone_save() {
            const zone_model = zone_getSaveModel();

            $.ajax({
                url: "/Administration/ZoneSave",
                type: "POST",
                contentType: "application/json",
                cache: false,
                data: JSON.stringify(zone_model),
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (zone_res) {
                    if (zone_res.success) {
                        showToast("Success", zone_res.message, true);
                        $(zone_selectors.itemModal).modal("hide");
                        zone_loadData();
                        return;
                    }

                    if (zone_res.errors && zone_res.errors.length > 0) {
                        applyValidationErrors(zone_res.errors, zone_selectors.form);

                        let zone_generalError = zone_res.errors.find(x => x.field === "general");
                        let zone_toastMessage = zone_generalError
                            ? zone_generalError.message
                            : "Please check input fields.";

                        showToast("Warning", zone_toastMessage, false);
                        return;
                    }

                    showToast("Error", zone_res.message || "Save failed", false);
                },
                error: function () {
                    showToast("Error", "Request error!", false);
                    $(zone_selectors.itemModal).modal("hide");
                }
            });
        }

        function zone_delete() {
            if (!zone_selectedRowData || zone_selectedRowData.id === 0) {
                showToast("Warning", "Select 1 row, please!", true);
                return;
            }

            if (!confirm("Are you sure you want to delete this record? This action cannot be undone.")) {
                return;
            }

            $.ajax({
                url: `/Administration/DeleteZone/` + zone_selectedRowData.id,
                type: "POST",
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (zone_result) {
                    if (zone_result.success) {
                        zone_loadData();
                        showToast("Success", "Delete Successfully!", true);
                        return;
                    }

                    showToast("Error", zone_result.message, false);
                },
                error: function () {
                    console.log("delete " + zone_selectedRowData.id);
                    showToast("Error", "Delete failed!", false);
                    $("#loadingSpinner").hide();
                }
            });
        }

        function zone_exportExcel() {
            const zone_grid = $(zone_selectors.grid).dxDataGrid("instance");
            const zone_workbook = new ExcelJS.Workbook();
            const zone_companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const zone_worksheet = zone_workbook.addWorksheet("Sheet 1");

            zone_worksheet.addRow([zone_companyName]);
            zone_worksheet.mergeCells("A1:D1");
            zone_worksheet.getRow(1).font = { bold: true };
            zone_worksheet.getRow(1).alignment = {
                vertical: "middle",
                horizontal: "left"
            };

            const zone_now = new Date();
            const zone_exportDate = zone_now.toLocaleString("vi-VN");

            zone_worksheet.addRow(["", "", "", zone_exportDate]);
            zone_worksheet.mergeCells("D2:D2");
            zone_worksheet.getRow(2).alignment = {
                vertical: "middle",
                horizontal: "right"
            };

            zone_worksheet.addRow([]);
            zone_worksheet.addRow([]);

            const zone_reportRow = zone_worksheet.addRow(["Zone"]);
            zone_worksheet.mergeCells("A5:D5");
            zone_reportRow.font = { bold: true, size: 14 };
            zone_reportRow.alignment = {
                vertical: "middle",
                horizontal: "center"
            };

            zone_worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: zone_grid,
                worksheet: zone_worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const zone_lastRow = zone_worksheet.lastRow.number + 2;

                zone_worksheet.mergeCells(`A${zone_lastRow}:D${zone_lastRow}`);
                zone_worksheet.getCell(`A${zone_lastRow}`).alignment = {
                    horizontal: "center"
                };
                zone_worksheet.getCell(`A${zone_lastRow}`).font = {
                    italic: true
                };

                let zone_fileName = "Zone.xlsx";

                zone_workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(
                        new Blob([buffer], { type: "application/octet-stream" }),
                        zone_fileName
                    );
                });
            });
        }

        return {
            init: zone_init,
            loadData: zone_loadData,
            openAddModal: zone_openAddModal,
            openEditModal: zone_openEditModal
        };
    })();

    $(document).ready(function () {
        zone_Module.init();
    });

    window.openModalZone = function () {
        $("#zone_mainModal").modal("show");
        zone_Module.loadData();
    };
</script>