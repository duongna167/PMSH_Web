<!-- Modal billimg-->
<style>
    .modal-dialog {
        margin-top: 0 !important;
    }
</style>
<div class="modal fade modal-xl" id="modalMaintenance" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
    aria-labelledby="staticBackdropLabelBilling" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content" style="border: 1px solid #bcbcbc">
            <div class="modal-header">
                <h5 class="modal-title">Account Maintenanace</h5>
            </div>
            <div class="modal-body">
                @* <div class="mb-2">
                    <button class="mui-button mui-button-search" >Post</button>
                </div> *@
                <div class="search-filter">
                    <div>
                        <button class="mui-button mui-button-new" onclick="searchMaintenance();">Search</button>

                        <button class="mui-button mui-button-new" id="btn-clear-maintenanace">Clear</button>
                        <button class="mui-button mui-button-new" onclick="openModalInvoice();">Envoice</button>
                        <button class="mui-button mui-button-new" onclick="openModalEditPosting();">Payment</button>
                        <button class="mui-button mui-button-new" onclick="closeModalMaintenance()">Close</button>
                    </div>
                    <div class="row mt-1" id="filter">

                        <!-- From Date -->
                        <div class="col-12 col-md-2 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    From Date
                                </label>
                                <div class="col-12 col-md-8">
                                    <div class="clearable" data-date-input data-format="DD/MM/YYYY" business-date
                                        data-name="fromDateMaintenance">
                                        <input type="text" class="date-ui form-control" placeholder="dd/mm/yyyy"
                                            autocomplete="off" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- To Date -->
                        <div class="col-12 col-md-2 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    To Date
                                </label>
                                <div class="col-12 col-md-8">
                                    <div class="clearable" data-date-input data-format="DD/MM/YYYY" business-date
                                        data-name="toDateMaintenance">
                                        <input type="text" class="date-ui form-control" placeholder="dd/mm/yyyy"
                                            autocomplete="off" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Folio -->
                        <div class="col-12 col-md-2 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Folio
                                </label>
                                <div class="col-12 col-md-8">
                                    <input type="text" class="form-control clearable" id="folioMaintenance">
                                </div>
                            </div>
                        </div>
                        <!-- Date checkbox -->
                        <div class="col-12 col-md-1 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-6 col-form-label text-md-end">
                                    Date
                                </label>
                                <div class="col-12 col-md-6 d-flex align-items-center">
                                    <input type="checkbox" class="clearable" name="dateMaintenance" id="dateMaintenance"
                                        value="1">
                                </div>
                            </div>
                        </div>

                        <!-- Payments / Active -->
                        <div class="col-12 col-md-2 mt-2">
                            <div class="row g-2">

                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Payments:
                                </label>
                                <div class="col-12 col-md-8 d-flex gap-3 align-items-center">
                                    <div>
                                        <input type="checkbox" class="clearable" name="paymentMaintenance"
                                            id="paymentMaintenance" value="1">
                                        <label class="form-check-label">Only</label>
                                    </div>

                                    <div>
                                        <input type="radio" class="clearable" name="isActiveMaintenance" value=""
                                            checked>
                                        <label class="form-check-label">All</label>
                                    </div>

                                    <div>
                                        <input type="radio" class="clearable" name="isActiveMaintenance" value="1">
                                        <label class="form-check-label">Open</label>
                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- Print -->
                        <div class="col-12 col-md-3 mt-2">
                            <div class="row g-2">
                                <label class="col-12 col-md-2 col-form-label text-md-end">
                                    Print:
                                </label>
                                <div class="col-12 col-md-8 d-flex gap-3 align-items-center">
                                    <div>
                                        <input type="radio" class="clearable" name="printMaintenance" value="" checked>
                                        <label class="form-check-label">All</label>
                                    </div>
                                    <div>
                                        <input type="radio" class="clearable" name="printMaintenance" value="1">
                                        <label class="form-check-label">Printed</label>
                                    </div>
                                    <div>
                                        <input type="radio" class="clearable" name="printMaintenance" value="0">
                                        <label class="form-check-label">Not Printed</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <div id="gridContainerMaintenance" class="gridContainer mt-2"></div>

            </div>
        </div>
    </div>
</div>
@await Html.PartialAsync("Options/Invoice")

<script>
    function openModalMaintenance() {
        const today = new Date().toISOString().split('T')[0];

        // Set default values for From Date and To Date

        searchMaintenance();
        $('#modalMaintenance').modal('show');
    }
    function closeModalMaintenance() {
        $('#modalMaintenance').modal('hide');
        resetMaintenanceFilter();
    }

    $(document).off("click", "#btn-clear-maintenanace").on("click", "#btn-clear-maintenanace", function () {
        resetMaintenanceFilter();
    })

    function openModalEditPosting() {
        alert("Winform đang lỗi vui lòng đợi cập nhật hoặc liên hệ admin để biết thêm chi tiết");
    }
    function resetMaintenanceFilter(containerSelector = '#filter') {
        const container = document.querySelector(containerSelector);
        if (!container) return;

        // Text / number / date inputs
        container.querySelectorAll('input.clearable[type="text"], input.clearable[type="number"]').forEach(input => {
            input.value = '';
        });

        // Checkboxes
        container.querySelectorAll('input.clearable[type="checkbox"]').forEach(cb => {
            cb.checked = false;
        });

        // Radios: reset về radio có checked mặc định
        const radioGroups = {};
        container.querySelectorAll('input.clearable[type="radio"]').forEach(radio => {
            if (!radioGroups[radio.name]) {
                radioGroups[radio.name] = [];
            }
            radioGroups[radio.name].push(radio);
        });

        Object.values(radioGroups).forEach(group => {
            const defaultRadio = group.find(r => r.hasAttribute('checked'));
            if (defaultRadio) {
                defaultRadio.checked = true;
            } else {
                group.forEach(r => r.checked = false);
            }
        });

        // Date inputs: clear + disable
        container.querySelectorAll('[data-date-input]').forEach(wrapper => {
            const input = wrapper.querySelector('input');
            if (input) {
                input.value = '';
                input.disabled = false;
            }
        });

        // Reset Date checkbox logic
        const dateCheckbox = container.querySelector('#dateMaintenance');
        if (dateCheckbox) {
            dateCheckbox.checked = false;
        }
        reloadBusinessDate();
    }

    function searchMaintenance() {
        var grid = $("#gridContainer").dxDataGrid("instance");
        var selectedRows = grid.getSelectedRowsData();
        var selectedIds = selectedRows.map(row => row.ID);
        $.ajax({
            url: '/Accounting/SearchMaintenance',
            type: 'get',
            dataType: 'json',
            data: {
                dateCheck: $('#dateMaintenance[type="checkbox"]').is(':checked') ? "1" : "",
                arID: selectedIds[0],
                folioNo: $('#folioMaintenance').val(),
                isActive: $('input[name="isActiveMaintenance"]:checked').val(),
                paymentOnly: $('#paymentMaintenance[type="checkbox"]').is(':checked') ? "1" : "",
                print: $('input[name="printMaintenance"]:checked').val(),
                fromDate: $('#fromDateMaintenance').val(),
                toDate: $('#toDateMaintenance').val(),
            },
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                initializeDataGridMaintenance(result);
            },
            error: function (xhr, statusText, err) {
                if (xhr.status == 401) {
                    sessionTimeout();
                }
            },

        });

    }

    function initializeDataGridMaintenance(data) {

        $("#gridContainerMaintenance").dxDataGrid({
            dataSource: data,
            keyExpr: "AccountReceivableTransID",

            height: 500,                    // ✅ FIX HEIGHT
            showBorders: true,

            // ===== LAYOUT / WIDTH =====
            columnAutoWidth: true,          // cột co theo dữ liệu
            allowColumnResizing: true,
            columnResizingMode: "widget",

            // ===== SCROLLING =====
            scrolling: {
                mode: "standard",           // ✅ cho phép scroll ngang
                useNative: true
            },

            paging: { pageSize: 15 },
            pager: {
                visible: true,
                allowedPageSizes: [15, 20, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },

            filterRow: {
                visible: true,
                applyFilter: "auto"
            },

            selection: {
                mode: "multiple",
                showCheckBoxesMode: "always"
            },

            columns: [
                {
                    dataField: "TransactionDate",
                    caption: "Transaction Date",
                    dataType: "datetime",
                    format: "dd/MM/yyyy",
                    minWidth: 160
                },
                {
                    dataField: "AccountName",
                    caption: "Account Name",
                    minWidth: 220
                },
                {
                    dataField: "FolioID",
                    caption: "Folio",
                    width: 80
                },
                {
                    dataField: "Amount",
                    caption: "Amount",
                    alignment: "right",
                    minWidth: 120
                },
                {
                    dataField: "Paid",
                    caption: "Paid",
                    alignment: "right",
                    minWidth: 120
                },
                {
                    dataField: "Balance",
                    caption: "Balance",
                    alignment: "right",
                    minWidth: 120
                },
                {
                    dataField: "CurrencyID",
                    caption: "Currency",
                    width: 90
                },
                {
                    dataField: "ConfirmationNo",
                    caption: "Confirmation No",
                    width: 130
                },
                {
                    dataField: "CreatedBy",
                    caption: "Created By",
                    width: 120
                },
                {
                    dataField: "CreatedDate",
                    caption: "Created Date",
                    dataType: "datetime",
                    format: "dd/MM/yyyy",
                    minWidth: 160
                },
                {
                    dataField: "UpdatedBy",
                    caption: "Updated By",
                    width: 120
                },
                {
                    dataField: "UpdatedDate",
                    caption: "Updated Date",
                    dataType: "datetime",
                    format: "dd/MM/yyyy",
                    minWidth: 160
                }
            ],

            // ===== AUTO SELECT FIRST ROW =====
            onContentReady: function (e) {
                const grid = e.component;
                if (grid.getSelectedRowKeys().length === 0) {
                    const key = grid.getKeyByRowIndex(0);
                    if (key !== undefined) {
                        grid.selectRows([key], false);
                    }
                }
            },

            onRowClick: function (e) {
                e.component.selectRows([e.key], false);
            }
        });
    }
</script>
