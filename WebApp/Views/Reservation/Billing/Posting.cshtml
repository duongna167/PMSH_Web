        const calc = calculateLineTotalPMS({
            qty: qty,
            price: price,
            taxRate: 0,
            isExpress: $pane.find('.js-chk-express').is(':checked'),
            pctExpress: parseFloat($pane.find('.js-input-express-pct').val()) || 0,
            isDiscount: $pane.find('.js-chk-discount').is(':checked'),
            pctDiscount: parseFloat($pane.find('.js-input-discount-pct').val()) || 0
        });

        // BUILD REF + SUPPL
        const rs = buildRefAndSuppl($pane);

        var itemObj = {
            id: Date.now(),
            code: transCode,
            articleCode: $pane.find('.js-art-code').val() || "",
            description: $pane.find('.js-art-desc').val()
                 || $pane.find('.js-trans-desc').val(),

            invoiceDesc: $pane.find('.js-invoice-desc').val(),

            quantity: qty,
            price: price,

            amountBeforeTax: calc.net,
            amount: calc.gross,

            reference: rs.reference,
            supplement: rs.supplement,

            checkNo: $pane.find('.js-invoice-checkNo').val()
        };

        invoiceList.push(itemObj);

        showToast("Success", "Item added to list", true);
        refreshInvoiceGrid();
        resetFormKeepInvoiceInfo();
    });

    // ---. HÀM RESET FORM NHƯNG GIỮ INPUT FIELD INVOICE DESC (CHO NÚT ADD) ---
    function resetFormKeepInvoiceInfo() {
        var $activePane = $('#invoice-pane');
        var currentDesc = $activePane.find('.js-invoice-desc').val(); 

        resetFormPosting();

        $activePane.find('.js-invoice-desc').val(currentDesc);

        $activePane.find('.js-trans-code').focus();
    }

    // ---  HÀM POSTING SERVICE  ---
    function PostingService() {
        const loginUser = parseInt(localStorage.getItem("userID")) || 0;
        const loginName = (localStorage.getItem("Loginname") || "").trim().replace(/^"(.*)"$/, '$1');
        const shiftID = parseInt(localStorage.getItem("shiftID")) || 0;

        var $activePane = $('.tab-pane.active');
        var activeTabId = $activePane.attr('id');
        var dataToSend = [];

        var selectedFolioID = parseInt($activePane.find('.js-window-select').val());

        if (!selectedFolioID) {
            showToast('Error', "Please select a Window No (Folio)!", false);
            return;
        }

        var isLocked = $activePane.find('.js-window-select option:selected').attr('data-locked');
        if (isLocked === 'true') {
            showToast('Error', "This Folio is Locked!", false);
            return;
        }

        //  DETAIL-PANE
        if (activeTabId === 'detail-pane') {
            var $pane = $('#detail-pane');

            var tCode = $pane.find('.js-trans-code').val();
            if (!tCode) return showToast("Warning","No transaction selected!",false);

            var qty = parseFloat($pane.find('.js-input-qty').val()) || 0;
            var price = parseNumberWithComma($pane.find('.js-input-price-net').val());

            var amountNet = parseNumberWithComma($pane.find('.js-amount-net').val());
            var amountGross = parseNumberWithComma($pane.find('.js-amount-gross').val());

            let rs = buildRefAndSuppl($pane);

            var model = {
                UserID: loginUser,
                UserName: loginName,
                ShiftID: shiftID,
                CashierNo: loginName,

                FolioID: selectedFolioID,
                OriginFolioID: selectedFolioID,

                ReservationID: idReservation,
                OriginReservationID: idReservation,
                RoomType: roomType,
                RoomID: roomID,

                ReceiptNo: "",
                CheckNo: "",

                TransactionCode: tCode,
                Description: $pane.find('.js-trans-desc').val(),
                ArticleCode: $pane.find('.js-art-code').val(),

                Quantity: qty,
                Price: price,

                Amount: amountGross,
                AmountMaster: amountGross,
                AmountGross: amountGross,
                AmountMasterGross: amountGross,
                AmountBeforeTax: amountNet,
                AmountMasterBeforeTax: amountNet,

                CurrencyID: $pane.find('.currency-select').val(),
                CurrencyMaster: $pane.find('.currency-select').val(),

                Reference: rs.reference,
                Supplement: rs.supplement,

                PostType: 1,
                GroupType: 1,

                UserInsertID: loginUser,
                UserUpdateID: loginUser
            };

            dataToSend.push(model);
        }

        // INVOICE-PANE
        else if (activeTabId === 'invoice-pane') {

            if (invoiceList.length === 0) {
                showToast("Warning","Invoice list is empty!",false);
                return;
            }

            var $pane = $('#invoice-pane');

            var invCheckNo = $pane.find('.js-invoice-checkNo').val();
            var invDesc = $pane.find('.js-invoice-desc').val();
            var invRef = $pane.find('.js-invoice-ref').val();

            invoiceList.forEach(function (item) {
                var model = {
                    UserID: loginUser,
                    UserName: loginName,
                    ShiftID: shiftID,
                    CashierNo: loginName,

                    FolioID: selectedFolioID,
                    OriginFolioID: selectedFolioID,

                    ReservationID: idReservation,
                    OriginReservationID: idReservation,
                    RoomType: roomType,

                    RoomID: roomID,

                    ReceiptNo: item.checkNo,
                    CheckNo: invCheckNo,

                    TransactionCode: item.code,
                    Description: invDesc || item.description,
                    ArticleCode: item.articleCode,

                    Quantity: item.quantity,
                    Price: item.price,

                    Amount: item.amount,
                    AmountMaster: item.amount,
                    AmountGross: item.amount,
                    AmountMasterGross: item.amount,
                    AmountBeforeTax: item.amountBeforeTax,
                    AmountMasterBeforeTax: item.amountBeforeTax,

                    CurrencyID: $pane.find('.currency-select').val(),
                    CurrencyMaster: $pane.find('.currency-select').val(),

                    Reference: item.reference,
                    Supplement: item.supplement,

                    PostType: 3,
                    GroupType: 1,

                    UserInsertID: loginUser,
                    UserUpdateID: loginUser
                };

                dataToSend.push(model);
            });
        }

        submitToDB(dataToSend, selectedFolioID);
    }

    // Hàm confirm post (api)
    function submitToDB(dataList,targetFolioID) {

        $.ajax({
            url: '/Billing/PostingSave',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(dataList),
            success: function (res) {
                if (res.success) {
                    showToast("Success","Posted Successfully! Invoice No: " + res.invoiceNo,true);

                    if(typeof invoiceList !== 'undefined') {
                        invoiceList = [];
                    }

                    resetFormPosting();
                    $('#modalPosting').modal('hide');
                    if (typeof listFolioNoID !== 'undefined' && typeof filterByFolioNo === 'function') {
                        // Tìm index của folioID vừa post trong danh sách folio của trang billing
                        var index = listFolioNoID.indexOf(targetFolioID);
                        if (index !== -1) {
                            filterByFolioNo(targetFolioID, index);
                        } else {
                            searchFolioDetail(0);
                        }
                    }
                } else {
                    showToast('Error', res.message || "Posting Failed", false);
                }
            },
            error: function (err) {

                console.error(err);
                showToast('Error', "System Error: " + (err.statusText || "Unknown"), false);
            }
        });
    }

    // ---: Khởi tạo grid F3 invoice list---
