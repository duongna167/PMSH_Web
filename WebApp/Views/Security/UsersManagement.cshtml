            <!-- HEADER -->
            <div class="modal-header py-2">
                <h5 id="attendantPointTitle" class="modal-title">
                    New AttendantPoint
                </h5>
            </div>

            <!-- BODY -->
            <div class="modal-body p-3" style="max-height:600px; overflow-y:auto;">

                <!-- BUTTON -->
                <div class="d-flex justify-content-start mb-3 gap-2">
                    <button id="btnSaveAtt"
                            class="mui-button mui-button-search">
                        Save
                    </button>

                    <button type="button"
                            id="btnClosePopup"
                            class="mui-button mui-button-new"
                            data-bs-dismiss="modal">
                        Close
                    </button>
                </div>

                <!-- FORM -->
                <div class="container-fluid">

                    <input type="hidden" id="txtid" name="txtid" />

                    <div class="row mb-2">
                        <div class="col-md-6">
                            <label class="form-label">Date:</label>
                            <input type="date"
                                   id="fromDatenew"
                                   name="fromDatenew"
                                   class="form-control form-control-sm" />
                        </div>
@* 
                        <div class="col-md-6">
                            <label class="form-label">Attendant ID:</label>
                            <select id="attendantnew"
                                    name="attendantnew"
                                    class="form-control form-control-sm">
                                <option value=""></option>
                                @foreach (var item in listatt)
                                {
                                    <option value="@item.ID">@item.Name</option>
                                }
