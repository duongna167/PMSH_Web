
<style>

    #modalContact .note-textarea {
        height: 160px;
    }


    /* Tăng độ ưu tiên bằng cách dùng ID cha */
    #modalContact .nav-tabs {
        border: none !important;
        background-color: transparent !important;
        padding: 0 !important;
    }


    #modalContact .nav-link {
        display: block;
        padding: var(--bs-nav-link-padding-y) var(--bs-nav-link-padding-x);
        font-size: var(--bs-nav-link-font-size);
        font-weight: var(--bs-nav-link-font-weight);
        color: #009444 !important;
        text-decoration: none;
        background: 0 0;
        transition: color .15s ease-in-out, background-color .15s ease-in-out, border-color .15s ease-in-out;
    }

    #modalContact .nav-tabs .nav-link {
        margin-bottom: calc(-1 * var(--bs-nav-tabs-border-width));
        border: var(--bs-nav-tabs-border-width) solid transparent;
        border-top-left-radius: var(--bs-nav-tabs-border-radius);
        border-top-right-radius: var(--bs-nav-tabs-border-radius);
    }

        #modalContact .nav-tabs .nav-link.active {
            background-color: var(--bs-nav-tabs-link-active-bg) !important;
            border-color: var(--bs-nav-tabs-link-active-border-color);
        }

    /* Ensure modals scroll correctly */
    #modalContact .gridContainer {
        min-height: 200px;
    }

    #modalContact .mui-card {
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1) !important;
        min-height: 500px;
        padding: 10px !important;
    }

    #modalContact .modal-body {
        padding: 0 12px 0 12px !important;
    }

    #modalContact .my-2 {
        margin-top: 0rem !important;
        margin-bottom: 0rem !important;
    }
</style>
<div class="modal fade profile-modal" id="modalContact" data-bs-backdrop="static" tabindex="-1" aria-labelledby="modalProfileContactLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Profile - Contact</h5>
            </div>
            <div class="modal-body">
                <div class="mb-2 mt-1">
                    <button type="button" id="con_btnSave" class="mui-button mui-button-new">Save</button>
                    <button type="button" id="con_btnClear" class="mui-button mui-button-new">Clear</button>
                    <button type="button" id="con_btnClose" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>
                <div class="profile_input" id="pro_con_formContainer">
                    <div class="main-infor mt-2" id="pro_search_profile_contact">
                        <div class="row justify-content-center">
                            <div class="d-flex justify-content-center">
                                <ul class="nav nav-tabs mb-2">
                                    <li class="nav-item">
                                        <button class="nav-link active" data-bs-toggle="tab"
                                                data-bs-target="#pro_search_contact-tab-address" type="button" role="tab">
                                            Address Information
                                        </button>
                                    </li>
                                    <li class="nav-item">
                                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#pro_search_contact-tab-other"
                                                type="button" role="tab">
                                            Other Information
                                        </button>
                                    </li>
                                </ul>
                            </div>
                            <div class="tab-content">
                                <div class="tab-pane fade show active" id="pro_search_contact-tab-address" role="tabpanel">
                                    <div class="row ">
                                        <div class="col-md-6 mui-card">
                                            <hr class="my-2">
                                            <input hidden id="con_id" name="con_id" />
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Code <span class="text-danger">*</span></label>
                                                <div class="col-sm-5">
                                                    <input type="text" class="form-control" id="con_txtCode" name="con_txtCode"
                                                           data-tooltip="The contact code will have a fixed length of 13 characters.">
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Full Name <span class="text-danger">*</span></label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="con_txtFullName" name="con_txtFullName" data-tooltip="Please typing as below: LastName MiddleName, FirstName, Mr. OR LastName MiddleName, FirstName.">
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">First / Last Name <span class="text-danger">* </span> </label>
                                                <div class="col-sm-3">
                                                    <input type="text" class="form-control" id="con_txtFirstName" name="con_txtFirstName">
                                                </div>
                                                <div class="col-sm-3">
                                                    <input type="text" class="form-control" id="con_txtLastName" name="con_txtLastName">
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Middle Name</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="con_txtMiddleName" name="con_txtMiddleName">
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Position / Dept</label>
                                                <div class="col-sm-6 d-flex gap-2">
                                                    <input type="text" class="form-control" id="con_txtPosition" name="con_txtPosition">
                                                    <input type="text" class="form-control" id="con_txtDept" name="con_txtDept">
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Language / Title</label>
                                                <div class="col-sm-3">
                                                    <select id="con_txtLanguage" name="con_txtLanguage" class="ms-2 tomselect-custom" data-placeholder="Please select Language"></select>
                                                </div>
                                                <div class="col-sm-3">
                                                    <select id="con_txtTitle" name="con_txtTitle" class="tomselect-custom" data-placeholder="Please select Title"></select>
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Salutation</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="con_txtSalutation" name="con_txtSalutation">
                                                </div>
                                            </div>
                                            <hr class="my-2">
                                        </div>

                                        <div class="col-md-6 mui-card">
                                            <hr class="my-2">
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Address</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="con_txtAddress" name="con_txtAddress">
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Home Address</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="con_txtHomeAddress" name="con_txtHomeAddress">
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">City</label>
                                                <div class="col-sm-6">
                                                    <select id="con_txtCity" name="con_txtCity" class="ms-2 tomselect-custom" data-placeholder="Please select City"></select>
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Postal Code</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="con_txtPostalCode" name="con_txtPostalCode">
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Country / State</label>
                                                <div class="col-sm-3">
                                                    <select id="con_txtCountry" name="con_txtCountry" class="ms-2 tomselect-custom" data-placeholder="Please select Country"></select>
                                                </div>
                                                <div class="col-sm-3">
                                                    <select id="con_txtState" name="con_txtState" class="tomselect-custom" data-placeholder="Please select State"></select>
                                                </div>
                                            </div>
                                            <hr class="my-2">
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="pro_search_contact-tab-other" role="tabpanel">
                                    <div class="row">
                                        <div class="col-md-6 mui-card">
                                            <hr class="my-2">
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Owner</label>
                                                <div class="col-sm-6">
                                                    <select id="con_txtOwner" name="con_txtOwner" class="ms-2 tomselect-custom" data-placeholder="Please select Owner"></select>
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Territory</label>
                                                <div class="col-sm-6">
                                                    <select id="con_txtTerritory" name="con_txtTerritory" class="ms-2 tomselect-custom" data-placeholder="Please select Territory"></select>
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">A/R No</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="con_txtARNo" name="con_txtARNo">
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Date of birth</label>
                                                <div class="col-sm-4" data-date-input data-format="DD/MM/YYYY" business-date data-name="con_txtDob">
                                                    <input type="text" class="date-ui form-control" placeholder="dd/mm/yyyy"
                                                           autocomplete="off" disabled />
                                                </div>
                                                <div class="col-sm-2">
                                                    <input type="checkbox" class="mt-2" checked id="con_chkActiveDob" name="con_chkActiveDob">
                                                </div>
                                            </div>
                                            <div class="row mb-2 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Active</label>
                                                <div class="col-sm-6">
                                                    <div class="form-check">
                                                        <input type="checkbox" class="" id="con_chkActive" name="con_chkActive" checked>
                                                    </div>
                                                </div>
                                            </div>
                                            <hr class="my-2">   
                                        </div>
                                        <div class="col-md-6 mui-card">
                                            <hr class="my-2">
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Telephone</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="con_txtTelephone" name="con_txtTelephone">
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Fax</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="con_txtFax" name="con_txtFax">
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Email</label>
                                                <div class="col-sm-6">
                                                    <input type="email" class="form-control" id="con_txtEmail" name="con_txtEmail">
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Website</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="con_txtWebsite" name="con_txtWebsite">
                                                </div>
                                            </div>
                                            <div class="row mb-1 align-items-center">
                                                <label class="col-sm-4 col-form-label text-sm-end">Hand Phone</label>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" id="con_txtHandPhone" name="con_txtHandPhone">
                                                </div>
                                            </div>
                                            <hr class="my-2">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    var pro_con_Module = {

        init: function () {
            this.initDOMEvents();
            this.bindNameEngine();
            this.initTomSelects();
        },

        initDOMEvents: function () {
            const self = this;

            // Sự kiện nút Save
            $('#con_btnSave').on('click', function () {
                self.saveProfile();
            });

            // Sự kiện nút Clear
            $('#con_btnClear').on('click', function () {
                self.clearForm();
            });

            // Xử lý Date of Birth checkbox
            $('#con_chkActiveDob').on('change', function () {
                const isChecked = $(this).is(':checked');
                const $wrapper = $('[data-name="con_txtDob"]');
                const $input = $wrapper.find('input.date-ui');
                $input.prop('disabled', !isChecked);
                if (!isChecked) $wrapper.addClass('opacity-50');
                else $wrapper.removeClass('opacity-50');
            });
        },

         bindNameEngine: function () {
            const self = this;
            const $full = $("#con_txtFullName");
            const $salutation = $("#con_txtSalutation");

            function processNameParsing() {
                let nameVal = $full.val();
                if (!nameVal) return;

                let p = GuestNameEngine.parseFullName(nameVal);
                console.log("Parsed Name:", p);

                $("#con_txtFirstName").val(p.first).trigger("input");
                $("#con_txtMiddleName").val(p.middle).trigger("input");
                $("#con_txtLastName").val(p.last).trigger("input");

                let resultSalutation = GuestNameEngine.buildSalutation(p.first, p.last);
                $salutation.val(resultSalutation);
            }

            $full.on("blur", processNameParsing);

            $full.on("keydown", function(e) {
                if (e.which === 13) {
                    e.preventDefault();
                    processNameParsing();

                    $("#con_txtFirstName").focus();
                }
            });

            $("#con_txtTitle").on("change", function() {
                const lastName = $("#con_txtLastName").val();

                const ts = getTomSelect("#con_txtTitle");
                if (!ts) return;

                const val = ts.getValue();

                const titleText = val ? ts.options[val]?.text : "";

                if (lastName && titleText && titleText !== "Enter or select...") {
                    $salutation.val("Dear " + titleText + " " + GuestNameEngine.smartCapitalize(lastName));
                } else if (lastName) {
                    $salutation.val("Dear " + GuestNameEngine.smartCapitalize(lastName));
                }
            });
        },

        initTomSelects: function () {
            const self = this;

            initTomSelect('.tomselect-custom');

            LoadingGlobal.show();

            const mapCode = (item) => ({
                value: item.id || item.ID,
                text: (item.code || item.Code) + " - " + (item.name || item.Name),
                data: item
            });

            const loadTasks = [
                loadDataToTomSelect("#con_txtLanguage", "/Profile/GetAllLanguage", mapCode),
                loadDataToTomSelect("#con_txtTitle", "/Profile/GetAllTitle",(item) => {
                    return {
                        value: item.id || item.ID,
                        text: item.Code || item.code,
                        data: item
                    };
                }),
                loadDataToTomSelect("#con_txtCity", "/Profile/GetAllCity", mapCode),
                loadDataToTomSelect("#con_txtCountry", "/Profile/GetAllCountry", mapCode),
                loadDataToTomSelect("#con_txtOwner", "/Profile/GetAllOwner", mapCode),
                loadDataToTomSelect("#con_txtTerritory", "/Profile/GetAllTerritory", mapCode),

                loadDataToTomSelect("#con_txtState", "/Profile/GetAllState", (item) => {
                    const zip = item.zipCode || item.ZipCode || "";
                    const name = item.stateName || item.StateName || "";
                    return {
                        value: item.id || item.ID,
                        text: (zip && name) ? `${zip} - ${name}` : (zip || name || "Unknown"),
                        data: item
                    };
                })
            ];

            Promise.all(loadTasks).finally(() => {
                LoadingGlobal.hide();
            });
        },

        getFormData: function () {

            const getTS = (id) => {
                const ts = getTomSelect(id);
                return ts ? ts.getValue() : null;
            };

            const getDate = (name) => {
                return $(`[data-name="${name}"]`).find("input.date-ui").val();
            };

            const loginName = (localStorage.getItem("Loginname") || "")
            .trim()
            .replace(/^"(.*)"$/, '$1');
            const loginUser = parseInt(localStorage.getItem("userID")) || 0;
            const defaultDate = "1900-01-01";

            return {

                ID: parseInt($("#con_id").val()) || 0,
                Type: 5,

                Code: $("#con_txtCode").val()?.trim(),
                Account: $("#con_txtFullName").val()?.trim(),
                Firstname: $("#con_txtFirstName").val()?.trim(),
                LastName: $("#con_txtLastName").val()?.trim(),
                MiddleName: $("#con_txtMiddleName").val()?.trim(),

                Position: $("#con_txtPosition").val()?.trim(),
                Department: $("#con_txtDept").val()?.trim(),

                LanguageID: parseInt(getTS("#con_txtLanguage")) || 0,
                TitleID: parseInt(getTS("#con_txtTitle")) || 0,

                Salutation: $("#con_txtSalutation").val()?.trim(),

                Address: $("#con_txtAddress").val()?.trim(),
                HomeAddress: $("#con_txtHomeAddress").val()?.trim(),

                City: getTS("#con_txtCity") || "",

                PostalCode: $("#con_txtPostalCode").val()?.trim(),

                CountryID: parseInt(getTS("#con_txtCountry")) || 0,
                StateID: parseInt(getTS("#con_txtState")) || 0,

                OwnerID: parseInt(getTS("#con_txtOwner")) || 0,
                TerritoryID: parseInt(getTS("#con_txtTerritory")) || 0,

                ARNo: $("#con_txtARNo").val()?.trim(),

                DateOfBirth: $("#con_chkActiveDob").is(":checked")
                ? $("input[name='con_txtDob']").val()
                : defaultDate,

                Active: $("#con_chkActive").is(":checked"),

                Telephone: $("#con_txtTelephone").val()?.trim(),
                Fax: $("#con_txtFax").val()?.trim() ,
                Email: $("#con_txtEmail").val()?.trim() ,
                Website: $("#con_txtWebsite").val()?.trim() ,
                HandPhone: $("#con_txtHandPhone").val()?.trim(),

                // Required fields backend hay cần
                Lastvisit: defaultDate,
                FirstReservation: defaultDate,
                LastReservation: defaultDate,
                WeddingAnniversary: defaultDate,
                Firstvisit: defaultDate,
                Expiry: defaultDate,
                LastContact: defaultDate,
                SpecialUpdateDate: defaultDate,

                StayNo: 0,

                UserInsertID: loginUser,
                UserUpdateID: loginUser
            };
        },

        clearForm: function () {
            const $container = $("#pro_con_formContainer");
            $container.find('input[type="text"], input[type="hidden"], input[type="email"], textarea').val('');
            $("#con_chkActive").prop("checked", true);
            $("#con_chkActiveDob").prop("checked", true).trigger('change');

            const tsIds = ["#con_txtLanguage", "#con_txtTitle", "#con_txtCity", "#con_txtCountry", "#con_txtState", "#con_txtOwner", "#con_txtTerritory"];
            tsIds.forEach(id => {
                const ts = getTomSelect(id);
                if (ts) ts.clear();
            });

            if (window.ValidationAdapter) ValidationAdapter.clear("#pro_con_formContainer");
            $("#con_txtCode").focus();
        },

        saveProfile: function () {
            const data = this.getFormData();
            LoadingGlobal.show();

            $.ajax({
                url: '/Profile/SaveProfile',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {
                    LoadingGlobal.hide();

                    if (res.success) {
                        showToast("Success",res.message || 'Profile saved successfully!', true);

                        const modalEl = document.getElementById('modalContact');
                        if (modalEl) {
                            const modalInstance = bootstrap.Modal.getInstance(modalEl);
                            if (modalInstance) modalInstance.hide();
                        }

                        if ($("#pro_search_btnSearch").length) {
                            $("#pro_search_btnSearch").trigger("click");
                        }
                    } else {
                        if (res.errors && res.errors.length > 0) {
                            ValidationAdapter.apply(res.errors, "#pro_con_formContainer");

                            showToast("Error",'Please check the highlighted fields.', false);
                        } else {
                            showToast("Error",res.message || 'An error occurred', false);
                        }
                    }
                },
                error: function () {
                    LoadingGlobal.hide();
                    showToast("Error", 'System error', false);
                }
            });
        },

        fillForm: function (data) {

            if (!data) return;

            const setTS = (id, value) => {
                const ts = getTomSelect(id);
                if (ts) ts.setValue(value || "");
            };

            $("#con_id").val(data.id || 0);

            $("#con_txtCode").val(data.code || "");
            $("#con_txtFullName").val(data.account || "");

            $("#con_txtFirstName").val(data.firstname || "");
            $("#con_txtMiddleName").val(data.middleName || "");
            $("#con_txtLastName").val(data.lastName || "");

            $("#con_txtPosition").val(data.position || "");
            $("#con_txtDept").val(data.department || "");

            setTS("#con_txtLanguage", data.languageID);
            setTS("#con_txtTitle", data.titleID);

            $("#con_txtSalutation").val(data.salutation || "");

            $("#con_txtAddress").val(data.address || "");
            $("#con_txtHomeAddress").val(data.homeAddress || "");

            setTS("#con_txtCity", data.city);

            $("#con_txtPostalCode").val(data.postalCode || "");

            setTS("#con_txtCountry", data.countryID);
            setTS("#con_txtState", data.stateID);

            setTS("#con_txtOwner", data.ownerID);
            setTS("#con_txtTerritory", data.territoryID);

            $("#con_txtARNo").val(data.arNo || "");

            // Date of Birth
            if (data.dateOfBirth) {
                $("#con_chkActiveDob").prop("checked", true).trigger("change");
                $('[data-name="con_txtDob"]').find("input.date-ui").val(data.dateOfBirth);
            } else {
                $("#con_chkActiveDob").prop("checked", false).trigger("change");
            }

            $("#con_chkActive").prop("checked", data.active !== false);

            $("#con_txtTelephone").val(data.telephone || "");
            $("#con_txtFax").val(data.fax || "");
            $("#con_txtEmail").val(data.email || "");
            $("#con_txtWebsite").val(data.website || "");
            $("#con_txtHandPhone").val(data.handPhone || "");

        },

        loadProfileByID: function (id) {
            const self = this;
            LoadingGlobal.show();
            $.ajax({
                url: '/Profile/GetProfileByID/',
                type: 'GET',
                data: { id: id },
                success: function (res) {
                    LoadingGlobal.hide();
                    if (res.code === 0) {
                        self.fillForm(res.profile);
                    } else {
                        showToast("Error", res.msg, false);
                    }
                },
                error: function () {
                    LoadingGlobal.hide();
                    showToast("Error", "Cannot load profile", false);
                }
            });
        }
    };

    window.initContactModal = function() {
        if (window.pro_con_Module) {
            window.pro_con_Module.init();
        }
    }

</script>
