<!-- Main Modal -->
<div class="modal fade"
     id="comTy_mainModal"
     tabindex="-1"
     aria-labelledby="comTy_mainModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-lg-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="comTy_mainModalLabel">Comment Type</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <button id="comTy_btnView" type="button" class="mui-button mui-button-search">View</button>
                        <button id="comTy_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="comTy_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="comTy_btnDelete" type="button" class="mui-button mui-button-delete">Delete</button>
                        <button id="comTy_btnExportExcel" type="button" class="mui-button mui-button-export">Excel</button>
                        <button type="button"
                                class="mui-button mui-button-new"
                                data-bs-dismiss="modal"
                                aria-label="Close">
                            Close
                        </button>
                    </div>

                    <div class="row g-2 mt-1">
                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label for="comTy_filterCode"
                                       class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Code
                                </label>
                                <div class="col-md-8">
                                    <input id="comTy_filterCode"
                                           name="comTy_filterCode"
                                           type="text"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label for="comTy_filterName"
                                       class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Name
                                </label>
                                <div class="col-md-8">
                                    <input id="comTy_filterName"
                                           name="comTy_filterName"
                                           type="text"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Status
                                </label>
                                <div class="col-md-8">
                                    <div class="d-flex align-items-center h-100">
                                        <div class="form-check d-flex align-items-center gap-2">
                                            <span class="status-color-box color-clean-uncheck"></span>
                                            <input type="checkbox"
                                                   id="comTy_chkShowInactive"
                                                   name="comTy_chkShowInactive" />
                                            <label class="form-check-label" for="comTy_chkShowInactive">
                                                Show Inactive
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mui-card mt-1">
                    <div id="comTy_gridContainer" class="gridContainer"></div>
                </div>

                <div id="comTy_loadingSpinner"
                     style="position: absolute;
                            top: 50%;
                            left: 50%;
                            transform: translate(-50%, -50%);
                            z-index: 999;
                            background: rgba(255, 255, 255, 0.55);
                            backdrop-filter: blur(2px);
                            width: 100%;
                            height: 100%;
                            display: flex;
                            align-items: center;
                            justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade"
     id="comTy_itemModal"
     tabindex="-1"
     aria-labelledby="comTy_itemModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="comTy_itemModalLabel">Add Comment Type</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <button type="button" id="comTy_btnSave" class="mui-button mui-button-new">Save</button>
                    <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>

                <form id="comTy_formContainer">
                    <div class="row g-2 mt-1 mb-2">
                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label for="comTy_code"
                                       class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Code
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <input id="comTy_code"
                                           name="comTy_code"
                                           type="text"
                                           class="form-control form-control-sm" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Status
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <div class="form-check d-inline-flex align-items-center gap-2">
                                        <input id="comTy_inactive"
                                               name="comTy_inactive"
                                               type="checkbox" />
                                        <label for="comTy_inactive" class="form-check-label text-danger">
                                            Inactive
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="comTy_name"
                                       class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Name
                                </label>
                                <div class="col-md-10">
                                    <input id="comTy_name"
                                           name="comTy_name"
                                           type="text"
                                           class="form-control form-control-sm" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="comTy_description"
                                       class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Description
                                </label>
                                <div class="col-md-10">
                                    <textarea id="comTy_description"
                                              name="comTy_description"
                                              rows="4"
                                              class="form-control form-control-sm"
                                              style="height:100px;"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="comTy_id" name="comTy_id" value="0" />
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    DevExpress.localization.locale("vi");

    var comTy_Module = (() => {
        let comTy_selectedRowData = null;

        const comTy_selectors = {
            mainModal: "#comTy_mainModal",
            itemModal: "#comTy_itemModal",
            form: "#comTy_formContainer",
            grid: "#comTy_gridContainer",
            loading: "#comTy_loadingSpinner",
            filterCode: "#comTy_filterCode",
            filterName: "#comTy_filterName",
            chkShowInactive: "#comTy_chkShowInactive",
            btnView: "#comTy_btnView",
            btnNew: "#comTy_btnNew",
            btnEdit: "#comTy_btnEdit",
            btnDelete: "#comTy_btnDelete",
            btnExportExcel: "#comTy_btnExportExcel",
            btnSave: "#comTy_btnSave",
            modalLabel: "#comTy_itemModalLabel",
            id: "#comTy_id",
            code: "#comTy_code",
            name: "#comTy_name",
            description: "#comTy_description",
            inactive: "#comTy_inactive"
        };

        function comTy_init() {
            comTy_bindEvents();
            comTy_resetForm();
            comTy_loadGrid([]);
            comTy_loadData();
        }

        function comTy_bindEvents() {
            $(document)
                .off("input change", `${comTy_selectors.form} input, ${comTy_selectors.form} select, ${comTy_selectors.form} textarea`)
                .on("input change", `${comTy_selectors.form} input, ${comTy_selectors.form} select, ${comTy_selectors.form} textarea`, function () {
                    if ($(this).hasClass("is-invalid")) {
                        $(this).removeClass("is-invalid");
                        $(this).next(".invalid-feedback").text("");
                    }
                });

            $(comTy_selectors.itemModal)
                .off("hidden.bs.modal")
                .on("hidden.bs.modal", function () {
                    comTy_resetForm();
                    applyValidationErrors([], comTy_selectors.form);
                });

            $(document)
                .off("click", comTy_selectors.btnView)
                .on("click", comTy_selectors.btnView, function () {
                    comTy_loadData();
                });

            $(document)
                .off("click", comTy_selectors.btnNew)
                .on("click", comTy_selectors.btnNew, function () {
                    comTy_openAddModal();
                });

            $(document)
                .off("click", comTy_selectors.btnEdit)
                .on("click", comTy_selectors.btnEdit, function () {
                    comTy_openEditModal();
                });

            $(document)
                .off("click", comTy_selectors.btnSave)
                .on("click", comTy_selectors.btnSave, function () {
                    comTy_save();
                });

            $(document)
                .off("click", comTy_selectors.btnDelete)
                .on("click", comTy_selectors.btnDelete, function () {
                    comTy_delete();
                });

            $(document)
                .off("click", comTy_selectors.btnExportExcel)
                .on("click", comTy_selectors.btnExportExcel, function () {
                    comTy_exportExcel();
                });
        }

        function comTy_resetForm() {
            const comTy_form = $(comTy_selectors.form)[0];

            if (comTy_form) {
                comTy_form.reset();
            }

            $(comTy_selectors.id).val("0");
            $(comTy_selectors.modalLabel).text("Add Comment Type");
            comTy_selectedRowData = null;
        }

        function comTy_openAddModal() {
            comTy_resetForm();
            $(comTy_selectors.modalLabel).text("Add Comment Type");
            $(comTy_selectors.itemModal).modal("show");
        }

        function comTy_openEditModal() {
            if (!comTy_selectedRowData) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }

            comTy_fillForm(comTy_selectedRowData);
            $(comTy_selectors.modalLabel).text("Update Comment Type");
            $(comTy_selectors.itemModal).modal("show");
        }

        function comTy_fillForm(comTy_data) {
            $(comTy_selectors.id).val(comTy_data.id);
            $(comTy_selectors.code).val(comTy_data.code);
            $(comTy_selectors.name).val(comTy_data.name);
            $(comTy_selectors.description).val(comTy_data.description);
            $(comTy_selectors.inactive).prop("checked", comTy_data.inactive);
        }

        function comTy_getSearchModel() {
            return {
                code: $(comTy_selectors.filterCode).val(),
                name: $(comTy_selectors.filterName).val(),
                inactive: $(comTy_selectors.chkShowInactive).prop("checked") ? 1 : 0
            };
        }

        function comTy_getSaveModel() {
            const comTy_id = parseInt($(comTy_selectors.id).val()) || 0;
            let comTy_loginName = (localStorage.getItem("Loginname") || "")
                .trim()
                .replace(/^"(.*)"$/, "$1");
            const comTy_loginUser = parseInt(localStorage.getItem("userID")) || 0;

            return {
                ID: comTy_id,
                Code: $(comTy_selectors.code).val(),
                Name: $(comTy_selectors.name).val(),
                Description: $(comTy_selectors.description).val(),
                Inactive: $(comTy_selectors.inactive).prop("checked"),
                CreatedBy: comTy_loginName,
                UpdatedBy: comTy_loginName,
                UserInsertID: comTy_loginUser,
                UserUpdateID: comTy_loginUser
            };
        }

        function comTy_showLoading() {
            $(comTy_selectors.loading).show();
        }

        function comTy_hideLoading() {
            $(comTy_selectors.loading).hide();
        }

        function comTy_loadData() {
            comTy_showLoading();

            $.ajax({
                url: "/Administration/GetCommentType",
                type: "GET",
                cache: false,
                data: comTy_getSearchModel(),
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (comTy_data) {
                    comTy_loadGrid(comTy_data || []);
                    comTy_hideLoading();
                },
                error: function () {
                    showToast("Error", "Unable to load data", false);
                    comTy_hideLoading();
                }
            });
        }

        function comTy_loadGrid(comTy_data) {
            $(comTy_selectors.grid).dxDataGrid({
                dataSource: comTy_data,
                width: "100%",
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: {
                    mode: "single"
                },
                hoverStateEnabled: true,
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "code", caption: "Code", width: "100" },
                    { dataField: "name", caption: "Name", width: "150" },
                    { dataField: "description", caption: "Description", minWidth: 120, cssClass: "col-description"},
                    { dataField: "inactive", caption: "Inactive", width: "60",
                        cellTemplate: function (container, options) {
                            $("<div>")
                                .dxCheckBox({
                                    value: options.value == 1 || options.value === true,
                                    readOnly: true
                                })
                                .css("transform", "scale(0.8)")
                                .appendTo(container);
                        }
                    },
                    { dataField: "createdBy", caption: "Created By", width: "80" },
                    { dataField: "createdDate", caption: "Cre.Date", dataType: "date", width: "80" },
                    { dataField: "updatedBy", caption: "Updated By", width: "80" },
                    { dataField: "updatedDate", caption: "Upd.Date", dataType: "date", width: "80" }
                ],
                filterRow: {
                    visible: true,
                    applyFilter: "auto"
                },
                paging: {
                    pageSize: 20
                },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: {
                    mode: "standard",
                    showScrollbar: "always"
                },
                onSelectionChanged: function (e) {
                    comTy_selectedRowData = e.selectedRowsData.length > 0
                        ? e.selectedRowsData[0]
                        : null;
                }
            });
        }

        function comTy_save() {
            const comTy_model = comTy_getSaveModel();

            $.ajax({
                url: "/Administration/CommentTypeSave",
                type: "POST",
                contentType: "application/json",
                cache: false,
                data: JSON.stringify(comTy_model),
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (comTy_res) {
                    if (comTy_res.success) {
                        showToast("Success", comTy_res.message, true);
                        $(comTy_selectors.itemModal).modal("hide");
                        comTy_loadData();
                        return;
                    }

                    if (comTy_res.errors && comTy_res.errors.length > 0) {
                        applyValidationErrors(comTy_res.errors, comTy_selectors.form);

                        let comTy_generalError = comTy_res.errors.find(x => x.field === "general");
                        let comTy_toastMessage = comTy_generalError
                            ? comTy_generalError.message
                            : "Please check input fields.";

                        showToast("Warning", comTy_toastMessage, false);
                        return;
                    }

                    showToast("Error", comTy_res.message || "Save failed", false);
                },
                error: function () {
                    showToast("Error", "Request error!", false);
                    $(comTy_selectors.itemModal).modal("hide");
                }
            });
        }

        function comTy_delete() {
            if (!comTy_selectedRowData || comTy_selectedRowData.id === 0) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }

            if (!confirm("Are you sure you want to delete this record? This action cannot be undone.")) {
                return;
            }

            $.ajax({
                url: `/Administration/DeleteCommentType/` + comTy_selectedRowData.id,
                type: "POST",
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (comTy_result) {
                    if (comTy_result.success) {
                        comTy_loadData();
                        showToast("Success", "Delete Successfully!", true);
                        return;
                    }

                    showToast("Error", comTy_result.message, false);
                },
                error: function () {
                    console.log("delete " + comTy_selectedRowData.id);
                    showToast("Error", "Delete failed!", false);
                    $("#loadingSpinner").hide();
                }
            });
        }

        function comTy_exportExcel() {
            const comTy_grid = $(comTy_selectors.grid).dxDataGrid("instance");
            const comTy_workbook = new ExcelJS.Workbook();
            const comTy_companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const comTy_worksheet = comTy_workbook.addWorksheet("Sheet 1");

            comTy_worksheet.addRow([comTy_companyName]);
            comTy_worksheet.mergeCells("A1:D1");
            comTy_worksheet.getRow(1).font = { bold: true };
            comTy_worksheet.getRow(1).alignment = {
                vertical: "middle",
                horizontal: "left"
            };

            const comTy_now = new Date();
            const comTy_exportDate = comTy_now.toLocaleString("vi-VN");

            comTy_worksheet.addRow(["", "", "", comTy_exportDate]);
            comTy_worksheet.mergeCells("D2:D2");
            comTy_worksheet.getRow(2).alignment = {
                vertical: "middle",
                horizontal: "right"
            };

            comTy_worksheet.addRow([]);
            comTy_worksheet.addRow([]);

            const comTy_reportRow = comTy_worksheet.addRow(["Comment Type"]);
            comTy_worksheet.mergeCells("A5:D5");
            comTy_reportRow.font = { bold: true, size: 14 };
            comTy_reportRow.alignment = {
                vertical: "middle",
                horizontal: "center"
            };

            comTy_worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: comTy_grid,
                worksheet: comTy_worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const comTy_lastRow = comTy_worksheet.lastRow.number + 2;

                comTy_worksheet.mergeCells(`A${comTy_lastRow}:D${comTy_lastRow}`);
                comTy_worksheet.getCell(`A${comTy_lastRow}`).alignment = {
                    horizontal: "center"
                };
                comTy_worksheet.getCell(`A${comTy_lastRow}`).font = {
                    italic: true
                };

                let comTy_fileName = "CommentType.xlsx";

                comTy_workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(
                        new Blob([buffer], { type: "application/octet-stream" }),
                        comTy_fileName
                    );
                });
            });
        }

        return {
            init: comTy_init,
            loadData: comTy_loadData,
            openAddModal: comTy_openAddModal,
            openEditModal: comTy_openEditModal
        };
    })();

    window.openModalCommentType = function () {
        const modalEl = document.querySelector("#comTy_mainModal");
        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

        $(modalEl).one("shown.bs.modal", function () {
            comTy_Module.init();
        });
        modal.show();
    };
</script>