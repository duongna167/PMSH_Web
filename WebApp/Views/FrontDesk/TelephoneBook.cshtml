@using DevExpress.XtraReports.UI


@{
    var selectedReport = @ViewBag.ReportHeader;

    var categories = @ViewBag.TelephoneBookCategoryList;

}
<div class="modal fade" id="tlpB_modal" tabindex="-1" aria-labelledby="tlpB_modalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-4by3">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tlpB_modalLabel">Telephone Book</h5>
            </div>
            <div class="modal-body">
                <div class="search-filter" id="tss_filterForm">
                    <div class="">
                        <button id="tlpB_btnView" class="mui-button mui-button-new">
                            View
                        </button>
                        <button id="tlpB_btnNew" class="mui-button mui-button-new">
                            New
                        </button>
                        <button id="tlpB_btnUpdate" class="mui-button mui-button-edit">
                            Edit
                        </button>
                        <button id="tlpB_btnDelete" class="mui-button mui-button-new">
                            Delete
                        </button>
                        <button id="tlpB_btnExportExcel" class="mui-button mui-button-new" type="button">
                            Excel
                        </button>
                        <button class="mui-button mui-button-new" type="button" data-bs-dismiss="modal">
                            Close
                        </button>

                    </div>
                    <div class="mt-1">
                        <div class="d-flex align-items-center gap-3">

                            <div class="d-flex align-items-center">
                                <label class="mb-0 me-2 text-nowrap" for="tlpB_CategoryCode">Category</label>
                                <input type="text" id="tlpB_CategoryCode" class="form-control form-control-sm" />
                            </div>

                            <div class="d-flex align-items-center">
                                <label class="mb-0 me-2 text-nowrap" for="tlpB_BookCode">Telephone</label>
                                <input type="text" id="tlpB_BookCode" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>

                </div>
                <div class="mui-card">
                    <div class="row">
                        <!-- gridWrapper chiếm 3/12 -->
                        <div class="col-md-3 pe-0">
                            <div id="tlpB_gridWrapper" class="gridContainer mt-2"> </div>
                            <div id="tlpB_gridWrapperloadingSpinner" style="text-align: center; padding: 20px;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                        </div>

                        <!-- Phần còn lại (nếu cần dùng sau) -->
                        <div class="col-md-9">
                            <div id="tlpB_gridContainer" class="gridContainer mt-2"></div>
                            <div id="tlpB_loadingSpinner" style="text-align: center; padding: 20px;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>


            </div>
        </div>
    </div>
</div>
<!-- Modal -->
<div class="modal fade" id="tlpB_telephonePopup" tabindex="-1" aria-labelledby="tlpB_popupLabel" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tlpB_popupLabel">Telephone Book</h5>

            </div>
            <div class="modal-body">
                <div class="search-filter">
                    <button type="button" class="mui-button mui-button-edit" id="tlpB_btnSavePopup">
                        Save
                    </button>
                    <button type="button" class="mui-button mui-button-edit" data-bs-dismiss="modal">Close</button>
                </div>
                <form id="tlpB_popupForm">
                    <div class="row g-2 align-items-center py-2">

                        <div class="col-12 col-md-6">
                            <div class="row g-1 align-items-center">
                                <label class="col-4 col-form-label col-form-label-sm text-end" for="tlpB_popupCategory">
                                    Category
                                </label>
                                <div class="col-8">
                                    <select id="tlpB_popupCategory" class="tomselect-custom">
                                        @foreach (var c in ViewBag.TelephoneBookCategoryList)
                                        {
                                            <option value="@c.ID">@c.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="row g-1 align-items-center">
                                <label class="col-4 col-form-label col-form-label-sm text-end" for="tlpB_popupName">
                                    Name
                                </label>
                                <div class="col-8">
                                    <input type="text" id="tlpB_popupName" class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="row g-1 align-items-center">
                                <label class="col-4 col-form-label col-form-label-sm text-end" for="tlpB_popupPhone">
                                    Telephone
                                </label>
                                <div class="col-8">
                                    <input type="text" id="tlpB_popupPhone" class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="row g-1 align-items-center">
                                <label class="col-4 col-form-label col-form-label-sm text-end" for="tlpB_popupAddress">
                                    Address
                                </label>
                                <div class="col-8">
                                    <input type="text" id="tlpB_popupAddress" class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="row g-1 align-items-center">
                                <label class="col-4 col-form-label col-form-label-sm text-end" for="tlpB_popupRemark">
                                    Remarks
                                </label>
                                <div class="col-8">
                                    <input type="text" id="tlpB_popupRemark" class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="row g-1 align-items-center">
                                <label class="col-4 col-form-label col-form-label-sm text-end" for="tlpB_popupWeb">
                                    Web Link
                                </label>
                                <div class="col-8">
                                    <input type="text" id="tlpB_popupWeb" class="form-control form-control-sm"
                                           value="http://www." />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="row g-1 align-items-center">
                                <label for="tlpB_popupColor" class="col-4 col-form-label col-form-label-sm text-end">
                                    Color
                                </label>
                                <div class="col-4">
                                    <input type="color" name="color" id="tlpB_popupColor" value="#027c75"
                                           class="form-control " style=" height:30px; padding:1px">
                                </div>
                            </div>
                        </div>

                    </div>

                </form>
            </div>

        </div>
    </div>
</div>

<script>
    var tlpB_Module = {
        // 1. Thuộc tính (Properties)
        VN_PHONE_REGEX: /^((0|\+84)(3|5|7|8|9)[0-9]{8}|0\d{2,3}\d{7,8})$/,
        selectedParentRow: null,

        // 2. Khởi tạo (Initialization)
        init: function (listTelephoneSelect) {
            this.bindEvents();
            initTomSelect(".tomselect-custom");
            this.loadTelephoneSelect(listTelephoneSelect);
            this.loadTelephoneGrid([]);
            $("#tlpB_btnView").trigger("click");
        },

        // 3. Đăng ký sự kiện (Event Bindings)
        bindEvents: function () {
            const self = this;

            // Nút Thêm mới
            $(document).off("click", "#tlpB_btnNew").on("click", "#tlpB_btnNew", function () {
                $("#tlpB_popupForm")[0].reset();
                $("#tlpB_popupForm").removeData("edit-id");
                clearTomSelect(".tomselect-custom");
                $("#tlpB_telephonePopup").modal("show");
            });

            // Nút Cập nhật (ngoài grid)
            $(document).off("click", "#tlpB_btnUpdate").on("click", "#tlpB_btnUpdate", function () {
                self.openEditModal();
            });

            // Nút Lưu trong Popup
            $(document).off("click", "#tlpB_btnSavePopup").on("click", "#tlpB_btnSavePopup", function () {
                self.saveData();
            });

            // Nút Xóa
            $(document).off("click", "#tlpB_btnDelete").on("click", "#tlpB_btnDelete", function () {
                self.deleteData();
            });

            // Nút Xem/Tìm kiếm
            $(document).off("click", "#tlpB_btnView").on("click", "#tlpB_btnView", function () {
                self.reloadParentGrid();
            });

            // Nút Xuất Excel
            $(document).off("click", "#tlpB_btnExportExcel").on("click", "#tlpB_btnExportExcel", function () {
                self.exportExcel();
            });
        },

        // 4. Các hàm xử lý nghiệp vụ (Business Logic)
        isValidVietnamPhone: function (phone) {
            return this.VN_PHONE_REGEX.test(phone);
        },

        signedIntToHexColor: function (argbInt) {
            let uint32 = argbInt >>> 0;
            let hex = (uint32 & 0x00FFFFFF).toString(16).padStart(6, "0");
            return "#" + hex;
        },

        hexToSignedInt: function (hex) {
            hex = hex.replace("#", "");
            let intVal = parseInt("FF" + hex, 16);
            return intVal > 0x7FFFFFFF ? intVal - 0x100000000 : intVal;
        },

        openEditModal: function () {
            const grid = $("#tlpB_gridContainer").dxDataGrid("instance");
            const selected = grid.getSelectedRowsData();

            if (selected.length === 0) {
                showToast('Warning', 'Please select a row to update.', false);
                return;
            }

            let row = selected[0];
            $.get("/FrontDesk/GetTelephoneById", { id: row.id }, function (data) {
                if (data) {
                    setTomSelectValue("#tlpB_popupCategory", data.telephoneBookCategoryID);
                    $("#tlpB_popupName").val(data.name);
                    $("#tlpB_popupPhone").val(data.telephone);
                    $("#tlpB_popupAddress").val(data.address);
                    $("#tlpB_popupRemark").val(data.remark);
                    $("#tlpB_popupWeb").val(data.webAddress);
                    $("#tlpB_popupColor").val(tlpB_Module.signedIntToHexColor(data.color));

                    $("#tlpB_popupForm").data("edit-id", data.id);
                    $("#tlpB_telephonePopup").modal("show");
                }
            });
        },

        saveData: function () {
            const self = this;
            const phone = $("#tlpB_popupPhone").val();
            if (!this.isValidVietnamPhone(phone)) {
                showToast('Error', 'The phone number is not valid.', false);
                return;
            }

            let editId = $("#tlpB_popupForm").data("edit-id");
            let postData = {
                name: $("#tlpB_popupName").val(),
                telephone: phone,
                address: $("#tlpB_popupAddress").val(),
                remark: $("#tlpB_popupRemark").val(),
                userID: JSON.parse(localStorage.getItem("userID")),
                webAddress: $("#tlpB_popupWeb").val(),
                categoryId: $("#tlpB_popupCategory").val(),
                color: this.hexToSignedInt($("#tlpB_popupColor").val())
            };

            let url = editId ? "/FrontDesk/UpdateTelephoneBook" : "/FrontDesk/InsertTelephoneBook";
            if (editId) postData.id = editId;

            $.post(url, postData, function (res) {
                if (res.success) {
                    showToast('Success', editId ? 'Updated successfully.' : 'Added successfully.', true);
                    $("#tlpB_telephonePopup").modal("hide");

                    // Refresh data
                    if (self.selectedParentRow) {
                        self.loadTelephoneDetail(self.selectedParentRow.id, self.selectedParentRow.name);
                    } else {
                        $("#tlpB_btnView").trigger("click");
                    }
                } else {
                    alert("Lỗi: " + res.message);
                }
            });
        },

        deleteData: function () {
            const self = this;
            const grid = $("#tlpB_gridContainer").dxDataGrid("instance");
            const selected = grid.getSelectedRowsData();

            if (selected.length === 0) {
                showToast('Warning', 'Please select a row to delete.', false);
                return;
            }

            let row = selected[0];
            if (confirm(`Are you sure you want to delete "${row.name}"?`)) {
                $.post("/FrontDesk/DeleteTelephoneBook", { id: row.id }, function (res) {
                    if (res.success) {
                        showToast('Success', 'Deleted successfully.', true);
                        if (self.selectedParentRow) {
                            self.loadTelephoneDetail(self.selectedParentRow.id, self.selectedParentRow.name);
                        }
                        $("#tlpB_btnView").trigger("click");
                    }
                });
            }
        },

        // 5. Grid & Data Loading
        reloadParentGrid: function () {
            $("#tlpB_gridWrapperloadingSpinner").show();
            $("#tlpB_gridWrapper").hide();

            $.ajax({
                url: '/FrontDesk/GetTelephoneBook',
                type: 'GET',
                data: {
                    CategoryCode: $("#tlpB_CategoryCode").val(),
                    BookCode: $("#tlpB_BookCode").val()
                },
                success: function (data) {
                    tlpB_Module.loadTelephoneSelect(data);
                    $("#tlpB_gridWrapperloadingSpinner").hide();
                    $("#tlpB_gridWrapper").show();
                }
            });
        },

        loadTelephoneSelect: function (data) {
            const self = this;
            $("#tlpB_gridWrapper").dxDataGrid({
                dataSource: data,
                height: "100%",
                selection: { mode: "single" },
                loadPanel: { enabled: false },
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "name", caption: "Name" }
                ],
                onSelectionChanged: function (e) {
                    if (e.selectedRowsData.length > 0) {
                        self.selectedParentRow = e.selectedRowsData[0];
                        self.loadTelephoneDetail(self.selectedParentRow.id, self.selectedParentRow.name);
                    }
                }
            });
        },

        loadTelephoneGrid: function (data) {
            $("#tlpB_gridContainer").dxDataGrid({
                dataSource: data,
                keyExpr: "id",
                height: "100%",
                loadPanel: { enabled: false },
                selection: { mode: "single" },
                columns: [
                    { dataField: "name", caption: "Name" },
                    { dataField: "telephone", caption: "Telephone" },
                    { dataField: "address", caption: "Address" },
                    { dataField: "remark", caption: "Remark" }
                ],
                onRowPrepared: function (e) {
                    if (e.rowType === "data" && e.data.color != null) {
                        let bgColor = tlpB_Module.signedIntToHexColor(e.data.color);
                        e.rowElement[0].style.setProperty("background-color", bgColor, "important");
                    }
                }
            });
        },

        loadTelephoneDetail: function (telephoneId, name) {
            $("#tlpB_gridContainer").hide();
            $("#tlpB_loadingSpinner").show();
            $.get('/FrontDesk/GetTelephoneDetail', { id: telephoneId, name: name }, function (result) {
                tlpB_Module.loadTelephoneGrid(result);
                $("#tlpB_loadingSpinner").hide();
                $("#tlpB_gridContainer").show();
            });
        },

        exportExcel: function () {
            const grid = $("#tlpB_gridContainer").dxDataGrid("instance");
            const workbook = new ExcelJS.Workbook();
            const worksheet = workbook.addWorksheet("Telephone Directory");
            const companyName = localStorage.getItem("CompanyName") || "Hotel System";

            worksheet.addRow([companyName]);
            worksheet.mergeCells('A1:D1');

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "Telephone_Directory.xlsx");
                });
            });
        }
    };

    window.openModalFDKTlpB = function () {
        tlpB_Module.init();
    };

    $("#tlpB_modal").on("hidden.bs.modal", function () {
        if (tlpB_Module.selectedParentRow) tlpB_Module.selectedParentRow.destroy();
    });

</script>
