<link rel="stylesheet" href="~/css/pages/billing.css" asp-append-version="true" />

<div class="modal fade managed-modal" id="modalBilling" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
     aria-labelledby="staticBackdropLabelBilling" aria-hidden="true">
    <div class="modal-dialog modal-xl billing-module-dialog">
        <div class="modal-content billing-module">
            <div class="modal-header">
                <h5 class="modal-title" id="staticBackdropLabelBilling">Billing Information</h5>
            </div>

            <div class="modal-body" style="padding: 0 !important">
                <div class="functions-pane">
                    <div class="function-menu flex-grow-1">
                        <div class="dropdown d-inline-block">
                            <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown" data-bs-display="static" aria-expanded="false"> View</a>
                            <div class="dropdown-menu dropdown-menu-custom-rsv">
                                <a class="dropdown-item" href="#" onclick="openBilling0();">By Total</a>
                                <a class="dropdown-item" href="#" onclick="openBilling1();">By Detail : Include Tax</a>
                                <a class="dropdown-item" href="#" onclick="openBilling2();">
                                    By Detail : Not Include
                                    Tax
                                </a>
                            </div>
                        </div>

                        <a href="#" class="js-checkout-single"  onclick="openModalPosting();"> Posting</a>
                        <a href="#" onclick="openModalEditPosting();"> Edit</a>

                        <div class="dropdown d-inline-block">
                            <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown" data-bs-display="static" aria-expanded="false"> Print</a>
                            <div class="dropdown-menu dropdown-menu-custom-rsv">
                                <a class="dropdown-item" href="#" onclick="PrintAndPreview(1);">
                                    Style: Billing
                                    Information
                                </a>
                                <a class="dropdown-item" href="#" onclick="PrintAndPreview(2);">
                                    Style: Billing
                                    Information (Selection)
                                </a>
                            </div>
                        </div>

                        <a href="#" class="js-checkout-single"    onclick="openModalPaymentBilling();"> Payment</a>
                        @* <a href="#" onclick="openModalEditPosting();"> Deposit</a> *@
                        <a href="#" class="js-checkout-single" onclick="openModalCheckOut();" id="unAssignRoom"> Check out</a>

                        @* <a href="#" class="" id="toggleFunctionMenu">Show Func.</a> *@
                        <button type="button" class="mui-button mui-button-close" onclick="closeModalBilling()">Close</button>
                    </div>

                </div>

                <div class="mui-card">
                    <div class="row g-2">
                        <div class="billing-col billing-col-status">
                            <div class="info-group">
                                <label>RSV Status:</label>
                                <span id="rsvStatusBilling"></span>
                            </div>
                        </div>
                        <div class="billing-col billing-col-short">
                            <div class="info-group">
                                <label>Conf.No:</label>
                                <span id="conNoBilling"></span>
                            </div>
                        </div>
                        <div class="billing-col billing-col-short">
                            <div class="info-group">
                                <label>Arrival:</label>
                                <span id="arivalBilling"></span>
                            </div>
                        </div>
                        <div class="billing-col billing-col-short">
                            <div class="info-group">
                                <label>Departure:</label>
                                <span id="departureBilling"></span>
                            </div>
                        </div>
                        <div class="billing-col billing-col-wide">
                            <div class="info-group">
                                <label>Group:</label>
                                <span id="groupBilling"></span>
                            </div>
                        </div>
                        <div class="billing-col billing-col-wide">
                            <div class="info-group">
                                <label>Company:</label>
                                <span id="companyBilling"></span>
                            </div>
                        </div>
                        <div class="billing-col billing-col-money">
                            <div class="info-group">
                                <label>Balance:</label>
                                <span id="balanceBilling" class="fw-bold"></span>
                            </div>
                        </div>
                        <div class="billing-col billing-col-money">
                            <div class="info-group">
                                <label>Total:</label>
                                <span id="totalBilling" class="fw-bold"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="billing-body-main">
                    <div class="folio-container">
                        <div class="folio-header">
                            @* <span>Folio no</span> *@
                            @* <span data-tooltip="Add Folio"><i class="fas fa-plus add-icon"
                                    onclick="openModalNewWindow();"></i></span> *@
                        </div>
                        <ul id="listFolioNo" class="folio-list"></ul>
                    </div>

                    <div class="grid-wrapper">
                        <div class="grid-header-info d-flex align-items-center">
                            <div style="flex-grow: 1; padding-left: 5px;">
                                <span id="infoBillingName"><i class="fas fa-spinner fa-spin"></i> Loading...</span>
                            </div>

                            <div style="flex: 0 0 12.5%; padding: 0 5px;">
                                <span class="me-2 text-muted" style="font-size:0.8rem; font-weight:600;">
                                    Folio
                                    Bal:
                                </span>
                                <label id="balanceBillingMaster" class="text-danger fw-bold">0</label>
                            </div>

                            <div style="flex: 0 0 12.5%; padding: 0 5px;">
                                <span id="totalBillingMasterLabel" class="me-2 text-muted" style="font-size:0.8rem; font-weight:600;">Total:</span>
                                <label id="totalBillingMaster" class="fw-bold">0</label>
                            </div>
                        </div>

                        <div class="overlay-menu" id="functionMenu" style="display: none;">
                            <a href="#" onclick="openModalNewWindow();">New Window</a>
                            <a href="#" onclick="deleteFolioNo();">Delete Window</a>

                            <div class="dropdown">
                                <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown" data-bs-display="static" aria-expanded="false">Lock Folio</a>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item" href="#" onclick="LockFolioOnly(folioNoID);">Only One</a>
                                    <a class="dropdown-item" href="#" onclick="LockFolio();">All Folio</a>
                                </div>
                            </div>
                            <div class="dropdown">
                                <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown" data-bs-display="static" aria-expanded="false">Unlock Folio</a>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item" href="#" onclick="UnLockFolioOnly(folioNoID);">Only One</a>
                                    <a class="dropdown-item" href="#" onclick="UnLockFolio();">All Folio</a>
                                </div>
                            </div>
                            <div class="dropdown">
                                <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown" data-bs-display="static" aria-expanded="false">Posting History</a>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item" href="#" onclick="PostingHistory(1);">By Folio</a>
                                    <a class="dropdown-item" href="#" onclick="PostingHistory(2);">By Invoice</a>
                                </div>
                            </div>
                            <a href="#" onclick="openModalSplitTransaction();">Split Transaction</a>
                            <a href="#" onclick="adjustTransaction();">Adjust Transaction</a>
                            <a href="#" id="deleteTransactionBilling" style="color:var(--danger-color);">
                                Delete
                                Transactions
                            </a>
                            <a href="#" onclick="ExportExcelBilling();">Export to Excel</a>

                            <div class="dropdown">
                                <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown" data-bs-display="static" aria-expanded="false">Transfer to Window</a>
                                <div class="dropdown-menu" id="listTransferToWindow"></div>
                            </div>
                            <a href="#" onclick="openModalTransactionDetail();">View Transaction Detail</a>
                            <a href="#" onclick="openModalTransferTransaction();">Transfer Transaction</a>
                            <a href="#" onclick="openModalSelectOption();">Options</a>
                        </div>

                        <div class="mui-card">
                            <div id="gridContainerBilling" class="gridContainer"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalConfirmDeleteTransaction" data-bs-backdrop="static" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content billing-module">
            <div class="modal-header">
                <h5 class="modal-title">Deletion Reason</h5>
            </div>
            <div class="modal-body">
                <div class="d-flex py-2 gap-2">
                    <button class="mui-button mui-button-delete" onclick="confirmDelete();">Confirm Delete</button>
                    <button class="mui-button mui-button-option"
                            onclick="closeModalConfirmTransaction();">
                        Close
                    </button>
                </div>
                <div class="mb-3">
                    <label class="form-label">Select Reason</label>
                    <select id="codeDeletionReason" class="form-select form-select-sm"></select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control form-control-sm" id="descriptionDeletionReason" rows="3"></textarea>
                </div>

            </div>
        </div>
    </div>
</div>
<div class="modal fade managed-modal" id="modalTransactionDetail" data-bs-backdrop="static" tabindex="-1"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title"> Detail Transaction Post </h6>
            </div>
            <div class="modal-body p-2">
                <div class="py-2">
                    <button type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                </div>
                <div class="gridContainer" id="gridTransactionDetail" style="height: 300px; width: 100%;"></div>
            </div>

        </div>
    </div>
</div>

<img id="logoSource" src="/images/logo-parner.png" hidden>

@await Html.PartialAsync("Billing/PostingNew")
@await Html.PartialAsync("Billing/Payment")
@await Html.PartialAsync("Billing/NewFolio")
@await Html.PartialAsync("Billing/PostingHistory")
@await Html.PartialAsync("Billing/ShiftLogin")
@await Html.PartialAsync("Billing/EditPosting")
@await Html.PartialAsync("Billing/SplitTransaction")
@await Html.PartialAsync("Billing/TransferTransaction")
@await Html.PartialAsync("Billing/AdjustTransaction")
@await Html.PartialAsync("Billing/SelectOption")

<script>
    function showBillingFunctionMenu(pageX, pageY) {
        const $menu = $("#functionMenu");
        const $wrapper = $(".grid-wrapper").first();

        if ($menu.length === 0 || $wrapper.length === 0) {
            return;
        }

        const wrapperOffset = $wrapper.offset();
        const wrapperWidth = $wrapper.outerWidth();
        const wrapperHeight = $wrapper.outerHeight();

        $menu.css({
            display: "block",
            position: "absolute",
            left: 0,
            top: 0,
            zIndex: 10000
        });

        const menuWidth = $menu.outerWidth();
        const menuHeight = $menu.outerHeight();
        const maxLeft = Math.max(0, wrapperWidth - menuWidth - 8);
        const maxTop = Math.max(0, wrapperHeight - menuHeight - 8);

        let left = pageX - wrapperOffset.left;
        let top = pageY - wrapperOffset.top;

        left = Math.min(Math.max(8, left), maxLeft);
        top = Math.min(Math.max(8, top), maxTop);

        $menu.css({
            left: left + "px",
            top: top + "px"
        });
    }

    $(document).ready(function () {

        $(document).on("mousedown", function (e) {
            if (!$(e.target).closest("#functionMenu").length) {
                $("#functionMenu").hide();
            }
        });

        // Ngăn chặn menu bị ẩn khi click vào các dropdown bên trong nó
        $("#functionMenu").on("click", function (e) {
            e.stopPropagation();
        });

        getDeletionReason();

        // SỰ KIỆN CHUỘT PHẢI TOÀN VÙNG GRID
        $("#gridContainerBilling").on("contextmenu", function (e) {
            e.preventDefault();

            const grid = $("#gridContainerBilling").dxDataGrid("instance");

            const rowElement = $(e.target).closest(".dx-data-row");

            if (rowElement.length > 0) {
                const rowIndex = rowElement.index();
                const rowData = grid.getVisibleRows()[rowIndex].data;

                if (!grid.isRowSelected(rowData.id)) {
                    grid.selectRows([rowData.id], false);
                }

                folioDetailID = rowData.id;
                invoiceNoPosting = rowData.invoiceNo;
            } else {

            }

            showBillingFunctionMenu(e.pageX, e.pageY);
        });

        // Ẩn menu khi click chuột trái ra ngoài
        $(document).on("click", function (e) {
            if (!$(e.target).closest("#functionMenu").length) {
                $("#functionMenu").hide();
            }
        });
    });

    var folioPosting = 1;
    var isMasterFolio = 0;
    var transactionNoPost = "0";
    var totalAmountBilling = 0;
    var invoiceNoPosting = 0;
    var listFolioNoID = [];
    var listFolioData = [];
    var folioNoID = 0;
    var currentFolioData = []; // full dataset for current folio (used in selection handler)
    var billingDetailXhr = null;
    var billingDetailRequestSeq = 0;
    var folioListXhr = null;

    function formatBillingSummaryNumber(value) {
        const parsed = Number(value || 0);
        if (isNaN(parsed)) return '0';
        return parsed.toLocaleString('vi-VN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function normalizeBillingHeaderText(value) {
        if (value === null || value === undefined) {
            return '';
        }

        const text = value.toString().trim();
        if (!text || text.toLowerCase() === 'undefined' || text.toLowerCase() === 'null') {
            return '';
        }

        return text;
    }

    function refreshBillingReservationSummary() {
        // Dùng dữ liệu đã cache từ grid - không cần gọi API GetReservationByID lại
        const cached = typeof _currentReservationData !== 'undefined' ? _currentReservationData : null;
        const masterFolio = (listFolioData || []).find(f => f.isMasterFolio);
        const companyName = normalizeBillingHeaderText(
            masterFolio && masterFolio.accountName
                ? masterFolio.accountName
                : (cached?.CompanyName || cached?.companyName || '')
        );
        const groupName = normalizeBillingHeaderText(
            cached?.GroupName || cached?.GroupCode || cached?.groupName || cached?.groupCode || ''
        );
        $('#groupBilling').text(groupName);
        $('#companyBilling').text(companyName);

        GetBalanceVND(idReservation);
    }

    function openBilling0() { searchFolioDetail(0); }
    function openBilling1() { searchFolioDetail(1); }
    function openBilling2() { searchFolioDetail(2); }
    function searchFolioDetail(type) {
        var $gridElement = $("#gridContainerBilling");
        var requestSeq = ++billingDetailRequestSeq;

        if ($gridElement.length > 0 && $gridElement.data("dxDataGrid")) {
            // Chỉ clear data khi Grid ĐÃ tồn tại
            $gridElement.dxDataGrid("instance").option("dataSource", []);
        }
        if (billingDetailXhr && billingDetailXhr.readyState !== 4) {
            billingDetailXhr.abort();
        }

        billingDetailXhr = $.ajax({
            url: '/Reservation/GetFolioDetailByFolioID',
            loadingGrid: "#gridContainerBilling",
            type: 'get',
            dataType: 'json',
            data: {
                mode: type,
                folioNo: folioNoID
            },
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                if (requestSeq !== billingDetailRequestSeq) return;
                initializeDataGridBilling(result);
            },
            error: function (xhr, statusText, err) {
                if (statusText === 'abort') return;
                if (xhr.status == 401) sessionTimeout();
            }
        });
    }

    invoiceNoPosting = 0;

    /**
     * {number} [preferredFolioId] - ID folio (PK) cần chọn sau khi reload (vd. vừa post ở Posting).
     */
    function getFolioNo(preferredFolioId) {
        if (folioListXhr && folioListXhr.readyState !== 4) {
            folioListXhr.abort();
        }

        folioListXhr = $.ajax({
            url: '/Billing/GetFolioNo',
            type: 'get',
            data: { reservationID: idReservation },
            success: function (result) {
                result = result || [];
                if (preferredFolioId > 0 && result && result.length > 0) {
                    const exists = result.some(function (f) { return f.id === preferredFolioId; });
                    if (exists) {
                        folioNoID = preferredFolioId;
                    }
                }
                if (result && result.length > 0) {
                    result.sort((a, b) => {
                        if (a.isMasterFolio === b.isMasterFolio) {
                            return Math.abs(a.folioNo) - Math.abs(b.folioNo);
                        }
                        return a.isMasterFolio ? 1 : -1;
                    });
                }
                listFolioData = result;
                refreshBillingReservationSummary();

                listFolioNoID = [];
                $('#listFolioNo').empty();
                $('#listTransferToWindow').empty();

                // removed useless isMasterFolio assignment

                var html = '';
                var htmlWindow = '';

                if (result.length > 0) {
                    for (var i = 0; i < result.length; i++) {
                        listFolioNoID.push(result[i].id);

                        // Nếu là Master thì hiện M + (số thứ tự), Guest thì hiện số
                        let label = result[i].isMasterFolio ? "M" + Math.abs(result[i].folioNo) : result[i].folioNo;

                        htmlWindow += `<a class="dropdown-item" href="#" onclick="transferToWindow(${result[i].id});">Window ${label}</a>`;

                        let activeClass = (folioNoID === result[i].id || (folioNoID === 0 && i === 0)) ? 'active' : '';
                        if (activeClass === 'active') folioNoID = result[i].id;

                        let lockIcon = result[i].status ? '<i class="fas fa-lock lock-icon"></i>' : '';

                        html += `
                                                <li class="folio-row">
                                                    <div class="folio-item ${activeClass}" onclick="filterByFolioNo(${result[i].id}, ${i}, this)">
                                                        ${label}
                                                    </div>
                                                    ${lockIcon}
                                                </li>`;
                    }
                }

                $('#listFolioNo').append(html);
                $('#listTransferToWindow').append(htmlWindow);

                if (result.length > 0) {
                    let defaultIndex = 0;
                    for (var j = 0; j < result.length; j++) {
                        if (result[j].id == folioNoID) {
                            defaultIndex = j;
                            break;
                        }
                    }
                    filterByFolioNo(folioNoID, defaultIndex);
                } else {
                    $('#infoBillingName').text('No folio found for this reservation.');
                    initializeDataGridBilling([]);
                    if (typeof renderFolioOptions === 'function') {
                        renderFolioOptions();
                    }
                }
            },
            error: function (xhr, statusText) {
                if (statusText === 'abort') return;
                if (xhr.status == 401) sessionTimeout();
                else {
                    $('#infoBillingName').text('Unable to load folio list.');
                    initializeDataGridBilling([]);
                }
            }
        });
    }


    function filterByFolioNo(folioNo, index, element) {
        $('.folio-item').removeClass('active');

        if (element) {
            $(element).addClass('active');
        } else {
            $('#listFolioNo .folio-row').eq(index).find('.folio-item').addClass('active');
        }

        let currentFolio = listFolioData.find(f => f.id == folioNo);

        let displayName = (currentFolio && currentFolio.accountName) ? currentFolio.accountName : lastname;

        let label = (currentFolio && currentFolio.isMasterFolio) ? "M" + Math.abs(currentFolio.folioNo) : (currentFolio ? currentFolio.folioNo : (index + 1));

        $('#infoBillingName').html(`[${label}] &nbsp; <b>${displayName}</b> (${folioNo})`);

        folioNoID = folioNo;
        folioPosting = index + 1;

        if (typeof syncPostingFolioSelectionFromBilling === 'function') {
            syncPostingFolioSelectionFromBilling(folioNo);
        }

        searchFolioDetail(0);
    }

    function getTotalAmount(data) {
        return data.reduce((total, item) => total + (parseFloat(item.amount) || 0), 0);
    }

    var folioDetailID = 0;
    var transCodeBilling = "";

    // Folio Bal = net balance (charges positive, payments negative)
    // Total = selected rows sum (updated on selection, reset to 0 when nothing selected)
    function updateFolioBal(data) {
        let balance = 0;
        (data || []).forEach(function (item) {
            balance += parseFloat(item.amount) || 0;
        });
        totalAmountBilling = balance;
        $('#balanceBillingMaster').text(formatBillingSummaryNumber(balance));
        $('#totalBillingMaster').text(formatBillingSummaryNumber(0));
        $('#totalBillingMasterLabel').text('Total:');
    }

    function initializeDataGridBilling(data) {
        currentFolioData = data || [];
        updateFolioBal(data);

        var existingGrid = $("#gridContainerBilling").data("dxDataGrid");
        if (existingGrid) {
            existingGrid.option("dataSource", data);
            return;
        }

        $("#gridContainerBilling").dxDataGrid({
            dataSource: data,
            keyExpr: "id",
            height: '100%',
            width: "100%",
            columnAutoWidth: false,
            allowColumnResizing: true,
            columnResizingMode: "widget",
            wordWrapEnabled: false,
            scrolling: {
                mode: "standard",
                showScrollbar: "always",
                scrollByContent: true,
                scrollByThumb: true
            },

            showRowLines: true,
            rowAlternationEnabled: true,
            hoverStateEnabled: true,
            paging: { pageSize: 20 },
            pager: {
                visible: true,
                allowedPageSizes: [20, 50, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            columns: [
                {
                    type: "selection",
                    width: 40,
                    fixed: true,
                    allowResizing: false
                },
                { dataField: "id", visible: false },
                {
                    dataField: 'date',
                    caption: 'Date',
                    width: 90,
                    calculateCellValue: function (rowData) {
                        if (!rowData.date) return '';

                        const datePart = rowData.date.split(' ')[0];
                        const parts = datePart.split('/');

                        if (parts.length !== 3) return rowData.date;

                        const day = parts[0].padStart(2, '0');
                        const month = parts[1].padStart(2, '0');
                        const year = parts[2];

                        return `${day}/${month}/${year}`;
                    }
                },
                {
                    dataField: 'codePrefix',
                    caption: '...',
                    width: 40,
                    alignment: "center"
                },
                {
                    dataField: "code",
                    caption: "Code",
                    width: 60
                },
                {
                    dataField: "description",
                    caption: "Description",
                    minWidth: 200
                },
                {
                    dataField: "",
                    caption: "Inv#",
                    width: 80
                },
                {
                    dataField: "amount",
                    caption: "Amount",
                    width: 100,
                    dataType: "number",
                    format: { type: "fixedPoint", precision: 2 },
                    cssClass: "fw-bold text-end"
                },
                { dataField: "currency", caption: "$", width: 50, alignment: "center" },
                { dataField: "supplement", caption: "Supplement", width: 120 },
                { dataField: "reference", caption: "Reference", width: 200 },
                { dataField: "userName", caption: "User", width: 80 },
                {
                    dataField: 'time',
                    caption: "Time",
                    width: 60,
                    calculateCellValue: function (rowData) {
                        if (!rowData.time) return '';

                        const dateStr = rowData.time;
                        const datePart = dateStr.split(' ')[0];
                        const timePart = dateStr.split(' ')[1] || '00:00';

                        const dParts = datePart.split('/');
                        if (dParts.length !== 3) return '';

                        const day = parseInt(dParts[0], 10);
                        const month = parseInt(dParts[1], 10) - 1;
                        const year = parseInt(dParts[2], 10);

                        const tParts = timePart.split(':');
                        const hour = parseInt(tParts[0] || 0, 10);
                        const minute = parseInt(tParts[1] || 0, 10);

                        const d = new Date(year, month, day, hour, minute);

                        let h = d.getHours();
                        const m = d.getMinutes().toString().padStart(2, '0');
                        const ampm = h >= 12 ? 'PM' : 'AM';

                        h = h % 12;
                        h = h ? h : 12;

                        return `${h}:${m} ${ampm}`;
                    }
                },
                { dataField: "groupCode", caption: "Group", width: 60 },
                { dataField: "subgroupCode", caption: "Sub", width: 60 },
                { dataField: "shiftID", caption: "Shift.No", width: 70 },
                { dataField: "property", caption: "Property", width: 80 },
                { dataField: "invoiceNo", caption: "Inv.No", width: 80 },
                { dataField: "transactionNo", caption: "Trn.No", width: 70 }
            ],
            filterRow: { visible: true, applyFilter: "auto" },
            selection: { mode: "multiple", showCheckBoxesMode: "always" },
            onContextMenuPreparing: function (e) {
                if (e.row && e.row.rowType === "data") {
                    const grid = e.component;
                    const rowData = e.row.data;

                    if (!grid.isRowSelected(rowData.id)) {
                        grid.selectRows([rowData.id], false);
                    }

                    folioDetailID = rowData.id;
                    invoiceNoPosting = rowData.invoiceNo;

                    // Hiển thị Menu tại vị trí chuột
                    showBillingFunctionMenu(e.event.pageX, e.event.pageY);

                    e.event.preventDefault();
                }
            },

            // 2. CLICK DÒNG (TỐI ƯU TOGGLE SELECTION)
            onRowClick: function (e) {
                if (e.rowType === "data") {
                    $("#functionMenu").hide();

                    // Kiểm tra nếu không phải click vào ô checkbox mặc định của Grid
                    if (!$(e.event.target).closest('.dx-command-select').length) {
                        const isSelected = e.component.isRowSelected(e.key);
                        if (isSelected) {
                            e.component.deselectRows([e.key]);
                        } else {
                            // true để giữ lại các dòng đã chọn trước đó
                            e.component.selectRows([e.key], true);
                        }
                    }
                }
            },

            // 3. THAY ĐỔI LỰA CHỌN — Total hiển thị tổng các dòng đang chọn
            onSelectionChanged: function (e) {
                const selectedRows = e.selectedRowsData;
                let selTotal = 0;

                if (selectedRows.length > 0) {
                    selectedRows.forEach(item => { selTotal += (parseFloat(item.amount) || 0); });
                    $('#totalBillingMasterLabel').text('Total:');
                } else {
                    $('#totalBillingMasterLabel').text('Total:');
                    $("#functionMenu").hide();
                }

                $('#totalBillingMaster').text(formatBillingSummaryNumber(selTotal));
            },

            // 4. KHI DỮ LIỆU LOAD XONG (CHỌN SẴN DÒNG NẾU CÓ)
            onContentReady: function (e) {
                // Chỉ chạy khi có biến selectedCodesFromResult (thường dùng sau khi Split/Transfer)
                if (typeof selectedCodesFromResult !== 'undefined' && data.length > 0) {
                    const keysToSelect = data
                        .filter(item => selectedCodesFromResult.includes(item.code))
                        .map(item => item.id);

                    if (keysToSelect.length > 0) {
                        e.component.selectRows(keysToSelect, false);
                    }
                }
            }
        });
    }
