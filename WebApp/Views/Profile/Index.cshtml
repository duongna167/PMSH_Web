            "#pro_search_txtLanguageGroup", "#pro_search_txtCountryGroup", "#pro_search_txtStateGroup",
            "#pro_search_txtCurrencyGroup", "#pro_search_txtVipGroup"
        ]; 

        // --- 4. RESET CHO CONTACT (Liên hệ) ---
        const contactInputs = [
            "#pro_search_idContact", "#pro_search_txtCodeContact", "#pro_search_txtFullNameContact", "#pro_search_txtLastContact",
            "#pro_search_txtFirstNameContact", "#pro_search_txtMiddleNameContact", "#pro_search_txtPositionContact",
