        function validatePayload(p) {
            if (!p.rateCodeId || p.rateCodeId <= 0) return "Rate Code is required (select a row on the left grid or pick Rate Code).";
            if (!p.roomTypeId || p.roomTypeId <= 0) return "Room Type is required.";
            return null;
        }

