                                                    id="timeDate"
                                                    value="07:00"
                                                    class="form-control form-control-sm">
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>

                            <!-- DAILY SECTION -->
                            <div class="col-12" id="dailySection">
                                <div class="row g-2">

                                    <!-- From Date -->
                                    <div class="col-12">
                                        <div class="row g-1 align-items-center">
