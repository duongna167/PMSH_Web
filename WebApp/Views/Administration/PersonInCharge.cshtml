@{
    var report = @ViewBag.ReportHeader;
    var chargeGroup = ViewBag.PersonInChargeGroupList;
    var chargeZone = ViewBag.PersonInChargeZoneList;
}
<style>
    .ts-control {
        min-height: 38px;
        border-radius: 0.375rem;
        border: 1px solid #ced4da;
        padding: 0.375rem 0.75rem;
        font-size: 1rem;
        transition: border-color .15s ease-in-out,box-shadow .15s ease-in-out;
        max-height: 85px; /* Giới hạn khoảng 2 dòng */
        overflow-y: auto;
    }

        .ts-control .item {
            background-color: #63af90 !important;
            color: white !important;
            border-radius: 4px !important;
        }

    .ts-wrapper.focus .ts-control {
        border-color: #86b7fe;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
        outline: 0;
    }

    .ts-wrapper.is-invalid .ts-control {
        border-color: #dc3545;
        padding-right: calc(1.5em + 0.75rem);
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 12' width='12' height='12' fill='none' stroke='%23dc3545'%3e%3ccircle cx='6' cy='6' r='4.5'/%3e%3cpath stroke-linejoin='round' d='M5.8 3.6h.4L6 6.5z'/%3e%3ccircle cx='6' cy='8.2' r='.6' fill='%23dc3545' stroke='none'/%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right calc(0.375em + 0.1875rem) center;
        background-size: calc(0.75em + 0.375rem) calc(0.75em + 0.375rem);
    }

    .ts-control::-webkit-scrollbar {
        width: 6px;
    }

    .ts-control::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 4px;
    }

    .ts-control::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 4px;
    }

        .ts-control::-webkit-scrollbar-thumb:hover {
            background: #63af90 !important;
        }

    .ts-dropdown {
        border-radius: 0.375rem;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        z-index: 1056;
        margin-top: 5px !important; /* Tạo khoảng cách nhỏ với input */
        border: 1px solid #63af90 !important; /* Viền xanh đồng bộ scrollbar */
    }

    /* Tùy chỉnh nút X xóa nhanh (Clear Button) */
    .tomselect-custom .ts-control {
        padding-right: 2.5rem !important;
        margin-right: 2.5rem !important;
    }

    .tomselect-custom .clear-button {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        border-radius: 0.575rem;
        cursor: pointer;
        font-size: 1.2rem;
        color: #dc3545 !important;
        font-weight: bold;
        z-index: 10;
        transition: color 0.2s;
        line-height: 1;
        background-color: #d3e8df !important;
    }

        .tomselect-custom .clear-button:hover {
            color: #d3e8df !important;
            background-color: #dc3545 !important;
        }
</style>

<div class="text-center" style="font-size: 20px">Person In Charge</div>
<div class="sticky-header bg-white p-2 shadow-sm z-3">
    <div class="mb-2">
        <button id="btnView" class="mui-button mui-button-search"> View</button>
        <button id="btnNew" class="mui-button mui-button-new"> New</button>
        <button id="btnEdit" class="mui-button mui-button-edit">  Edit</button>
        <button id="btnDelete" class="mui-button mui-button-delete">  Delete</button>
        <button id="btnRefresh" class="mui-button mui-button-search">  Refresh</button>
    </div>
    <div class="row g-3 align-items-end">
        <div class="col-auto">
            <div class="d-flex align-items-center gap-3">
                <div class="d-flex align-items-center">
                    <label for="codeInput" class="me-2 mb-0 fw-bold">Code:</label>
                    <input type="text" id="codeInput" class="form-control form-control-sm" style="width: 100px;" />
                </div>
                <div class="d-flex align-items-center">
                    <label for="nameInput" class="me-2 mb-0 fw-bold">Name:</label>
                    <input type="text" id="nameInput" class="form-control form-control-sm" style="width: 150px;" />
                </div>
                <div class="form-check d-flex align-items-center gap-2 mb-0">
                    <input class="form-check-input" type="checkbox" id="chkshowInactive" name="chkshowInactive">
                    <label class="form-check-label mb-0 text-nowrap" for="chkshowInactive">Show Inactive</label>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="d-flex align-items-center">
                <label for="personInchargeGroupId" class="me-2 mb-0 fw-bold text-nowrap">Group:</label>
                <div class="flex-grow-1">
                    <select id="personInchargeGroupId" name="group" class="tomselect-custom" multiple>
                        @foreach (var sg in chargeGroup)
                        {
                            <option value="@sg.ID">@sg.Name</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="d-flex align-items-center">
                <label for="personInchargeZoneId" class="me-2 mb-0 fw-bold text-nowrap">Zone:</label>
                <div class="flex-grow-1">
                    <select id="personInchargeZoneId" name="zone" class="tomselect-custom" multiple>
                        @foreach (var i in chargeZone)
                        {
                            <option value="@i.ID">@i.Name</option>
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

</div>

<div class="mui-card">
    <div id="gridContainerRateCode" class="gridContainer"></div>
</div>


<div class="modal fade" id="itemModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header py-2">
                <h5 class="modal-title" id="itemModalLabel">Person In Charge</h5>
            </div>
            <!-- FOOTER -->
            <div class="modal-footer justify-content-start">
                <div>
                    <button type="button" id="btnSaveItem" class="mui-button mui-button-save">
                        Save
                    </button>
                    <button type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">
                        Close
                    </button>
                </div>
            </div>
            <!-- BODY -->
            <div class="modal-body">
                <form id="formContainer">
                    <input type="hidden" id="id" name="id" value="0" />

                    <div class="container-fluid">
                        <!-- Row 1 -->
                        <div class="row g-3 align-items-end">

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">
                                    Code 
                                </label>
                                <input type="text" id="txtcode" name="txtcode"
                                       class="form-control form-control-sm" readonly>
                                <div class="invalid-feedback"></div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    Name <span class="text-danger">*</span>
                                </label>
                                <input type="text" id="txtname" name="txtname"
                                       class="form-control form-control-sm">
                                <div class="invalid-feedback"></div>
                            </div>

                            <div class="col-md-2 d-flex align-items-center justify-content-end">
                                <div class="form-check mt-3">
                                    <input class="form-check-input" type="checkbox"
                                           id="inactive" name="inactive">
                                    <label class="form-check-label text-danger fw-semibold"
                                           for="inactive">
                                        Inactive
                                    </label>
                                </div>
                            </div>

                        </div>

                        <!-- Row 2 -->
                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Person In Charge Group</label>
                                <select id="personInChargeGroupId" name="personInChargeGroupId"
                                        class="form-control form-control-sm">
                                    <option value="">-- Select Group --</option>
                                    @foreach (var sg in chargeGroup)
                                    {
                                        <option value="@sg.ID">@sg.Name</option>
                                    }
                                </select>
                                <div class="invalid-feedback"></div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Person In Charge Zone</label>
                                <span class="text-danger">*</span>
                                <select id="personInChargeZoneId" name="personInChargeZoneId"
                                        class="form-control form-control-sm">
                                    <option value="">-- Select Zone --</option>
                                    @foreach (var sg in chargeZone)
                                    {
                                        <option value="@sg.ID">@sg.Name</option>
                                    }
                                </select>
                                <div class="invalid-feedback"></div>
                            </div>
                        </div>

                        <!-- Row 3 -->
                        <div class="row g-3 mt-1">
                            <div class="col-md-4">
                                <label class="form-label">Telephone</label>
                                <input type="text" id="txtTelePhone" name="txtTelePhone"
                                       class="form-control form-control-sm">
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Hand Phone</label>
                                <input type="text" id="txtMobilePhone" name="txtMobilePhone"
                                       class="form-control form-control-sm">
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Email</label>
                                <input type="text" id="txtEmail" name="txtEmail"
                                       class="form-control form-control-sm">
                            </div>
                        </div>

                        <!-- Row 4 -->
                        <div class="row mt-2">
                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <textarea id="txtdescription" name="txtdescription"
                                          class="form-control" rows="3"></textarea>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>


<div id="loadingSpinnerRateCode" style="display: none; text-align: center; padding: 20px;">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
</div>

<script>
    DevExpress.localization.locale("vi");
    var selectedRowData = null;

    $(document).ready(function () {
        $("#btnView").trigger("click");

        $(".tomselect-custom").on("change", function() {
        const val = $(this).val();
        const wrapper = $(this).next(".ts-wrapper");
            if (val && val.length > 0) {
                wrapper.removeClass("is-invalid");
                wrapper.parent().find(".invalid-feedback").hide();
            }
        });

        $("#formContainer").on("input change", "input, select, textarea", function () {
            if ($(this).hasClass("is-invalid")) {
                $(this).removeClass("is-invalid");
                $(this).next(".invalid-feedback").text("");
            }
        });

        $('#itemModal').on('hidden.bs.modal', function () {
             applyValidationErrors([], "#formContainer");
             $(".ts-wrapper").removeClass("is-invalid");
             $(".invalid-feedback").hide();
        });

        initializeTomSelects();

        $("#btnRefresh").click(function() {
            const ids = ['#personInchargeGroupId', '#personInchargeZoneId'];
            ids.forEach(id => {
                const ts = document.querySelector(id).tomselect;
                if(ts) ts.clear();
            });
            $("#codeInput").val("");
            $("#nameInput").val("");
            $("#chkshowInactive").prop("checked", false);

             $("#btnView").trigger("click");
        });
    });


    function generatePicCode(lastCode) {
        let next = parseInt(lastCode || "0", 10) + 1;
        return next.toString().padStart(6, '0');
    }

    function initializeTomSelects() {
        const selectors = ["#personInchargeGroupId", "#personInchargeZoneId"];
        selectors.forEach(selector => {
            const el = document.querySelector(selector);
            if (el) {
                 if (el.tomselect) el.tomselect.destroy();
                    new TomSelect(el, {
                        plugins: {
                        'remove_button': { title: 'Deselect' },
                        'dropdown_input': {},
                        'clear_button': { title: 'Clear all' },
                    },
                    dropdownParent: 'body',
                    create: false,
                    maxItems: null,
                    valueField: 'value',
                    labelField: 'text',
                    searchField: ['text'],
                    placeholder: ' Enter or select options...',
                    onClear: function() {
                    const self = this;
                    setTimeout(() => {
                        self.close();
                        self.blur();
                    }, 10);
                },
                    render: {
                        option: function(data, escape) {
                            return `<div class="p-2"> ${escape(data.text)} </div>`;
                        },
                        item: function(data, escape) {
                            return '<div title="' + escape(data.text) + '">' + escape(data.text) + '</div>';
                        }
                    }

                });
            }
        });
    }

    $("#btnNew").click(function () {
        $("#formContainer")[0].reset();
        $("#id").val("0");

        $(".ts-wrapper").removeClass("is-invalid");
        $(".invalid-feedback").hide();

        $("#itemModalLabel").text("New Person In Charge");
        $("#itemModal").modal("show");
    });

    function loadGrid(data) {
        var listGroupCharge = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.PersonInChargeGroupList ?? new List<object>()));
        $("#gridContainerRateCode").dxDataGrid({
            dataSource: data,
            height: 500,
            width: "100%",
            allowColumnResizing: true,
            columnResizingMode: "widget",
            // selection: { mode: "multiple" ,showCheckBoxesMode: "always",selectAllMode: "page"},
            selection: { mode: "single" },
            hoverStateEnabled: true,
            columnAutoWidth: false,
            columns: [
            { dataField: "id", caption: "ID", visible: false },
            { dataField: "code", caption: "Code", width: "5%" },
            { dataField: "name", caption: "Name", width: "10%" },
            { dataField: "telePhone", caption: "Phone", width: "9%" },
            { dataField: "mobile", caption: "Mobile", width: "9%" },
            { dataField: "email", caption: "Email", width: "9%" },
            {
                dataField: "groupID",
                caption: "Group",
                width: "7%",
                lookup: {
                    dataSource: listGroupCharge,
                    valueExpr: "ID",
                    displayExpr: "Code"
                }
            },
            { dataField: "zoneID", caption: "Zone", groupIndex: 0, visible: false },
            { dataField: "description", caption: "Description", width: "15%" },
            { dataField: "updatedBy", caption: "Updated By", width: "5%",},
            { dataField: "updatedDate", caption: "Updated Date", dataType: "date", format: "dd/MM/yyyy", width: "12%" },
            { dataField: "createdBy", caption: "Created By", width: "5%" },
            { dataField: "createdDate", caption: "Created Date", dataType: "date", format: "dd/MM/yyyy", width: "12%" },
            { dataField: "inactive", caption: "Inactive", width: "5%" },
        ],
            filterRow: { visible: true, applyFilter: "auto" },
            paging: { pageSize: 20 },
            pager: {
                visible: true,
                allowedPageSizes: [20, 50, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            scrolling: { mode: "standard", showScrollbar: "always" },
              onSelectionChanged: function(e){
                  selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
            }
        });
    }

    $(document).off("click", "#btnView").on("click", "#btnView", function () {
          $("#loadingSpinnerRateCode").show();
          var groupIdSearch = $("#personInchargeGroupId").val();
          var zoneIdSearch = $("#personInchargeZoneId").val();

          var groupIdString = (groupIdSearch && groupIdSearch.length > 0) ? groupIdSearch.join(",") : "";
          var zoneIdString = (zoneIdSearch && zoneIdSearch.length > 0) ? zoneIdSearch.join(",") : "";

          $.ajax({
              url: "/Administration/GetPersonInCharge",
              type: "GET",
              cache: false,
              data: {

                  code: $("#codeInput").val() || "",
                  name: $("#nameInput").val() || "",
                  group: groupIdString,
                  zone:zoneIdString,
                  isActive: $("#chkshowInactive").prop("checked") ? 1 : 0
              },
              crossDomain: false,
              headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
              success: function(data){
                  loadGrid(data);
                  $("#loadingSpinnerRateCode").hide();
              },
              error: function(xhr, status, error){
                 showToast("Error", "Unable to load data", false);
                 $("#loadingSpinnerRateCode").hide();
              }
             });
    });

    function editMember(data) {
        $("#id").val(data.id);
        $("#txtcode").val(data.code);
        $("#txtname").val(data.name);
        $("#txtdescription").val(data.description);
        $("#txtEmail").val(data.email);
        $("#txtTelePhone").val(data.telephone);
        $("#txtMobilePhone").val(data.mobile);
        $("#inactive").prop("checked", data.inactive);

        $("#personInChargeGroupId").val(data.groupID);
        $("#personInChargeZoneId").val(data.zoneID);

        $("#itemModalLabel").text("Update Person In Charge");
        $("#itemModal").modal("show");
    }

    $("#btnEdit").on("click", function () {
        if (!selectedRowData) {
            showToast("Warning","Please select a row first!", true);
            return;
        }
        editMember(selectedRowData);
    });

    $("#btnSaveItem").click(function () {

        const id = parseInt($("#id").val()) || 0;
        let loginName = (localStorage.getItem("Loginname") || "")
            .trim()
            .replace(/^"(.*)"$/, '$1');
        const loginUser = parseInt(localStorage.getItem("userID")) || 0;
        const model = {
              ID: id,
              Code: $("#txtcode").val(),
              Name: $("#txtname").val(),
              Description: $("#txtdescription").val(),
              PersonInChargeGroupID: parseInt($("#personInChargeGroupId").val()) || 0,
              PersonInChargeZoneID: parseInt($("#personInChargeZoneId").val()) || 0,
              Email: $("#txtEmail").val(),
              TelePhone: $("#txtTelePhone").val(),
              MobilePhone: $("#txtMobilePhone").val(),
              Inactive: $("#inactive").prop("checked"),
              CreatedBy: loginName,
              UpdatedBy: loginName
        };

        $.ajax({
            url: "/Administration/PersonInChargeSave",
            type: "POST",
            contentType: "application/json",
            cache: false,
            data: JSON.stringify(model),
            traditional: true,
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (res) {
                if (res.success) {
                    showToast("Success", res.message, true);
                    $("#itemModal").modal("hide");
                    $("#btnView").trigger("click");
                } else {
                    if (res.errors && res.errors.length > 0) {
                        applyValidationErrors(res.errors, "#formContainer");
                        let generalError = res.errors.find(x => x.field === "general");
                        let toastMessage = generalError ? generalError.message : "Please check input fields.";

                        showToast("Warning", toastMessage, false);
                    } else {
                        showToast("Error", res.message || "Save failed", false);
                    }
                }
            },
            error: function (xhr) {
                showToast("Error", "Request error!", false);
                $("#itemModal").modal("hide");
            }
        });
    });

    $("#btnDelete").click(function () {
           if (!selectedRowData || selectedRowData.id === 0) {
               showToast('Warning', "Select 1 row, please!", true);

               return;
           }
           if (!confirm("Are you sure you want to delete this record? This action cannot be undone.")) {
                return;
            }
           $.ajax({
               url: `/Administration/DeletePersonInCharge/`+ selectedRowData.id,
               type: "POST",
               traditional: true,
               crossDomain: false,
               headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
               success: function(result){
                    if(result.success){
                        $("#btnView").trigger("click");
                        showToast("Success","Delete Successfully!",true);
                    } else {
                        showToast("Error",result.message,false);
                    }
               },
               error: function(){
                   console.log("delete "+ selectedRowData.id);
                    showToast("Error","Delete failed!" ,false);
                    $("#loadingSpinner").hide();
               },
           });
       });

</script>
