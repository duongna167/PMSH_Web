<div class="modal fade modal-xl" id="op_changes_modal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
     aria-labelledby="op_changes_staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-full-height">

            <div class="modal-header">
                <h5 class="modal-title" id="op_changes_staticBackdropLabel">User Activity Log Profile</h5>
            </div>

            <div class="modal-body d-flex flex-column" style="height: calc(100vh - 120px);">

                <div class="py-2 flex-shrink-0">
                    <button class="mui-button mui-button-new" id="op_changes_btnPrintGrid"> Print</button>
                    <button class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>

                <div class="mui-card mt-2 d-flex flex-column flex-grow-1 overflow-hidden">
                    <div id="op_changes_gridContainerSearchChanges" class="mt-2 gridContainer flex-grow-1 h-100"></div>
                </div>

            </div>

        </div>
    </div>
</div>

<script>
    var op_changes_Module = {
        profileID: 0,

        init: function (profileID) {
            this.profileID = profileID || 0;
            this.initDOMEvents();
            this.loadData();
        },

        initDOMEvents: function () {
            const self = this;

            $("#op_changes_btnPrintGrid").off("click").on("click", function () {
                self.printGrid();
            });
        },

        loadData: function () {
            const self = this;
            let showActive = $('#showActive').is(':checked') ? '0' : ''; 

            $.ajax({
                url: '/Profile/SearchProfileChanges',
                type: 'GET',
                loadingGrid: '#op_changes_gridContainerSearchChanges',
                data: {
                    profileID: self.profileID,
                },
                success: function (data) {
                    self.renderGrid(data);
                },
                error: function () {
                    alert('Error retrieving Changes data.');
                }
            });
        },

        renderGrid: function (data) {
            $("#op_changes_gridContainerSearchChanges").dxDataGrid({
                dataSource: data,
                height: "100%",
                width: "100%",

                allowColumnResizing: true,
                columnAutoWidth: false,

                scrolling: {
                    mode: "standard",
                    rowRenderingMode: "virtual",
                    columnRenderingMode: "virtual",
                    showScrollbar: "always",
                    useNative: false
                },

                columns: [
                    {
                        dataField: "userName",
                        caption: "User",
                        width: 80
                    },
                    {
                        dataField: "time",
                        caption: "Time",
                        width: 70,
                        alignment: "center"
                    },
                    {
                        dataField: "date",
                        caption: "Date",
                        dataType: "date",
                        format: "dd/MM/yyyy",
                        width: 100
                    },
                    {
                        dataField: "change",
                        caption: "Change",
                        width: 100
                    },
                    {
                        dataField: "oldValue",
                        caption: "Old Value",
                        width: 220
                    },
                    {
                        dataField: "newValue",
                        caption: "New Value",
                        width: 220
                    },
                    {
                        dataField: "description",
                        caption: "Description",
                        minWidth: 300
                    }
                ],

                paging: { pageSize: 15 },
                wordWrapEnabled: true,
                pager: {
                    visible: true,
                    allowedPageSizes: [15, 20, 'all'],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true,
                },

                selection: {
                    mode: "multiple",
                    showCheckBoxesMode: "none"
                },

                showBorders: false,

                onRowClick: function (e) {
                    // optional
                }
            });
        },

        printGrid: function () {
            var container = document.getElementById("op_changes_gridContainerSearchChanges");
            if (!container) return;

            var clone = container.cloneNode(true);

            clone.style.height = "auto !important";
            clone.style.maxHeight = "none !important";
            clone.style.overflow = "visible !important";

            var tables = clone.querySelectorAll("table");
            tables.forEach(function (table) {
                table.style.height = "auto !important";
                table.style.maxHeight = "none !important";
            });

            var scrollableDivs = clone.querySelectorAll("div[style*='overflow'], div.scrollable, div.k-grid-content");
            scrollableDivs.forEach(function (div) {
                div.style.height = "auto !important";
                div.style.maxHeight = "none !important";
                div.style.overflow = "visible !important";
            });

            var gridHtml = clone.outerHTML;

            var printWindow = window.open("", "", "width=1200,height=800");
            var doc = printWindow.document;
            doc.open();

            var html = doc.createElement("html");
            var head = doc.createElement("head");
            var title = doc.createElement("title");
            title.innerText = "Changes";
            head.appendChild(title);

            var links = document.querySelectorAll("link[rel='stylesheet']");
            links.forEach(function (link) {
                if (link.href) {
                    var newLink = doc.createElement("link");
                    newLink.rel = "stylesheet";
                    newLink.href = link.href;
                    head.appendChild(newLink);
                }
            });

            var styles = document.querySelectorAll("style");
            var allStyles = "";
            styles.forEach(function (s) {
                allStyles += s.innerHTML + "\n";
            });

            allStyles += `
                <style type="text/css">
                    body {
                        font-family: Arial, sans-serif;
                        margin: 15mm;
                        print-color-adjust: exact;
                        -webkit-print-color-adjust: exact;
                    }
                    #logGridReportContainer,
                    table, div, .k-grid, .k-grid-content {
                        height: auto !important;
                        max-height: none !important;
                        overflow: visible !important;
                    }
                    table {
                        width: 100% !important;
                        border-collapse: collapse;
                        page-break-inside: auto;
                    }
                    tr {
                        page-break-inside: avoid;
                        page-break-after: auto;
                    }
                    th, td {
                        border: 1px solid #000 !important;
                        padding: 6px !important;
                        font-size: 12px !important;
                        text-align: left;
                    }
                    @@media print {
                        body { margin: 10mm; }
                        .no-print { display: none !important; }
                        @@page { margin: 10mm; }
                    }
                </style>
            `;

            var styleTag = doc.createElement("style");
            styleTag.innerHTML = allStyles;
            head.appendChild(styleTag);

            html.appendChild(head);

            var body = doc.createElement("body");
            body.innerHTML = gridHtml;
            html.appendChild(body);

            doc.write(html.outerHTML);
            doc.close();

            printWindow.onload = function () {
                printWindow.focus();
                printWindow.print();
                // printWindow.close();
            };
        }
    };

    // Hàm Global để gọi mở Modal (truyền ID của profile vào đây)
    window.openOpChangesModal = function (profileID) {
        if (window.op_changes_Module) {
            window.op_changes_Module.init(profileID);
        }
    };
    
</script>
