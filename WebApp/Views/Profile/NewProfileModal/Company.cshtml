<script>
    var pro_com_Module = {
        currentType: 1, // Mặc định là 1 (Company)

        init: function (type) {
            if (type) this.currentType = type; // Cập nhật type dựa trên nút vừa bấm

            this.updateModalTitle();
            this.initDOMEvents();
            this.initTomSelects();
        },

        updateModalTitle: function() {
            let title = "Profile - Company";
            if (this.currentType === 2) title = "Profile - Travel Agent";
            if (this.currentType === 3) title = "Profile - Source";

            $("#modalCompany .modal-title").text(title);
        },

        initDOMEvents: function () {
            const self = this;
            $('#com_btnSave').off('click').on('click', function () {
                self.saveProfile();
            });
            $('#com_btnClear').off('click').on('click', function () {
                self.clearForm();
            });
        },

        getFormData: function () {
            const getTS = (id) => {
                const ts = getTomSelect(id);
                return ts ? ts.getValue() : 0;
            };

            const data = {
                ID: parseInt($("#com_id").val()) || 0,
                // QUAN TRỌNG: Gửi type tương ứng về Backend
                Type: this.currentType,
                Code: $("#com_txtCode").val()?.trim(),
                Account: $("#com_txtAccount").val()?.trim(),
                Address: $("#com_txtAddress").val()?.trim(),
                City: getTS("#com_txtCity"),
                CountryID: parseInt(getTS("#com_txtCountry")),
                StateID: parseInt(getTS("#com_txtState")),
                Company: $("#com_txtCompany").val()?.trim(),
                TaxCode: $("#com_txtTax").val()?.trim(),
                HomeAddress: $("#com_txtBusAddress").val()?.trim(),
                Telephone: $("#com_txtTelephone").val()?.trim(),
                Email: $("#com_txtEmail").val()?.trim(),
                Website: $("#com_txtWebsite").val()?.trim(),
                BusinessTitle: $("#com_txtBusTitle").val()?.trim(),
                Active: $("#com_chkActive").is(":checked"),
                Description: $("#com_txtNote").val()?.trim()
            };

            return data;
        },

        clearForm: function () {
            const $container = $("#pro_com_formContainer");
            // Reset tất cả input text, hidden, email và textarea
            $container.find('input[type="text"], input[type="hidden"], input[type="email"], textarea').val('');

            // Reset Checkbox
            $("#com_chkActive").prop("checked", true);
            $("#com_chkBlackList").prop("checked", false);
            $("#com_txtBlackListReason").prop("disabled", true);

            // Reset TomSelect
            const tsIds = [
                "#com_txtCity", "#com_txtCountry", "#com_txtState",
                "#com_txtOwner", "#com_txtTerritory", "#com_txtCompanyType",
                "#com_txtCurrency", "#com_txtSaleInCharge", "#com_txtMarketType", "#com_txtMarket"
            ];
            tsIds.forEach(id => {
                const ts = getTomSelect(id);
                if (ts) ts.clear();
            });

            // Xóa báo lỗi validation
            if (window.ValidationAdapter) {
                ValidationAdapter.clear("#pro_com_formContainer");
            }
        },

        saveProfile: function () {
            const self = this;
            const data = self.getFormData();
            LoadingGlobal.show();

            $.ajax({
                url: '/Profile/SaveProfile',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {
                    LoadingGlobal.hide();
                    if (res.success) {
                        showToast("Success", res.message || 'Profile saved successfully!', true);
                        setTimeout(() => { $('#modalCompany').modal('hide'); }, 1000);
                    } else {
                        if (res.errors && res.errors.length > 0) {
                            ValidationAdapter.apply(res.errors, "#pro_com_formContainer");
                            showToast("Error", 'Please check the highlighted fields.', false);
                        } else {
                            showToast("Error", res.message || 'An error occurred', false);
                        }
                    }
                },
                error: function (xhr) {
                    LoadingGlobal.hide();
                    showToast("Error", 'Internal Server Error. Please try again.', false);
                }
            });
        },

        initTomSelects: function () {
            const self = this;

            initTomSelect('.tomselect-custom');

            LoadingGlobal.show();

            const mapCode = (item) => ({
                value: item.id || item.ID,
                text: (item.code || item.Code) + " - " + (item.name || item.Name),
                data: item
            });

            const loadTasks = [
                loadDataToTomSelect("#com_txtCity", "/Profile/GetAllCity", mapCode),
                loadDataToTomSelect("#com_txtCountry", "/Profile/GetAllCountry", mapCode),
                loadDataToTomSelect("#com_txtOwner", "/Profile/GetAllOwner", mapCode),
                loadDataToTomSelect("#com_txtCurrency", "/Profile/GetAllCurrency", mapCode),
                loadDataToTomSelect("#com_txtCompanyType", "/Profile/GetAllAccountType", mapCode),
                loadDataToTomSelect("#com_txtSaleInCharge", "/Profile/GetAllOwner", mapCode), // Dùng chung bảng Owner
                loadDataToTomSelect("#com_txtMarketType", "/Profile/GetAllMarketType", mapCode),
                loadDataToTomSelect("#com_txtMarket", "/Profile/GetAllMarket", mapCode),
                loadDataToTomSelect("#com_txtProfileType", "/Profile/GetAllProfileType", mapCode),

                loadDataToTomSelect("#com_txtState", "/Profile/GetAllState", (item) => {
                    const zip = item.zipCode || item.ZipCode || "";
                    const name = item.stateName || item.StateName || "";
                    return {
                        value: item.id || item.ID,
                        text: (zip && name) ? `${zip} - ${name}` : (zip || name || "Unknown"),
                        data: item
                    };
                })
            ];

            Promise.all(loadTasks).finally(() => {
                LoadingGlobal.hide();

                const tsProfileType = getTomSelect("#com_txtProfileType");
                if (tsProfileType) {
                    tsProfileType.setValue(self.currentType);
                }
            });
        },
    };

    $(document).ready(function () {
        pro_com_Module.init();
    });
</script>

