            $("#pro_search_txtCheckboxDobContact").prop("checked", true); 
            $("#pro_search_txtDobContact").prop("disabled", true);
        }

        if ($("#pro_search_txtActiveIndividual").length) $("#pro_search_txtActiveIndividual").prop("checked", true);
        if ($("#pro_search_txtActiveContact").length) $("#pro_search_txtActiveContact").prop("checked", true);

        // Reload lại ngày tháng nghiệp vụ nếu có hàm hỗ trợ
        if (typeof reloadBusinessDate === "function") {
            reloadBusinessDate();
        } 
    }

