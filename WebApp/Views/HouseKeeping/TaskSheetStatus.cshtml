@using DevExpress.XtraReports.UI

@{
    ViewBag.Title = ViewBag.ReportHeader;
    var listatt = ViewBag.hkpAttendantList;
    var zoneList = ViewBag.ZoneList;
}

<div class="modal fade" id="tss_modal" tabindex="-1" aria-labelledby="tss_modalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-4by3">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tss_modalLabel">Task Sheet Status</h5>
            </div>
            <div class="modal-body">
                <div class="search-filter" id="tss_filterForm">
                    <div>
                        <button id="tss_btnView" class="mui-button mui-button-new"
                            onclick="tss_Module.search()">View</button>
                        <button id="tss_btnRefesh" class="mui-button mui-button-new"
                            onclick="tss_Module.refresh()">Refesh</button>
                        <button id="tss_Report" class="mui-button mui-button-new" type="button">Report</button>
                        <button id="tss_btnExportExcel" class="mui-button mui-button-new" type="button">Excel</button>
                        <button class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                    </div>
                    <div class="mt-1">
                        <div class="row g-2 mt-1 align-items-center">
                            <div class="col-12 col-sm-6 col-md-3 col-lg-2 col-xl-2">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 text-md-end mb-0 text-nowrap">From</label>
                                    <div class="col-8">
                                        <div class="clearable" data-date-input data-format="DD/MM/YYYY" business-date
                                            data-name="tss_fromDate">
                                            <input type="text" id="tss_display_fromDate"
                                                class="date-ui form-control form-control-sm clearable"
                                                placeholder="dd/mm/yyyy" autocomplete="off" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-sm-6 col-md-3 col-lg-2 col-xl-2">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 text-md-end mb-0 text-nowrap">To</label>
                                    <div class="col-8">
                                        <div class="clearable" data-date-input data-format="DD/MM/YYYY" business-date
                                            data-name="tss_toDate">
                                            <input type="text" id="tss_display_toDate"
                                                class="date-ui form-control form-control-sm clearable"
                                                placeholder="dd/mm/yyyy" autocomplete="off" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-sm-12 col-md-6 col-lg-3 col-xl-3">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 text-md-end mb-0 text-nowrap">Attendant</label>
                                    <div class="col-8">
                                        <select id="tss_attendant" name="tss_attendant" class="tomselect-custom"
                                            multiple>
                                            @foreach (var item in listatt)
                                            {
                                                <option value="@item.ID">@item.Name</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-sm-6 col-md-3 col-lg-2 col-xl-2">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 text-md-end mb-0 text-nowrap">Room</label>
                                    <div class="col-8">
                                        <input type="text" id="tss_room" name="tss_room"
                                            class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-sm-6 col-md-3 col-lg-3 col-xl-3">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 text-md-end mb-0 text-nowrap">Zone</label>
                                    <div class="col-8">
                                        <select id="tss_zone" name="tss_zone" class="tomselect-custom" multiple>
                                            @foreach (var item in zoneList)
                                            {
                                                <option value="@item.Code">@item.Code</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mui-card">
                    <div id="tss_gridContainer" class="gridContainer mt-2"></div>
                </div>

                <div id="tss_loadingSpinner"
                    style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:1000;">
                    <i class="fa-solid fa-spinner fa-spin fa-2x"></i>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="tss_report" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">

        <div class="modal-content">

            <!-- Modal Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="attendantPointTitle">Report</h5>

            </div>

            <!-- Modal Body -->
            <div class="modal-body">

                <!-- Action buttons -->
                <div class="d-flex justify-content-start mb-3 gap-2">
                    <button id="tss_btnExportpopExcel" class="mui-button mui-button-new" type="button">
                        Excel
                    </button>

                    <button id="tss_closeReport" class="mui-button mui-button-new" data-bs-dismiss="modal">
                        Close
                    </button>
                </div>

                <!-- Grid container -->
                <div id="logGridContainer" class="gridContainer mt-2">
                    <!-- Grid render here -->
                </div>

            </div>
        </div>
    </div>
</div>



<script>

    var tss_Module = { 
        gridInstance: null,

        init: function () {
            this.search(); // Khởi tạo bảng trống trước
            initTomSelect('.tomselect-custom');
            this.bindEvents();
        },

        getFilters: function () {
            return {
                fromDate: $("#tss_fromDate").val() || dateSystem,
                toDate: $("#tss_toDate").val() || dateSystem,
                attendant: $("#tss_attendant").val(),
                room: $("#tss_room").val(),
                zone: $("#tss_zone").val(),
            };
        },

        refresh: function () {
            $("#tss_attendant").val("");
            $("#tss_zone").val("");
            $("#tss_room").val("");
            reloadBusinessDate();
            // Gọi lại hàm khởi tạo ngày của DateInput nếu cần
            this.search();
        },

        search: function () {
            const filters = this.getFilters();
            const self = this; // Gán self để dùng bên trong AJAX

            $("#loadingSpinner").show();

            $.ajax({
                url: '/HouseKeeping/TaskSheetStatusData',
                type: 'GET',
                data: filters, // Truyền trực tiếp filters, không cần bọc { filters } nếu backend nhận trực tiếp
                traditional: true,
                success: function (result) {
                    console.log(result);
                    // SỬA LỖI Ở ĐÂY: Dùng self thay vì this
                    self.initializeTaskSheetStatusGrid(result);

                    // Kiểm tra nếu có container cho PopGrid thì mới init
                    if ($("#logGridContainer").length > 0) {
                        self.initializeTaskSheetStatusPopGrid(result);
                    }

                    $("#loadingSpinner").hide();
                },
                error: function (xhr) {
                    console.error(xhr);
                    alert("Không thể tải báo cáo.");
                    $("#loadingSpinner").hide();
                }
            });
        },

        initializeTaskSheetStatusGrid: function (data) {

            $("#tss_gridContainer").dxDataGrid({
                dataSource: data,
                allowColumnResizing: true,
                columnAutoWidth: true,
                height: "100%",

                groupPanel: {
                    visible: true   // hiển thị khu vực group phía trên
                },

                grouping: {
                    autoExpandAll: true   // tự động expand group
                },

                columns: [
                    { dataField: "colIndex", caption: "No", width: 50 },

                    { dataField: "roomNo", caption: "RoomNo" },

                    { dataField: "hkstatusID", caption: "Room Status" },

                    { dataField: "fostatus", caption: "FOStatus" },

                    {
                        dataField: "attendant",
                        caption: "Attendant",
                        groupIndex: 0   // 🔥 GROUP THEO ATTENDANT
                    },

                    {
                        dataField: "taskDate",
                        caption: "Task Date",
                        dataType: "date",
                        format: "dd/MM/yyyy"
                    },

                    { dataField: "complete", caption: "Status" }
                ],

                onCellPrepared: function (e) {

                    if (e.rowType === "data" && e.column.dataField === "hkstatusID") {

                        const status = (e.value || "").toLowerCase();

                        if (status.includes("dirty")) {
                            e.cellElement.css({
                                "background-color": "red",
                                "color": "white"
                            });
                        }
                        else if (status.includes("clean")) {
                            e.cellElement.css({
                                "background-color": "green",
                                "color": "white"
                            });
                        }
                    }
                }
            });
        },


        initializeTaskSheetStatusPopGrid: function (data) {
            // Tương tự, dùng ID chuẩn logGridContainer
            $("#logGridContainer").dxDataGrid({
                dataSource: data,
                // ... Cấu hình PopGrid của bạn
            });
        },
        bindEvents: function () {
            const self = this;

            // Dùng .off().on() để tránh trùng lặp sự kiện khi init lại
            $("#tss_Report").off("click").on("click", function () {
                $('#tss_report').modal("show");
            });

            $('#tss_closeReport').off("click").on("click", function () {
                $('#tss_report').modal("hide");
            });

            // Sửa lỗi ID gridContainer tại đây
            $("#tss_btnExportExcel").off("click").on("click", function () {
                const grid = $("#tss_gridContainer").dxDataGrid("instance");
                if (!grid) {
                    showToast("Error","The data is not yet available.",false);
                    return;
                }
                self.exportToExcel(grid, 'Task Sheet Status Group');
            });

            $("#tss_btnExportpopExcel").off("click").on("click", function () {
                const grid = $("#logGridContainer").dxDataGrid("instance");
                if (!grid) {
                    showToast("Error","The data report is not yet available.",false);
                    return;
                }
                self.exportToExcel(grid, 'Task Sheet Status Report');
            });
        },

        // Tách hàm Export dùng chung để code gọn hơn
        exportToExcel: function (gridInstance, reportName) {
            const workbook = new ExcelJS.Workbook();
            const worksheet = workbook.addWorksheet("Sheet 1");

            // Header Công ty
            worksheet.addRow(['Công ty Cổ phần Giải pháp Công nghệ CS-Solution']);
            worksheet.mergeCells('A1:E1');
            worksheet.getRow(1).font = { bold: true };

            // Tên báo cáo
            const reportRow = worksheet.addRow(['', '', reportName]);
            worksheet.mergeCells('C5:F5');
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { horizontal: 'center' };

            DevExpress.excelExporter.exportDataGrid({
                component: gridInstance,
                worksheet: worksheet,
                topLeftCell: { row: 7, column: 1 }
            }).then(() => {
                workbook.xlsx.writeBuffer().then((buffer) => {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), reportName + ".xlsx");
                });
            });
        }
    }
    // Hàm global để ModalManager gọi sau khi hiện modal
    window.openModalTaskSheetStatus = function () {
        tss_Module.init();
    };

    // Tự dọn dẹp biến khi Modal đóng để tránh rò rỉ bộ nhớ
    $("#tss_modal").on("hidden.bs.modal", function () {
        if (tss_Module.tsAttendant) tss_Module.tsAttendant.destroy();
        if (tss_Module.tsZone) tss_Module.tsZone.destroy();
    });



</script>
