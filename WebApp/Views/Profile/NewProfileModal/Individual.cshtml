<script>
    var pro_ind_Module = {

        init: function () {
            this.initDOMEvents();
            this.bindNameEngine();
            this.initStateControls();
            this.initTomSelects();
        },

        initDOMEvents: function () {
            const self = this;

            $('#ind_btnSearch').on('click', function() {
                self.openModalSearch();
            });

            $('#ind_btnSave').on('click', function() {self.saveProfile();});

            $('#ind_btnClear').on('click', function() {self.clearForm();});

            $('#ind_fileUpload').on('change', this.handleImage);

            $('#ind_search_name, #ind_search_first').on('keydown', function (e) {

                if (e.key === "Enter") {
                    pro_ind_Module.searchIndividual();
                }

            });
        },

        handleImage: function (event) {

            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();

            reader.onload = (e) => {
                $('#ind_imgPreview').attr('src', e.target.result);
            };

            reader.readAsDataURL(file);
        },

        initTomSelects: function () {
            const self = this;

            initTomSelect('.tomselect-custom');

            const mapCode = (item) => ({
                value: item.id || item.ID,
                text: (item.code || item.Code) + "-" + (item.name || item.Name),
                data: item
            });

            const loadTasks = [
                loadDataToTomSelect("#ind_txtLanguage", "/Profile/GetAllLanguage", mapCode),
                loadDataToTomSelect("#ind_txtTitle", "/Profile/GetAllTitle",(item) => {
                    return {
                        value: item.id || item.ID,
                        text: item.Code || item.code,
                        data: item
                    };
                }),
                loadDataToTomSelect("#ind_txtNationality", "/Profile/GetAllNationality", mapCode),
                loadDataToTomSelect("#ind_txtCountry", "/Profile/GetAllCountry", mapCode),
                loadDataToTomSelect("#ind_txtCity", "/Profile/GetAllCity", mapCode),
                loadDataToTomSelect("#ind_txtState", "/Profile/GetAllState", (item) => {
                    const zip = item.zipCode || item.ZipCode || "";

                    const name = item.stateName || item.StateName || "";

                    return {
                        value: item.id || item.ID,
                        text: (zip && name) ? `${zip} - ${name}` : (zip || name || "Unknown"),
                        data: item
                    };
                }),
                loadDataToTomSelect("#ind_txtVIP", "/Profile/GetAllVIP", mapCode)
            ];

            Promise.all(loadTasks)
        },

        bindNameEngine: function () {
            const self = this;
            const $full = $("#ind_txtFullName");
            const $salutation = $("#ind_txtSalutation");

            function processNameParsing() {
                let nameVal = $full.val();
                if (!nameVal) return;

                let p = GuestNameEngine.parseFullName(nameVal);
                console.log("Parsed Name:", p);

                $("#ind_txtFirstName").val(p.first).trigger("input");
                $("#ind_txtMiddleName").val(p.middle).trigger("input");
                $("#ind_txtLastName").val(p.last).trigger("input");

                let resultSalutation = GuestNameEngine.buildSalutation(p.first, p.last);
                $salutation.val(resultSalutation);
            }

            $full.on("blur", processNameParsing);

            $full.on("keydown", function(e) {
                if (e.which === 13) {
                    e.preventDefault();
                    processNameParsing();

                    $("#ind_txtFirstName").focus();
                }
            });

            $("#ind_txtTitle").on("change", function() {
                const lastName = $("#ind_txtLastName").val();

                const ts = getTomSelect("#ind_txtTitle");
                if (!ts) return;

                const val = ts.getValue();

                const titleText = val ? ts.options[val]?.text : "";

                if (lastName && titleText && titleText !== "Enter or select...") {
                    $salutation.val("Dear " + titleText + " " + GuestNameEngine.smartCapitalize(lastName));
                } else if (lastName) {
                    $salutation.val("Dear " + GuestNameEngine.smartCapitalize(lastName));
                }
            });
        },

        initStateControls: function () {
            const self = this;
            const $dobCheckbox = $("#ind_chkActiveDob");
            const $dobWrapper = $('[data-name="ind_txtDob"]');
            const $dobInput = $dobWrapper.find('input.date-ui');

            const $blackCheckbox = $("#ind_chkBlackList");
            const $blackInput = $("#ind_txtBlackListReason");

            function updateDOB() {
                const isChecked = $dobCheckbox.is(":checked");
                $dobInput.prop("disabled", !isChecked);

                if (!isChecked) {
                    $dobWrapper.addClass("opacity-50");
                } else {
                    $dobWrapper.removeClass("opacity-50");
                }
            }

            function updateBlackList() {
                const isChecked = $blackCheckbox.is(":checked");
                if (isChecked) {
                    $blackInput.addClass("black-active").prop("disabled", false).focus();
                } else {
                    $blackInput.removeClass("black-active").prop("disabled", true).val('');
                }
            }

            $dobCheckbox.on("change", updateDOB);
            $blackCheckbox.on("change", updateBlackList);

            updateDOB();
            updateBlackList();
        },

        getFormData: function () {

            const getTS = (id) => {
                const ts = getTomSelect(id);
                return ts ? ts.getValue() : 0;
            };
            const loginName = (localStorage.getItem("Loginname") || "")
            .trim()
            .replace(/^"(.*)"$/, '$1');
            const loginUser = parseInt(localStorage.getItem("userID")) || 0;
            const defaultDate = "1900-01-01";

            const data = {
                // --- Định danh ---
                ID: parseInt($("#ind_id").val()) || 0,
                Type: 0,

                Code: $("#ind_txtCode").val()?.trim(),
                Account: $("#ind_txtFullName").val()?.trim(),
                Firstname: $("#ind_txtFirstName").val()?.trim(),
                LastName: $("#ind_txtLastName").val()?.trim(),
                MiddleName: $("#ind_txtMiddleName").val()?.trim(),

                LanguageID: parseInt(getTS("#ind_txtLanguage")) || 0,
                TitleID: parseInt(getTS("#ind_txtTitle")) || 0,
                NationalityID: parseInt(getTS("#ind_txtNationality")) || 0,
                City: getTS("#ind_txtCity") || "",
                CountryID: parseInt(getTS("#ind_txtCountry")) || 0,
                PostalCode: $("#ind_txtPostal").val()?.trim(),
                StateID: parseInt(getTS("#ind_txtState")) || 0,
                Religion: $("#ind_txtReligion").val()?.trim(),
                Nation: $("#ind_txtNation").val()?.trim(),
                PurposeOfStay: $("#ind_txtPOS").val()?.trim(),
                Address: $("#ind_txtAddress").val()?.trim(),

                Salutation: $("#ind_txtSalutation").val()?.trim(),
                VIPID: parseInt(getTS("#ind_txtVIP")) || 0,
                VIPReason: $("#ind_txtVipReason").val()?.trim(),
                PrefRoom: $("#ind_txtPrefRoom").val()?.trim(),
                Other: $("#ind_txtOther").val()?.trim(),
                PassPort: $("#ind_txtPassport").val()?.trim(),
                IdentityCard: $("#ind_txtIdentityCard").val()?.trim(),

                DateOfBirth: $("#ind_chkActiveDob").is(":checked")
                ? $("input[name='ind_txtDob']").val()
                : defaultDate,

                Active: $("#ind_chkActive").is(":checked"),
                Contact: $("#ind_chkContact").is(":checked"),
                Keyword: $("#ind_txtKeyword").val()?.trim(),
                IsBlackList: $("#ind_chkBlackList").is(":checked"),
                BlackListReason: $("#ind_txtBlackListReason").val()?.trim(),

                // --- Attributes ---
                RateCode: $("#ind_txtRateCode").val()?.trim(),
                ARNo: $("#ind_txtARNo").val()?.trim(),
                MemberNo: $("#ind_txtMemberNo").val()?.trim(),

                // --- Tax & Communications ---
                Company: $("#ind_txtTaxCompany").val()?.trim(),
                TaxCode: $("#ind_txtTaxCode").val()?.trim(),
                HomeAddress: $("#ind_txtTaxBusAddress").val()?.trim(),

                Telephone: $("#ind_txtTelephone").val()?.trim(),
                HandPhone: $("#ind_txtHandPhone").val()?.trim(),
                Fax: $("#ind_txtFax").val()?.trim(),
                Email: $("#ind_txtEmail").val()?.trim(),
                Website: $("#ind_txtWebsite").val()?.trim(),
                BusinessTitle: $("#ind_txtBusinessTitle").val()?.trim(),

                // --- History ---
                LastRoom: $("#ind_txtLastRoom").val(),
                StayNo: parseInt($("#ind_txtStayCount").val()) || 0,

                Lastvisit: defaultDate,
                FirstReservation: defaultDate,
                LastReservation: defaultDate,
                WeddingAnniversary: defaultDate,
                Firstvisit: defaultDate,
                Expiry: defaultDate,
                LastContact: defaultDate,
                SpecialUpdateDate: defaultDate,

                UserInsertID: loginUser,
                UserUpdateID: loginUser
            };


            return data;
        },

        clearForm: function () {
            const self = this;
            const $container = $("#pro_ind_formContainer");

            $container.find('input[type="text"], input[type="hidden"], input[type="email"], input[type="tel"], textarea').val('');

            $("#ind_chkActive").prop("checked", true);
            $("#ind_chkContact").prop("checked", false);
            $("#ind_chkActiveDob").prop("checked", true);
            $("#ind_chkBlackList").prop("checked", false);

            const tsIds = [
                "#ind_txtLanguage", "#ind_txtTitle", "#ind_txtNationality",
                "#ind_txtCountry", "#ind_txtCity", "#ind_txtState", "#ind_txtVIP"
            ];
            tsIds.forEach(id => {
                const ts = getTomSelect(id);
                if (ts) ts.clear();
            });

            $("#ind_imgPreview").attr('src', '/images/uploads/profile.png');

            self.initStateControls();

            if (window.ValidationAdapter) {
                ValidationAdapter.clear("#pro_ind_formContainer");
            }

            $("#ind_txtCode").focus();
        },

        saveProfile: function () {
            const self = this;
            const data = self.getFormData();

            $.ajax({
                url: '/Profile/SaveProfile',
                type: 'POST',
                showLoading: true,
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {

                    if (res.success) {
                        showToast("Success",res.message || 'Profile saved successfully!', true);

                        const modalEl = document.getElementById('modalIndividual');
                        if (modalEl) {
                            const modalInstance = bootstrap.Modal.getInstance(modalEl);
                            if (modalInstance) modalInstance.hide();
                        }

                        if ($("#pro_search_btnSearch").length) {
                            $("#pro_search_btnSearch").trigger("click");
                        }
                    } else {
                        if (res.errors && res.errors.length > 0) {
                            ValidationAdapter.apply(res.errors, "#pro_ind_formContainer");

                            showToast("Error",'Please check the highlighted fields.', false);
                        } else {
                            showToast("Error",res.message || 'An error occurred', false);
                        }
                    }
                },
                error: function (xhr) {
                    showToast("Error",'Internal Server Error. Please try again.', false);
                    console.error(xhr);
                }
            });
        },

        fillFormData: function (data) {
            if (!data) return;
            const self = this;
            const $container = $("#pro_ind_formContainer");
            
            $("#ind_id").val(data.id || 0);
            $("#ind_txtCode").val(data.code || "");
            $("#ind_txtFullName").val(data.account || "");
            $("#ind_txtFirstName").val(data.firstname || "");
            $("#ind_txtLastName").val(data.lastName || "");
            $("#ind_txtMiddleName").val(data.middleName || "");
            $("#ind_txtAddress").val(data.address || "");
            $("#ind_txtPostal").val(data.postalCode || "");
            $("#ind_txtReligion").val(data.religion || "");
            $("#ind_txtNation").val(data.nation || "");
            $("#ind_txtPOS").val(data.purposeOfStay || "");

            $("#ind_txtSalutation").val(data.salutation || "");
            $("#ind_txtVipReason").val(data.vipReason || "");
            $("#ind_txtPrefRoom").val(data.prefRoom || "");
            $("#ind_txtOther").val(data.other || "");
            $("#ind_txtPassport").val(data.passPort || "");
            $("#ind_txtIdentityCard").val(data.identityCard || "");
            $("#ind_txtKeyword").val(data.keyword || "");
            $("#ind_txtBlackListReason").val(data.blackListReason || "");
            $("#ind_txtNote").val(data.description || ""); 

            $("#ind_txtTaxCompany").val(data.company || "");
            $("#ind_txtTaxCode").val(data.taxCode || "");
            $("#ind_txtTaxBusAddress").val(data.homeAddress || "");
            $("#ind_txtTelephone").val(data.telephone || "");
            $("#ind_txtHandPhone").val(data.handPhone || "");
            $("#ind_txtFax").val(data.fax || "");
            $("#ind_txtEmail").val(data.email || "");
            $("#ind_txtWebsite").val(data.website || "");
            $("#ind_txtBusinessTitle").val(data.businessTitle || "");

            $("#ind_chkActive").prop("checked", data.active === true);
            $("#ind_chkContact").prop("checked", data.contact === true);
            $("#ind_chkBlackList").prop("checked", data.isBlackList === true);

            if (data.dateOfBirth) {
                $("#ind_chkActiveDob").prop("checked", true);
                const dob = moment(data.dateOfBirth).format("DD/MM/YYYY");
                $('[data-name="ind_txtDob"] input.date-ui').val(dob);
                $("#ind_txtDob").val(data.dateOfBirth); 
            } else {
                $("#ind_chkActiveDob").prop("checked", false);
            }

            const setTS = (id, value) => {
                const ts = getTomSelect(id);
                if (ts) ts.setValue(value || 0);
            };

            setTS("#ind_txtLanguage", data.languageID);
            setTS("#ind_txtTitle", data.titleID);
            setTS("#ind_txtNationality", data.nationalityID);
            setTS("#ind_txtCountry", data.countryID);
            setTS("#ind_txtCity", data.city);
            setTS("#ind_txtState", data.stateID);
            setTS("#ind_txtVIP", data.vipID);

            self.initStateControls();

            //làm sau
            if (data.ImagePath) {
                $("#ind_imgPreview").attr('src', data.imagePath);
            } else {
                $("#ind_imgPreview").attr('src', '/images/uploads/profile.png');
            }
        },

        openModalSearch: function () {
            const self = this;
            const modalEl = document.getElementById('pro_search_modalIndividualSearch');
            const modal = new bootstrap.Modal(modalEl);
            modal.show();

            self.initSearchGrid();

            $('#pro_search_btnViewIndividual').off('click').on('click', function() {
                self.searchIndividual();
            });
        },

        searchIndividual: function () {
            const self = this;
            const lastName = $('#ind_search_name').val()?.trim() || "";
            const firstName = $('#ind_search_first').val()?.trim() || "";


            $.ajax({
                url: '/Profile/ProfileIndividualSearch',
                type: 'GET',
                loadingGrid: '#pro_individualGrid',
                data: {
                    LastName: lastName,
                    FirstName: firstName
                },
                success: function (res) {
                    if (!res.success) {
                        showToast("Error", res.message, false);
                        return;
                    }

                    self.renderSearchGrid(res.data || []);
                },
                error: function () {
                    showToast("Error", "Cannot fetch search results", false);
                }
            });
        },

        renderSearchGrid: function (data) {

            const self = this;

            $("#pro_individualGrid").dxDataGrid({

                dataSource: data,

                keyExpr: "id",

                columns: [
                    {
                        dataField: "id",
                        visible: false
                    },
                    {
                        dataField: "name",
                        caption: "Name"
                    }
                ],

                selection: {
                    mode: "single"
                },

                hoverStateEnabled: true,

                height: 300,
                scrolling: {
                    mode: "standard",
                    showScrollbar: "always"
                },

                onRowDblClick: function (e) {

                    console.log("Row Data:", e.data);

                    if (!e.data) return;

                    self.loadProfileByID(e.data.id);

                }

            });

        },

        initSearchGrid: function() {
            if (!$("#pro_individualGrid").addClass('dx-datagrid').length) {
                 this.renderSearchGrid([]);
            }
        },

        loadProfileByID: function (id) {

            const self = this;

            $.ajax({
                url: '/Profile/GetProfileByID/',
                type: 'GET',
                contentType: "application/json",
                data: {id: id},
                success: function (res) {

                    if (res.code !== 0) {
                        showToast("Error", res.msg, false);
                        return;
                    }

                    self.fillFormData(res.profile);

                    const modal = bootstrap.Modal.getInstance(
                        document.getElementById("pro_search_modalIndividualSearch")
                    );

                    if (modal) modal.hide();

                    showToast("Success", "Profile loaded", true);

                },

                error: function () {
                    showToast("Error", "Cannot load profile", false);

                }

            });

        },
    };


    window.initIndividualModal = function() {
        if (window.pro_ind_Module) {
            window.pro_ind_Module.init();
        }
    };

</script>
