        exportAllotInfoToExcel: function () {
            // 1. Lấy instance của Grid Allotment Information
            const grid = $("#allot_search_gridAllotInfor").dxDataGrid("instance");
            if (!grid || grid.getDataSource().items().length === 0) {
                showToast("Warning", "No data available in Allotment Information to export!", false);
                return;
            }

            const workbook = new ExcelJS.Workbook();
            const worksheet = workbook.addWorksheet("Allotment Info");
            const companyName = localStorage.getItem("CompanyName") || "Hotel Management System";
            const now = new Date();
            const exportDateStr = "Export Date: " + now.toLocaleString("vi-VN");

            // 2. Cấu hình tiêu đề và định dạng file
            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 6, column: 1 }, // Dữ liệu bắt đầu từ dòng 6
                customizeCell: function (options) {
                    const { gridCell, excelCell } = options;
                    if (gridCell.rowType === "header") {
                        excelCell.font = { bold: true };
                        excelCell.alignment = { horizontal: 'center' };
                        excelCell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFD3D3D3' } };
                    }
                }
            }).then(function () {
                // 3. Thêm Header tùy chỉnh phía trên bảng dữ liệu
                // Dòng 1: Tên công ty
                worksheet.mergeCells('A1:D1');
                const row1 = worksheet.getCell('A1');
                row1.value = companyName;
                row1.font = { bold: true, size: 14 };

                // Dòng 2: Ngày giờ xuất
                worksheet.mergeCells('A2:D2');
                const row2 = worksheet.getCell('A2');
                row2.value = exportDateStr;
                row2.font = { italic: true };

                // Dòng 4: Tiêu đề báo cáo
                worksheet.mergeCells('A4:F4');
                const reportTitle = worksheet.getCell('A4');
                reportTitle.value = "ALLOTMENT INFORMATION REPORT";
                reportTitle.font = { bold: true, size: 16 };
                reportTitle.alignment = { horizontal: 'center' };

                // 4. Thực hiện ghi file và tải về
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "Allotment_Information.xlsx");
                });
            });
        },

