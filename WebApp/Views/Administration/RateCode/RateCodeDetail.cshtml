            const uid = parseInt(localStorage.getItem("userID"), 10) || 0;
            return {
                id: parseInt($(sel.modalDetailId).val(), 10) || 0,
                userId: uid,
                rateCodeId: resolveRateCodeId(),
                roomTypeId: parseInt($(sel.roomType).val(), 10) || 0,
                packageId: parseInt($(sel.package).val(), 10) || 0,
                seasonId: parseInt($(sel.season).val(), 10) || 0,
                fromDate: modalDateIso("rtCD_modalFromDate"),
                toDate: modalDateIso("rtCD_modalToDate"),
                transactionCode: $(sel.transCode).val() || "",
                currencyId: ($(sel.currency).val() || "").trim(),
                minLos: parseInt($(sel.minLos).val(), 10) || 0,
                maxLos: parseInt($(sel.maxLos).val(), 10) || 0,
                minNoOfRoom: parseInt($(sel.minNoOfRoom).val(), 10) || 0,
                maxNoOfRoom: parseInt($(sel.maxNoOfRoom).val(), 10) || 0,
                printRate: $(sel.printRate).is(":checked"),
                discount: $(sel.discount).is(":checked"),
                a1: parseDec(sel.amt1), a1AfterTax: parseDec(sel.amt1Net),
                a2: parseDec(sel.amt2), a2AfterTax: parseDec(sel.amt2Net),
