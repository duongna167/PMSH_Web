@using DevExpress.XtraReports.UI

@{
    var listz = ViewBag.ZoneList;
    var selectedReport = @ViewBag.ReportHeader;
}

<!-- =========================
     BS5 MODAL (MAIN VIEW)
     Prefix = dii_ (Dialing Information)
     ========================= -->
<div class="modal fade" id="dii_modal" tabindex="-1" aria-labelledby="dii_modalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable modal-dialog-centered modal-4by3">
        <div class="modal-content">

            <div class="modal-header py-2">
                <h5 class="modal-title" id="dii_modalLabel">Dialing Information</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">

                    <div class="mt-2">
                        <button id="dii_btnPrint" class="mui-button mui-button-new">View</button>
                        <button id="dii_btnExportExcel" class="mui-button mui-button-new" type="button">Excel</button>
                        <button class="mui-button mui-button-new" data-bs-dismiss="modal" aria-label="Close">Close</button>

                    </div>

                    <div class="mt-2">
                        <div class="row g-2 px-1 align-items-center">

                            <!-- From -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2 col-xl-2">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 fw-bold mb-0 text-nowrap text-md-end">
                                        From:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <div data-date-input data-format="DD/MM/YYYY" data-name="dii_fromDate" business-date>
                                            <input type="text"
                                                   id="dii_ShowfromDate"
                                                   name="dii_ShowfromDate"
                                                   class="date-ui form-control form-control-sm"
                                                   autocomplete="off"  />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- To -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2 col-xl-2">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 fw-bold mb-0 text-nowrap text-md-end">
                                        To:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <div data-date-input data-format="DD/MM/YYYY" data-name="dii_toDate" business-date>
                                            <input type="text"
                                                   id="dii_ShowtoDate"
                                                   name="dii_ShowtoDate"
                                                   class="date-ui form-control form-control-sm"
                                                   autocomplete="off"  />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Phone -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl-3">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 fw-bold mb-0 text-nowrap text-md-end">
                                        Phone:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <input type="text"
                                               id="dii_phoneNo"
                                               name="dii_phoneNo"
                                               class="form-control form-control-sm"
                                               placeholder="Enter phone no..." />
                                    </div>
                                </div>
                            </div>

                            <!-- View -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2 col-xl-2">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 fw-bold mb-0 text-nowrap text-md-end">
                                        View:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <select id="dii_viewBy" name="dii_viewBy" class="form-select form-select-sm">
                                            <option value="0">All</option>
                                            <option value="1">Room</option>
                                            <option value="2">Ext</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Zone -->
                            <div class="col-12 col-sm-6 col-md-8 col-lg-3 col-xl-3">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="col-4 col-sm-4 col-md-2 col-lg-4 col-xl-4 fw-bold mb-0 text-nowrap text-md-end">
                                        Zone:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-10 col-lg-8 col-xl-8">
                                        <select id="dii_zone" name="dii_zone" class="tomselect-custom w-100" multiple placeholder="Select zones...">
                                            @foreach (var sg in ViewBag.ZoneList)
                                            {
                                                <option value="@sg.Code">@sg.Code</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>

                <div class="mui-card">
                    <div id="dii_gridWrapper" class="mt-2">
                        <div class="gridContainer" id="dii_gridContainer"></div>
                    </div>
                </div>

                <div id="dii_loadingSpinner"
                     style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:1000;">
                    <i class="fa-solid fa-spinner fa-spin"></i>
                </div>

            </div>

        </div>
    </div>
</div>

<script>
    var dii_Module = {

        gridInstance: null,

        init: function () {
            this.getBusinessDate();
            initTomSelect("#dii_zone");
            this.loadTelephoneGrid();
            this.bindEvents();
        },

        destroy: function () {

            // Dispose DevExtreme grid
            try {
                if (this.gridInstance) {
                    this.gridInstance.dispose();
                }
            } catch (e) { }

            // Empty grid container
            try {
                $("#dii_gridContainer").empty();
            } catch (e) { }

            // Null refs
            this.gridInstance = null;
        },

        getBusinessDate: function () {
            return $.ajax({
                url: '/Reservation/GetBusinessDate',
                type: 'get',
                dataType: 'json',
                crossDomain: false,
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                success: function (result) {

                    // Gán vào input type="date"
                    $('#dii_fromDate').val(result.split('T')[0]);
                    $('#dii_toDate').val(result.split('T')[0]);

                },
                error: function (xhr, statusText, err) {
                    if (xhr.status == 401) {
                        sessionTimeout();
                    }
                }
            });
        },

        loadTelephoneGrid: function (data) {
            $("#dii_gridContainer").dxDataGrid({
                dataSource: data,
                height: "100%",
                width: "100%", // Đảm bảo grid chiếm hết chiều rộng modal
                columnAutoWidth: false, // Tắt tự động để các giá trị px bên dưới có hiệu lực
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                columns: [
                    { dataField: "fromPhoneNo", caption: "From Phone No", width: 100 },
                    { dataField: "toPhoneNo", caption: "To Phone No", width: 150 },
                    { dataField: "timeStart", caption: "Time Start", dataType: "datetime", format: "dd/MM/yyyy ", width: 180 },
                    { dataField: "timeEnd", caption: "Time End", dataType: "datetime", format: "dd/MM/yyyy" , width: 180 },
                    { dataField: "duration", caption: "Duration", dataType: "datetime", format: "HH:mm:ss", width: 120,  },
                    { dataField: "area", caption: "Area", width: 150 },
                    { dataField: "amount", caption: "Amount", dataType: "number", format: "#,##0.00", width: 130 },
                    { dataField: "currency", caption: "Currency", width: 100,  }
                ],
                scrolling: {
                    mode: "standard",
                    showScrollbar: "always", // Luôn hiện thanh cuộn để user biết là có thể kéo ngang
                    scrollByContent: true,
                    useNative: false // Giúp thanh cuộn mượt hơn trên một số trình duyệt
                },
                paging: {
                    pageSize: 20
                },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 40, 'all'],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: {
                    visible: true,
                    applyFilter: "auto"
                },
                showBorders: true,
                wordWrapEnabled: false // Giữ dữ liệu trên một dòng để trigger scroll ngang tốt hơn
            });


            this.gridInstance = $("#dii_gridContainer").dxDataGrid("instance");
        },

        bindEvents: function () {
            const self = this;

            $("#dii_phoneNo").off("input").on("input", function () {
                const value = $(this).val();
                const grid = $("#dii_gridContainer").dxDataGrid("instance");

                grid.filter([
                    ["toPhoneNo", "contains", value]  // lọc theo cột telephone
                ]);
            });

            $(document).off("click", "#dii_btnPrint").on("click", "#dii_btnPrint", function () {
                $("#dii_loadingSpinner").show();

                $.ajax({
                    url: '/FrontDesk/GetDialingInformation',
                    type: 'GET',
                    data: {
                        fromDate: $("#dii_fromDate").val(),
                        toDate: $("#dii_toDate").val(),
                        phoneNo: $("#dii_phoneNo").val(),
                        view: $("#dii_viewBy").val(),
                        zone: ($("#dii_zone").val() || []).join(","),
                    },
                    success: function (data) {
                        console.log(data);
                        self.loadTelephoneGrid(data);
                        $("#dii_loadingSpinner").hide();
                    },
                    error: function () {
                        alert("Không thể tải dữ liệu");
                        $("#dii_loadingSpinner").hide();
                    }
                });
            });

            $("#dii_btnExportExcel").off("click").on("click", function () {
                const grid = $("#dii_gridContainer").dxDataGrid("instance");   // 🔥 khai báo grid

                const workbook = new ExcelJS.Workbook();
                const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
                const worksheet = workbook.addWorksheet("Sheet 1");

                // === Dòng 1: Tên công ty (merge theo 4 cột) ===
                worksheet.addRow([companyName]);
                worksheet.mergeCells('A1:D1');
                worksheet.getRow(1).font = { bold: true };
                worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

                // === Dòng 2: Ngày giờ xuất (bên phải) ===
                const now = new Date();
                const exportDate = now.toLocaleString("vi-VN");
                worksheet.addRow(['', '', '', exportDate]);
                worksheet.mergeCells('D2:D2');  // cột D thôi
                worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

                // === Dòng 3–4: trống
                worksheet.addRow([]);
                worksheet.addRow([]);

                // === Dòng 5: Tiêu đề báo cáo (ở giữa) ===
                const reportRow = worksheet.addRow(['Dialing Information']);
                worksheet.mergeCells('A5:D5');
                reportRow.font = { bold: true, size: 14 };
                reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

                // === Dòng 6: trống
                worksheet.addRow([]);

                // === Xuất dữ liệu grid bắt đầu từ dòng 7 ===
                DevExpress.excelExporter.exportDataGrid({
                    component: grid,
                    worksheet: worksheet,
                    autoFilterEnabled: true,
                    topLeftCell: { row: 7, column: 1 }
                }).then(function () {
                    // Footer (sau cùng)
                    const lastRow = worksheet.lastRow.number + 2;
                    worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
                    worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
                    worksheet.getCell(`A${lastRow}`).font = { italic: true };

                    // Ghi file
                    let fileName = "Dialing Information.xlsx";

                    workbook.xlsx.writeBuffer().then(function (buffer) {
                        saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
                    });
                });
            });
        },
    };

    // Global entry points
    window.openModalDII = function () {
        dii_Module.init();
        $("#dii_modal").modal("show");
    };

    // Automatic cleanup: ANY modal with ID starting with dii_
    $(document).off("hidden.bs.modal.dii_cleanup").on("hidden.bs.modal.dii_cleanup", ".modal[id^='dii_']", function () {
        dii_Module.destroy();
    });
</script>
