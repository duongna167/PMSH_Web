@using DevExpress.XtraReports.UI

@{
    ViewBag.Title = ViewBag.ReportHeader;
    var roomList = ViewBag.RoomList;
    var zoneList = ViewBag.ZoneList;
}

<style>
    #gss_modal {
        z-index: 1053;
    }
    #gss_editModal {
        z-index: 1054;
    }
    .gss-status-box {
        display: inline-block;
        width: 18px;
        height: 18px;
        margin-right: 4px;
        vertical-align: middle;
        border: 1px solid #ccc;
    }

    .gss-color-clean-uncheck {
        background-color: cyan;
    }

    .gss-color-dirty {
        background-color: red;
    }

    .gss-color-outoforder {
        background-color: lightgray;
    }

    .gss-color-pickup {
        background-color: yellow;
    }

    .gss-color-clean {
        background-color: lime;
    }

    .gss-color-outofservices {
        background-color: lightgray;
    }

    .gss-hk-clean-uncheck {
        background-color: cyan;
        color: black;
    }

    .gss-hk-dirty {
        background-color: red;
        color: white;
    }

    .gss-hk-outoforder {
        background-color: lightgray;
        color: black;
    }

    .gss-hk-pickup {
        background-color: yellow;
        color: black;
    }

    .gss-hk-clean {
        background-color: lime;
        color: black;
    }

    .gss-hk-outofservices {
        background-color: lightgray;
        color: black;
    }

    /* IMPORTANT: fixed height to avoid dx grid 0 height */
    #gss_gridContainer {
        height: 550px;
        width: 100%;
    }

    /* optional */
    #gss_logGridContainer {
        height: 250px;
        width: 100%;
        overflow: auto;
    }
</style>
<!-- =========================
     GSS MAIN MODAL (BS5)
========================= -->
<div class="modal fade" id="gss_modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header">
                <h6 class="modal-title" id="gss_title">Guest Service Status</h6>
            </div>

            <!-- BODY -->
            <div class="modal-body">

                <div class="search-filter">
                                    <!-- ACTIONS -->
                    <div>
                        <button id="gss_btnView" class="mui-button mui-button-new" type="button">View</button>
                        <button id="gss_btnExportExcel" class="mui-button mui-button-new" type="button">Excel</button>

                        <button id="gss_btnResvGuest" class="mui-button mui-button-search" type="button">
                            Resv
                        </button>

                        <button id="gss_btnEditGuest" class="mui-button mui-button-edit" type="button">
                            Edit
                        </button>
                        <button class="mui-button mui-button-edit" data-bs-dismiss="modal" aria-label="Close">Close</button>
                    </div>

                    <!-- FILTER PANEL -->
                    <div class="d-flex flex-wrap align-items-center gap-3 mt-1 mb-2">

                        <div class="d-flex align-items-center gap-2">
                            <label class="mb-0 text-nowrap">Service Status:</label>
                            <select id="gss_servicestatus" name="tomselect-custom"
                                    class="form-control form-control-sm w-auto">
                                <option value="0">All</option>
                                <option value="1">Make Up Room</option>
                                <option value="2">Do Not Disturb</option>
                            </select>
                        </div>

                        <div class="d-flex align-items-center gap-2">
                            <label class="mb-0 text-nowrap">Room:</label>
                            <select id="gss_room" name="gss_room" class="tomselect-custom" multiple style="width: 240px;">
                                @foreach (var item in roomList)
                            {
                                <option value="@item.RoomNo">@item.RoomNo</option>
                            }
                            </select>
                        </div>

                        <div class="d-flex align-items-center gap-2">
                            <label class="mb-0 text-nowrap">Zone:</label>
                            <select id="gss_zone" name="gss_zone" class="tomselect-custom" multiple style="width: 240px;">
                                @foreach (var item in zoneList)
                            {
                                <option value="@item.Code">@item.Code</option>
                            }
                            </select>
                        </div>
                    </div>

                    <!-- ROOM STATUS CHECKBOXES -->
                    <div class="d-flex flex-wrap align-items-center gap-3 mb-2">

                        <div class="d-flex align-items-center gap-2">
                            <label class="mb-0 text-nowrap">Room Status:</label>
                        </div>

                        <div class="form-check">
                            <span class="gss-status-box gss-color-clean-uncheck"></span>
                            <input type="checkbox" id="gss_cleanUncheck" name="gss_includeOptions" value="1" checked>
                            <label class="form-check-label" for="gss_cleanUncheck">Clean Uncheck</label>
                        </div>

                        <div class="form-check">
                            <span class="gss-status-box gss-color-dirty"></span>
                            <input type="checkbox" id="gss_dirty" name="gss_includeOptions" value="2" checked>
                            <label class="form-check-label" for="gss_dirty">Dirty</label>
                        </div>

                        <div class="form-check">
                            <span class="gss-status-box gss-color-outoforder"></span>
                            <input type="checkbox" id="gss_outofOrder" name="gss_includeOptions" value="5" checked>
                            <label class="form-check-label" for="gss_outofOrder">Out of Order</label>
                        </div>

                        <div class="form-check">
                            <span class="gss-status-box gss-color-pickup"></span>
                            <input type="checkbox" id="gss_pickup" name="gss_includeOptions" value="3" checked>
                            <label class="form-check-label" for="gss_pickup">Pickup</label>
                        </div>

                        <div class="form-check">
                            <span class="gss-status-box gss-color-clean"></span>
                            <input type="checkbox" id="gss_clean" name="gss_includeOptions" value="4" checked>
                            <label class="form-check-label" for="gss_clean">Clean</label>
                        </div>

                        <div class="form-check">
                            <span class="gss-status-box gss-color-outofservices"></span>
                            <input type="checkbox" id="gss_outofServices" name="gss_includeOptions" value="6" checked>
                            <label class="form-check-label" for="gss_outofServices">Out of Services</label>
                        </div>

                    </div>
                </div>

                <!-- GRID -->
                <div class="mui-card">
                    <div id="gss_gridContainer" class="gridContainer"></div>
                </div>

            </div>
        </div>
    </div>
</div>


<!-- =========================
     EDIT MODAL
========================= -->
<div class="modal fade" id="gss_editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content" style="max-width:520px;">

            <div class="modal-header">
                <h6 class="modal-title">Edit</h6>
            </div>

            <div class="modal-body p-3">

                <div class="d-flex justify-content-start mb-3 gap-2">
                    <button id="gss_btnSaveEdit" class="mui-button mui-button-search" type="button">
                        Save
                    </button>

                    <button type="button" id="gss_btnCloseEdit" class="mui-button mui-button-new"
                            data-bs-dismiss="modal">
                        Close
                    </button>
                </div>

                <div class="mb-3">
                    <div class="d-flex align-items-center gap-2">
                        <label class="mb-0 text-nowrap">Service Status:</label>
                        <select id="gss_servicestatus_edit" class="form-control form-control-sm" style="width:200px">
                            <option value="0"></option>
                            <option value="1">Make Up Room</option>
                            <option value="2">Do Not Disturb</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- =========================
     RESERVATION MODAL (existing)
     (Your system must already have this)
========================= -->
<div class="modal fade" id="newReservationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">Reservation</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body"></div>
        </div>
    </div>
</div>


<!-- =========================
     LOADING SPINNER
========================= -->
<div id="gss_loadingSpinner" style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
    z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
    height: 100%;display: flex;align-items: center;justify-content: center;">
    <div class="spinner-border text-primary"></div>
</div>

<script>
    /* global bootstrap, TomSelect, DevExpress, ExcelJS, saveAs */

    var gss_Module = (function () {

        // ====== Private state ======
        let _modalEl = null;
        let _modal = null;

        let _editModalEl = null;
        let _editModal = null;

        let _grid = null;

        let _tomRoom = null;
        let _tomZone = null;

        let _lastData = null;
        let _selectedRow = null;
        let _selectedRows = [];

        // prevent double init grid
        let _gridInitializedOnce = false;

        // ====== DOM helpers ======
        function $id(id) { return $("#" + id); }

        function showLoading() { $id("gss_loadingSpinner").show(); }
        function hideLoading() { $id("gss_loadingSpinner").hide(); }

        function getSelectedRoomStatusesCsv() {
            return $("input[name='gss_includeOptions']:checked")
                .map(function () { return this.value; })
                .get()
                .join(",");
        }

        function getFilters() {
            const roomVal = $id("gss_room").val() || [];
            const zoneVal = $id("gss_zone").val() || [];

            return {
                servicestatsu: $id("gss_servicestatus").val(),
                room: roomVal,
                roomStatus: getSelectedRoomStatusesCsv(),
                zone: zoneVal.join(",")
            };
        }


        // ====== Grid ======
        function disposeMainGrid() {
            try {
                const inst = $("#gss_gridContainer").dxDataGrid("instance");
                if (inst) inst.dispose();
            } catch (e) { }
            $("#gss_gridContainer").empty();
            _grid = null;
            _gridInitializedOnce = false;
        }

        function buildMainGrid(data) {
            if (!Array.isArray(data)) return false;

            // Important: always dispose before rebuild
            disposeMainGrid();

            _grid = $("#gss_gridContainer").dxDataGrid({
                dataSource: data,
                allowColumnResizing: true,
                columnAutoWidth: true,
                width: "100%",
                columns: [
                    { dataField: "roomNo", caption: "Room" },
                    { dataField: "roomTypeCode", caption: "Room Type" },
                    {
                        dataField: "hkstatus",
                        caption: "Room Status",
                        cellTemplate: function (container, options) {
                            let colorClass = "";
                            switch (options.value) {
                                case "Clean Uncheck":
                                case "Clean Non-Checked":
                                    colorClass = "gss-hk-clean-uncheck"; break;
                                case "Dirty":
                                    colorClass = "gss-hk-dirty"; break;
                                case "Out Of Order":
                                    colorClass = "gss-hk-outoforder"; break;
                                case "Pickup":
                                    colorClass = "gss-hk-pickup"; break;
                                case "Clean":
                                    colorClass = "gss-hk-clean"; break;
                                case "Out Of Services":
                                    colorClass = "gss-hk-outofservices"; break;
                                default:
                                    colorClass = "";
                            }

                            $("<div>")
                                .addClass(colorClass)
                                .css({
                                    "border-radius": "4px",
                                    "text-align": "center",
                                    "font-weight": "bold",
                                    "padding": "2px 6px"
                                })
                                .text(options.value || "")
                                .appendTo(container);
                        }
                    },
                    { dataField: "fostatus", caption: "FO Status" },
                    { dataField: "guestServiceStatus", caption: "Service Status" },
                    { dataField: "floor", caption: "Floor" },
                    { dataField: "reservationStatus", caption: "Reservation Status" },
                    { dataField: "updatedBy", caption: "Updated By" },
                    { dataField: "updatedDate", caption: "Updated Date", dataType: "date", format: "dd/MM/yyyy" },
                    { dataField: "createdBy", caption: "Created By" },
                    { dataField: "createdDate", caption: "Created Date", dataType: "date", format: "dd/MM/yyyy" }
                ],
                paging: { pageSize: 25 },
                scrolling: {
                    useNative: true,
                    showScrollbar: "always"
                },
                pager: {
                    visible: true,
                    allowedPageSizes: [25, 50, 'all'],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: { visible: true, applyFilter: "auto" },
                headerFilter: { visible: true },
                selection: { mode: "multiple", showCheckBoxesMode: "none" },
                showBorders: true,

                onRowClick: function (e) {
                    _selectedRow = e.data || null;
                },
                onSelectionChanged: function (e) {
                    _selectedRows = e.selectedRowsData || [];
                },
                onRowPrepared: function (e) {
                    if (e.rowType === "data" && e.data?.isTotal) {
                        e.rowElement.css({
                            "font-weight": "bold",
                            "background-color": "#f6f6f6"
                        });
                    }
                }
            }).dxDataGrid("instance");

            _gridInitializedOnce = true;
            return true;
        }

        // ====== AJAX flow ======
        function loadDataAndRenderGrid() {
            showLoading();

            const filters = getFilters();

            return $.ajax({
                url: "/HouseKeeping/GuestServiceStatusData",
                type: "GET",
                data: filters,
                traditional: true,
                crossDomain: false,
                headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() }
            })
                .done(function (result) {

                    // STRICT: only render grid if valid data returned
                    if (!Array.isArray(result)) {
                        hideLoading();
                        alert("Invalid response: expected array.");
                        return;
                    }

                    _lastData = result;

                    // IMPORTANT: only build grid if modal is shown (height not 0)
                    // If called too early, postpone until shown.
                    if (_modalEl && $(_modalEl).hasClass("show")) {
                        buildMainGrid(result);
                    }

                    hideLoading();
                })
                .fail(function () {
                    hideLoading();
                    alert("Cannot load report.");
                });
        }

        // ====== Reservation flow ======
        function openReservation(resvId) {
            if (!resvId) {
                alert("Reservation ID not found.");
                return;
            }

            const modal = $("#newReservationModal");
            modal.find(".modal-body").html(`
                <div class="text-center py-5">
                    <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-3">Loading reservation...</p>
                </div>
                `);

            modal.modal("show");

            $.ajax({
                url: "/Reservation/EncryptId",
                type: "POST",
                data: { id: resvId }
            })
                .done(function (response) {
                    if (!response?.success) {
                        modal.modal("hide");
                        alert("EncryptId failed.");
                        return;
                    }

                    $.ajax({
                        url: "/Reservation/NewReservation",
                        type: "GET",
                        data: { key: response.encryptedId },
                        cache: false
                    })
                        .done(function (html) {
                            modal.find(".modal-body").html(html);
                        })
                        .fail(function () {
                            modal.find(".modal-body").html(`
              <div class="alert alert-danger m-4">
                <strong>Error!</strong> Cannot load reservation.
              </div>
            `);
                        });
                })
                .fail(function () {
                    modal.modal("hide");
                    alert("Server connection error.");
                });
        }

        // ====== Edit flow ======
        function openEditModal() {
            if (!_selectedRows || _selectedRows.length < 1) {
                alert("Please select row(s) first.");
                return;
            }
            _editModal.show();
        }

        function saveEdit() {
            if (!_selectedRows || _selectedRows.length < 1) {
                alert("No selected rows.");
                return;
            }

            const newStatus = $id("gss_servicestatus_edit").val();
            if (!newStatus) {
                alert("Please choose Service Status.");
                return;
            }

            showLoading();

            $.ajax({
                url: "/HouseKeeping/EditGuestService",
                type: "POST",
                dataType: "json",
                data: {
                    Ids: _selectedRows,
                    servicestatus: newStatus
                },
                crossDomain: false,
                headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() }
            })
                .done(function (result) {
                    hideLoading();

                    if (result?.message) showToast("Success", result.message, true);

                    _editModal.hide();
                    $id("gss_servicestatus_edit").val("0");

                    // reload
                    loadDataAndRenderGrid();
                })
                .fail(function (xhr) {
                    hideLoading();
                    if (xhr.status === 401) sessionTimeout();
                });
        }

        // ====== Export ======
        function exportExcel() {
            const grid = $("#gss_gridContainer").dxDataGrid("instance");
            if (!grid) {
                alert("Grid not ready.");
                return;
            }

            const selectedReport = "Guest Service Status";
            const workbook = new ExcelJS.Workbook();
            const worksheet = workbook.addWorksheet("Sheet 1");

            worksheet.addRow(["Công ty Cổ phần Giải pháp Công nghệ CS-Solution"]);
            worksheet.mergeCells("A1:E1");
            worksheet.getRow(1).font = { bold: true };
            worksheet.getRow(1).alignment = { vertical: "middle", horizontal: "left" };

            const now = new Date();
            const exportDate = now.toLocaleString("vi-VN");
            worksheet.addRow(["", "", "", "", " " + exportDate]);
            worksheet.mergeCells("E2:H2");
            worksheet.getRow(2).alignment = { vertical: "middle", horizontal: "right" };

            worksheet.addRow([]);
            worksheet.addRow([]);

            const reportRow = worksheet.addRow(["", "", selectedReport]);
            worksheet.mergeCells("C5:F5");
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { vertical: "middle", horizontal: "center" };

            worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const lastRow = worksheet.lastRow.number + 2;
                worksheet.getCell(`A${lastRow}`).value = "--- END ---";
                worksheet.mergeCells(`A${lastRow}:F${lastRow}`);
                worksheet.getCell(`A${lastRow}`).alignment = { horizontal: "center" };
                worksheet.getCell(`A${lastRow}`).font = { italic: true };

                const fileName = selectedReport + ".xlsx";
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
                });
            });
        }

        // ====== Events ======
        function bindEvents() {

            // view
            $(document).off("click.gss", "#gss_btnView").on("click.gss", "#gss_btnView", function () {
                loadDataAndRenderGrid();
            });

            // export
            $(document).off("click.gss", "#gss_btnExportExcel").on("click.gss", "#gss_btnExportExcel", function () {
                exportExcel();
            });

            // resv
            $(document).off("click.gss", "#gss_btnResvGuest").on("click.gss", "#gss_btnResvGuest", function () {
                if (!_selectedRow) {
                    alert("Please select a row first.");
                    return;
                }
                openReservation(_selectedRow.resvID);
            });

            // edit open
            $(document).off("click.gss", "#gss_btnEditGuest").on("click.gss", "#gss_btnEditGuest", function () {
                openEditModal();
            });

            // edit save
            $(document).off("click.gss", "#gss_btnSaveEdit").on("click.gss", "#gss_btnSaveEdit", function () {
                saveEdit();
            });

            // when edit modal hidden => reset
            $(_editModalEl).off("hidden.bs.modal.gss").on("hidden.bs.modal.gss", function () {
                $id("gss_servicestatus_edit").val("0");
                $("#gss_logGridContainer").empty();
            });
        }

        // ====== Modal lifecycle ======
        function initModals() {
            _modalEl = document.getElementById("gss_modal");
            _editModalEl = document.getElementById("gss_editModal");

            if (!_modalEl || !_editModalEl) {
                console.warn("gss modal elements not found.");
                return;
            }

            _modal = bootstrap.Modal.getOrCreateInstance(_modalEl, { backdrop: "static" });
            _editModal = bootstrap.Modal.getOrCreateInstance(_editModalEl, { backdrop: "static" });

            // IMPORTANT: Grid must be initialized only in shown.bs.modal
            const onModalOpen = function () {
                console.log("GSS Module: Executing onModalOpen...");
                initTomSelects();

                if (Array.isArray(_lastData) && !_gridInitializedOnce) {
                    buildMainGrid(_lastData);
                }

                if (!_lastData) {
                    loadDataAndRenderGrid();
                }
            };

            // FIX: Kiểm tra nếu modal đã có class 'show' (đang hiển thị) thì chạy luôn
            if (_modalEl.classList.contains('show')) {
                onModalOpen();
            }

            // cleanup on hide
            $(_modalEl).off("hidden.bs.modal.gss").on("hidden.bs.modal.gss", function () {
                destroy();
            });
        }

        // ====== Public API ======
        function init() {
                    // ====== TomSelect ======
            initTomSelect(".tomselect-custom") ;

            initModals();
            bindEvents();
        }

        function openModal() {
            if (!_modal) init();
            loadDataAndRenderGrid();
            _modal.show();
        }

        function destroy() {

            // dispose grids
            disposeMainGrid();

            // clear selections
            _selectedRow = null;
            _selectedRows = [];
            _lastData = null;

            // destroy tomselect
            try { if (_tomRoom) _tomRoom.destroy(); } catch (e) { }
            try { if (_tomZone) _tomZone.destroy(); } catch (e) { }
            _tomRoom = null;
            _tomZone = null;

            // unbind events
            $(document).off(".gss");

            // empty containers
            $("#gss_gridContainer").empty();
            $("#gss_logGridContainer").empty();

            hideLoading();
        }

        return {
            init: init,
            openModal: openModal,
            destroy: destroy
        };

    })();


    // ===== Global entry =====
    window.openModalGss = function () {
        gss_Module.openModal();
    };


    // ===== Global cleanup for all gss_ modals =====
    $(document).off("hidden.bs.modal.gss_global").on("hidden.bs.modal.gss_global", ".modal[id^='gss_']", function () {
        // Only destroy when MAIN modal hidden
        if (this.id === "gss_modal") {
            gss_Module.destroy();
        }
    });
</script>
