<!-- Main Modal -->
<div class="modal fade" id="pickupDropPlace_mainModal" tabindex="-1" aria-labelledby="pickupDropPlace_mainModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="pickupDropPlace_mainModalLabel">Pickup Drop Place</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <button id="pickupDropPlace_btnView" type="button" class="mui-button mui-button-search">View</button>
                        <button id="pickupDropPlace_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="pickupDropPlace_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="pickupDropPlace_btnDelete" type="button" class="mui-button mui-button-delete">Delete</button>
                        <button id="pickupDropPlace_btnExportExcel" type="button" class="mui-button mui-button-export">Excel</button>
                        <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal" aria-label="Close">Close</button>
                    </div>

                    <div class="row g-2 mt-1">
                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label for="pickupDropPlace_filterCode" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Code
                                </label>
                                <div class="col-md-8">
                                    <input id="pickupDropPlace_filterCode"
                                           name="pickupDropPlace_filterCode"
                                           type="text"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label for="pickupDropPlace_filterName" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Name
                                </label>
                                <div class="col-md-8">
                                    <input id="pickupDropPlace_filterName"
                                           name="pickupDropPlace_filterName"
                                           type="text"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Status
                                </label>
                                <div class="col-md-8">
                                    <div class="d-flex align-items-center h-100">
                                        <div class="form-check d-flex align-items-center gap-2">
                                            <span class="status-color-box color-clean-uncheck"></span>
                                            <input type="checkbox" id="pickupDropPlace_chkShowInactive" name="pickupDropPlace_chkShowInactive">
                                            <label class="form-check-label" for="pickupDropPlace_chkShowInactive">Show Inactive</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mui-card mt-1">
                    <div id="pickupDropPlace_gridContainer" class="gridContainer"></div>
                </div>

                <div id="pickupDropPlace_loadingSpinner"
                     style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                     z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                     height: 100%;display: flex;align-items: center;justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="pickupDropPlace_itemModal" tabindex="-1" aria-labelledby="pickupDropPlace_itemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="pickupDropPlace_itemModalLabel">Add Pickup Drop Place</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <button type="button" id="pickupDropPlace_btnSave" class="mui-button mui-button-new">Save</button>
                    <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>

                <form id="pickupDropPlace_formContainer">
                    <div class="row g-2 mt-1 mb-2">
                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label for="pickupDropPlace_code" class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Code
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <input id="pickupDropPlace_code"
                                           name="pickupDropPlace_code"
                                           type="text"
                                           class="form-control form-control-sm" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Status
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <div class="form-check d-inline-flex align-items-center gap-2">
                                        <input id="pickupDropPlace_inactive"
                                               name="pickupDropPlace_inactive"
                                               type="checkbox" />
                                        <label for="pickupDropPlace_inactive" class="form-check-label text-danger">
                                            Inactive
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="pickupDropPlace_name" class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Name
                                </label>
                                <div class="col-md-10">
                                    <input id="pickupDropPlace_name"
                                           name="pickupDropPlace_name"
                                           type="text"
                                           class="form-control form-control-sm" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="pickupDropPlace_description" class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Description
                                </label>
                                <div class="col-md-10">
                                    <textarea id="pickupDropPlace_description"
                                              name="pickupDropPlace_description"
                                              rows="4"
                                              class="form-control form-control-sm"
                                              style="height:100px;"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="pickupDropPlace_id" name="pickupDropPlace_id" value="0" />
                </form>
            </div>

        </div>
    </div>
</div>

<script>
    var pickupDropPlace_Module = (() => {
        let pickupDropPlace_selectedRowData = null;

        const pickupDropPlace_selectors = {
            mainModal: "#pickupDropPlace_mainModal",
            itemModal: "#pickupDropPlace_itemModal",
            form: "#pickupDropPlace_formContainer",
            grid: "#pickupDropPlace_gridContainer",
            loading: "#pickupDropPlace_loadingSpinner",

            filterCode: "#pickupDropPlace_filterCode",
            filterName: "#pickupDropPlace_filterName",
            chkShowInactive: "#pickupDropPlace_chkShowInactive",

            btnView: "#pickupDropPlace_btnView",
            btnNew: "#pickupDropPlace_btnNew",
            btnEdit: "#pickupDropPlace_btnEdit",
            btnDelete: "#pickupDropPlace_btnDelete",
            btnExportExcel: "#pickupDropPlace_btnExportExcel",
            btnSave: "#pickupDropPlace_btnSave",

            modalLabel: "#pickupDropPlace_itemModalLabel",

            id: "#pickupDropPlace_id",
            code: "#pickupDropPlace_code",
            name: "#pickupDropPlace_name",
            description: "#pickupDropPlace_description",
            inactive: "#pickupDropPlace_inactive"
        };

        function pickupDropPlace_init() {
            pickupDropPlace_bindEvents();
            pickupDropPlace_resetForm();
            pickupDropPlace_loadGrid([]);
            pickupDropPlace_loadData();
        }

        function pickupDropPlace_bindEvents() {
            $(document)
                .off("input change", `${pickupDropPlace_selectors.form} input, ${pickupDropPlace_selectors.form} select, ${pickupDropPlace_selectors.form} textarea`)
                .on("input change", `${pickupDropPlace_selectors.form} input, ${pickupDropPlace_selectors.form} select, ${pickupDropPlace_selectors.form} textarea`, function () {
                    if ($(this).hasClass("is-invalid")) {
                        $(this).removeClass("is-invalid");
                        $(this).next(".invalid-feedback").text("");
                    }
                });

            $(pickupDropPlace_selectors.itemModal)
                .off("hidden.bs.modal")
                .on("hidden.bs.modal", function () {
                    applyValidationErrors([], pickupDropPlace_selectors.form);
                });

            $(document)
                .off("click", pickupDropPlace_selectors.btnView)
                .on("click", pickupDropPlace_selectors.btnView, function () {
                    pickupDropPlace_loadData();
                });

            $(document)
                .off("click", pickupDropPlace_selectors.btnNew)
                .on("click", pickupDropPlace_selectors.btnNew, function () {
                    pickupDropPlace_openAddModal();
                });

            $(document)
                .off("click", pickupDropPlace_selectors.btnEdit)
                .on("click", pickupDropPlace_selectors.btnEdit, function () {
                    pickupDropPlace_openEditModal();
                });

            $(document)
                .off("click", pickupDropPlace_selectors.btnSave)
                .on("click", pickupDropPlace_selectors.btnSave, function () {
                    pickupDropPlace_save();
                });

            $(document)
                .off("click", pickupDropPlace_selectors.btnDelete)
                .on("click", pickupDropPlace_selectors.btnDelete, function () {
                    pickupDropPlace_delete();
                });

            $(document)
                .off("click", pickupDropPlace_selectors.btnExportExcel)
                .on("click", pickupDropPlace_selectors.btnExportExcel, function () {
                    pickupDropPlace_exportExcel();
                });
        }

        function pickupDropPlace_resetForm() {
            const pickupDropPlace_form = $(pickupDropPlace_selectors.form)[0];
            if (pickupDropPlace_form) {
                pickupDropPlace_form.reset();
            }

            $(pickupDropPlace_selectors.id).val("0");
            $(pickupDropPlace_selectors.modalLabel).text("Add Pickup Drop Place");
        }

        function pickupDropPlace_openAddModal() {
            pickupDropPlace_resetForm();
            $(pickupDropPlace_selectors.modalLabel).text("Add Pickup Drop Place");
            $(pickupDropPlace_selectors.itemModal).modal("show");
        }

        function pickupDropPlace_openEditModal() {
            if (!pickupDropPlace_selectedRowData) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }

            pickupDropPlace_fillForm(pickupDropPlace_selectedRowData);
            $(pickupDropPlace_selectors.modalLabel).text("Update Pickup Drop Place");
            $(pickupDropPlace_selectors.itemModal).modal("show");
        }

        function pickupDropPlace_fillForm(pickupDropPlace_data) {
            $(pickupDropPlace_selectors.id).val(pickupDropPlace_data.id);
            $(pickupDropPlace_selectors.code).val(pickupDropPlace_data.code);
            $(pickupDropPlace_selectors.name).val(pickupDropPlace_data.name);
            $(pickupDropPlace_selectors.description).val(pickupDropPlace_data.description);
            $(pickupDropPlace_selectors.inactive).prop("checked", pickupDropPlace_data.inactive);
        }

        function pickupDropPlace_getSearchModel() {
            return {
                code: $(pickupDropPlace_selectors.filterCode).val(),
                name: $(pickupDropPlace_selectors.filterName).val(),
                inactive: $(pickupDropPlace_selectors.chkShowInactive).prop("checked") ? 1 : 0
            };
        }

        function pickupDropPlace_getSaveModel() {
            const pickupDropPlace_id = parseInt($(pickupDropPlace_selectors.id).val()) || 0;
            let pickupDropPlace_loginName = (localStorage.getItem("Loginname") || "")
                .trim()
                .replace(/^"(.*)"$/, "$1");
            const pickupDropPlace_loginUser = parseInt(localStorage.getItem("userID")) || 0;

            return {
                ID: pickupDropPlace_id,
                Code: $(pickupDropPlace_selectors.code).val(),
                Name: $(pickupDropPlace_selectors.name).val(),
                Description: $(pickupDropPlace_selectors.description).val(),
                Inactive: $(pickupDropPlace_selectors.inactive).prop("checked"),
                CreatedBy: pickupDropPlace_loginName,
                UpdatedBy: pickupDropPlace_loginName,
                UserInsertID: pickupDropPlace_loginUser,
                UserUpdateID: pickupDropPlace_loginUser
            };
        }

        function pickupDropPlace_showLoading() {
            $(pickupDropPlace_selectors.loading).show();
        }

        function pickupDropPlace_hideLoading() {
            $(pickupDropPlace_selectors.loading).hide();
        }

        function pickupDropPlace_loadData() {
            pickupDropPlace_showLoading();

            $.ajax({
                url: "/Administration/GetPickupDropPlace",
                type: "GET",
                cache: false,
                data: pickupDropPlace_getSearchModel(),
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (pickupDropPlace_data) {
                    pickupDropPlace_loadGrid(pickupDropPlace_data || []);
                    pickupDropPlace_hideLoading();
                },
                error: function () {
                    showToast("Error", "Unable to load data", false);
                    pickupDropPlace_hideLoading();
                }
            });
        }

        function pickupDropPlace_loadGrid(pickupDropPlace_data) {
            $(pickupDropPlace_selectors.grid).dxDataGrid({
                dataSource: pickupDropPlace_data,
                width: "100%",
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                hoverStateEnabled: true,
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "code", caption: "Code", width: "100" },
                    { dataField: "name", caption: "Name", width: "150" },
                    { dataField: "description", caption: "Description", minWidth: 120, cssClass: "col-description"},
                    { dataField: "inactive", caption: "Inactive", width: "60",
                        cellTemplate: function (container, options) {
                            $("<div>")
                                .dxCheckBox({
                                    value: options.value == 1 || options.value === true,
                                    readOnly: true
                                })
                                .css("transform", "scale(0.8)")
                                .appendTo(container);
                        }
                    },
                    { dataField: "createdBy", caption: "Created By", width: "80" },
                    { dataField: "createdDate", caption: "Cre.Date", dataType: "date", width: "80" },
                    { dataField: "updatedBy", caption: "Updated By", width: "80" },
                    { dataField: "updatedDate", caption: "Upd.Date", dataType: "date", width: "80" }
                ],
                filterRow: { visible: true, applyFilter: "auto" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: { mode: "standard", showScrollbar: "always" },
                onSelectionChanged: function (e) {
                    pickupDropPlace_selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
                }
            });
        }

        function pickupDropPlace_save() {
            const pickupDropPlace_model = pickupDropPlace_getSaveModel();

            $.ajax({
                url: "/Administration/PickupDropPlaceSave",
                type: "POST",
                contentType: "application/json",
                cache: false,
                data: JSON.stringify(pickupDropPlace_model),
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (pickupDropPlace_res) {
                    if (pickupDropPlace_res.success) {
                        showToast("Success", pickupDropPlace_res.message, true);
                        $(pickupDropPlace_selectors.itemModal).modal("hide");
                        pickupDropPlace_loadData();
                    } else {
                        if (pickupDropPlace_res.errors && pickupDropPlace_res.errors.length > 0) {
                            applyValidationErrors(pickupDropPlace_res.errors, pickupDropPlace_selectors.form);
                            let pickupDropPlace_generalError = pickupDropPlace_res.errors.find(x => x.field === "general");
                            let pickupDropPlace_toastMessage = pickupDropPlace_generalError ? pickupDropPlace_generalError.message : "Please check input fields.";

                            showToast("Warning", pickupDropPlace_toastMessage, false);
                        } else {
                            showToast("Error", pickupDropPlace_res.message || "Save failed", false);
                        }
                    }
                },
                error: function () {
                    showToast("Error", "Request error!", false);
                    $(pickupDropPlace_selectors.itemModal).modal("hide");
                }
            });
        }

        function pickupDropPlace_delete() {
            if (!pickupDropPlace_selectedRowData || pickupDropPlace_selectedRowData.id === 0) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }

            if (!confirm("Are you sure you want to delete this record? This action cannot be undone.")) {
                return;
            }

            $.ajax({
                url: `/Administration/DeletePickupDropPlace/` + pickupDropPlace_selectedRowData.id,
                type: "POST",
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (pickupDropPlace_result) {
                    if (pickupDropPlace_result.success) {
                        pickupDropPlace_loadData();
                        showToast("Success", "Delete Successfully!", true);
                    } else {
                        showToast("Error", pickupDropPlace_result.message, false);
                    }
                },
                error: function () {
                    console.log("delete " + pickupDropPlace_selectedRowData.id);
                    showToast("Error", "Delete failed!", false);
                    $("#loadingSpinner").hide();
                }
            });
        }

        function pickupDropPlace_exportExcel() {
            const pickupDropPlace_grid = $(pickupDropPlace_selectors.grid).dxDataGrid("instance");

            const pickupDropPlace_workbook = new ExcelJS.Workbook();
            const pickupDropPlace_companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const pickupDropPlace_worksheet = pickupDropPlace_workbook.addWorksheet("Sheet 1");

            pickupDropPlace_worksheet.addRow([pickupDropPlace_companyName]);
            pickupDropPlace_worksheet.mergeCells("A1:D1");
            pickupDropPlace_worksheet.getRow(1).font = { bold: true };
            pickupDropPlace_worksheet.getRow(1).alignment = { vertical: "middle", horizontal: "left" };

            const pickupDropPlace_now = new Date();
            const pickupDropPlace_exportDate = pickupDropPlace_now.toLocaleString("vi-VN");
            pickupDropPlace_worksheet.addRow(["", "", "", pickupDropPlace_exportDate]);
            pickupDropPlace_worksheet.mergeCells("D2:D2");
            pickupDropPlace_worksheet.getRow(2).alignment = { vertical: "middle", horizontal: "right" };

            pickupDropPlace_worksheet.addRow([]);
            pickupDropPlace_worksheet.addRow([]);

            const pickupDropPlace_reportRow = pickupDropPlace_worksheet.addRow(["Pickup Drop Place"]);
            pickupDropPlace_worksheet.mergeCells("A5:D5");
            pickupDropPlace_reportRow.font = { bold: true, size: 14 };
            pickupDropPlace_reportRow.alignment = { vertical: "middle", horizontal: "center" };

            pickupDropPlace_worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: pickupDropPlace_grid,
                worksheet: pickupDropPlace_worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const pickupDropPlace_lastRow = pickupDropPlace_worksheet.lastRow.number + 2;
                pickupDropPlace_worksheet.mergeCells(`A${pickupDropPlace_lastRow}:D${pickupDropPlace_lastRow}`);
                pickupDropPlace_worksheet.getCell(`A${pickupDropPlace_lastRow}`).alignment = { horizontal: "center" };
                pickupDropPlace_worksheet.getCell(`A${pickupDropPlace_lastRow}`).font = { italic: true };

                let pickupDropPlace_fileName = "PickupDropPlace.xlsx";
                pickupDropPlace_workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), pickupDropPlace_fileName);
                });
            });
        }

        return {
            init: pickupDropPlace_init,
            loadData: pickupDropPlace_loadData,
            openAddModal: pickupDropPlace_openAddModal,
            openEditModal: pickupDropPlace_openEditModal
        };
    })();

    window.openModalPickupDropPlace = function () {
        const modalEl = document.querySelector("#pickupDropPlace_mainModal");
        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

        $(modalEl).one("shown.bs.modal", function () {
            pickupDropPlace_Module.init();
        });
        modal.show();
    };
</script>