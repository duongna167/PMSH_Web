@using DevExpress.XtraReports.UI
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    var selectedReport = @ViewBag.ReportHeader;
    var tlplist = ViewBag.TransactionGroupList;
    var transg = ViewBag.TransactionSubGroupList;
    var user = ViewBag.UsersList;
    var trans = ViewBag.TransactionsList;
}

<div class="modal fade" id="casA_modalMain" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header py-2">
                <h5 class="modal-title" id="casA_modalTitle">Cashier Audit</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">

                    <!-- ACTIONS -->
                    <div>
                        <button id="casA_btnView" type="button" class="mui-button mui-button-new">View</button>
                        <button id="casA_btnDetail" type="button" class="mui-button mui-button-new">Detail</button>
                        <button id="casA_btnExportExcel" type="button" class="mui-button mui-button-new">Excel</button>
                        <button id="casA_btnClose" type="button" class="mui-button mui-button-new">Close</button>
                    </div>

                    <!-- FILTER -->
                    <div class="mt-1">
                        <div class="row g-2 align-items-center">

                            <!-- From Date -->
                            <div class="col-12 col-sm-6 col-md-3 col-lg-3 col-xl-3">
                                <div class="d-flex align-items-center gap-2">
                                    <label for="casA_fromDateUi"
                                        class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4
                                                fw-bold mb-0 text-nowrap text-md-end">
                                        From Date:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <div data-date-input data-format="DD/MM/YYYY" business-date data-name="casA_fromDate">
                                            <input id="casA_fromDateUi"
                                                name="casA_fromDateUi"
                                                type="text"
                                                class="date-ui form-control form-control-sm"
                                                placeholder="dd/mm/yyyy"
                                                autocomplete="off" />
                                        </div>
                                        <input type="hidden" id="casA_fromDate" name="casA_fromDate" />
                                    </div>
                                </div>
                            </div>

                            <!-- To Date -->
                            <div class="col-12 col-sm-6 col-md-3 col-lg-3 col-xl-3">
                                <div class="d-flex align-items-center gap-2">
                                    <label for="casA_toDateUi"
                                        class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4
                                                fw-bold mb-0 text-nowrap text-md-end">
                                        To Date:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <div data-date-input data-format="DD/MM/YYYY" business-date data-name="casA_toDate">
                                            <input id="casA_toDateUi"
                                                name="casA_toDateUi"
                                                type="text"
                                                class="date-ui form-control form-control-sm"
                                                placeholder="dd/mm/yyyy"
                                                autocomplete="off" />
                                        </div>
                                        <input type="hidden" id="casA_toDate" name="casA_toDate" />
                                    </div>
                                </div>
                            </div>

                            <!-- Login Name -->
                            <div class="col-12 col-sm-6 col-md-3 col-lg-3 col-xl-3">
                                <div class="d-flex align-items-center gap-2">
                                    <label for="casA_userName"
                                        class="col-4 col-sm-4 col-md-5 col-lg-4 col-xl-4
                                                fw-bold mb-0 text-nowrap text-md-end">
                                        Login Name:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-7 col-lg-8 col-xl-8">
                                        <select id="casA_userName"
                                                name="casA_userName"
                                                class="tomselect-custom w-100"
                                                multiple>
                                            @foreach (var u in ViewBag.UsersList)
                                            {
                                                <option value="@u.LoginName">@u.LoginName</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Shift -->
                            <div class="col-12 col-sm-6 col-md-3 col-lg-2 col-xl-2">
                                <div class="d-flex align-items-center gap-2">
                                    <label for="casA_shiftID"
                                        class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4
                                                fw-bold mb-0 text-nowrap text-md-end">
                                        Shift:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <input type="text"
                                            id="casA_shiftID"
                                            name="casA_shiftID"
                                            class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>

                            <!-- Option -->
                            <div class="col-12">
                                <div class="row g-1 align-items-center">
                                    <label class="col-12 col-md-1 text-md-end mb-0 fw-bold text-nowrap">
                                        Option:
                                    </label>

                                    <div class="col-12 col-md-10 d-flex flex-wrap gap-2">
                                        <div class="form-check form-check-inline mb-0">
                                            <input type="radio"
                                                name="casA_optionFilter"
                                                id="casA_allShift"
                                                value="All"
                                                checked>
                                            <label class="form-check-label text-nowrap" for="casA_allShift">
                                                All shift
                                            </label>
                                        </div>

                                        <div class="form-check form-check-inline mb-0">
                                            <input type="radio"
                                                name="casA_optionFilter"
                                                id="casA_onlyTransaction"
                                                value="Only">
                                            <label class="form-check-label text-nowrap" for="casA_onlyTransaction">
                                                Only Transaction Posted
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
                
                <!-- GRID -->
                <div class="mui-card">
                    <div id="casA_gridWrapper" class="mt-2" style="max-height: 500px;">
                        <div class="gridContainer" id="casA_gridContainer"></div>
                    </div>
                </div>

                <!-- LOADING -->
                <div id="casA_loadingSpinner"
                    style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                    z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                    height: 100%;display: flex;align-items: center;justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- DETAIL MODAL (XL) -->
<div class="modal fade" id="casA_modalDetail" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header py-2">
                <h6 class="modal-title" id="casA_modalDetailTitle">Transactions Shift Detail</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">

                <div class="mb-2 mt-1">
                    <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>

                <!-- HEADER INFO -->
                <div class="row g-2 mb-2">

                    <div class="col-lg-4 col-md-4 col-8 d-flex align-items-center">
                        <label class="col-5 me-2 text-end">Cashier No</label>
                        <input id="casA_m_cashierNo" name="casA_m_cashierNo" class="form-control form-control-sm flex-grow-1" readonly />
                    </div>

                    <div class="col-lg-4 col-md-4 col-8 d-flex align-items-center">
                        <label class="col-5 me-2 text-end">Shift No</label>
                        <input id="casA_m_shiftNo" name="casA_m_shiftNo" class="form-control form-control-sm flex-grow-1" readonly />
                    </div>

                    <div class="col-lg-4 col-md-4 col-8 d-flex align-items-center">
                        <label class="col-5 me-2 text-end">Shift Date</label>
                        <div data-date-input data-format="DD/MM/YYYY" data-name="casA_m_shiftDate" class="flex-grow-1">
                            <input type="text"
                                   id="casA_m_shiftDate"
                                   name="casA_m_shiftDate"
                                   class="date-ui form-control form-control-sm"
                                   placeholder="dd/mm/yyyy"
                                   autocomplete="off"
                                   disabled />
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-4 col-8 d-flex align-items-center">
                        <label class="col-5 me-2 text-end">User Name</label>
                        <input id="casA_m_userName" name="casA_m_userName" class="form-control form-control-sm flex-grow-1" readonly />
                    </div>

                    <div class="col-lg-4 col-md-4 col-8 d-flex align-items-center">
                        <label class="col-5 me-2 text-end">Login Time</label>
                        <input id="casA_m_loginTime" name="casA_m_loginTime" class="form-control form-control-sm flex-grow-1" readonly />
                    </div>

                    <div class="col-lg-4 col-md-4 col-8 d-flex align-items-center">
                        <label class="col-5 me-2 text-end">Full Name</label>
                        <input id="casA_m_fullName" name="casA_m_fullName" class="form-control form-control-sm flex-grow-1" readonly />
                    </div>

                </div>

                <div class="mui-card">
                    <div id="casA_gridShiftDetail" class="gridContainer" style="height:420px"></div>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
    const casA_Module = (function () {

        let mainModal = null;
        let detailModal = null;

        let tsUser = null;

        let selectedRow = null;

        let originalData = [];
        let detailGridInstance = null;

        const sel = {
            modalMain: "#casA_modalMain",
            modalDetail: "#casA_modalDetail",

            btnView: "#casA_btnView",
            btnDetail: "#casA_btnDetail",
            btnExcel: "#casA_btnExportExcel",
            btnClose: "#casA_btnClose",

            loading: "#casA_loadingSpinner",

            fromHidden: "#casA_fromDate",
            toHidden: "#casA_toDate",

            userName: "#casA_userName",
            shiftID: "#casA_shiftID",

            optName: "casA_optionFilter",

            gridMain: "#casA_gridContainer",

            m_cashierNo: "#casA_m_cashierNo",
            m_shiftNo: "#casA_m_shiftNo",
            m_shiftDateName: "casA_m_shiftDate",
            m_shiftDate: "#casA_m_shiftDate",
            m_userName: "#casA_m_userName",
            m_loginTime: "#casA_m_loginTime",
            m_fullName: "#casA_m_fullName",

            gridDetail: "#casA_gridShiftDetail"
        };

        function init() {
            mainModal = bootstrap.Modal.getOrCreateInstance(document.querySelector(sel.modalMain), { backdrop: "static" });
            detailModal = bootstrap.Modal.getOrCreateInstance(document.querySelector(sel.modalDetail), { backdrop: "static" });

            $(sel.modalMain).off("shown.bs.modal.casA").on("shown.bs.modal.casA", async function () {
                bindEvents();
                initPickers();
                initTomSelects();
                await ensureBusinessDate();
                await view(true);
            });

            $(sel.modalMain).off("hidden.bs.modal.casA").on("hidden.bs.modal.casA", function () {
                cleanup();
            });

            $(sel.modalDetail).off("hidden.bs.modal.casA").on("hidden.bs.modal.casA", function () {
                // keep detail grid instance cached; no heavy cleanup needed
            });
        }

        function open() {
            mainModal.show();
        }

        function bindEvents() {
            $(document)
                .off("click.casA", sel.btnView).on("click.casA", sel.btnView, async function () { await view(false); });

            $(document)
                .off("click.casA", sel.btnDetail).on("click.casA", sel.btnDetail, function () { openDetail(); });

            $(document)
                .off("click.casA", sel.btnExcel).on("click.casA", sel.btnExcel, function () { exportExcel(); });

            $(document)
                .off("click.casA", sel.btnClose).on("click.casA", sel.btnClose, function () { mainModal.hide(); });

            $(document)
                .off("change.casA", `input[name='${sel.optName}']`)
                .on("change.casA", `input[name='${sel.optName}']`, function () { applyFilterAndReload(); });
        }

        function initPickers() {
            if (typeof window.initDateInputs === "function") window.initDateInputs();
        }

        function initTomSelects() {
            destroyTomSelects();

            const el = document.querySelector(sel.userName);
            if (!el) return;

            tsUser = new TomSelect(el, {
                plugins: ['remove_button'],
                create: false,
                maxItems: null,
                allowEmptyOption: true,
                persist: false
            });
        }

        function destroyTomSelects() {
            try { if (tsUser) { tsUser.destroy(); tsUser = null; } } catch { }
        }

        async function ensureBusinessDate() {
            // Preferred business-date pipeline
            try {
                if (typeof window.waitForBusinessDate === "function") {
                    const fromIso = await window.waitForBusinessDate("casA_fromDate", 10000);
                    const toIso = await window.waitForBusinessDate("casA_toDate", 10000);

                    if (fromIso) $(sel.fromHidden).val(fromIso);
                    if (toIso) $(sel.toHidden).val(toIso);

                    if (fromIso && toIso) return;
                }
            } catch { }

            // Fallback endpoint
            return $.ajax({
                url: '/Reservation/GetBusinessDate',
                type: 'get',
                dataType: 'json',
                crossDomain: false,
                headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() },
                success: function (result) {
                    const iso = (result || "").split('T')[0];
                    $(sel.fromHidden).val(iso);
                    $(sel.toHidden).val(iso);
                },
                error: function (xhr) {
                    if (xhr.status === 401) sessionTimeout();
                }
            });
        }

        function getPayload(isInitial) {
            let fromDateISO = $(sel.fromHidden).val() || "";
            let toDateISO = $(sel.toHidden).val() || "";

            return {
                userName: ($(sel.userName).val() || []).map(r => (r || "").replace("''", "'")).join("','") || "",
                fromDate: fromDateISO,
                toDate: toDateISO,
                shiftID: $(sel.shiftID).val() || ""
            };
        }

        async function view(isInitial) {
            $(sel.loading).show();

            const payload = getPayload(isInitial);

            if (!payload.fromDate || !payload.toDate) {
                $(sel.loading).hide();
                showToast("Warning", "Please select From/To date.", false);
                return;
            }

            $.ajax({
                url: "/Cashiering/GetCashierAudit",
                type: "GET",
                data: payload,
                success: function (data) {
                    originalData = Array.isArray(data) ? data : [];
                    applyFilterAndReload();
                    $(sel.loading).hide();
                },
                error: function (xhr, status, error) {
                    console.error("Load error:", status, error);
                    $(sel.loading).hide();
                    showToast("Error", "Failed to load data.", false);
                    destroyMainGrid();
                }
            });
        }

        function getOption() {
            return $(`input[name='${sel.optName}']:checked`).val(); // All | Only
        }

        function applyFilterAndReload() {
            const option = getOption();
            let filtered = originalData;

            if (option === "Only") {
                filtered = originalData.filter(x => Number(x.countTransaction) > 0);
            }

            // Strict: only render if data valid
            if (!Array.isArray(filtered) || filtered.length === 0) {
                destroyMainGrid();
                showToast("Warning", "No records to display", false);
                return;
            }

            renderMainGrid(filtered);
        }

        function destroyMainGrid() {
            try {
                const inst = $(sel.gridMain).dxDataGrid("instance");
                if (inst) inst.dispose();
            } catch { }
            $(sel.gridMain).empty();
            selectedRow = null;
        }

        function renderMainGrid(data) {
            destroyMainGrid();

            $(sel.gridMain).dxDataGrid({
                dataSource: data,
                height: 500,
                width: "100%",
                showBorders: true,
                allowColumnResizing: true,
                selection: { mode: "single" },

                columns: [
                    { dataField: "date", caption: "Date", width: "8%", dataType: "date", format: "dd/MM/yyyy" },
                    {
                        dataField: "shiftNo",
                        caption: "Shift.No",
                        width: "8%",
                        cellTemplate: function (container, options) {
                            const count = options.data?.countTransaction || 0;
                            $("<span>")
                                .text(`${options.value} (${count})`)
                                .css("font-weight", count > 0 ? "bold" : "normal")
                                .appendTo(container);
                        }
                    },
                    { dataField: "cashierNo", caption: "Cashier.No", width: "8%" },
                    {
                        dataField: "amountVND",
                        caption: "Amount (VND)",
                        width: "9%",
                        dataType: "number",
                        alignment: "right",
                        customizeText: function (e) {
                            const v = e.value || 0;
                            return v.toLocaleString("vi-VN", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                        }
                    },
                    { dataField: "amountUSD", caption: "Amount (USD)", width: "8%", dataType: "number", alignment: "right" },
                    { dataField: "userName", caption: "User", width: "8%" },
                    { dataField: "fullName", caption: "Full Name", width: "16%" },
                    { dataField: "loginTime", caption: "Login Time", width: "11%" },
                    { dataField: "logoutTime", caption: "Logout Time", width: "11%", dataType: "date" },
                    { dataField: "status", caption: "Status", width: "7%" },
                    { dataField: "countTransaction", visible: false }
                ],

                scrolling: { mode: "standard", showScrollbar: "always", scrollByContent: true },
                paging: { pageSize: 50 },
                pager: {
                    visible: true,
                    allowedPageSizes: [50, 100, 'all'],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: { visible: true, applyFilter: "auto" },

                onRowClick: function (e) {
                    selectedRow = e.data || null;
                }
            });
        }

        function ensureDetailGrid() {
            if (detailGridInstance) return;

            detailGridInstance = $(sel.gridDetail).dxDataGrid({
                dataSource: [],
                showBorders: true,
                height: 500,
                grouping: { autoExpandAll: true },
                columns: [
                    { dataField: "paymentType", caption: "Payment", groupIndex: 0 },
                    { dataField: "currencyID", caption: "Currency", groupIndex: 1 },
                    { dataField: "transactionCode", caption: "Trans. Code" },
                    { dataField: "description", caption: "Description" },
                    { dataField: "amount", caption: "Amount", dataType: "number", format: "#,##0.00" },
                    { dataField: "transactionDate", caption: "Date", dataType: "date", format: "dd/MM/yyyy" },
                    {
                        caption: "Time",
                        dataType: "datetime",
                        format: "HH:mm:ss",
                        calculateCellValue: row => new Date(row.transactionDate)
                    },
                    { dataField: "reference", caption: "Reference" },
                    { dataField: "supplement", caption: "Supplement" },
                    { dataField: "folioID", caption: "FolioNo" },
                    { dataField: "roomNo", caption: "Room" },
                    { dataField: "account", caption: "Account" }
                ]
            }).dxDataGrid("instance");
        }

        function openDetail() {
            if (!selectedRow) {
                showToast("Warning", "Please select 1 row to update.", false);
                return;
            }
            loadShiftDetail(selectedRow.shiftNo);
        }

        function loadShiftDetail(shiftId) {
            $.ajax({
                url: "/Cashiering/GetShiftDetail",
                type: "GET",
                data: { shiftID: shiftId, type: 0 },
                success: function (data) {
                    ensureDetailGrid();

                    detailGridInstance.option("dataSource", (data && data.details) ? data.details : []);

                    $(sel.m_cashierNo).val(selectedRow.cashierNo ?? "");
                    $(sel.m_shiftNo).val(selectedRow.shiftNo ?? "");

                    // Use your dateInput wrapper if present
                    const dateInput = document.querySelector(`[data-name='${sel.m_shiftDateName}']`)?.dateInput;
                    if (dateInput && selectedRow.date) dateInput.setISO(selectedRow.date);

                    $(sel.m_userName).val(selectedRow.userName ?? "");
                    $(sel.m_loginTime).val(selectedRow.loginTime ?? "");
                    $(sel.m_fullName).val(selectedRow.fullName ?? "");

                    detailModal.show();
                },
                error: function () {
                    showToast("Error", "Failed to load detail.", false);
                }
            });
        }

        function exportExcel() {
            const grid = $(sel.gridMain).dxDataGrid("instance");
            if (!grid) {
                showToast("Warning", "No data to export.", false);
                return;
            }

            const workbook = new ExcelJS.Workbook();
            const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const worksheet = workbook.addWorksheet("Sheet 1");

            worksheet.addRow([companyName]);
            worksheet.mergeCells('A1:D1');
            worksheet.getRow(1).font = { bold: true };
            worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

            const now = new Date();
            const exportDate = now.toLocaleString("vi-VN");
            worksheet.addRow(['', '', '', exportDate]);
            worksheet.mergeCells('D2:D2');
            worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

            worksheet.addRow([]);
            worksheet.addRow([]);

            const reportRow = worksheet.addRow(['Cashier Audit']);
            worksheet.mergeCells('A5:D5');
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

            worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const lastRow = worksheet.lastRow.number + 2;
                worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
                worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
                worksheet.getCell(`A${lastRow}`).font = { italic: true };

                let fileName = "Cashier Audit.xlsx";
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
                });
            });
        }

        function cleanup() {
            destroyTomSelects();
            destroyMainGrid();
            // keep detail grid instance (optional). If you want strict dispose, uncomment:
            // try { if (detailGridInstance) { detailGridInstance.dispose(); detailGridInstance = null; $(sel.gridDetail).empty(); } } catch { }

            $(document).off(".casA");
        }

        return { init, open };

    })();

    // Option A global entry
    window.openModalCasA = function () {
        casA_Module.open();
    };

    $(document).ready(function () {
        casA_Module.init();
        // If you want auto-open:
        // window.openModalCasA();
    });
</script>