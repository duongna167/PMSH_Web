@using DevExpress.XtraReports.UI

@{
   
}

<style>
    .btn-modal-detail {
        width: 28px;
        height: 28px;
        border: 1px solid rgba(0,0,0,0.5);
        background: #ffffff;
        color: #222;
        font-size: 16px;
        font-weight: 600;
        line-height: 1;
        border-radius: 4px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.15s ease;
    }

        /* Hover */
        .btn-modal-detail:hover {
            background: #f0f0f0;
            border-color: rgba(0,0,0,0.7);
        }

        /* Active (khi nhấn) */
        .btn-modal-detail:active {
            background: #e0e0e0;
            transform: scale(0.95);
        }

        /* Focus */
        .btn-modal-detail:focus {
            outline: none;
            box-shadow: 0 0 0 2px rgba(0,0,0,0.1);
        }
    /* Cố định chiều cao hàng trên Desktop để có scroll riêng từng bảng */
    @@media (min-width: 768px) {
        .row-top-grids {
            height: 300px !important;
            flex-shrink: 0;
        }

        .row-bottom-resv {
            flex-grow: 1;
            min-height: 0;
        }
    }

    /* Responsive cho Mobile */
    @@media (max-width: 767px) {
        .modal-body {
            height: auto !important;
            overflow-y: auto !important;
        }

        .row-top-grids, .row-bottom-resv {
            height: auto !important;
            display: block !important;
        }

            .row-top-grids > div, .row-bottom-resv > div {
                height: 350px !important; /* Cố định chiều cao mỗi bảng trên mobile để Grid không bị mất scroll */
                margin-bottom: 25px;
            }

        .grid-wrapper {
            height: 100% !important;
        }
    }

    /* Đẩy lề phải cho cột Total để không bị giáp lề */
    .grid-column-total {
        padding-right: 15px !important;
        font-weight: bold;
        color: #000;
    }

    /* Đảm bảo toàn bộ các ô căn lề phải có khoảng cách an toàn */
    .dx-datagrid-rowsview .dx-row > td {
        padding-right: 8px !important;
    }

    .dx-loadpanel-content {
        background: transparent !important;
        box-shadow: none !important;
        border: none !important;
    }

    .dx-overlay-shader {
        background: rgba(255,255,255,0.55) !important;
    }

    .custom-loader-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Tiêu đề bảng */
    .table-header-custom {
        font-size: 14px;
        font-weight: bold;
        color: #000;
        border-bottom: 2px solid #009444;
        padding-bottom: 5px;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* Hàng chứa bảng Reservation bên dưới sẽ tự chiếm phần còn lại */
    .row-bottom-resv {
        flex-grow: 1;
        min-height: 0;
    }

    .grid-wrapper {
        display: flex;
        flex-direction: column;
        height: 100%;
        min-height: 0; /* Quan trọng để flexbox tính toán đúng */
        position: relative;
    }

    /* Đảm bảo bản thân component Grid chiếm trọn wrapper */
    #allot_search_gridAllotInfor,
    #allot_search_gridAllotDetail,
    #allot_search_gridReservation {
        flex-grow: 1;
        height: 100% !important;
        width: 100% !important;
    }

    /* Loại bỏ lề mặc định của container-fluid bên trong body modal nếu cần */
    .modal-body .container-fluid {
        display: flex;
        flex-direction: column;
    }
</style>
<div class="modal fade" id="allot_search_modal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-light py-2">
                <h5 class="modal-title">Allotment Search</h5>
            </div>

            <div class="modal-body d-flex flex-column" style="height: calc(100vh - 120px);">
                <div class="py-2">
                    <button id="allot_search_btnView" class="mui-button mui-button-view">View</button>
                    <button id="allot_search_btnNew" class="mui-button mui-button-new">New</button>
                    <button id="allot_search_btnEdit" class="mui-button mui-button-edit">Edit</button>
                    <button id="allot_search_btnDelete" class="mui-button mui-button-delete">Delete</button>
                    <button id="allot_search_btnDetail" class="mui-button mui-button-new">Detail</button>
                    <button id="allot_search_btnExportExcel" class="mui-button mui-button-export">Excel</button>
                    <button class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                </div>
                <div class="mui-card mb-2 bg-light border-0 d-flex flex-column flex-grow-1 overflow-hidden">

                    <div class="p-2 flex-shrink-0">
                        <div class="row g-3 align-items-center flex-wrap">

                            <div class="col-auto d-flex align-items-center">
                                <label class="fw-bold small me-2 mb-0">Code</label>
                                <input type="text" id="allot_search_code" class="form-control form-control-sm" style="width: 150px;" placeholder="Enter code...">
                            </div>

                            <div class="col-auto d-flex align-items-center">
                                <label class="fw-bold small me-2 mb-0">Market</label>
                                <div style="width: 120px;">
                                    <select id="allot_search_market" class="tomselect-custom w-100">
                                        @foreach (var z in ViewBag.MarketList)
                                        {
                                            <option value="@z.ID">@z.Code</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="col-auto d-flex align-items-center">
                                <label class="fw-bold small me-2 mb-0">All.Type</label>
                                <div style="width: 100px;">
                                    <select id="allot_search_type" class="tomselect-custom w-100">
                                        @foreach (var g in ViewBag.AllotTypeList)
                                        {
                                            <option value="@g.ID">@g.Code</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="col-auto d-flex align-items-center">
                                <label class="fw-bold small me-2 mb-0">Profile</label>
                                <div class="d-flex gap-1">
                                    <input id="allot_search_profileId" type="hidden" />
                                    <input id="allot_search_profileName" class="form-control form-control-sm" style="width: 130px;" placeholder="" />
                                    <button onclick="allot_search_Module.openProSearchModal()" class="" data-tooltip="Search Profile">
                                        <i class="fa-solid fa-arrow-down text-dark"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="col-auto d-flex align-items-center">
                                <label class="fw-bold small me-2 mb-0">Zone</label>
                                <div style="width: 120px;">
                                    <select id="allot_search_zone" class="tomselect-custom w-100" multiple>
                                        @foreach (var z in ViewBag.ZoneList)
                                        {
                                            <option value="@z.Code">@z.Code</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="col-auto d-flex align-items-center">
                                <input class="" type="checkbox" id="allot_search_default">
                                <label class="form-check-label small ms-1" for="allot_search_default" style="font-size: 11px;">Default</label>
                            </div>

                            <div class="col-auto d-flex align-items-center">
                                <input class="" type="checkbox" id="allot_search_history">
                                <label class="form-check-label small ms-1" for="allot_search_history" style="font-size: 11px;">Show history</label>
                            </div>
                        </div>

                    </div>

                    <div class="gridContainer flex-grow-1 d-flex flex-column position-relative py-2">
                        <div class="container-fluid px-0 h-100 d-flex flex-column">

                            <div class="row g-3 mb-3 row-top-grids">
                                <div class="col-md-6 d-flex flex-column h-100">
                                    <div class="table-header-custom flex-shrink-0">Allotment Information</div>
                                    <div class="grid-wrapper">
                                        <div id="allot_search_gridAllotInfor"></div> 
                                    </div>
                                </div>

                                <div class="col-md-6 d-flex flex-column h-100">
                                    <div class="table-header-custom flex-shrink-0">Allotment Detail</div>
                                    <div class="grid-wrapper">
                                        <div id="allot_search_gridAllotDetail"></div> 
                                    </div>
                                </div>
                            </div>

                            <div class="row row-bottom-resv">
                                <div class="col-12 d-flex flex-column h-100">
                                    <div class="table-header-custom flex-shrink-0">Reservation</div>
                                    <div class="grid-wrapper">
                                        <div id="allot_search_gridReservation"></div> 
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Popup for New Item -->
<div class="modal fade" id="allot_setup_itemModal" tabindex="-1" data-bs-backdrop="static" aria-labelledby="allot_setup_label" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="allot_setup_label">Allotment Setup</h5>
            </div>

            <div class="modal-body">

                <!-- Action -->
                <div class="py-2">
                    <button id="allot_setup_btnSaveItem" class="mui-button mui-button-save">Save</button>
                    <button data-bs-dismiss="modal" class="mui-button mui-button-close">Close</button>

                </div>

                <form id="allot_setup_formContainer">
                    <div class="container-fluid px-2">

                        <input type="hidden" id="allot_setup_id" name="id" value="0" />

                        <div class="row g-2">

                            <div class="col-12 col-lg-9">

                                <!-- Code -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-semibold mb-1 mb-md-0 text-end">
                                        Code <span class="text-danger">*</span>
                                    </div>
                                    <div class="col-12 col-md-8 text-start">
                                        <input type="text"
                                               id="allot_setup_code"
                                               name="allot_setup_code"
                                               class="form-control form-control-sm" />
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>

                                <!-- Name -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-bold mb-1 mb-md-0 text-end">
                                        Name
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <input type="text"
                                               id="allot_setup_name"
                                               name="allot_setup_name"
                                               class="form-control form-control-sm" />
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>

                                <!-- Profile -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-semibold mb-1 mb-md-0 text-end">
                                        Profile <span class="text-danger">*</span>
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <div class="input-group input-group-sm">
                                            <input id="allot_setup_profileID" type="hidden" />
                                            <input id="allot_setup_profileName"
                                                   class="form-control"
                                                   placeholder="..."
                                                   readonly />
                                            <button class="btn btn-outline-secondary"
                                                    type="button"
                                                    onclick="allot_search_Module.openProAllotModal()"
                                                    data-tooltip="Search Profile">
                                                <i class="fa-solid fa-arrow-down text-dark"></i>
                                            </button>
                                        </div>
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>

                                <!-- Market -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-bold mb-1 mb-md-0 text-end">
                                        Market
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <select id="allot_setup_marketID"
                                                name="allot_setup_marketID"
                                                class="tomselect-custom w-100">
                                            @foreach (var u in ViewBag.MarketList)
                                            {
                                                <option value="@u.ID">@u.Code - @u.Name</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <!-- Allotment Type -->
                                <div class="row mb-3 align-items-center">
                                    <div class="col-12 col-md-4 fw-semibold mb-1 mb-md-0 text-end">
                                        All.Type <span class="text-danger">*</span>
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <select id="allot_setup_type"
                                                name="allot_setup_type"
                                                class="tomselect-custom w-100">
                                            @foreach (var u in ViewBag.AllotTypeList)
                                            {
                                                <option value="@u.ID">@u.Code - @u.Name</option>
                                            }
                                        </select>
                                        <div class="invalid-feedback"></div>
                                    </div>
                                </div>

                            </div>

                        </div>
                    </div>
                </form>

            </div>

        </div>
    </div>
</div>

<!-- Modal Detail by Stage -->
<div class="modal fade" id="allot_detail_modal" tabindex="-1" data-bs-backdrop="static" aria-labelledby="allot_detail_label" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2 bg-light">
                <h5 class="modal-title" id="allot_detail_label" style="font-size: 14px;">Allotment Detail by Stage</h5>
            </div>

            <div class="modal-body d-flex flex-column" style="height: 500px;">
                <div class="py-2 d-flex align-items-center gap-2 border-bottom mb-2">
                    <button id="allot_detail_btnSearchDetail" class="mui-button mui-button-view">Search</button>
                    <button id="allot_detail_btnExport" class="mui-button mui-button-export">Export</button>
                    <button data-bs-dismiss="modal" class="mui-button mui-button-close">Close</button>
                </div>

                <div class="grid-wrapper gridContainer flex-grow-1">
                    <div id="allot_detail_gridAllotDetailByStage"></div>
                </div>

                <div class="py-2 d-flex align-items-center gap-3 border-top mt-2">
                    <div class="d-flex align-items-center gap-1">
                        <button class="btn-modal-detail" onclick="allot_search_Module.changeDetailDate(-1)">-</button>
                        <div data-date-input data-format="DD/MM/YYYY" data-name="allot_detail_searchDate">
                            <input type="text" class="date-ui form-control form-control-sm" style="width: 120px;">
                        </div>
                        <button class="btn-modal-detail" onclick="allot_search_Module.changeDetailDate(1)">+</button>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <label class="small fw-bold mb-0">Display No of Days</label>
                        <select id="allot_detail_noOfDays" class="form-select form-select-sm" style="width: 70px;">
                            <option value="10">10</option>
                            <option value="15">15</option>
                            <option value="20" selected>20</option>
                            <option value="30">30</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>

    var allot_search_Module = {
        selectedRowData: null,
        selectedDetailRow: null,
        currentNoOfDays: 20,

        baseGridOptions: {
            height: "100%",
            width: "100%",
            showBorders: true,
            hoverStateEnabled: true,
            wordWrapEnabled: false,
            allowColumnResizing: true,
            columnResizingMode: "widget",
            columnAutoWidth: false,
            selection: { mode: "single" },
            scrolling: {
                mode: "standard",
                showScrollbar: "always",
                useNative: false
            },
            loadPanel: {
                enabled: false
            },
            filterRow: { visible: true, applyFilter: "auto" }
        },

        initGrid: function (containerId, options) {
            const fullOptions = $.extend(true, {}, this.baseGridOptions, options);
            return $(containerId).dxDataGrid(fullOptions);
        },

        init: function () {
            this.initEvents();
            this.intitDOMEvents();
        },

        initEvents: function () {
            const self = this;

            window.openModalAllotSearch = function () {
                initTomSelect(".tomselect-custom");
                clearMultipleTomSelect([
                    "#allot_search_market",
                    "#allot_search_type"
                ]);
                self.reloadGrid();

            };

            $('#allot_setup_itemModal').on('hidden.bs.modal', function () {
                ValidationAdapter.clear("#allot_setup_formContainer");
            });

            // events input
            $("#allot_setup_formContainer").on("input", "input, textarea", function () {
                if ($(this).hasClass("is-invalid")) {
                    ValidationAdapter.clearField(this);
                }
            });

            // event tomselect
            $("#allot_setup_formContainer").on("change", "select.tomselect-custom", function () {
                if (this.tomselect) {
                    ValidationAdapter.clearField(this);
                }
            });
        },

        intitDOMEvents: function () {
            const self = this;
            $("#allot_search_btnView").on("click", () => self.reloadGrid());
            $("#allot_search_btnNew").on("click", () => self.openNewModal());
            $("#allot_search_btnEdit").on("click", () => self.openEditModal());
            $("#allot_setup_btnSaveItem").on("click", () => self.saveAllotment());
            $("#allot_search_btnDelete").on("click", () => self.confirmDelete());
            $("#allot_search_btnExportExcel").on("click", () => self.exportAllotInfoToExcel());
            $("#allot_search_btnDetail").on("click", () => self.openModalDetail());
            $("#allot_detail_btnSearchDetail").on("click", () => self.fetchDetailByStage());
            $("#allot_detail_btnExport").on("click", () => self.exportDetailStageToExcel());
            

            $("#allot_search_profileName").on("input", function() {
                if ($(this).val().trim() === "") {
                    $("#allot_search_profileId").val("");
                }
            });

            $("#allot_detail_noOfDays").on("change", function () {
                allot_search_Module.fetchDetailByStage();
            });
        },

        reloadGrid: function () {
            const self = this;

            const filterData = {
                code: $("#allot_search_code").val(),
                marketID: getTomSelectData("#allot_search_market")?.value,
                allotmentTypeID: getTomSelectData("#allot_search_type")?.value,
                profileID: $("#allot_search_profileId").val(),
                zone: (getTomSelectData("#allot_search_zone") || []).map(x => x.value).join(","),
                isDefault: $('#allot_search_default').is(':checked') ? 1 : 0
            };

            self.renderDetailGrid([]);
            self.renderResvGrid([]);

            // $("#allot_search_loading").show();
            $.ajax({
                url: '/Allotment/GetAllotmentSearch',
                type: 'GET',
                data: filterData,
                success: function (data) {
                    self.renderMainGrid(data);

                    if (data && data.length > 0) {
                        const firstRow = data[0];
                        self.selectedRowData = firstRow; 

                        self.fetchAllotmentDetail(firstRow.id);
                        self.fetchReservation(firstRow.id, "");
                    } else {
                        self.renderDetailGrid([]);
                        self.renderResvGrid([]);
                    }

                    // $("#allot_search_loading").hide();
                },
                error: function (xhr, status, error) {
                    showToast("Error", "Unable to load data", false);
                    // $("#allot_search_loading").hide();
                }
            });
        },

        renderMainGrid: function (data) {
            const self = this;
            var listMarket = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.MarketList ?? new List<object>()));
            var listAllType = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.AllotTypeList ?? new List<object>()));

            self.initGrid("#allot_search_gridAllotInfor",{
                dataSource: data,
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "profileID", visible: false },
                    { dataField: "code",caption: "All.Code",width: 110 },
                    { dataField: "allotmentName",caption: "All.Name",width: 180},
                    { dataField: "accountName",caption: "Profile",width: 180},
                    // { dataField: "marketID", visible: false },
                    {
                        dataField: "marketID",
                        caption: "Market",
                        width: 100,
                        lookup: {
                            dataSource: listMarket,
                            valueExpr: "ID",
                            displayExpr: "Name"
                        }
                    },
                    // { dataField: "allotmentTypeID", visible: false },
                    {
                        dataField: "allotmentTypeID",
                        caption: "All.Type",
                        width: 100,
                        lookup: {
                            dataSource: listAllType,
                            valueExpr: "ID",
                            displayExpr: "Name"
                        }
                    },
                    { dataField: "cuttOfDay", caption: "Cutt.Day",width: 70 },
                    { dataField: "cuttOfDate", caption: "Cutt.Date", dataType: "date", format: "dd/MM/yyyy",  width: 110 },
                    { dataField: "createBy", caption: "Created By", width: 90 },
                    { dataField: "createDate",  caption: "Created Date", dataType: "date", format: "dd/MM/yyyy hh:mm", width: 110 }, 
                    { dataField: "updateBy", caption: "Updated By", width: 90 },
                    { dataField: "updateDate", caption: "Updated Date", dataType: "date", format: "dd/MM/yyyy hh:mm", width: 110 }
                ],

                onSelectionChanged: function (e) {
                    const selectedRow = e.selectedRowsData[0];
                    if (selectedRow) {
                        self.selectedRowData = selectedRow;

                        self.resetDetailGrids();

                        self.fetchAllotmentDetail(selectedRow.id);
                        self.fetchReservation(selectedRow.id, "");
                    }
                }
            });

        },

        fetchAllotmentDetail: function(allotmentId) {
            const self = this;
            const isHistory = $("#allot_search_history").is(":checked");

            $.get('/Allotment/GetAllotmentDetail', { allotmentId: allotmentId, isHistoryChecked: isHistory }, function(res) {
                self.renderDetailGrid(res.data, res.roomTypeColumns);;
            });
        },

        renderDetailGrid: function (data, roomTypeColumns) {
            const self = this;

            // Định nghĩa các cột cố định ban đầu
            let dynamicColumns = [
                { dataField: "From Date", caption: "From Date", width: 90 },
                { dataField: "To Date", caption: "To Date", width: 90 },
                { dataField: "Stage", caption: "Stage", width: 70 },
                { dataField: "CutOff", caption: "CutOff", width: 60 }
            ];

            // Thêm các cột RoomType dựa trên danh sách từ Server (luôn có dù data rỗng)
            if (roomTypeColumns) {
                roomTypeColumns.forEach(colName => {
                    dynamicColumns.push({
                        dataField: colName,
                        caption: colName,
                        width: 60,
                        alignment: "right"
                    });
                });
            }

            // Thêm cột Total cuối cùng và xử lý lề (padding)
            dynamicColumns.push({
                dataField: "Total",
                caption: "Total",
                width: 70,
                alignment: "right",
                cssClass: "grid-column-total"
            });

            self.initGrid("#allot_search_gridAllotDetail", {
                dataSource: data,
                columns: dynamicColumns,
                columnAutoWidth: false,
                wordWrapEnabled: false
            });
        },

        resetDetailGrids: function () {
            const detailGrid = $("#allot_search_gridAllotDetail").dxDataGrid("instance");
            const reservationGrid = $("#allot_search_gridReservation").dxDataGrid("instance");

            if (detailGrid) {
                detailGrid.option("dataSource", []);
            }

            if (reservationGrid) {
                reservationGrid.option("dataSource", []);
            }
        },

        fetchReservation: function(allotmentId, roomTypeCode) {
            const self = this;
            // $("#allot_search_loading").show();

            $.get('/Allotment/GetAllotmentResvSearch', {
                allotmentId: allotmentId,
                roomTypeCode: roomTypeCode
            }, function(res) {
                self.renderResvGrid(res);
                // $("#allot_search_loading").hide();
            }).fail(function() {
