@using DevExpress.XtraReports.UI
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewBag.Title = ViewBag.ReportHeader;
    var uList = ViewBag.UsersList;
}
@* <link href="~/css/pages/reservation.css" rel="stylesheet" /> *@
<style>
    .modal-body {
        padding: 0 12px 0 12px !important;
    }

    .mui-card {
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1) !important;
        min-height: 50vh;
        padding: 10px;
    }
</style>
<div>
    <div class="text-center" id="reportTitle" style="font-size: 20px">Folio History </div>
    <div class="search-filter">

        <!-- ACTION BUTTONS -->
        <div class="d-flex gap-2 mb-2">
            <button id="btnView" type="button" class="mui-button mui-button-new">View</button>
            <button id="btnDetail" type="button" class="mui-button mui-button-new">Details</button>
            <button id="btnExportExcel" type="button" class="mui-button mui-button-new">Excel</button>
        </div>

        <!-- FILTER CONTENT -->
        <div class="row g-2 align-items-start">

            <!-- DATE FILTER -->
            <div class="col-lg-2 col-md-6">

                <div class="d-flex align-items-center">
                    <label class="col-md-2 col-form-label me-2 text-end">From:</label>
                    <div data-date-input data-format="DD/MM/YYYY" business-date data-name="fromDate">
                        <input type="text" class="date-ui form-control form-control-sm w-auto" placeholder="dd/mm/yyyy"
                            autocomplete="off" />
                    </div>
                </div>

                <div class="d-flex align-items-center">
                    <label class="col-md-2 col-form-label me-2 text-end">To:</label>
                    <div data-date-input data-format="DD/MM/YYYY" business-date data-name="toDate">
                        <input type="text" class="date-ui form-control form-control-sm w-auto" placeholder="dd/mm/yyyy"
                            autocomplete="off" />
                    </div>
                </div>
            </div>

            <!-- CARD CATEGORY -->
            <div class="col-lg-4 col-md-6">

                <!-- Folio -->
                <div class="row g-1">
                    <div class="col-6 d-flex align-items-center">
                        <label class="col-md-4 col-form-label me-2 text-end">From Folio:</label>
                        <input type="text" id="fromFolio" class="form-control form-control-sm flex-grow-1">
                    </div>

                    <div class="col-6 d-flex align-items-center">
                        <label class="col-md-4 col-form-label me-2 text-end">To Folio:</label>
                        <input type="text" id="toFolio" class="form-control form-control-sm flex-grow-1">
                    </div>
                </div>

                <!-- Room -->
                <div class="row g-1 ">
                    <div class="col-6 d-flex align-items-center">
                        <label class="col-md-4 col-form-label me-2 text-end">From Room:</label>
                        <input type="text" id="fromRoom" class="form-control form-control-sm flex-grow-1">
                    </div>

                    <div class="col-6 d-flex align-items-center">
                        <label class="col-md-4 col-form-label me-2 text-end">To Room:</label>
                        <input type="text" id="toRoom" class="form-control form-control-sm flex-grow-1">
                    </div>
                </div>

                <!-- Users -->
                <div class="d-flex align-items-center">
                    <label class="col-md-2 col-form-label me-3 text-end">Users:</label>
                    <select id="users" name="users" class="tomselect-custom flex-grow-1 me-2" multiple>
                        @foreach (var sg in ViewBag.UsersList)
                        {
                            <option value="@sg.LoginName">
                                @sg.LoginName - @sg.LastName
                            </option>
                        }
                    </select>
                </div>
            </div>

            <!-- ACTION -->
            <div class="col-lg-6 col-md-12">
                <div class="row g-1 ms-3">
                    <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                        <label class="small d-flex align-items-center gap-1">
                            <input type="checkbox" id="allAction" value="" checked>
                            All Action
                        </label>
                    </div>
                </div>
                <hr class="my-2">
                <div class="row g-1 ms-3" id="action">
                    <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                        <label class="small d-flex align-items-center gap-1">
                            <input type="checkbox" id="nightPost" value="2" checked>
                            NIGHT_POST
                        </label>
                    </div>
                    <div class="col-6 col-sm-4 col-md-3 col-lg-2"><label
                            class="small d-flex align-items-center gap-1"><input type="checkbox" id="earlyCheckout"
                                value="3" checked>
                            EARLY_CHECKOUT</label></div>
                    <div class="col-6 col-sm-4 col-md-3 col-lg-2"><label
                            class="small d-flex align-items-center gap-1"><input type="checkbox" id="tranferred"
                                value="7" checked>
                            TRANSFERRED</label></div>

                    <div class="col-6 col-sm-4 col-md-3 col-lg-2"><label
                            class="small d-flex align-items-center gap-1"><input type="checkbox" id="postGen" value="0"
                                checked>
                            POST_GEN</label></div>
                    <div class="col-6 col-sm-4 col-md-3 col-lg-2"><label
                            class="small d-flex align-items-center gap-1"><input type="checkbox" id="advanceBill"
                                value="4" checked>
                            ADVANCE_BILL</label></div>
                    <div class="col-6 col-sm-4 col-md-3 col-lg-2"><label
                            class="small d-flex align-items-center gap-1"><input type="checkbox" id="correct" value="5"
                                checked>
                            CORRECT</label></div>

                    <div class="col-6 col-sm-4 col-md-3 col-lg-2"><label
                            class="small d-flex align-items-center gap-1"><input type="checkbox" id="post" value="1"
                                checked>
                            POST</label></div>
                    <div class="col-6 col-sm-4 col-md-3 col-lg-2"><label
                            class="small d-flex align-items-center gap-1"><input type="checkbox" id="split" value="6"
                                checked>
                            SPLIT</label></div>
                    <div class="col-6 col-sm-4 col-md-3 col-lg-2"><label
                            class="small d-flex align-items-center gap-1"><input type="checkbox" id="deleted" value="8"
                                checked>
                            DELETED</label></div>

                    <div class="col-6 col-sm-4 col-md-3 col-lg-2"><label
                            class="small d-flex align-items-center gap-1"><input type="checkbox" id="pay" value="9"
                                checked>
                            PAY</label></div>
                </div>
            </div>
        </div>
    </div>

</div>

<div id="loadingSpinnerRateCode" style="display: none; text-align: center; padding: 20px;">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
</div>
<div class="mui-card">
    <div id="gridContainerRateCode" class="mt-2 gridContainer"></div>
</div>
</div>
<div class="modal fade" id="modaldetailGrid" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header py-2">
                <h6 class="modal-title">Transactions History Detail</h6>
            </div>

            <div class="modal-body">
                <div class="mb-2 mt-1">
                    <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>
                <!-- DETAIL GRID -->
                <div class="mui-card">
                    <div id="detailPopup" class="gridContainer" style="height:420px"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>

    DevExpress.localization.locale("vi");
    let selectedRowData = null;

    $(document).ready(async function () {
        // Khi thay đổi checkbox "All"
        $("#allAction").change(function () {
            var isChecked = $(this).is(":checked");
            $("#action input[type='checkbox']").not(this).prop("checked", isChecked);
        });

        // Khi thay đổi từng checkbox con, nếu tất cả được check thì tự động check "All"
        $("#action input[type='checkbox']").not("#allAction").change(function () {
            var allChecked = $("#action input[type='checkbox']").not("#allAction").length ===
                $("#action input[type='checkbox']:checked").not("#allAction").length;
            $("#allAction").prop("checked", allChecked);
        });
        await window.initDateInputs();
        await reloadGrid(isInitial = true);
        initializeTomSelects();
    });
    function initializeTomSelects() {
        const selectors = ["#users"];

        for (const id of selectors) {
            const el = document.querySelector(id);
            if (!el) continue;

            // Nếu đã khởi tạo rồi thì destroy
            if (el.tomselect) el.tomselect.destroy();

            const ts = new TomSelect(el, {
                plugins: ['remove_button'],
                create: false,
                maxItems: null,
                allowEmptyOption: true,
                placeholder: '',
                persist: false,
                render: {
                    option: function (data, escape) {
                        return `<div>${escape(data.text)}</div>`;
                    }
                }
            });

        }
    }

    function loadGrid(data) {
        $("#gridContainerRateCode").dxDataGrid({
            dataSource: data,
            height: "500px",
            width: "100%",
            columnAutoWidth: true,
            allowColumnResizing: true,
            columnResizingMode: "widget",
            selection: { mode: "single" },
            columns: [
                { dataField: "property", caption: "Property", width: "10%" },
                { dataField: "actionText", caption: "Action", width: "20%" },
                { dataField: "moreInformation", caption: "More Information ", width: "10%" },
                {
                    caption: "Date",
                    width: "11%",
                    calculateCellValue: function (rowData) {
                        if (!rowData.actionDate) return "";
                        let d = new Date(rowData.actionDate);
                        return d.toLocaleDateString("en-GB"); // dd/MM/yyyy
                    }
                },
                {
                    caption: "Time",
                    width: "11%",
                    calculateCellValue: function (rowData) {
                        if (!rowData.actionDate) return "";
                        let d = new Date(rowData.actionDate);
                        return d.toLocaleTimeString("en-GB", { hour: "2-digit", minute: "2-digit", second: "2-digit" });
                    }
                },
                { dataField: "fromRoom", caption: "F_Room", width: "11%" },
                { dataField: "fromFolioID", caption: "F_Folio ", width: "11%" },
                { dataField: "fromName", caption: "F_Guest ", width: "11%" },
                { dataField: "toRoom", caption: "T_Room", width: "11%" },
                { dataField: "toFolioID", caption: "T_Folio", width: "11%" },
                { dataField: "toName", caption: "T_Guest", width: "11%" },
                { dataField: "amountIncTax", caption: "Amount", width: "11%", dataType: "number", format: "#,##0.00" },
                { dataField: "actionUser", caption: "User", width: "11%" },
                { dataField: "machine", caption: "Machine", width: "11%" },

            ],
            filterRow: { visible: true, applyFilter: "auto" },
            paging: { pageSize: 20 },
            pager: {
                visible: true,
                allowedPageSizes: [20, 50, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            scrolling: { mode: "standard", showScrollbar: "always", scrollByContent: true },
            onRowClick: function (e) {
                selectedRowData = e.data;
                console.log("Selected Row:", selectedRowData);
            }
        });
    }
    $("#detailPopup").dxPopup({
        title: "Detail Information",
        width: 800,
        height: 500,
        visible: false,
        showCloseButton: true,
        contentTemplate: function () {
            return $("<div id='detailGrid'>").dxDataGrid({
                showBorders: true,
                columns: [
                    { dataField: "actionText", caption: "Action" },
                    { dataField: "moreInformation", caption: "More Information" },
                    { dataField: "transactionDate", caption: "Trans. Date" },
                    {
                        caption: "Date",
                        calculateCellValue: function (rowData) {
                            if (!rowData.actionDate) return "";
                            let d = new Date(rowData.actionDate);
                            return d.toLocaleDateString("en-GB");
                        }
                    },
                    {
                        caption: "Time",
                        calculateCellValue: function (rowData) {
                            if (!rowData.actionDate) return "";
                            let d = new Date(rowData.actionDate);
                            return d.toLocaleTimeString("en-GB", {
                                hour: "2-digit",
                                minute: "2-digit",
                                second: "2-digit"
                            });
                        }
                    }
                ]
            });
        }
    });


    function showDetailPopup(rowData) {
        let invoiceNo = rowData.invoiceNo;
        console.log("InvoiceNo:", invoiceNo);

        $.ajax({
            url: "/Cashiering/GetSearchPostingHistoryDetail",
            type: "GET",
            data: { invoiceNo: invoiceNo },
            success: function (data) {
                loadDetailGrid(data);
                new bootstrap.Modal("#modaldetailGrid").show();
            }
            ,
            error: function () {
                console.error("Không thể tải dữ liệu chi tiết");
            }
        });
    }
    function loadDetailGrid(data) {
        $("#detailPopup").dxDataGrid({
            dataSource: data,
            height: "500px",
            allowColumnResizing: true,
            selection: { mode: "single" },

            columns: [
                { dataField: "actionText", caption: "Action" },
                { dataField: "moreInformation", caption: "More Information" },
                { dataField: "transactionDate", caption: "Trans. Date", dataType: "date", format: "dd/MM/yyyy" },
                {
                    caption: "Date",
                    calculateCellValue: function (rowData) {
                        if (!rowData.actionDate) return "";
                        let d = new Date(rowData.actionDate);
                        return d.toLocaleDateString("en-GB");
                    }
                },
                {
                    caption: "Time",
                    calculateCellValue: function (rowData) {
                        if (!rowData.actionDate) return "";
                        let d = new Date(rowData.actionDate);
                        return d.toLocaleTimeString("en-GB", {
                            hour: "2-digit",
                            minute: "2-digit",
                            second: "2-digit"
                        });
                    }
                }
            ],

            scrolling: {
                mode: "standard", // Không dùng virtual để footer hiển thị đúng
                showScrollbar: "always",
                scrollByContent: true
            },
            paging: {
                pageSize: 50
            },
            pager: {
                visible: true,
                allowedPageSizes: [50, 100, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            filterRow: {
                visible: true,
                applyFilter: "auto"
            },
            showBorders: true,
            width: "100%",
            height: "500px",

            onRowPrepared: function (e) {
                if (e.data && e.data.isSubtotal) {
                    e.rowElement.css({ "font-weight": "bold" });
                }
                if (e.data && e.data.isGrandTotal) {
                    e.rowElement.css({ "font-weight": "bold" });
                }
            },
            onRowClick: function (e) {
                selectedRowData = e.data;
                console.log('onRowClick:', selectedRowData);

            }
        });
    }



    $("#btnDetail").on("click", function () {
        if (selectedRowData) {
            showDetailPopup(selectedRowData);
        } else {
            showToast("Warning", "Please choose 1 row ", false);
        }
    });

    $("#btnView").on("click", function () {
        reloadGrid();
    });

    // Reload grid với filter từ form
    async function reloadGrid(isInitial = false) {
        try {
            $("#loadingSpinnerRateCode").show();

            let fromDateISO = $("#fromDate").val() || '';
            let toDateISO = $("#toDate").val() || '';
            let usersParam = "";
            let selectedusers = $("#users").val();

            // Nếu là load lần đầu (initial) và fromDate chưa có → bắt buộc chờ business date
            if (isInitial && (!fromDateISO || !toDateISO)) {
                fromDateISO = await waitForBusinessDate("fromDate", 10000); // timeout 10s để an toàn
                toDateISO = await waitForBusinessDate("toDate", 10000); // timeout 10s để an toàn
            }

            // Nếu vẫn rỗng sau khi chờ → báo lỗi hoặc fallback (tùy yêu cầu)
            if (!fromDateISO || !toDateISO) {
                console.log("Không tải được ngày mặc định. Vui lòng chọn From Date thủ công.");
                $("#loadingSpinnerRateCode").hide();
                return;
            }

            usersParam = selectedusers.map(r => r.replace("''")).join("','");
            var actionType = $("#action input[type='checkbox']:checked")
                .map(function () { return this.value; })
                .get()
                .join(",");
            // Gửi ajax
            $.ajax({
                url: '/Cashiering/GetFolioHistoryView',
                type: 'POST',
                data: {
                    fromDate: fromDateISO,   // YYYY-MM-DD an toàn
                    toDate: toDateISO,
                    fromFolioID: $("#fromFolio").val(),
                    toFolioID: $("#toFolio").val(),
                    fromRoom: $("#fromRoom").val(),
                    toRoom: $("#toRoom").val(),
                    actionType: actionType,
                    user: usersParam
                },
                success: function (data) {
                    loadGrid(data);
                    console.log("Data trả về:", data);
                    $("#loadingSpinnerRateCode").hide();
                },
                error: function (xhr, status, error) {
                    alert("Không thể tải dữ liệu");
                    $("#loadingSpinnerRateCode").hide();
                }
            });
        } catch (error) {
            console.error(error);
        }


    }

    $("#btnExportExcel").click(function () {
        const grid = $("#gridContainerRateCode").dxDataGrid("instance");   // 🔥 khai báo grid

        const workbook = new ExcelJS.Workbook();
        const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
        const worksheet = workbook.addWorksheet("Sheet 1");

        // === Dòng 1: Tên công ty (merge theo 4 cột) ===
        worksheet.addRow([companyName]);
        worksheet.mergeCells('A1:D1');
        worksheet.getRow(1).font = { bold: true };
        worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

        // === Dòng 2: Ngày giờ xuất (bên phải) ===
        const now = new Date();
        const exportDate = now.toLocaleString("vi-VN");
        worksheet.addRow(['', '', '', exportDate]);
        worksheet.mergeCells('D2:D2');  // cột D thôi
        worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

        // === Dòng 3–4: trống
        worksheet.addRow([]);
        worksheet.addRow([]);

        // === Dòng 5: Tiêu đề báo cáo (ở giữa) ===
        const reportRow = worksheet.addRow([' Folio History']);
        worksheet.mergeCells('A5:D5');
        reportRow.font = { bold: true, size: 14 };
        reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

        // === Dòng 6: trống
        worksheet.addRow([]);

        // === Xuất dữ liệu grid bắt đầu từ dòng 7 ===
        DevExpress.excelExporter.exportDataGrid({
            component: grid,
            worksheet: worksheet,
            autoFilterEnabled: true,
            topLeftCell: { row: 7, column: 1 }
        }).then(function () {
            // Footer (sau cùng)
            const lastRow = worksheet.lastRow.number + 2;
            worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
            worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
            worksheet.getCell(`A${lastRow}`).font = { italic: true };

            // Ghi file
            let fileName = "Folio History.xlsx";
            workbook.xlsx.writeBuffer().then(function (buffer) {
                saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
            });
        });
    });


</script>
