<script>
    var pro_ind_Module = {

        init: function () {
            this.initEvents();
            this.initDOMEvents();
            this.bindNameEngine();
            this.initStateControls();
            this.initTomSelects();
        },

        initEvents: function () {
            window.openModalProInd = function () {
                initDateInputs();
            }
        },

        initDOMEvents: function () {
            $('#ind_fileUpload').on('change', this.handleImage);
        },

        handleImage: function (event) {

            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();

            reader.onload = (e) => {
                $('#ind_imgPreview').attr('src', e.target.result);
            };

            reader.readAsDataURL(file);
        },

        initTomSelects: function () {
            const self = this;

            initTomSelect('.tomselect-custom');

            LoadingGlobal.show();

            const mapCode = (item) => ({
                value: item.id || item.ID,
                text: (item.code || item.Code) + "-" + (item.name || item.Name), 
                data: item
            });

            const loadTasks = [
                loadDataToTomSelect("#ind_txtLanguage", "/Profile/GetAllLanguage", mapCode),
                loadDataToTomSelect("#ind_txtTitle", "/Profile/GetAllTitle", mapCode),
                loadDataToTomSelect("#ind_txtNationality", "/Profile/GetAllNationality", mapCode),
                loadDataToTomSelect("#ind_txtCountry", "/Profile/GetAllCountry", mapCode),
                loadDataToTomSelect("#ind_txtCity", "/Profile/GetAllCity", mapCode),
                loadDataToTomSelect("#ind_txtState", "/Profile/GetAllState", (item) => {
                    const zip = item.zipCode || item.ZipCode || "";

                    const name = item.stateName || item.StateName || "";

                    return {
                        value: item.id || item.ID,
                        text: (zip && name) ? `${zip} - ${name}` : (zip || name || "Unknown"),
                        data: item
                    };
                }),
                loadDataToTomSelect("#ind_txtVIP", "/Profile/GetAllVIP", mapCode)
            ];

            Promise.all(loadTasks).finally(() => {
                LoadingGlobal.hide();
            });
        },

        bindNameEngine: function () {
            const self = this;
            const $full = $("#ind_txtFullName");
            const $salutation = $("#ind_txtSalutation");

            function processNameParsing() {
                let nameVal = $full.val();
                if (!nameVal) return;

                let p = GuestNameEngine.parseFullName(nameVal);
                console.log("Parsed Name:", p);

                $("#ind_txtFirstName").val(p.first);
                $("#ind_txtMiddleName").val(p.middle);
                $("#ind_txtLastName").val(p.last);

                let resultSalutation = GuestNameEngine.buildSalutation(p.first, p.last);
                $salutation.val(resultSalutation);
            }

            $full.on("blur", processNameParsing);

            $full.on("keydown", function(e) {
                if (e.which === 13) { 
                    e.preventDefault(); 
                    processNameParsing();

                    $("#ind_txtFirstName").focus();
                }
            });

            $("#ind_txtTitle").on("change", function() {
                const lastName = $("#ind_txtLastName").val();

                const ts = getTomSelect("#ind_txtTitle");
                if (!ts) return;

                const val = ts.getValue();

                const titleText = val ? ts.options[val]?.text : "";

                if (lastName && titleText && titleText !== "Enter or select...") {
                    $salutation.val("Dear " + titleText + " " + GuestNameEngine.smartCapitalize(lastName));
                } else if (lastName) {
                    $salutation.val("Dear " + GuestNameEngine.smartCapitalize(lastName));
                }
            });
        },

        initStateControls: function () {
            const self = this;
            const $dobCheckbox = $("#ind_chkActiveDob");
            const $dobWrapper = $('[data-name="ind_txtDob"]');
            const $dobInput = $dobWrapper.find('input.date-ui');

            const $blackCheckbox = $("#ind_chkBlackList");
            const $blackInput = $("#ind_txtBlackListReason");

            // 1. Logic cho Date of Birth (DOB)
            function updateDOB() {
                const isChecked = $dobCheckbox.is(":checked");
                $dobInput.prop("disabled", !isChecked);

                // Nếu disable thì làm mờ cả icon lịch
                if (!isChecked) {
                    $dobWrapper.addClass("opacity-50");
                } else {
                    $dobWrapper.removeClass("opacity-50");
                }
            }

            // 2. Logic cho Blacklist
            function updateBlackList() {
                const isChecked = $blackCheckbox.is(":checked");
                if (isChecked) {
                    // Khi bị Blacklist: Nền đen, cho phép nhập
                    $blackInput.addClass("black-active").prop("disabled", false).focus();
                } else {
                    // Mặc định: Nền trắng, disable để tránh nhập nhầm
                    $blackInput.removeClass("black-active").prop("disabled", true).val('');
                }
            }

            // Gán sự kiện change
            $dobCheckbox.on("change", updateDOB);
            $blackCheckbox.on("change", updateBlackList);

            // Chạy ngay khi khởi tạo để đồng bộ trạng thái ban đầu
            updateDOB();
            updateBlackList();
        },

        getFormData: function () {
            
            const getTS = (id) => {
                const ts = getTomSelect(id);
                return ts ? ts.getValue() : 0;
            };

            const loginName = (localStorage.getItem("Loginname") || "")
            .trim()
            .replace(/^"(.*)"$/, '$1');
            const loginUser = parseInt(localStorage.getItem("userID")) || 0;

            const data = {
                // --- Định danh ---
                ID: parseInt($("#ind_id").val()) || 0,
                Type: 0, // Individual

                // --- Address Information (Cột 1) ---
                Code: $("#ind_txtCode").val()?.trim(),
                Account: $("#ind_txtFullName").val()?.trim(), // Full Name bắt buộc
                Firstname: $("#ind_txtFirstName").val()?.trim(), // Bắt buộc
                LastName: $("#ind_txtLastName").val()?.trim(),   // Bắt buộc
                MiddleName: $("#ind_txtMiddleName").val()?.trim(),

                LanguageID: parseInt(getTS("#ind_txtLanguage")),
                TitleID: parseInt(getTS("#ind_txtTitle")),
                NationalityID: parseInt(getTS("#ind_txtNationality")), // Bắt buộc
                City: getTS("#ind_txtCity"), 
                CountryID: parseInt(getTS("#ind_txtCountry")),
                PostalCode: $("#ind_txtPostal").val()?.trim(),
                StateID: parseInt(getTS("#ind_txtState")),
                Religion: $("#ind_txtReligion").val()?.trim(),
                Nation: $("#ind_txtNation").val()?.trim(),
                PurposeOfStay: $("#ind_txtPOS").val()?.trim(),
                Address: $("#ind_txtAddress").val()?.trim(),

                // --- Internal Information (Cột 2) ---
                Salutation: $("#ind_txtSalutation").val()?.trim(),
                VIPID: parseInt(getTS("#ind_txtVIP")),
                VIPReason: $("#ind_txtVipReason").val()?.trim(),
                PrefRoom: $("#ind_txtPrefRoom").val()?.trim(),
                Other: $("#ind_txtOther").val()?.trim(),
                PassPort: $("#ind_txtPassport").val()?.trim(),
                IdentityCard: $("#ind_txtIdentityCard").val()?.trim(),

                // Lấy từ input hidden của component DateInput
                DateOfBirth: $("#ind_chkActiveDob").is(":checked") ? $("#ind_txtDob").val() : null,

                Active: $("#ind_chkActive").is(":checked"),
                Contact: $("#ind_chkContact").is(":checked"),
                Keyword: $("#ind_txtKeyword").val()?.trim(),
                IsBlackList: $("#ind_chkBlackList").is(":checked"),
                BlackListReason: $("#ind_txtBlackListReason").val()?.trim(),

                // --- Attributes ---
                RateCode: $("#ind_txtRateCode").val()?.trim(),
                ARNo: $("#ind_txtARNo").val()?.trim(),
                MemberNo: $("#ind_txtMemberNo").val()?.trim(),

                // --- Tax & Communications (Cột 3) ---
                Company: $("#ind_txtTaxCompany").val()?.trim(),
                TaxCode: $("#ind_txtTaxCode").val()?.trim(),
                HomeAddress: $("#ind_txtTaxBusAddress").val()?.trim(), // Map vào HomeAddress trong Model

                Telephone: $("#ind_txtTelephone").val()?.trim(),
                HandPhone: $("#ind_txtHandPhone").val()?.trim(),
                Fax: $("#ind_txtFax").val()?.trim(),
                Email: $("#ind_txtEmail").val()?.trim(),
                Website: $("#ind_txtWebsite").val()?.trim(),
                BusinessTitle: $("#ind_txtBusinessTitle").val()?.trim(),

                // --- History (Chỉ đọc hoặc nạp nếu cần) ---
                LastRoom: $("#ind_txtLastRoom").val(),
                Lastvisit: $("#ind_txtLastRoomDate").val(), // Ngày Last visit
                StayNo: parseInt($("#ind_txtStayCount").val()) || 0,

                UserInsertID: loginUser,
                UserUpdateID: loginUser
            };

            return data;
        },

        clearForm: function () {
            const self = this;
            const $container = $("#pro_ind_formContainer");

            $container.find('input[type="text"], input[type="hidden"], input[type="email"], input[type="tel"], textarea').val('');

            $("#ind_chkActive").prop("checked", true);
            $("#ind_chkContact").prop("checked", false);
            $("#ind_chkActiveDob").prop("checked", true);
            $("#ind_chkBlackList").prop("checked", false);

            const tsIds = [
                "#ind_txtLanguage", "#ind_txtTitle", "#ind_txtNationality",
                "#ind_txtCountry", "#ind_txtCity", "#ind_txtState", "#ind_txtVIP"
            ];
            tsIds.forEach(id => {
                const ts = getTomSelect(id);
                if (ts) ts.clear(); 
            });

            $("#ind_imgPreview").attr('src', '/images/uploads/profile.png');

            self.initStateControls();

            if (window.ValidationAdapter) {
                ValidationAdapter.clear("#pro_ind_formContainer");
            }

            $("#ind_txtCode").focus();
        },

    };

    $(document).ready(function(){
        pro_ind_Module.init();
    });
</script>
