@using DevExpress.XtraReports.UI


@{
    var selectedReport = @ViewBag.ReportHeader;

}

<link href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
<div class="text-center" id="reportTitle" style="font-size: 20px">AR Trace</div>
<div class="sticky-header bg-white p-2 shadow-sm z-3">
    <div class="">
        <button id="btnPrint" class="mui-button button-report-view"> View</button>
        <button id="btnNew" class="mui-button mui-button-new"> New</button>
        <button id="btnUpdate" class="mui-button mui-button-edit"> Edit</button>
        <button id="btnDelete" class="mui-button button-report-delete">
            Delete</button>
        <button id="btnResolve" class="mui-button mui-button-resolve"> Resolve</button>
        <button id="btnUnsolve" class="mui-button mui-button-unsolve">
            Unsolve</button>
        <button id="btnExportExcel" class="mui-button mui-button-export" type="button"> Excel</button>

    </div>
</div>
<div class="mui-card">
    @*     <div style="font-size: 20px;" class="mt-1" id="reportTitle"></div> *@
    <div id="gridContainer" class="gridContainer mt-2"></div>
</div>
<div id="overlay" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 999;"></div>

<div class="modal fade" id="popupNewArtraces" tabindex="-1" aria-labelledby="popupNewArtracesLabel" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="popupNewArtracesLabel">
                    <span id="textPopup">AR Trace New</span>
                </h5>
            </div>

            <!-- Body -->
            <div class="modal-body">

                <!-- Action buttons -->
                <div class="d-flex justify-content-start gap-2 flex-wrap">
                    <button id="btnSearchAuto" class="mui-button mui-button-advance" type="button">
                        Search
                    </button>
                    <button id="btnOkAutoUpdate" class="mui-button mui-button-advance" type="button">
                        Save
                    </button>
                    <button id="btnSaveAuto" class="mui-button mui-button-new" type="button">
                        Save
                    </button>
                    <button id="btnClosePopup" class="mui-button mui-button-new" data-bs-dismiss="modal" type="button">
                        Close
                    </button>
                </div>

                <!-- Sticky content -->
                <div class="sticky-top bg-white p-2 shadow-sm">

                    <!-- Selected account -->
                    <div class="mb-3">
                        <div id="gridSelectedAccount" class="gridContainer"></div>
                    </div>

                    <!-- Hidden id -->
                    <input type="text" id="idselectedRowData" name="idselectedRowData"
                        style="display:none !important" />

                    <!-- Trace info -->
                    <div class="d-flex flex-wrap mb-3">
                        <div class="d-flex align-items-center me-4 mb-2">
                            <label class="me-2 mb-0">Trace Time:</label>
                            <input type="date" id="tracetime" class="form-control form-control-sm w-auto"
                                data-business-date />
                        </div>

                        <div class="d-flex align-items-start mb-2">
                            <label class="me-2 mt-1">Trace Text:</label>
                            <textarea id="traceText" class="form-control form-control-sm" rows="4"
                                style="width:320px; height: 50px;"></textarea>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>


<div class="modal fade" id="popupSearchArtraces" tabindex="-1" role="dialog" aria-labelledby="popupSearchArtracesLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="popupSearchArtracesLabel">
                    AR Trace - Select Account
                </h5>
                </button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <div class="d-flex justify-content-start gap-2">
                    <button id="btnOkSelect" class="mui-button mui-button-advance" type="button">
                        Ok
                    </button>

                    <button id="btnClosepSearchArtracesPopup" class="mui-button mui-button-new" data-bs-dismiss="modal"
                        type="button">
                        Close
                    </button>
                </div>

                <div class="mui-card">
                    <div id="gridContainerSelectAccount" class="gridContainer mt-2"></div>
                </div>
            </div>

        </div>
    </div>
</div>


<div id="loadingSpinner"
    style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:1000;">
    <i class="fa-solid fa-spinner fa-spin"></i>
</div>

<script>
    $(document).ready(function () {
        $("#btnResolve").hide();
        $("#btnUnsolve").hide();
        $("#btnPrint").trigger("click");
    });

    function toDateOnly(value) {
        if (!value) return '';
        return value.substring(0, 10);
    }

    async function initializegridSelectedAccount(data) {
        // Hiển thị danh sách đã chọn ở bảng thứ 2
        $("#gridSelectedAccount").dxDataGrid({
            dataSource: data,
            showBorders: true,
            height: "300px",
            columns: [
                { dataField: "accountName", caption: "Account Name", width: 466 }
            ]
        });
    }

    $(document).off("click", "#btnPrint").on("click", "#btnPrint", function () {
        $("#loadingSpinner").show();
        $.ajax({
            url: '/Accounting/ARTracesData',
            type: 'GET',
            data: {

            },
            traditional: true,
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {

                console.log(result);
                initializeARTracesGrid(result);
                $("#loadingSpinner").hide();
            },
            error: function () {
                alert("Không th? t?i báo cáo.");
                $("#loadingSpinner").hide();
            }
        });
    });
    var selectedRowData = null;
    function initializeARTracesGrid(data) {
        $("#gridContainer").dxDataGrid({
            dataSource: data,
            showBorders: true,
            selection: { mode: "single" },
            paging: { pageSize: 20 },
            pager: {
                showPageSizeSelector: true,
                allowedPageSizes: [20, 50, 100],
                showInfo: true
            },
            width: "100%",
            height: "500px",
            filterRow: { visible: true },
            columns: [
                { dataField: "id", caption: "ID", visible: false },

                { dataField: "name", caption: "Name", width: "18%" },

                { dataField: "traceAt", caption: "Trace Time", dataType: "date", format: "dd/MM/yyyy", width: "14%" },

                { dataField: "resolvedAt", caption: "Resolved At", dataType: "date", format: "dd/MM/yyyy", width: "12%" },

                { dataField: "resolvedBy", caption: "Resolved By", width: "9%" },

                { dataField: "createdBy", caption: "Created By", width: "9%" },

                { dataField: "createdDate", caption: "Created Date", dataType: "date", format: "dd/MM/yyyy", width: "14%" },

                { dataField: "updatedBy", caption: "Updated By", width: "8%" },

                { dataField: "updatedDate", caption: "Updated Date", dataType: "date", format: "dd/MM/yyyy", width: "16%" }
            ],
            scrolling: {
                mode: "standard", // Không dùng virtual để footer hiển thị đúng
                showScrollbar: "always",
                scrollByContent: true
            },
            paging: {
                pageSize: 50
            },
            pager: {
                visible: true,
                allowedPageSizes: [50, 100, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            filterRow: {
                visible: true,
                applyFilter: "auto"
            },
            // 🔥 Quan trọng: gán selectedRowData khi click chọn
            onRowClick: function (e) {
                selectedRowData = e.data; // 🔥 lấy data của row vừa click
                console.log("Selected Row (RowClick):", selectedRowData);
                if (selectedRowData.resolvedBy === "Unresolved") {
                    // Nếu chưa resolve
                    $("#btnUnsolve").hide();
                    $("#btnResolve").show();
                } else {
                    // Nếu đã resolve
                    $("#btnResolve").hide();
                    $("#btnUnsolve").show();
                }
            }
        });
    }
    $("#btnNew").on("click", function () {
        $("#gridSelectedAccount").show();
        initializegridSelectedAccount([]);
        $("#btnOkAutoUpdate").hide();
        $("#btnSearchAuto, #btnSaveAuto").show();

        if (!selectedRowDatasa || selectedRowDatasa.length === 0) {
            $("#btnSearchAuto").trigger("click");

            $("#createdDate").closest('.d-flex').hide();
        } else {
            $("#createdDate").hide();
        }

        $("#textPopup").text("AR Trace New");

        $('#popupNewArtraces').modal('show');
    });

    $("#btnUpdate").on("click", function () {
        $("#btnOkAutoUpdate").show();
        $("#gridSelectedAccount").hide();
        $("#textPopup").text("AR Trace Edit");
        if (!selectedRowData || selectedRowData.length === 0) {
            showToast('Error', "Please select at least one account!", false);
            return;
        }
        console.log('selectedRowData', selectedRowData);

        $("#btnSearchAuto").hide();
        $("#btnSaveAuto").hide();
        $("#idselectedRowData").val(selectedRowData.id);
        $("#tracetime").val(toDateOnly(selectedRowData.traceAt));
        $("#traceText").val(selectedRowData.traceText);
        $('#popupNewArtraces').modal('show');

    });

    $("#btnSearchAuto").on("click", function () {

        // Hiển thị loading (nếu có)
        $("#loadingSpinner").show();

        // Mở modal đúng cách
        const modalEl = document.getElementById('popupSearchArtraces');
        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();

        $.ajax({
            url: '/Accounting/ARAccountReceivableSearch',
            type: 'GET',
            data: {},
            traditional: true,
            headers: {
                "X-CSRF-TOKEN-HEADERNAME":
                    $("input[name='__RequestVerificationToken']").val()
            },
            success: function (result) {
                console.log(result);
                initializeARAccountReceivableSearchGrid(result);
                $("#loadingSpinner").hide();
            },
            error: function () {
                alert("Không thể tải dữ liệu.");
                $("#loadingSpinner").hide();
            }
        });
    });

    var selectedRowDatasa = [];

    function initializeARAccountReceivableSearchGrid(data) {
        $("#gridContainerSelectAccount").dxDataGrid({
            dataSource: data,
            showBorders: true,
            selection: {
                mode: "multiple",        // ✅ Cho phép chọn nhiều dòng
                showCheckBoxesMode: "always" // ✅ Hiển thị checkbox chọn
            },
            paging: { pageSize: 20 },
            height: 500,
            pager: {
                showPageSizeSelector: true,
                allowedPageSizes: [20, 50, 100],
                showInfo: true
            },
            filterRow: { visible: true },
            columns: [
                { dataField: "id", caption: "ID", width: 80, visible: false },
                { dataField: "accountName", caption: "Account Name", width: 200 },
                { dataField: "accountNo", caption: "Account No", width: 200 },
                { dataField: "contactName", caption: "Contact Name", width: 200 },
                { dataField: "telePhone", caption: "Phone", width: 120 },
                { dataField: "email", caption: "Email", width: 120 }
            ],
            scrolling: {
                mode: "standard",
                showScrollbar: "always",
                scrollByContent: true
            },
            paging: {
                pageSize: 50
            },
            pager: {
                visible: true,
                allowedPageSizes: [50, 100, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            filterRow: {
                visible: true,
                applyFilter: "auto"
            },

            // ✅ Sự kiện khi người dùng chọn/bỏ chọn dòng
            onSelectionChanged: function (e) {
                selectedRowDatasa = e.selectedRowsData; // Danh sách các dòng đã chọn
                console.log("Selected Rows:", selectedRowDatasa);
            }
        });
    }

    $("#btnOkAutoUpdate").on("click", function () {

        if (!selectedRowData || selectedRowData.length === 0) {
            showToast('Error', "Please select at least one account!", false);
            return;
        }

        $("#loadingSpinner").show();
        $.ajax({
            url: '/Accounting/ARTraceUpdate',
            type: 'POST',
            data: {
                idselectedRowData: $("#idselectedRowData").val(),
                tracetime: $("#tracetime").val(),
                traceText: $("#traceText").val(),
                user: localStorage.getItem("Loginname")

            },
            traditional: true,
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                if (result.success) {
                    showToast('Success', result.message, true);
                    $('#popupNewArtraces').modal("hide");
                    $("#btnPrint").trigger("click");
                    clearNewArtraces();
                } else {
                    showToast('Error', 'Please select before saving.', false);
                }
                console.log(result);

                $("#loadingSpinner").hide();
            },
            error: function () {
                alert("Không th? t?i báo cáo.");
                $("#loadingSpinner").hide();
            }
        });
    });
    $("#btnSaveAuto").on("click", function () {

        if (selectedRowDatasa.length === 0) {
            showToast('Error', "Please select at least one account!", false);
            return;
        }

        $("#loadingSpinner").show();
        $.ajax({
            url: '/Accounting/ARTraceSave',
            type: 'POST',
            contentType: "application/json; charset=utf-8", // ✅ gửi JSON chuẩn
            data: JSON.stringify({
                tracetime: $("#tracetime").val(),
                traceText: $("#traceText").val(),
                user: localStorage.getItem("Loginname"),
                selectedAccounts: selectedRowDatasa // ✅ gửi mảng sang server
            }),
            traditional: true,
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                if (result.success) {
                    $('#popupNewArtraces').modal("hide");
                    showToast('Success', result.message, true);
                    clearNewArtraces();
                    $("#btnPrint").trigger("click");
                } else {
                    showToast('Error', 'Please select.', false);
                }
                console.log(result);

                $("#loadingSpinner").hide();
            },
            error: function () {
                alert("Không th? t?i báo cáo.");
                $("#loadingSpinner").hide();
            }
        });
    });
    $("#btnResolve").on("click", function () {

        if (selectedRowData.length === 0) {
            showToast('Error', "Please select at least one account!", false);
            return;
        }

        $("#loadingSpinner").show();
        $.ajax({
            url: '/Accounting/ARTraceResolve',
            type: 'POST',

            data: {
                id: selectedRowData.id,
                user: localStorage.getItem("Loginname"),

            },
            traditional: true,
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                if (result.success) {

                    $("#btnPrint").trigger("click");
                } else {
                    showToast('Error', 'Please select.', false);
                }
                console.log(result);

                $("#loadingSpinner").hide();
            },
            error: function () {
                alert("Không th? t?i báo cáo.");
                $("#loadingSpinner").hide();
            }
        });
    });
    $("#btnUnsolve").on("click", function () {

        if (selectedRowData.length === 0) {
            showToast('Error', "Please select at least one account!", false);
            return;
        }

        $("#loadingSpinner").show();
        $.ajax({
            url: '/Accounting/ARTraceUnresolve',
            type: 'POST',

            data: {
                id: selectedRowData.id,
                user: localStorage.getItem("Loginname"),

            },
            traditional: true,
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                if (result.success) {

                    $("#btnPrint").trigger("click");
                } else {
                    showToast('Error', 'Please select.', false);
                }
                console.log(result);

                $("#loadingSpinner").hide();
            },
            error: function () {
                alert("Không th? t?i báo cáo.");
                $("#loadingSpinner").hide();
            }
        });
    });
    function clearNewArtraces() {

        $("#traceText").val("");
        initializegridSelectedAccount([]);
        selectedRowDatasa = null;
    }
    $('#btnClosePopup, #overlay').click(function () {
        $('#popupNewArtraces').modal('hide');
        $('#popupSearchArtraces').modal('hide');
        clearNewArtraces();
    });

    $('#btnClosepSearchArtracesPopup, #overlay').click(function () {

        $('#popupSearchArtraces').modal('hide');
    });

    $("#btnOkSelect").on("click", function () {

        if (selectedRowDatasa.length === 0) {
            showToast('Error', "Please select at least one account!", false);
            return;
        }
        $('#popupSearchArtraces').modal('hide');
        $('#popupNewArtraces').modal('show');
        // Tạo dữ liệu hiển thị cho bảng Selected
        const selectedAccounts = selectedRowDatasa.map(item => ({
            accountName: item.accountName
        }));

        initializegridSelectedAccount(selectedAccounts);

        console.log("Đã chọn:", selectedAccounts);
    });

    $(document).off("click", "#btnDelete").on("click", "#btnDelete", function () {
        if (!selectedRowData) {
            showToast('Error', 'Please select 1 row to delete.', false);
            return;
        }

        $.ajax({
            url: '/Accounting/ARTraceDelete',
            type: 'POST',
            data: {
                id: selectedRowData.id


            },
            traditional: true,
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                if (result.success) {

                    $("#btnPrint").trigger("click");
                } else {
                    showToast('Error', 'Please select .', false);
                }

            },
            error: function () {
                alert("Không th? t?i báo cáo.");
                $("#loadingSpinner").hide();
            }
        });


    });



    $("#btnExportExcel").click(function () {
        const grid = $("#gridContainer").dxDataGrid("instance");   // 🔥 khai báo grid

        const workbook = new ExcelJS.Workbook();
        const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
        const worksheet = workbook.addWorksheet("Sheet 1");

        // === Dòng 1: Tên công ty (merge theo 4 cột) ===
        worksheet.addRow([companyName]);
        worksheet.mergeCells('A1:D1');
        worksheet.getRow(1).font = { bold: true };
        worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

        // === Dòng 2: Ngày giờ xuất (bên phải) ===
        const now = new Date();
        const exportDate = now.toLocaleString("vi-VN");
        worksheet.addRow(['', '', '', exportDate]);
        worksheet.mergeCells('D2:D2');  // cột D thôi
        worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

        // === Dòng 3–4: trống
        worksheet.addRow([]);
        worksheet.addRow([]);

        // === Dòng 5: Tiêu đề báo cáo (ở giữa) ===
        const reportRow = worksheet.addRow(['Telephone Directory']);
        worksheet.mergeCells('A5:D5');
        reportRow.font = { bold: true, size: 14 };
        reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

        // === Dòng 6: trống
        worksheet.addRow([]);

        // === Xuất dữ liệu grid bắt đầu từ dòng 7 ===
        DevExpress.excelExporter.exportDataGrid({
            component: grid,
            worksheet: worksheet,
            autoFilterEnabled: true,
            topLeftCell: { row: 7, column: 1 }
        }).then(function () {
            // Footer (sau cùng)
            const lastRow = worksheet.lastRow.number + 2;
            worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
            worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
            worksheet.getCell(`A${lastRow}`).font = { italic: true };

            // Ghi file
            let fileName = "ARTrace.xlsx";
            workbook.xlsx.writeBuffer().then(function (buffer) {
                saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
            });
        });
    });
</script>
