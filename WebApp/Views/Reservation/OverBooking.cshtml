<!-- MAIN MODAL: Overbooking Search -->
<div class="modal fade" id="obk_modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content modal-full-height">

            <div class="modal-header">
                <h5 class="modal-title">Overbooking Search</h5>
            </div>

            <div class="modal-body">

                <!-- Sticky Header -->
                <div class="sticky-header bg-white p-2 shadow-sm z-3">

                    <div class="pb-2">
                        <button class="mui-button mui-button-new" id="obk_btnSearch">Search</button>
                        <button class="mui-button mui-button-new" id="obk_btnNew">New</button>
                        <button class="mui-button mui-button-new" id="obk_btnEdit">Edit</button>
                        <button class="mui-button mui-button-new" id="obk_btnActivityLog">Activity Log</button>
                        <button class="mui-button mui-button-new" id="obk_btnClose">Close</button>
                    </div>

                    <!-- Filter -->
                    <div class="filter-panel">
                        <div class="container-fluid mb-1">

                            <div class="row g-2 mt-1 align-items-center">

                                <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl-3">
                                    <div class="row g-1 align-items-center">
                                        <label class="col-3 col-md-4 text-md-end mb-0 text-nowrap">
                                            Date
                                        </label>
                                        <div class="col-9 col-md-8">
                                            <div data-date-input data-format="DD/MM/YYYY" data-name="fromDate"
                                                 business-date>
                                                <input type="text" class="date-ui form-control form-control-sm"
                                                       placeholder="dd/mm/yyyy" autocomplete="off" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>

                        </div>
                    </div>

                </div>

                <!-- Loading -->
                <div id="obk_loadingSpinnerForm" style="display: none; text-align: center; padding: 20px;">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>

                <!-- Grid -->
                <div class="mui-card">
                    <div id="obk_gridContainer" class="gridContainer mt-2"></div>
                </div>

            </div>
        </div>
    </div>
</div>


<!-- Modal: New Overbooking -->
<div class="modal fade" id="obk_modalNewOverBooking" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
     aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Overbooking Setup</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">
                    <div>
                        <button class="mui-button mui-button-new" id="obk_btnSave">OK</button>
                        <button class="mui-button mui-button-new" id="obk_btnCloseNew">Close</button>
                    </div>
                </div>

                <div class="mt-1">
                    <div class="row g-2">

                        <input type="hidden" id="obk_idOverBooking">

                        <!-- From Date -->
                        <div class="col-12 col-md-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    From Date
                                </label>
                                <div class="col-12 col-md-8">
                                    <div data-date-input data-format="DD/MM/YYYY" data-name="fromDateNew">
                                        <input type="text" class="date-ui form-control form-control-sm"
                                               placeholder="dd/mm/yyyy" autocomplete="off" />
                                    </div>

                                </div>
                            </div>
                        </div>

                        <!-- To Date -->
                        <div class="col-12 col-md-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    To Date
                                </label>
                                <div class="col-12 col-md-8">
                                    <div data-date-input data-format="DD/MM/YYYY" data-name="toDateNew">
                                        <input type="text" class="date-ui form-control form-control-sm"
                                               placeholder="dd/mm/yyyy" autocomplete="off" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Days -->
                        <div class="col-12">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-2 col-form-label text-md-end">
                                    Days
                                </label>
                                <div class="col-12 col-md-10">
                                    <div class="d-flex flex-wrap gap-3">

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="checkbox" name="obk_dayName" checked id="obk_sun">
                                            <label class="d-flex align-items-center gap-2-label">Sun</label>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="checkbox" name="obk_dayName" checked id="obk_mon">
                                            <label class="d-flex align-items-center gap-2-label">Mon</label>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="checkbox" name="obk_dayName" checked id="obk_tue">
                                            <label class="d-flex align-items-center gap-2-label">Tue</label>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="checkbox" name="obk_dayName" checked id="obk_wed">
                                            <label class="d-flex align-items-center gap-2-label">Wed</label>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="checkbox" name="obk_dayName" checked id="obk_thu">
                                            <label class="d-flex align-items-center gap-2-label">Thu</label>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="checkbox" name="obk_dayName" checked id="obk_fri">
                                            <label class="d-flex align-items-center gap-2-label">Fri</label>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="checkbox" name="obk_dayName" checked id="obk_sat">
                                            <label class="d-flex align-items-center gap-2-label">Sat</label>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="checkbox" id="obk_includeOutOfOrder" name="obk_includeOptions"
                                                   value="1" checked="">
                                            <label class="d-flex align-items-center gap-2-label"
                                                   for="obk_includeOutOfOrder">
                                                Include Out of Order
                                            </label>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Room Type -->
                        <div class="col-12 col-md-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-5 col-form-label text-md-end">
                                    Room Type
                                </label>
                                <div class="col-12 col-md-7">
                                    <select id="obk_roomType" class="form-select form-select-sm"
                                            asp-items="ViewBag.cboRoomType"></select>
                                </div>
                            </div>
                        </div>

                        <!-- Overbooking Level -->
                        <div class="col-12 col-md-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-7 col-form-label text-md-end">
                                    Overbooking Level
                                </label>
                                <div class="col-12 col-md-5">
                                    <input type="number" id="obk_obLevel" class="form-control form-control-sm text-end">
                                </div>
                            </div>
                        </div>

                        <!-- No to sell -->
                        <div class="col-12 col-md-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-5 col-form-label text-md-end">
                                    No to sell
                                </label>
                                <div class="col-12 col-md-7">
                                    <input type="number" id="obk_noToSell"
                                           class="form-control form-control-sm text-end">
                                </div>
                            </div>
                        </div>

                        <!-- Type -->
                        <div class="col-12 col-md-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-2 col-form-label text-md-end">
                                    Type
                                </label>
                                <div class="col-12 col-md-10">
                                    <div class="d-flex gap-4">

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="radio" name="obk_type" checked>
                                            <label class="d-flex align-items-center gap-2-label">Number</label>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="radio" name="obk_type">
                                            <label class="d-flex align-items-center gap-2-label">Percentage</label>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Quantity -->
                        <div class="col-12 col-md-6 mb-2">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-6">
                                    Quantity Room
                                </label>
                                <input id="obk_quantityRoom" class="col-6 col-md-2" disabled />
                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>


<!-- Modal: Activity Log -->
<div class="modal fade" id="obk_modalActivityLog" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
     aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Activity Log Overbooking</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">
                    <button type="button" class="mui-button mui-button-new" id="obk_btnCloseActivityLog">Close</button>
                </div>

                <div class="mui-card">
                    <div id="obk_gridContainerActivityLog" class="gridContainer mt-2"></div>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
    var obk_Module = {

        selectedRowData: null,
        gridInstance: null,
        gridActivityInstance: null,

        init: function () {
            const self = this;

            $(document).ready(async function () {
                // IMPORTANT: your #fromDate does not exist (date input uses data-name="fromDate")
                await waitForBusinessDate("fromDate");

                self.searchReservation();
                self.getNumberOfRoom($('#obk_roomType').val());
            });

            self.bindEvents();
        },

        bindEvents: function () {
            const self = this;

            // Search
            $(document).off("click", "#obk_btnSearch").on("click", "#obk_btnSearch", function () {
                self.searchReservation();
            });

            // New
            $(document).off("click", "#obk_btnNew").on("click", "#obk_btnNew", function () {
                self.openModalNew();
            });

            // Edit
            $(document).off("click", "#obk_btnEdit").on("click", "#obk_btnEdit", async function () {
                if (!self.selectedRowData) {
                    showToast("Warning", "Please select 1 row to update.", false);
                    return;
                }

                await self.openModalNew();
                await self.fillOverBookingForm(self.selectedRowData);
            });

            // Activity Log
            $(document).off("click", "#obk_btnActivityLog").on("click", "#obk_btnActivityLog", function () {
                self.getActivityLog();
            });

            // Close main modal
            $(document).off("click", "#obk_btnClose").on("click", "#obk_btnClose", function () {
                $("#obk_modal").modal("hide");
            });

            // Save
            $(document).off("click", "#obk_btnSave").on("click", "#obk_btnSave", function () {
                self.saveOverBooking();
            });

            // Close New
            $(document).off("click", "#obk_btnCloseNew").on("click", "#obk_btnCloseNew", function () {
                self.closeModalNew();
            });

            // Close Activity Log
            $(document).off("click", "#obk_btnCloseActivityLog").on("click", "#obk_btnCloseActivityLog", function () {
                self.closeActivityLog();
            });

            // RoomType change
            $(document).off("change", "#obk_roomType").on("change", "#obk_roomType", function () {
                var selectedValue = $(this).val();
                if (selectedValue != 0) {
                    self.getNumberOfRoom(selectedValue);
                }
            });
        },

        openModalNew: function () {
            $('#obk_modalNewOverBooking').modal('show');
            initDateInputs();
            this.clearForm();
        },

        fillOverBookingForm: function (data) {
            console.log('data', data.Date);

            $("#obk_idOverBooking").val(data.ID);

            UI.setHiddenDate("fromDateNew", data.Date);
            UI.setHiddenDate("toDateNew", data.Date);

            $("input[name='obk_dayName']").prop("checked", false);

            const d = moment(data.Date, "DD/MM/YYYY");
            const dayMap = ["obk_sun", "obk_mon", "obk_tue", "obk_wed", "obk_thu", "obk_fri", "obk_sat"];
            $("#" + dayMap[d.day()]).prop("checked", true);

            $("#obk_roomType").val(data.RoomTypeID);

            $("#obk_obLevel").val(data.Overbooking);

            $("#obk_noToSell").val(data.NotoSell);

            $("#obk_quantityRoom").val(data.Quantity);

            if (data.Type === "Number") {
                $("input[name='obk_type']").eq(0).prop("checked", true);
            } else {
                $("input[name='obk_type']").eq(1).prop("checked", true);
            }
        },

        closeModalNew: function () {
            this.clearForm();
            $('#obk_modalNewOverBooking').modal('hide');
        },

        searchReservation: async function () {
            $("#obk_loadingSpinnerForm").show();

            const dateIso = $("#fromDate").val() || dateSystem;

            $.ajax({
                url: '/Reservation/SearchOverBooking',
                type: 'get',
                dataType: 'json',
                data: {
                    date: dateIso
                },
                crossDomain: false,
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                success: (result) => {
                    listData = result;
                    this.initializeDataGridSearch(result);
                },
                error: function (xhr, statusText, err) {
                    if (xhr.status == 401) {
                        sessionTimeout();
                    }
                },
                complete: function () {
                    $("#obk_loadingSpinnerForm").hide();
                }
            });
        },

        initializeDataGridSearch: function (data) {
            const self = this;

            const limitedData = data.slice(0, 100);

            $("#obk_gridContainer").dxDataGrid({
                dataSource: limitedData,
                allowColumnResizing: true,
                columnAutoWidth: false,
                columnMinWidth: 80,
                height: "100%",

                paging: {
                    enabled: true,
                    pageSize: 15
                },
                pager: {
                    visible: true,
                    allowedPageSizes: [15, 20, 30],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },

                scrolling: {
                    mode: "standard",
                    showScrollbar: "always"
                },

                filterRow: {
                    visible: true,
                    applyFilter: "auto"
                },

                selection: {
                    mode: "single"
                },

                columns: [
                    { dataField: "Date", caption: "Date", dataType: "date", format: "dd/MM/yyyy", width: "8%" },
                    { dataField: "RoomType", caption: "Room Type", width: "8%" },
                    { dataField: "Quantity", caption: "Quantity", dataType: "number", width: "7%" },
                    { dataField: "NotoSell", caption: "No To Sell", dataType: "number", width: "8%" },
                    { dataField: "Overbooking", caption: "Overbooking", dataType: "number", width: "8%" },
                    { dataField: "Type", caption: "Type", width: "7%" },
                    { dataField: "CreateBy", caption: "Created By", width: "9%" },
                    { dataField: "CreateDate", caption: "Created Date", dataType: "date", format: "dd/MM/yyyy", width: "10%" },
                    { dataField: "UpdateBy", caption: "Updated By", width: "9%" },
                    { dataField: "UpdateDate", caption: "Updated Date", dataType: "date", format: "dd/MM/yyyy", width: "10%" },

                    { dataField: "ID", visible: false },
                    { dataField: "RoomTypeID", visible: false }
                ],

                onRowClick: function (e) {
                    // keep your old logic (even though these fields do not exist in HTML)
                    waitListID = e.data.WaitListID;
                    $('#companyWaitList').val(e.data.Company);
                    $('#sourceWaitList').val(e.data.Source);
                    $('#phoneWaitList').val(e.data.Phone);
                    $('#agentWaitList').val(e.data.Agent);
                    $('#groupWaitList').val(e.data.Group);
                    $('#vipWaitList').val("");
                    self.selectedRowData = e.data;
                }
            });

            self.gridInstance = $("#obk_gridContainer").dxDataGrid("instance");
        },

        getNumberOfRoom: function (id) {
            return $.ajax({
                url: '/Reservation/GetCNumberOfRoom',
                type: 'get',
                dataType: 'json',
                crossDomain: false,
                data: { roomTypeID: id },
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                success: function (result) {
                    $('#obk_quantityRoom').val(result);
                },
                error: function (xhr, statusText, err) {
                    if (xhr.status == 401) {
                        sessionTimeout();
                    }
                }
            });
        },

        saveOverBooking: async function () {
            const fromDate = await waitForBusinessDate("fromDateNew");
            const toDate = await waitForBusinessDate("toDateNew");

            const days = [];
            if ($('#obk_sun').is(':checked')) days.push('sun');
            if ($('#obk_mon').is(':checked')) days.push('mon');
            if ($('#obk_tue').is(':checked')) days.push('tue');
            if ($('#obk_wed').is(':checked')) days.push('wed');
            if ($('#obk_thu').is(':checked')) days.push('thu');
            if ($('#obk_fri').is(':checked')) days.push('fri');
            if ($('#obk_sat').is(':checked')) days.push('sat');

            const idOverBooking = $('#obk_idOverBooking').val();
            const roomType = $('#obk_roomType').val();
            const obLevel = $('#obk_obLevel').val();
            const noToSell = $('#obk_noToSell').val();
            const quantity = $('#obk_quantityRoom').val();
            const type = $('input[name="obk_type"]:checked').next('label').text().trim();
            const userName = JSON.parse(localStorage.getItem("Loginname"));
            const userID = JSON.parse(localStorage.getItem("userID"));

            var formData = new FormData();
            formData.append('id', idOverBooking);
            formData.append('fromDate', fromDate);
            formData.append('toDate', toDate);
            formData.append('days', JSON.stringify(days));
            formData.append('quantity', quantity);
            formData.append('roomType', roomType);
            formData.append('obLevel', obLevel);
            formData.append('noToSell', noToSell);
            formData.append('type', type);
            formData.append('userName', userName);
            formData.append('userID', userID);

            $.ajax({
                url: '/Reservation/SaveOverBooking',
                type: 'POST',
                processData: false,
                contentType: false,
                data: formData,
                success: (data) => {
                    if (data.code == 0) {
                        this.closeModalNew();
                        this.searchReservation();
                        showToast('Success', data.msg, true);
                    } else {
                        showToast('Error', data.msg, false);
                    }
                },
                error: function (xhr, statusText, err) {
                    // Xử lý lỗi
                }
            });
        },

        clearForm: function () {
            $('#obk_idOverBooking').val("");
            $('#obk_roomType').val(0);
            $('#obk_obLevel').val('');
            $('#obk_noToSell').val('');

            this.getNumberOfRoom($('#obk_roomType').val());

            // your original function call
            reloadBusinessDate();
        },

        getActivityLog: function () {
            $.ajax({
                url: '/Reservation/GetActivityLogOverBooking',
                type: 'get',
                dataType: 'json',
                crossDomain: false,
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                success: (result) => {
                    this.initializeDataGridActivityLog(result);
                },
                error: function (xhr, statusText, err) {
                    if (xhr.status == 401) {
                        sessionTimeout();
                    }
                },
                complete: function () {
                    $("#obk_loadingSpinnerForm").hide();
                }
            });

            $('#obk_modalActivityLog').modal('show');
        },

        initializeDataGridActivityLog: function (data) {

            const limitedData = data.slice(0, 100);

            $("#obk_gridContainerActivityLog").dxDataGrid({
                dataSource: limitedData,
                allowColumnResizing: true,
                columnAutoWidth: true,
                columnMinWidth: 90,
                paging: {
                    enabled: true,
                    pageSize: 15
                },
                pager: {
                    visible: true,
                    allowedPageSizes: [15, 20, 30],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: {
                    mode: 'standard',
                    showScrollbar: 'always',
                    useNative: false
                },
                filterRow: {
                    visible: true,
                    applyFilter: "auto"
                },
                selection: {
                    mode: "single"
                },
                height: "100%",
                columns: [
                    { dataField: "UserName", caption: "User", width: 120 },
                    { dataField: "Date", caption: "Date", dataType: "date", format: "dd/MM/yyyy", width: 130 },
                    { dataField: "Time", caption: "Time", width: 90 },
                    { dataField: "Change", caption: "Action", width: 100 },
                    { dataField: "NewValue", caption: "New Value", minWidth: 250 },
                    { dataField: "OldValue", caption: "Old Value", minWidth: 200, visible: false },
                    { dataField: "Description", caption: "Description", minWidth: 200 }
                ]
            });

            this.gridActivityInstance = $("#obk_gridContainerActivityLog").dxDataGrid("instance");
        },

        closeActivityLog: function () {
            $('#obk_modalActivityLog').modal('hide');
        },

        destroy: function () {

            // destroy grid
            if (this.gridInstance) {
                try { this.gridInstance.dispose(); } catch (e) { }
                this.gridInstance = null;
            }
            $("#obk_gridContainer").empty();

            // destroy activity grid
            if (this.gridActivityInstance) {
                try { this.gridActivityInstance.dispose(); } catch (e) { }
                this.gridActivityInstance = null;
            }
            $("#obk_gridContainerActivityLog").empty();

            this.selectedRowData = null;
        }
    };

    // Global open entry
    window.openModalObk = function () {
        $("#obk_modal").modal("show");
        obk_Module.init();
    };

    // Cleanup when main modal closes
    $("#obk_modal").on("hidden.bs.modal", function () {
        obk_Module.destroy();
    });
</script>