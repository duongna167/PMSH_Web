    $(document).on('change', '#arrivalShow', async function () {
        if (window.isSyncingDates) return;

        window.isSyncingDates = true;

        try {
            const nights = parseInt($('#nights').val(), 10) || 1;
            const arrivalIso = $('#arrival').val() || dateSystem;
            const departureIso = UI.addDaysIso(arrivalIso, nights);

            UI.setHiddenDate("departure", departureIso);
            Promise.resolve().then(updateDates);

        } finally {
            window.isSyncingDates = false;
        }
    });

    $(document).on('change', '#departureShow, #nights', async function (e) {
        if (window.isSyncingDates) return;
        window.isSyncingDates = true;

        try {
            const targetId = e.target.id;
            const arrivalIso = $('#arrival').val() || dateSystem;
            let departureIso = $('#departure').val();
            let nights = parseInt($('#nights').val(), 10) || 1;

            if (targetId === 'departureShow') {
                if (arrivalIso && departureIso) {
                    if (departureIso <= arrivalIso) {
                        const safeNights = nights > 0 ? nights : 1;
                        const newArrival = UI.addDaysIso(departureIso, -safeNights);
                        UI.setHiddenDate("arrival", newArrival);
                    } else {
                        calculateNights();
                    }
                }
            }

            else if (targetId === 'nights') {
                if (nights < 1) {
                    nights = 1;
                    $('#nights').val(1);
                }
                const newDeparture = UI.addDaysIso(arrivalIso, nights);
                UI.setHiddenDate("departure", newDeparture);
            }
            let      day = parseInt($('#nights').val(), 10) || 1;

             const rateAfterDiscount = parseFloat(
                 $('#txtRateAfterDiscount').val().replace(/\./g, '').replace(',', '.')
             ) || 0;

             const netAfterDiscount = parseFloat(
                 $('#txtNetAfterDiscount').val().replace(/\./g, '').replace(',', '.')
             ) || 0;

       
             console.log(day);

             const total = rateAfterDiscount * day;
             const totalNet = netAfterDiscount * day;

             $('#txtTotal').val(total.toLocaleString('vi-VN'));
             $('#txtTotalNet').val(totalNet.toLocaleString('vi-VN'));
            Promise.resolve().then(updateDates);

            // recalculateReservationAmounts();
            // recalculateNetReverseReservationAmounts();

        } catch (err) {
            console.error("Lỗi cập nhật ngày tháng:", err);
        } finally {
            window.isSyncingDates = false;
        }
    });

