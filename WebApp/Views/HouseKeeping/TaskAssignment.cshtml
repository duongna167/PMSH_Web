<div class="modal fade" id="popupNewGridTurndown" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <!-- Modal Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="attendantPointTitle">Turndown Management</h5>
               
            </div>

            <!-- Modal Body -->
            <div class="modal-body">

                <!-- Action buttons -->
                <div class="d-flex justify-content-start mb-3 gap-2">
                    <button id="btnViewTurndown" class="mui-button mui-button-new" type="button">View</button>
                    <button id="btnOkTurndown" class="mui-button mui-button-new" type="button">Ok</button>
                    <button class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>

                <!-- Sticky Filter Panel -->
                <div class="sticky-header bg-white p-2 shadow-sm z-3">
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-1 filter-panel">

                        <div class="d-flex align-items-center flex-wrap mb-2">

                            <!-- Turndown & Reservation Status -->
                            <div class="d-flex flex-column me-3">
                                <div class="d-flex align-items-center">
                                    <label class="mb-1 me-2 fw-bold">Turndown Status:</label>

                                    <div class="form-check me-3">
                                        <input  type="checkbox" id="required" name="includeOptionsTurndown" value="1" checked>
                                        <label class="form-check-label" for="required">Required</label>
                                    </div>
                                    <div class="form-check me-3">
                                        <input  type="checkbox" id="notrequired" name="includeOptionsTurndown" value="2" checked>
                                        <label class="form-check-label" for="notrequired">Not Required</label>
                                    </div>
                                    <div class="form-check me-3">
                                        <input  type="checkbox" id="completed" name="includeOptionsTurndown" value="3" checked>
                                        <label class="form-check-label" for="completed">Completed</label>
                                    </div>

                                    <label class="mb-1 me-2 fw-bold ms-3">Reservation Status:</label>
                                    <div class="form-check me-3">
                                        <input  type="checkbox" id="arrivals" name="includeOptionsReservation" value="5" checked>
                                        <label class="form-check-label" for="arrivals">Arrivals</label>
                                    </div>
                                    <div class="form-check me-3">
                                        <input  type="checkbox" id="arrived" name="includeOptionsReservationVI" value="1" checked>
                                        <label class="form-check-label" for="arrived">Arrived</label>
                                    </div>
                                    <div class="form-check me-3">
                                        <input  type="checkbox" id="stayover" name="includeOptionsReservation" value="1,6" checked>
                                        <label class="form-check-label" for="stayover">Stay Over</label>
                                    </div>
                                </div>
                            </div>

                            <!-- Room Status -->
                            <div class="d-flex flex-column me-3">
                                <div class="d-flex align-items-center">
                                    <label class="mb-1 me-2 fw-bold">Room Status:</label>

                                    <div class="form-check me-3">
                                        <span class="status-color-box color-clean-uncheck"></span>
                                        <input  type="checkbox" id="cleanNoncheck" name="includeOptionsRoom" value="1" checked>
                                        <label class="form-check-label" for="cleanNoncheck">Clean Non-Checked</label>
                                    </div>
                                    <div class="form-check me-3">
                                        <span class="status-color-box color-dirty"></span>
                                        <input  type="checkbox" id="dirty" name="includeOptionsRoom" value="2" checked>
                                        <label class="form-check-label" for="dirty">Dirty</label>
                                    </div>
                                    <div class="form-check me-3">
                                        <span class="status-color-box color-outoforder"></span>
                                        <input  type="checkbox" id="outofOrder" name="includeOptionsRoom" value="5" checked>
                                        <label class="form-check-label" for="outofOrder">Out of Order</label>
                                    </div>
                                    <div class="form-check me-3">
                                        <span class="status-color-box color-pickup"></span>
                                        <input  type="checkbox" id="pickup" name="includeOptionsRoom" value="3" checked>
                                        <label class="form-check-label" for="pickup">Pickup</label>
                                    </div>
                                    <div class="form-check me-3">
                                        <span class="status-color-box color-clean"></span>
                                        <input  type="checkbox" id="clean" name="includeOptionsRoom" value="4" checked>
                                        <label class="form-check-label" for="clean">Clean</label>
                                    </div>
                                    <div class="form-check me-3">
                                        <span class="status-color-box color-outofservices"></span>
                                        <input  type="checkbox" id="outofServices" name="includeOptionsRoom" value="6" checked>
                                        <label class="form-check-label" for="outofServices">Out of Services</label>
                                    </div>
                                </div>
                            </div>

                            <!-- Advanced Search -->
                            <div class="d-flex flex-column">
                                <div class="d-flex align-items-center mb-2">
                                    <label class="mb-1 me-2 fw-bold">Advance Search:</label>
                                    <div class="d-flex align-items-center me-3">
                                        <label class="me-2 mb-0">From Room:</label>
                                        <input type="text" id="fromRoom" name="fromRoom" class="form-control form-control-sm w-auto" />
                                    </div>
                                    <div class="d-flex align-items-center me-3">
                                        <label class="me-2 mb-0">To Room:</label>
                                        <input type="text" id="toRoom" name="toRoom" class="form-control form-control-sm w-auto" />
                                    </div>
                                    <div class="d-flex align-items-center me-3">
                                        <label class="me-2 mb-0">Room Type:</label>
                                        <select id="roomTypead" name="roomTypead" class="tomselect-custom" multiple>
                                            <option value=""></option>
                                            @foreach (var item in listrt)
                                            {
                                                <option value="@item.Code">@item.Code</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center mb-2">
                                    <div class="d-flex align-items-center me-3">
                                        <label class="me-2 mb-0">Section:</label>
                                        <select id="sectionAd" name="sectionAd" class="tomselect-custom" multiple>
                                            <option value=""></option>
                                            @foreach (var item in hkpSectionlist)
                                            {
                                                <option value="@item.ID">@item.Code</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="d-flex align-items-center me-3">
                                        <label class="me-2 mb-0">Zone:</label>
                                        <select id="zoneAd" name="zoneAd" class="tomselect-custom" multiple>
                                            <option value=""></option>
                                            @foreach (var item in listzone)
                                            {
                                                <option value="@item.Code">@item.Code</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                        </div>

                    </div>
                </div>

                <!-- Grid Container -->
                <div id="logGriTurndownContainer" class="gridContainer mt-2">
                    <!-- Nội dung bảng hoặc grid sẽ được render tại đây -->
                </div>

            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="popupNewGridReport" tabindex="-1"
     aria-labelledby="popupNewGridReportLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-md modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="popupNewGridReportLabel">
                    Task Sheet Report
                </h5>
             
            </div>

            <!-- Body -->
            <div class="modal-body mb-2">

                <div class="d-flex justify-content-start mb-3 gap-2">
                    <button id="btnViewpopExcel"
                            class="mui-button mui-button-new"
                            type="button">
                        View
                    </button>

                    <button type="button"
                            class="mui-button mui-button-new"
                            data-bs-dismiss="modal">
                        Close
                    </button>
                </div>

                <div class="container-fluid px-0">
                    <div class="row g-2 mt-1 align-items-center">

                        <!-- Task Date From -->
                        <div class="col-12 col-md-6">
                            <div class="row g-1 align-items-center">
                                <label class="col-5 text-md-end mb-0">Task Date</label>
                                <div class="col-7">
                                    <div class="clearable"
                                        data-date-input
                                        data-format="DD/MM/YYYY"
                                        data-name="fromDatere"
                                        business-date>
                                        <input type="text" class="date-ui form-control form-control-sm" autocomplete="off" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- To -->
                        <div class="col-12 col-md-6">
                            <div class="row g-1 align-items-center">
                                <label class="col-5 text-md-end mb-0">To</label>
                                <div class="col-7">
                                    <div class="clearable"
                                        data-date-input
                                        data-format="DD/MM/YYYY"
                                        data-name="toDatere"
                                        business-date>
                                        <input type="text" class="date-ui form-control form-control-sm" autocomplete="off" disabled />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Facility Task -->
                        <div class="col-12 col-md-6">
                            <div class="row g-1 align-items-center">
                                <label class="col-5 text-md-end mb-0">Facility Task</label>
                                <div class="col-7">
                                    <select id="taskcodeexpan" class="form-select form-select-sm">
