@{
    // var listctry = ViewBag.CountryList;
}


<!-- =========================
     MAIN MODAL (modal-xl)
     ========================= -->
<div class="modal fade" id="faCt_modalMain" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Facility Category</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">
                <!-- Toolbar -->
                    <div>
                        <button id="faCt_btnView" type="button" class="mui-button mui-button-search">View</button>
                        <button id="faCt_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="faCt_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="faCt_btnDelete" type="button" class="mui-button mui-button-delete">Delete</button>
                        <button id="faCt_btnExportExcel" type="button" class="mui-button mui-button-export">Excel</button>
                        <button id="faCt_btnClose" type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                    </div>

                    <!-- ERP Search Filter -->
                    <div class="row g-2 m-1">

                        <div class="col-12 col-md-4">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-2 col-form-label col-form-label-sm text-md-end"
                                        for="faCt_codeInput">Code</label>
                                <div class="col-md-8">
                                    <input type="text"
                                            id="faCt_codeInput"
                                            name="faCt_codeInput"
                                            class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-2 col-form-label col-form-label-sm text-md-end"
                                        for="faCt_nameInput">Name</label>
                                <div class="col-md-8">
                                    <input type="text"
                                            id="faCt_nameInput"
                                            name="faCt_nameInput"
                                            class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-2 col-md-4 col-lg-4 col-form-label col-form-label-sm text-md-end" for="faCt_chkshowInactive">Show Inactive</label>
                                <div class="col-md-8">
                                    <div class="form-check d-flex align-items-center gap-2">
                                        <input 
                                            type="checkbox"
                                            id="faCt_chkshowInactive"
                                            name="faCt_chkshowInactive">
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <!-- Grid -->
                <div class="mui-card">
                    <div id="faCt_gridContainer" class="gridContainer"></div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- =========================
     EDIT / NEW MODAL (modal-xl)
     ========================= -->
<div class="modal fade" id="faCt_modalEdit" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="faCt_itemModalLabel">Facility Category</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">
                    <button type="button" id="faCt_btnSaveItem" class="mui-button mui-button-save">Save</button>
                    <button type="button" data-bs-dismiss="modal" class="mui-button mui-button-close">Close</button>
                </div>

                <form id="faCt_formContainer" novalidate>

                    <div class="row g-2 mt-1">

                        <div class="col-12 col-lg-8">
                            <div class="row g-2 align-items-center">
                                <label for="faCt_code" class="col-md-3 col-form-label col-form-label-sm text-md-end">Code</label>
                                <div class="col-md-9">
                                    <input type="text"
                                            id="faCt_code"
                                            name="code"
                                            class="form-control form-control-sm"
                                            placeholder="Enter code..." />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-4">
                            <div class="row g-2 align-items-center">
                                <div class="col-md-12 d-flex align-items-center">
                                    <input type="checkbox"
                                            id="faCt_inactive"
                                            name="faCt_inactive"
                                            class="me-2" />
                                    <label for="faCt_inactive" class="form-check-label text-danger">Inactive</label>
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="row g-2 mt-1">
                        <div class="col-12">
                            <div class="row g-2 align-items-center">
                                <label for="faCt_name" class="col-md-2 col-form-label col-form-label-sm text-md-end">Name</label>
                                <div class="col-md-10">
                                    <input type="text"
                                            id="faCt_name"
                                            name="name"
                                            class="form-control form-control-sm"
                                            placeholder="Enter name..." />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-2 mt-1 mb-2">
                        <div class="col-12">
                            <div class="row g-2 align-items-start">
                                <label for="faCt_description" class="col-md-2 col-form-label col-form-label-sm text-md-end">Description</label>
                                <div class="col-md-10">
                                    <textarea id="faCt_description"
                                                name="faCt_description"
                                                class="form-control form-control-sm"
                                                rows="3"
                                                placeholder="Enter description..."
                                                style="height: 100px;"></textarea>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="faCt_id" name="faCt_id" value="0" />

                </form>

            </div>
        </div>
    </div>
</div>

<div id="faCt_loadingSpinner"
    style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
    z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
    height: 100%;display: flex;align-items: center;justify-content: center;">
    <div class="spinner-border text-primary"></div>
</div>

<script>
    var faCt_Module = (function () {
        "use strict";

        const SEL = {
            modalMain: "#faCt_modalMain",
            modalEdit: "#faCt_modalEdit",
            spinner: "#faCt_loadingSpinner",

            btnView: "#faCt_btnView",
            btnNew: "#faCt_btnNew",
            btnEdit: "#faCt_btnEdit",
            btnDelete: "#faCt_btnDelete",
            btnExportExcel: "#faCt_btnExportExcel",

            codeInput: "#faCt_codeInput",
            nameInput: "#faCt_nameInput",
            chkshowInactive: "#faCt_chkshowInactive",

            grid: "#faCt_gridContainer",

            form: "#faCt_formContainer",
            modalLabel: "#faCt_itemModalLabel",
            btnSaveItem: "#faCt_btnSaveItem",

            id: "#faCt_id",
            code: "#faCt_code",
            name: "#faCt_name",
            description: "#faCt_description",
            inactive: "#faCt_inactive"
        };

        let _gridInstance = null;
        let _selectedRowData = null;
        let _bound = false;

        function showLoading(show) {
            if (show) $(SEL.spinner).show();
            else $(SEL.spinner).hide();
        }

        function csrfHeaders() {
            return {
                "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
            };
        }

        function resetValidation() {
            if (typeof applyValidationErrors === "function") {
                applyValidationErrors([], SEL.form);
            }
            $(`${SEL.form} .form-control, ${SEL.form} .form-select`).removeClass("is-invalid");
            $(`${SEL.form} .invalid-feedback`).text("");
        }

        function clearForm() {
            $(SEL.form)[0].reset();
            resetValidation();
            $(SEL.id).val("0");
        }

        function disposeGrid() {
            try {
                const inst = $(SEL.grid).dxDataGrid("instance");
                if (inst) inst.dispose();
            } catch (e) { }

            _gridInstance = null;
            _selectedRowData = null;
            $(SEL.grid).empty();
        }

        function fillForm(data) {
            $(SEL.id).val(data.id || 0);
            $(SEL.code).val(data.code || "");
            $(SEL.name).val(data.name || "");
            $(SEL.description).val(data.description || "");
            $(SEL.inactive).prop("checked", !!data.inactive);
        }

        function getSaveModel() {
            const id = parseInt($(SEL.id).val(), 10) || 0;
            const loginName = (localStorage.getItem("Loginname") || "").trim().replace(/^"(.*)"$/, "$1");

            return {
                ID: id,
                Code: $(SEL.code).val(),
                Name: $(SEL.name).val(),
                Description: $(SEL.description).val(),
                Inactive: $(SEL.inactive).prop("checked"),
                CreatedBy: loginName,
                UpdatedBy: loginName
            };
        }

        function initGrid(data) {
            disposeGrid();

            _gridInstance = $(SEL.grid).dxDataGrid({
                dataSource: data || [],
                width: "100%",
                showBorders: true,
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                hoverStateEnabled: true,

                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "code", caption: "Code", width: "80px" },
                    { dataField: "name", caption: "Name", width: "150px" },
                    { dataField: "description", caption: "Description" },
                    {
                        dataField: "inactive",
                        caption: "Inactive",
                        width: "60",
                        cellTemplate: function (container, options) {
                            $("<div>")
                                .dxCheckBox({
                                    value: !!options.value,
                                    readOnly: true
                                })
                                .css("transform", "scale(0.8)")
                                .appendTo(container);
                        }
                    },
                    { dataField: "createdBy", caption: "Created By", width: "80" },
                    { dataField: "createdDate", caption: "Cre.Date", dataType: "date", width: "80" },
                    { dataField: "updatedBy", caption: "Updated By", width: "80" },
                    { dataField: "updatedDate", caption: "Upd.Date", dataType: "date", width: "80" }
                ],

                filterRow: { visible: true, applyFilter: "auto" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: {
                    mode: "standard",
                    showScrollbar: "always"
                },

                onSelectionChanged: function (e) {
                    _selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
                }
            }).dxDataGrid("instance");
        }

        function loadGridData() {
            showLoading(true);

            $.ajax({
                url: "/HouseKeepingAdmin/GetFacilityCategory",
                type: "GET",
                cache: false,
                data: {
                    code: $(SEL.codeInput).val(),
                    name: $(SEL.nameInput).val(),
                    inactive: $(SEL.chkshowInactive).prop("checked") ? 1 : 0
                },
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (data) {
                    initGrid(data);
                    showLoading(false);
                },
                error: function () {
                    showLoading(false);
                    showToast("Error", "Unable to load data", false);
                }
            });
        }

        function openNew() {
            clearForm();
            $(SEL.modalLabel).text("Add Facility Category");
            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).show();
        }

        function openEdit() {
            if (!_selectedRowData) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }

            clearForm();
            fillForm(_selectedRowData);
            $(SEL.modalLabel).text("Update Facility Category");
            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).show();
        }

        function save() {
            const model = getSaveModel();

            $.ajax({
                url: "/HouseKeepingAdmin/FacilityCategorySave",
                type: "POST",
                contentType: "application/json",
                cache: false,
                data: JSON.stringify(model),
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (res) {
                    if (res.success) {
                        showToast("Success", res.message, true);
                        bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).hide();
                        loadGridData();
                    } else {
                        if (res.errors && res.errors.length > 0) {
                            applyValidationErrors(res.errors, SEL.form);
                            const genErr = res.errors.find(x => x.field === "general");
                            if (genErr) showToast("Warning", genErr.message, false);
                        } else {
                            showToast("Error", res.message || "Save failed", false);
                        }
                    }
                },
                error: function () {
                    showToast("Error", "Request error!", false);
                    bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).hide();
                }
            });
        }

        function removeSelected() {
            if (!_selectedRowData || _selectedRowData.id === 0) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }

            if (!confirm("Are you sure you want to delete this record? This action cannot be undone.")) {
                return;
            }

            $.ajax({
                url: "/HouseKeepingAdmin/DeleteFacilityCategory/" + _selectedRowData.id,
                type: "POST",
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (result) {
                    if (result.success) {
                        loadGridData();
                        showToast("Success", "Delete Successfully!", true);
                    } else {
                        showToast("Error", result.message, false);
                    }
                },
                error: function () {
                    showToast("Error", "Delete failed!", false);
                }
            });
        }

        function exportExcel() {
            const grid = $(SEL.grid).dxDataGrid("instance");
            if (!grid) {
                showToast("Warning", "No grid data to export.", false);
                return;
            }

            const workbook = new ExcelJS.Workbook();
            const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const worksheet = workbook.addWorksheet("Sheet 1");

            worksheet.addRow([companyName]);
            worksheet.mergeCells("A1:D1");
            worksheet.getRow(1).font = { bold: true };
            worksheet.getRow(1).alignment = { vertical: "middle", horizontal: "left" };

            const now = new Date();
            const exportDate = now.toLocaleString("vi-VN");
            worksheet.addRow(["", "", "", exportDate]);
            worksheet.mergeCells("D2:D2");
            worksheet.getRow(2).alignment = { vertical: "middle", horizontal: "right" };

            worksheet.addRow([]);
            worksheet.addRow([]);

            const reportRow = worksheet.addRow(["Facility Category"]);
            worksheet.mergeCells("A5:D5");
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { vertical: "middle", horizontal: "center" };

            worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const lastRow = worksheet.lastRow.number + 2;
                worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
                worksheet.getCell(`A${lastRow}`).alignment = { horizontal: "center" };
                worksheet.getCell(`A${lastRow}`).font = { italic: true };

                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "FacilityCategory.xlsx");
                });
            });
        }

        function bindEventsOnce() {
            if (_bound) return;
            _bound = true;

            $(document)
                .off("click.faCt", SEL.btnView).on("click.faCt", SEL.btnView, loadGridData)
                .off("click.faCt", SEL.btnNew).on("click.faCt", SEL.btnNew, openNew)
                .off("click.faCt", SEL.btnEdit).on("click.faCt", SEL.btnEdit, openEdit)
                .off("click.faCt", SEL.btnDelete).on("click.faCt", SEL.btnDelete, removeSelected)
                .off("click.faCt", SEL.btnExportExcel).on("click.faCt", SEL.btnExportExcel, exportExcel)
                .off("click.faCt", SEL.btnSaveItem).on("click.faCt", SEL.btnSaveItem, save);

            $(document)
                .off("input.faCt change.faCt", `${SEL.form} input, ${SEL.form} select, ${SEL.form} textarea`)
                .on("input.faCt change.faCt", `${SEL.form} input, ${SEL.form} select, ${SEL.form} textarea`, function () {
                    if ($(this).hasClass("is-invalid")) {
                        $(this).removeClass("is-invalid");
                        $(this).next(".invalid-feedback").text("");
                    }
                });

            $(SEL.modalEdit)
                .off("shown.bs.modal.faCt")
                .on("shown.bs.modal.faCt", function () {
                })
                .off("hidden.bs.modal.faCt")
                .on("hidden.bs.modal.faCt", function () {
                    clearForm();
                });

            $(SEL.modalMain)
                .off("hidden.bs.modal.faCt")
                .on("hidden.bs.modal.faCt", function () {
                    $(SEL.codeInput).val("");
                    $(SEL.nameInput).val("");
                    $(SEL.chkshowInactive).prop("checked", false);

                    disposeGrid();
                    showLoading(false);
                });
        }

        function init() {
            bindEventsOnce();
        }

        function open() {
            init();

            const modalEl = document.querySelector(SEL.modalMain);
            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

            modal.show();
            loadGridData();
        }

        return { init, open };
    })();

    window.openModalFaCt = function () {
        faCt_Module.open();
    };

</script>