@* <link href="~/css/pages/reservation.css" rel="stylesheet" asp-append-version="true" /> *@

<div class="header mt-2" style="border-bottom:none;justify-content:center">
    <h3 id="content-title">
        Overbooking Search
    </h3>
</div>
<div class="search-filter">
    <div>
        <button class="mui-button mui-button-new" onclick="searchReservation()">Search</button>

        <button class="mui-button mui-button-new" onclick="openModalNew()">New</button>
        <button class="mui-button mui-button-new" id="btn-edit-overbk">Edit</button>
        <button class="mui-button mui-button-new" onclick="getActivityLog()">Activity Log</button>

    </div>
    <div class="d-flex flex-wrap align-items-center gap-2 mt-1">
        <div class="d-flex align-items-center me-4 ms-1">
            <label for="tracetime" class="me-2 mb-0">Date:</label>
            <div data-date-input data-format="DD/MM/YYYY" data-name="fromDate" business-date>
                <input type="text" class="date-ui form-control" placeholder="dd/mm/yyyy" autocomplete="off" />
            </div>
        </div>
    </div>
</div>

<div>

    <div id="loadingSpinnerForm" style="display: none; text-align: center; padding: 20px;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
    <!-- DevExtreme DataGrid -->
    <div id="gridContainer" class="gridContainer mt-2"></div>
</div>

<!-- Modal cancel-->
<div class="modal fade modal" id="modalNewOverBooking" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
    aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Overbooking Setup</h5>
            </div>
            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <button class="mui-button mui-button-new" onclick="SaveOverBooking();">OK</button>
                        <button class="mui-button mui-button-new" onclick="closeModalNew()">Close</button>
                    </div>
                </div>
                <div class="mt-1">
                    <div class="row g-2">
                        <input type="hidden" id="idOverBooking">
                        <!-- From Date -->
                        <div class="col-12 col-md-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    From Date
                                </label>
                                <div class="col-12 col-md-8">
                                    <div data-date-input data-format="DD/MM/YYYY" data-name="fromDateNew">
                                        <input type="text" class="date-ui form-control" placeholder="dd/mm/yyyy"
                                            autocomplete="off" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- To Date -->
                        <div class="col-12 col-md-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    To Date
                                </label>
                                <div class="col-12 col-md-8">
                                    <div data-date-input data-format="DD/MM/YYYY" data-name="toDateNew">
                                        <input type="text" class="date-ui form-control" placeholder="dd/mm/yyyy"
                                            autocomplete="off" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Days of Week -->
                        <div class="col-12">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-2 col-form-label text-md-end">
                                    Days
                                </label>
                                <div class="col-12 col-md-10">
                                    <div class="d-flex flex-wrap gap-3">

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="checkbox" name="dayName" checked id="sun">
                                            <label class="d-flex align-items-center gap-2-label">Sun</label>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="checkbox" name="dayName" checked id="mon">
                                            <label class="d-flex align-items-center gap-2-label">Mon</label>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="checkbox" name="dayName" checked id="tue">
                                            <label class="d-flex align-items-center gap-2-label">Tue</label>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="checkbox" name="dayName" checked id="wed">
                                            <label class="d-flex align-items-center gap-2-label">Wed</label>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="checkbox" name="dayName" checked id="thu">
                                            <label class="d-flex align-items-center gap-2-label">Thu</label>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="checkbox" name="dayName" checked id="fri">
                                            <label class="d-flex align-items-center gap-2-label">Fri</label>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="checkbox" name="dayName" checked id="sat">
                                            <label class="d-flex align-items-center gap-2-label">Sat</label>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="checkbox" id="includeOutOfOrder" name="includeOptions"
                                                value="1" checked="">
                                            <label class="d-flex align-items-center gap-2-label"
                                                for="includeOutOfOrder">Include Out of
                                                Order</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Room Type -->
                        <div class="col-12 col-md-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-5 col-form-label text-md-end">
                                    Room Type
                                </label>
                                <div class="col-12 col-md-7">
                                    <select id="roomType" class="form-select form-select-sm"
                                        asp-items="ViewBag.cboRoomType"></select>
                                </div>
                            </div>
                        </div>

                        <!-- Overbooking Level -->
                        <div class="col-12 col-md-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-7 col-form-label text-md-end">
                                    Overbooking Level
                                </label>
                                <div class="col-12 col-md-5">
                                    <input type="number" id="obLevel" class="form-control form-control-sm text-end">
                                </div>
                            </div>
                        </div>

                        <!-- No to sell -->
                        <div class="col-12 col-md-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-5 col-form-label text-md-end">
                                    No to sell
                                </label>
                                <div class="col-12 col-md-7">
                                    <input type="number" id="noToSell" class="form-control form-control-sm text-end">
                                </div>
                            </div>
                        </div>

                        <!-- Type Radio -->
                        <div class="col-12 col-md-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-2 col-form-label text-md-end">
                                    Type
                                </label>
                                <div class="col-12 col-md-10">
                                    <div class="d-flex gap-4">

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="radio" name="type" checked>
                                            <label class="d-flex align-items-center gap-2-label">Number</label>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <input type="radio" name="type">
                                            <label class="d-flex align-items-center gap-2-label">Percentage</label>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Quantity -->
                        <div class="col-12 col-md-6 mb-2">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-6 ">
                                    Quantity Room
                                </label>
                                <input id="quantityRoom" class="col-6 col-md-2" disabled />
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- Modal activity log-->
<div class="modal fade modal" id="modalActivityLog" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
    aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="staticBackdropLabel">Activity Log Overbooking</h5>
            </div>
            <div class="modal-body">
                <div class="search-filter">
                    <button type="button" class="mui-button mui-button-new" onclick="closeActivityLog();">Close</button>
                </div>
                <div class="mui-card">
                    <div id="gridContainerActivityLog" class="gridContainer mt-2"></div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    $(document).ready(async function () {
        searchReservation();
        getNumberOfRoom($('#roomType').val());

    });

    var selectedRowData = null;

    function openModalNew() {
        $('#modalNewOverBooking').modal('show');
        UI.setHiddenDate("fromDateNew", dateSystem);
        UI.setHiddenDate("toDateNew", dateSystem);
        clearForm();
    }


    $(document).off("click", "#btn-edit-overbk").on("click", "#btn-edit-overbk", async function () {
        if (!selectedRowData) {
            showToast("Warning", "Please select 1 row to update.", false);
            return;
        }

        await openModalNew();
        await fillOverBookingForm(selectedRowData)
    });

    function fillOverBookingForm(data) {
        console.log('data', data.Date);

        // ===== ID (update mode) =====
        $("#idOverBooking").val(data.ID);

        // ===== Date =====
        // Update chỉ có 1 ngày → set From = To
        UI.setHiddenDate("fromDateNew", data.Date);
        UI.setHiddenDate("toDateNew", data.Date);

        // ===== Days =====
        // Update 1 ngày → chỉ check đúng thứ của ngày đó
        $("input[name='dayName']").prop("checked", false);

        const d = moment(data.Date, "DD/MM/YYYY");
        const dayMap = ["sun", "mon", "tue", "wed", "thu", "fri", "sat"];
        $("#" + dayMap[d.day()]).prop("checked", true);

        // ===== Room Type =====
        $("#roomType").val(data.RoomTypeID);

        // ===== Overbooking level =====
        $("#obLevel").val(data.Overbooking);

        // ===== No to sell =====
        $("#noToSell").val(data.NotoSell);

        // ===== Quantity =====
        $("#quantityRoom").val(data.Quantity);

        // ===== Type =====
        if (data.Type === "Number") {
            $("input[name='type']").eq(0).prop("checked", true);
        } else {
            $("input[name='type']").eq(1).prop("checked", true);
        }
    }

    function closeModalNew() {
        clearForm();
        $('#modalNewOverBooking').modal('hide');
    }

    function searchReservation() {

        $("#loadingSpinnerForm").show();

        $.ajax({
            url: '/Reservation/SearchOverBooking',
            type: 'get',
            dataType: 'json',
            data: {
                date: $('#fromDate').val()
            },
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {

                listData = result;
                initializeDataGridSearch(result);
            },
            error: function (xhr, statusText, err) {
                if (xhr.status == 401) {
                    sessionTimeout();
                }
            },
            complete: function () {
                $("#loadingSpinnerForm").hide();
            }
        });

    }
        function initializeDataGridSearch(data) {

        const limitedData = data.slice(0, 100);

        $("#gridContainer").dxDataGrid({
            dataSource: limitedData,
            allowColumnResizing: true,
            columnAutoWidth: false,   // 🔴 BẮT BUỘC tắt
            columnMinWidth: 80,
            height: "500px",

            paging: {
                enabled: true,
                pageSize: 15
            },
            pager: {
                visible: true,
                allowedPageSizes: [15, 20, 30],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },

            scrolling: {
                mode: "standard",
                showScrollbar: "always"
            },

            filterRow: {
                visible: true,
                applyFilter: "auto"
            },

            selection: {
                mode: "single"
            },

            columns: [
                { dataField: "Date", caption: "Date", dataType: "date", format: "dd/MM/yyyy", width: "8%" },
                { dataField: "RoomType", caption: "Room Type", width: "8%" },
                { dataField: "Quantity", caption: "Quantity", dataType: "number", width: "7%" },
                { dataField: "NotoSell", caption: "No To Sell", dataType: "number", width: "8%" },
                { dataField: "Overbooking", caption: "Overbooking", dataType: "number", width: "8%" },
                { dataField: "Type", caption: "Type", width: "7%" },
                { dataField: "CreateBy", caption: "Created By", width: "9%" },
                { dataField: "CreateDate", caption: "Created Date", dataType: "date", format: "dd/MM/yyyy", width: "10%" },
                { dataField: "UpdateBy", caption: "Updated By", width: "9%" },
                { dataField: "UpdateDate", caption: "Updated Date", dataType: "date", format: "dd/MM/yyyy", width: "10%" },

                { dataField: "ID", visible: false },
                { dataField: "RoomTypeID", visible: false }
            ],

            onRowClick: function (e) {
                waitListID = e.data.WaitListID;
                $('#companyWaitList').val(e.data.Company);
                $('#sourceWaitList').val(e.data.Source);
                $('#phoneWaitList').val(e.data.Phone);
                $('#agentWaitList').val(e.data.Agent);
                $('#groupWaitList').val(e.data.Group);
                $('#vipWaitList').val("");
                selectedRowData = e.data;
            }
        });
    }


    $('#roomType').on('change', function () {
        // Get the selected value
        var selectedValue = $(this).val();
        if (selectedValue != 0) {
            getNumberOfRoom(selectedValue);
        }
        // Your logic here
    });
    function getNumberOfRoom(id) {
        return $.ajax({
            url: '/Reservation/GetCNumberOfRoom',
            type: 'get',
            dataType: 'json',
            crossDomain: false,
            data: { roomTypeID: id },
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                $('#quantityRoom').val(result);

            },
            error: function (xhr, statusText, err) {
                if (xhr.status == 401) {
                    sessionTimeout();
                }
            }
        });
    }

    function SaveOverBooking() {
        const fromDate = $('#fromDateNew').val();
        const toDate = $('#toDateNew').val();

        // Chuyển days thành mảng các ngày được chọn
        const days = [];
        if ($('#sun').is(':checked')) days.push('sun');
        if ($('#mon').is(':checked')) days.push('mon');
        if ($('#tue').is(':checked')) days.push('tue');
        if ($('#wed').is(':checked')) days.push('wed');
        if ($('#thu').is(':checked')) days.push('thu');
        if ($('#fri').is(':checked')) days.push('fri');
        if ($('#sat').is(':checked')) days.push('sat');

        const idOverBooking = $('#idOverBooking').val();
        const roomType = $('#roomType').val();
        const obLevel = $('#obLevel').val();
        const noToSell = $('#noToSell').val();
        const quantity = $('#quantityRoom').val();
        const type = $('input[name="type"]:checked').next('label').text().trim();
        const userName = JSON.parse(localStorage.getItem("Loginname"));
        const userID = JSON.parse(localStorage.getItem("userID"));

        var formData = new FormData();
        formData.append('id', idOverBooking);
        formData.append('fromDate', fromDate);
        formData.append('toDate', toDate);
        // Gửi days dưới dạng JSON string của mảng
        formData.append('days', JSON.stringify(days));
        formData.append('quantity', quantity);
        formData.append('roomType', roomType);
        formData.append('obLevel', obLevel);
        formData.append('noToSell', noToSell);
        formData.append('type', type);
        formData.append('userName', userName);
        formData.append('userID', userID);

        $.ajax({
            url: '/Reservation/SaveOverBooking',
            type: 'POST',
            processData: false,
            contentType: false,
            data: formData,
            success: function (data) {
                if (data.code == 0) {
                    closeModalNew();
                    searchReservation();
                    showToast('Success', data.msg, true);
                } else {
                    showToast('Error', data.msg, false);
                }
            },
            error: function (xhr, statusText, err) {
                // Xử lý lỗi
            }
        });
    }
    function clearForm() {
        $('#idOverBooking').val("");
        $('#roomType').val(0);
        $('#obLevel').val('');
        $('#noToSell').val('');
        getNumberOfRoom($('#roomType').val());
        reloadBusinessDate();
    }

    function getActivityLog() {

        $.ajax({
            url: '/Reservation/GetActivityLogOverBooking',
            type: 'get',
            dataType: 'json',

            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                initializeDataGridActivityLog(result);
            },
            error: function (xhr, statusText, err) {
                if (xhr.status == 401) {
                    sessionTimeout();
                }
            },
            complete: function () {
                $("#loadingSpinnerForm").hide();
            }
        });
        $('#modalActivityLog').modal('show');
    }
    function initializeDataGridActivityLog(data) {
        // Kiểm tra dữ liệu đầu vào

        // Nếu cần giới hạn tổng số bản ghi, ví dụ 100 bản ghi
        const limitedData = data.slice(0, 100);

        $("#gridContainerActivityLog").dxDataGrid({
            dataSource: limitedData, // Sử dụng dữ liệu đã giới hạn
            allowColumnResizing: true,
            columnAutoWidth: true,
            columnMinWidth: 90,
            paging: {
                enabled: true, // Bật phân trang
                pageSize: 15 // Mỗi trang 15 bản ghi
            },
            pager: {
                visible: true,
                allowedPageSizes: [15, 20, 30], // Chỉ các kích thước trang cố định
                showPageSizeSelector: true,
                showInfo: true, // Hiển thị thông tin phân trang
                showNavigationButtons: true
            },
            scrolling: {
                mode: 'standard', // Thay 'virtual' bằng 'standard' để kiểm tra
                showScrollbar: 'always',
                useNative: false
            },
            filterRow: {
                visible: true,
                applyFilter: "auto"
            },
            selection: {
                mode: "single"
            },
            height: "500px",
            columns: [
                { dataField: "UserName", caption: "User", width: 120 },
                { dataField: "Date", caption: "Date", dataType: "date", format: "dd/MM/yyyy", width: 130 },
                { dataField: "Time", caption: "Time", width: 90 },
                { dataField: "Change", caption: "Action", width: 100 },
                { dataField: "NewValue", caption: "New Value", minWidth: 250 },
                { dataField: "OldValue", caption: "Old Value", minWidth: 200, visible: false },
                { dataField: "Description", caption: "Description", minWidth: 200 }
            ]



        });
    }
    function closeActivityLog() {

        $('#modalActivityLog').modal('hide');

    }
</script>
