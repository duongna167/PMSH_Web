@{
    //
}

<div class="text-center" style="font-size: 20px">Group Owner</div>
<div class="sticky-header bg-white p-2 shadow-sm z-3">

    <div class="mt-2">
        <button id="btnNew" class="mui-button mui-button-new"> New</button>
        <button id="btnUpdate" class="mui-button mui-button-edit"> Edit</button>
        <button id="btnDelete" class="mui-button mui-button-delete"> Delete</button>
    </div>

</div>

<div class="mui-card">
    <div id="gridContainerRateCode" class="mt-2 gridContainer"></div>
</div>

<!-- Modal Popup for New Item -->
<div class="modal fade" id="itemModal" tabindex="-1" aria-labelledby="itemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title fs-6" id="itemModalLabel">Group Owner</h5>
            </div>

            <div class="modal-footer justify-content-start">
                <button type="button" id="btnSaveItem" class="mui-button mui-button-save px-3">Save</button>
                <button type="button" data-bs-dismiss="modal" class="mui-button mui-button-close">Close</button>
            </div>

            <div class="modal-body py-1">
                <form id="formContainer">
                    <div class="container-fluid p-0">
                        <div class="row g-2 mb-2 align-items-end">
                            <div class="col-8">
                                <label for="code" class="form-label small fw-bold mb-1">Code</label>
                                <input type="text" id="code" name="code" class="form-control form-control-sm" />
                                <div class="invalid-feedback"></div>
                            </div>
                            <div class="col-4 pb-1">
                                <div class="form-check">
                                    <input type="checkbox" id="inactive" name="inactive" class="form-check-input" />
                                    <label for="inactive" class="form-check-label small text-danger">Inactive</label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-2">
                            <label for="name" class="form-label small fw-bold mb-1">Name</label>
                            <input type="text" id="name" name="name" class="form-control form-control-sm" />
                            <div class="invalid-feedback"></div>
                        </div>

                        <div class="mb-2">
                            <label for="description" class="form-label small fw-bold mb-1">Description</label>
                            <textarea id="description" name="description" class="form-control form-control-sm" rows="2" style="height:60px"></textarea>
                        </div>

                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <label for="contact" class="form-label small fw-bold mb-1">Contact</label>
                                <input type="text" id="contact" name="contact" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label for="telephone" class="form-label small fw-bold mb-1">Telephone</label>
                                <input type="text" id="telephone" name="telephone" class="form-control form-control-sm" />
                            </div>
                        </div>

                        <div class="mb-2">
                            <label for="address" class="form-label small fw-bold mb-1">Address</label>
                            <input type="text" id="address" name="address" class="form-control form-control-sm" />
                        </div>

                        <div class="mb-1">
                            <label for="email" class="form-label small fw-bold mb-1">Email</label>
                            <input type="email" id="email" name="email" class="form-control form-control-sm" />
                        </div>

                        <input type="hidden" id="id" name="id" value="0" />
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>
<div id="loadingSpinnerRateCode" style="display: none; text-align: center; padding: 20px;">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
</div>

<script>
    var selectedRowData = null;

    $(document).ready(function () {
        reloadGrid();

        $("#formContainer").on("input change", "input, select, textarea", function () {
            if ($(this).hasClass("is-invalid")) {
                $(this).removeClass("is-invalid");
                $(this).next(".invalid-feedback").text("");
            }
        });
        $('#itemModal').on('hidden.bs.modal', function () {
             applyValidationErrors([], "#formContainer");
        });
    });

    function loadGrid(data) {
        const dataSource = data || [];
        $("#gridContainerRateCode").dxDataGrid({
            dataSource: dataSource,
            height: 550,
            width: "100%",
            columnAutoWidth: true,
            allowColumnResizing: true,
            selection: { mode: "single" },
            hoverStateEnabled: true,
            columns: [
                { dataField: "id", caption: "ID", visible: false },
                { dataField: "groupOwnerCode", caption: "Group Owner Code", width: "12%" },
                { dataField: "groupOwnerName", caption: "Group Owner Name", width: "7%" },
                { dataField: "description", caption: "Description", width: "12%" },
                { dataField: "contact", caption: "Contact", width: "10%" },
                { dataField: "address", caption: "Address", width: "15%" },
                { dataField: "email", caption: "Email", width: "12%" },
                { dataField: "telephone", caption: "Telephone", width: "8%" },

                { dataField: "createdBy", caption: "Create By", width: "5%" },
                { dataField: "createdDate", caption: "Create Date", dataType: "date", format: "dd/MM/yyyy", width: "7%" },
                { dataField: "updatedBy", caption: "Update By", width: "5%" },
                { dataField: "updatedDate", caption: "Update Date", dataType: "date", format: "dd/MM/yyyy", width: "7%" }
            ],
            scrolling: { mode: "standard", showScrollbar: "always" },
            filterRow: { visible: true, applyFilter: "auto" },
            paging: { pageSize: 20 },
            pager: { showPageSizeSelector: true, visible:true, allowedPageSizes: [20, 50, 'all'], showInfo: true,showNavigationButtons: true },
            onSelectionChanged: function (e) {
                selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
            }
        });
    }

    function reloadGrid() {
        $("#loadingSpinnerRateCode").show();

        $.ajax({
            url: "/Administration/GetGroupOwner",
            type: 'GET',
            cache: false,
            success: function(data){
                loadGrid(data);
                $("#loadingSpinnerRateCode").hide();
            },
            error: function(xhr, status, error){
                alert("Unable to load data");
                $("#loadingSpinnerRateCode").hide();
            }
        });
    }

    $("#btnNew").click(function (){
        $("#formContainer")[0].reset();
        $("#id").val("0");
        $("#itemModalLabel").text("Add Group Owner");
        $("#itemModal").modal("show");
    });

    function editForm(data){
        $("#id").val(data.id);
        $("#code").val(data.groupOwnerCode);
        $("#name").val(data.groupOwnerName);
        $("#description").val(data.description);
        $("#inactive").prop("checked", data.inactive);
        $("#contact").val(data.contact);
        $("#address").val(data.address);
        $("#email").val(data.email);
        $("#telephone").val(data.telephone);

        $("#itemModalLabel").text("Update Group Owner");
        $("#itemModal").modal("show");
    }

    $("#btnUpdate").click(function (){
        if (!selectedRowData){
            showToast("Warning","Please select a row first",true);
            return;
        }

        editForm(selectedRowData);
    });

    $("#btnSaveItem").click(function (){
        const id = parseInt($("#id").val()) || 0;
        const loginName = (localStorage.getItem("Loginname") || "")
                .trim().replace(/^"(.*)"$/,'$1');
        const loginUser = parseInt(localStorage.getItem("userID")) || 0;
        const model = {
              ID: id,
              GroupOwnerCode: $("#code").val(),
              GroupOwnerName: $("#name").val(),
              Description: $("#description").val(),
              Inactive: $("#inactive").prop("checked"),
              Contact: $("#contact").val(),
              Address: $("#address").val(),
              Email: $("#email").val(),
              Telephone: $("#telephone").val(),
              CreatedBy: loginName,
              UpdatedBy: loginName
        };

        $.ajax({
            url: "/Administration/GroupOwnerSave",
            type: "POST",
            contentType: "application/json",
            cache: false,
            data: JSON.stringify(model),
            traditional: true,
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (res) {
                if (res.success) {
                    showToast("Success", res.message, true);
                    $("#itemModal").modal("hide");
                    reloadGrid();
                } else {
                    if (res.errors && res.errors.length > 0) {
                        applyValidationErrors(res.errors, "#formContainer");
                        let generalError = res.errors.find(x => x.field === "general");
                        let toastMessage = generalError ? generalError.message : "Please check input fields.";

                        showToast("Warning", toastMessage, false);
                    } else {
                        showToast("Error", res.message || "Save failed", false);
                    }
                }
            },
            error: function (xhr) {
                showToast("Error", "Request error!", false);
                $("#itemModal").modal("hide");
            }

        });
    });
</script>
