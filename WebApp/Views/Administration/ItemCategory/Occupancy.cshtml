<div class="modal fade" id="occP_mainModal" tabindex="-1" aria-labelledby="occP_mainModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="occP_mainModalLabel">Occupancy Config</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <button id="occP_btnNew" type="button" class="mui-button mui-button-new">New</button>
                    <button id="occP_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                    <button id="occP_btnDelete" type="button" class="mui-button mui-button-delete">Delete</button>
                    <button type="button" data-bs-dismiss="modal" class="mui-button mui-button-close">Close</button>
                </div>

                <div class="mui-card mt-1">
                    <div id="occP_gridContainer" class="gridContainer"></div>
                </div>

                <div id="occP_loadingSpinner" 
                    style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                    z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                    height: 100%;display: flex;align-items: center;justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="occP_itemModal" tabindex="-1" aria-labelledby="occP_itemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="occP_itemModalLabel">Add Occupancy</h5>
            </div>

            <div class="search-filter">
                <button type="button" id="occP_btnSave" class="mui-button mui-button-save">Save</button>
                <button type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
            </div>

            <div class="modal-body">
                <form id="occP_form">
                    <div class="row g-2 mt-1 mb-2">
                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label for="occP_typeText" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Type
                                </label>
                                <div class="col-md-8">
                                    <input id="occP_typeText"
                                            name="occP_typeText"
                                            type="text"
                                            class="form-control form-control-sm bg-light"
                                            value="Hotel"
                                            disabled>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label for="occP_occupancylevel" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Occ. Level
                                </label>
                                <div class="col-md-8">
                                    <input id="occP_occupancylevel"
                                            name="occP_occupancylevel"
                                            type="number"
                                            step="any"
                                            class="form-control form-control-sm" placeholder="0.00" min="0">
                                    <div class="invalid-feedback" id="occP_occupancylevelError"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label for="occP_title" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Title
                                </label>
                                <div class="col-md-8">
                                    <input id="occP_title"
                                            name="occP_title"
                                            type="text"
                                            class="form-control form-control-sm">
                                    <div class="invalid-feedback" id="occP_titleError"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label for="occP_colorValue" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Color
                                </label>
                                <div class="col-md-8">
                                    <div class="input-group input-group-sm">
                                        <input id="occP_colorValue"
                                                name="occP_colorValue"
                                                type="text"
                                                class="form-control"
                                                readonly>
                                        <input id="occP_colorPicker"
                                                name="occP_colorPicker"
                                                type="color"
                                                class="form-control flex-grow-0"
                                                style="width:42px;">
                                        <button id="occP_btnClearColor"
                                                type="button"
                                                class="btn btn-outline-secondary">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                    <div class="invalid-feedback d-block" id="occP_colorError"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2 align-items-center">
                                <label for="occP_email" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Notification Email
                                </label>
                                <div class="col-md-8">
                                    <input id="occP_email"
                                            name="occP_email"
                                            type="email"
                                            class="form-control form-control-sm">
                                    <div class="invalid-feedback" id="occP_emailError"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="occP_description" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Description
                                </label>
                                <div class="col-md-8">
                                    <textarea id="occP_description"
                                                name="occP_description"
                                                class="form-control form-control-sm"
                                                rows="5" style="height: 100px;"></textarea>
                                    <div class="invalid-feedback" id="occP_descriptionError"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="occP_id" name="occP_id" value="0" />
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    var occP_Module = (function () {
        let selectedRowData = null;

        const selectors = {
            mainModal: "#occP_mainModal",
            itemModal: "#occP_itemModal",
            form: "#occP_form",
            grid: "#occP_gridContainer",
            loading: "#occP_loadingSpinner",

            btnNew: "#occP_btnNew",
            btnEdit: "#occP_btnEdit",
            btnDelete: "#occP_btnDelete",
            btnSave: "#occP_btnSave",
            btnClearColor: "#occP_btnClearColor",

            itemModalLabel: "#occP_itemModalLabel",

            id: "#occP_id",
            occupancylevel: "#occP_occupancylevel",
            title: "#occP_title",
            email: "#occP_email",
            description: "#occP_description",
            colorValue: "#occP_colorValue",
            colorPicker: "#occP_colorPicker"
        };

        function init() {
            bindEvents();
            loadGrid();
        }

        function bindEvents() {
            $(selectors.btnNew).off("click").on("click", openAddModal);
            $(selectors.btnEdit).off("click").on("click", openEditModal);
            $(selectors.btnDelete).off("click").on("click", deleteRecord);
            $(selectors.btnSave).off("click").on("click", saveRecord);
            $(selectors.btnClearColor).off("click").on("click", clearColor);

            $(selectors.colorPicker).off("input").on("input", function () {
                $(selectors.colorValue).val(hexToArgbInt($(this).val()));
            });

            $(selectors.form).off("input change", "input, select, textarea").on("input change", "input, select, textarea", function () {
                clearFieldError(this);
            });

            $(selectors.itemModal).off("hidden.bs.modal").on("hidden.bs.modal", function () {
                resetForm();
                applyValidationErrors([], selectors.form);
            });
        }

        function loadGrid() {
            $(selectors.loading).show();

            $.ajax({
                url: "/Administration/GetOccupancy",
                type: "GET",
                success: function (data) {
                    renderGrid(data || []);
                    $(selectors.loading).hide();
                },
                error: function () {
                    $(selectors.loading).hide();
                    showToast("Error", "Unable to load data.", false);
                }
            });
        }

        function renderGrid(data) {
            $(selectors.grid).dxDataGrid({
                dataSource: data,
                keyExpr: "id",
                width: "100%",
                columnAutoWidth: false,
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                hoverStateEnabled: true,
                filterRow: { visible: true, applyFilter: "auto" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: { mode: "standard", showScrollbar: "always" },
                columns: [
                    {
                        caption: "STT",
                        width: 50,
                        alignment: "center",
                        cellTemplate: function (container, options) {
                            const grid = options.component;
                            const pageIndex = grid.pageIndex();
                            const pageSize = grid.pageSize();
                            const stt = pageIndex * pageSize + options.rowIndex + 1;
                            container.text(stt);
                        }
                    },
                    { dataField: "id", caption: "ID", visible: false },
                    { dataField: "type", caption: "Type", width: 100 },
                    { dataField: "occupancylevel", caption: "Occ. Level", width: 100 },
                    { dataField: "title", caption: "Title", width: 200 },
                    { dataField: "email", caption: "Email", width: 200 },
                    { dataField: "description", caption: "Description", minWidth: 200, cssClass: "col-description" },
                    { dataField: "color", caption: "Color", visible: false },
                    { dataField: "createBy", caption: "Create By", width: 80 },
                    { dataField: "createDate", caption: "Cre.Date", dataType: "date", format: "dd/MM/yyyy", width: 80 },
                    { dataField: "updateBy", caption: "Update By", width: 80 },
                    { dataField: "updateDate", caption: "Upd.Date", dataType: "date", format: "dd/MM/yyyy", width: 80 }
                ],
                onRowPrepared: function (e) {
                    if (e.rowType === "data" && e.data.color) {
                        const colorHex = argbIntToHex(e.data.color);
                        e.rowElement.css("background-color", colorHex);
                        e.rowElement.css("color", getContrastColor(colorHex));
                    }
                },
                onSelectionChanged: function (e) {
                    selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
                }
            });
        }

        function openAddModal() {
            resetForm();
            $(selectors.id).val("0");
            $(selectors.itemModalLabel).text("Add Occupancy");
            $(selectors.itemModal).modal("show");
        }

        function openEditModal() {
            if (!selectedRowData) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }

            resetForm();
            fillForm(selectedRowData);
            $(selectors.itemModalLabel).text("Edit Occupancy Config");
            $(selectors.itemModal).modal("show");
        }

        function fillForm(data) {
            $(selectors.id).val(data.id || 0);
            $(selectors.occupancylevel).val(data.occupancylevel ?? "");
            $(selectors.title).val(data.title ?? "");
            $(selectors.email).val(data.email ?? "");
            $(selectors.description).val(data.description ?? "");

            if (data.color) {
                const hex = argbIntToHex(data.color);
                $(selectors.colorPicker).val(hex);
                $(selectors.colorValue).val(data.color);
            } else {
                $(selectors.colorPicker).val("#ffffff");
                $(selectors.colorValue).val("");
            }
        }

        function saveRecord() {
            const loginName = (localStorage.getItem("Loginname") || "").trim().replace(/^"(.*)"$/, "$1");

            const model = {
                id: parseInt($(selectors.id).val()) || 0,
                type: 0,
                occupancylevel: parseFloat($(selectors.occupancylevel).val()) || 0,
                title: $(selectors.title).val().trim(),
                email: $(selectors.email).val().trim(),
                description: $(selectors.description).val().trim(),
                color: $(selectors.colorValue).val(),
                createBy: loginName,
                updateBy: loginName
            };

            $.ajax({
                url: "/Administration/OccupancySave",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(model),
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val()
                },
                success: function (res) {
                    if (res.success) {
                        showToast("Success", res.message, true);
                        $(selectors.itemModal).modal("hide");
                        loadGrid();
                        return;
                    }

                    if (res.errors && res.errors.length > 0) {
                        applyValidationErrors(res.errors, selectors.form);

                        const generalError = res.errors.find(x => x.field === "general");
                        showToast("Warning", generalError ? generalError.message : "Please check input fields.", false);
                        return;
                    }

                    showToast("Error", res.message || "Save failed.", false);
                },
                error: function (xhr) {
                    const errorMessage = xhr?.responseJSON?.message || xhr?.statusText || "Save failed.";
                    showToast("Error", errorMessage, false);
                }
            });
        }

        function deleteRecord() {
            if (!selectedRowData || !selectedRowData.id) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }

            if (!confirm("Are you sure you want to delete this record?")) {
                return;
            }

            $.ajax({
                url: "/Administration/OccupancyDelete/" + selectedRowData.id,
                type: "POST",
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val()
                },
                success: function (result) {
                    if (result.success) {
                        selectedRowData = null;
                        loadGrid();
                        showToast("Success", "Delete successfully!", true);
                    } else {
                        showToast("Error", result.message || "Delete failed!", false);
                    }
                },
                error: function () {
                    showToast("Error", "Delete failed!", false);
                }
            });
        }

        function resetForm() {
            $(selectors.form)[0].reset();
            $(selectors.id).val("0");
            $(selectors.colorPicker).val("#ffffff");
            $(selectors.colorValue).val("");
            applyValidationErrors([], selectors.form);
        }

        function clearColor() {
            $(selectors.colorPicker).val("#ffffff");
            $(selectors.colorValue).val("");
        }

        function clearFieldError(element) {
            const $element = $(element);
            if ($element.hasClass("is-invalid")) {
                $element.removeClass("is-invalid");
            }

            const $feedback = $element.siblings(".invalid-feedback");
            if ($feedback.length) {
                $feedback.text("");
            }
        }

        function hexToArgbInt(hex) {
            hex = (hex || "").replace("#", "");
            if (hex.length !== 6) return "";

            const r = parseInt(hex.substring(0, 2), 16);
            const g = parseInt(hex.substring(2, 4), 16);
            const b = parseInt(hex.substring(4, 6), 16);
            const a = 255;

            return (a << 24) | (r << 16) | (g << 8) | b;
        }

        function argbIntToHex(argb) {
            const unsigned = argb >>> 0;
            const r = (unsigned >> 16) & 0xFF;
            const g = (unsigned >> 8) & 0xFF;
            const b = unsigned & 0xFF;

            return "#" +
                r.toString(16).padStart(2, "0") +
                g.toString(16).padStart(2, "0") +
                b.toString(16).padStart(2, "0");
        }

        function getContrastColor(hexColor) {
            const r = parseInt(hexColor.substring(1, 3), 16);
            const g = parseInt(hexColor.substring(3, 5), 16);
            const b = parseInt(hexColor.substring(5, 7), 16);
            const yiq = ((r * 299) + (g * 587) + (b * 114)) / 1000;

            return yiq >= 128 ? "black" : "white";
        }

        function open(){
            init();

            const modalEl = document.querySelector(selectors.mainModal);
            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

            $(modalEl).one("shown.bs.modal", function () {
                loadGrid();
            });

            modal.show();

        }

        return {
            open:open,
            init: init,
            loadGrid: loadGrid,
            openAddModal: openAddModal,
            openEditModal: openEditModal
        };
    })();
        // Global entry
    window.openModalOccupancyConfig = function () {
        occP_Module.open();
    };

</script>