            return false;
        }
        var rt = ($("#txtRoomType").val() || "").toString().trim();
        if (!rt || rt === "0") {
            showToast('Error', 'Room Type cannot be blank', false);
            return false;
        }
        var marketId = ($("#txtMarketID").val() || "").toString().trim();
        if (!marketId || marketId === "0") {
            showToast('Error', 'Market cannot be blank', false);
            return false;
        }
        var nat = ($("#txtNationality").val() || "").toString().trim();
        if (!nat || nat === "0") {
            showToast('Error', 'Nationality cannot be blank', false);
            return false;
        }
        var resTypeText = ($('#txtResType').find('option:selected').text() || "").trim();
        if (!resTypeText) {
            showToast('Error', 'Reservation Type cannot be blank', false);
            return false;
        }
