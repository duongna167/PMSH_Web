<div class="modal fade" id="modalSplitTransaction" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-sm">

            <!-- HEADER -->
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-semibold">Split Transaction</h5>
            </div>

            <!-- BODY -->
            <div class="modal-body">

                <!-- ACTION -->
                <div class="d-flex gap-2 py-2">
                    <button class="mui-button mui-button-search" id="btnSplitTransaction">
                        Split
                    </button>
                    <button class="mui-button mui-button-clear" onclick="closeModalSplitTransaction();">
                        Close
                    </button>
                </div>

                <!-- INFO CARD -->
                <div class="p-3 border rounded bg-light mb-3">

                    <div class="row mb-2">
                        <label class="col-4 text-muted">Transaction Info</label>
                        <div class="col-8 fw-semibold text-dark" id="transactionInfoSplit"></div>
                    </div>

                    <div class="row">
                        <label class="col-4 text-muted">Amount</label>
                        <div class="col-8 fw-semibold text-dark" id="amountTtoalSplit"></div>
                    </div>

                </div>

                <!-- TYPE -->
                <div class="mb-3">
                    <label class="form-label text-muted">Split Type</label>

                    <div class="d-flex gap-4 mt-1">
                        <div class="form-check">
                            
                            <label class="form-check-label"><input class="me-1" type="radio" name="typeDiscountSplit"
                                                                       value="0" checked>Amount</label>
                            </div>

                            <div class="form-check">
                                <label class="form-check-label"><input class="me-1" type="radio" name="typeDiscountSplit"
                                                                           value="1">Percentage</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-2">
                            <label class="form-label text-muted mb-0" style="min-width: 80px;">
                                Value
                            </label>
                            <input id="valueSplitTransaction" class="form-control text-end" placeholder="Enter value" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>

    /* =========================
     * OPEN MODAL
     * ========================= */
    function openModalSplitTransaction() {

        // reset radio
        $('input[name="typeDiscountSplit"][value="0"]').prop('checked', true);

        var grid = $("#gridContainerBilling").dxDataGrid("instance");
        var selectedRows = grid.getSelectedRowsData();

        if (!selectedRows || selectedRows.length === 0) return;

        const amount = parseFloat(selectedRows[0].amount) || 0;

        // hiển thị amount (format chuẩn)
        $("#amountTtoalSplit").text(formatNumberWithComma(amount));

        // set value input
        $("#valueSplitTransaction").val(formatNumberWithComma(amount));

        folioDetailID = selectedRows[0].id;

        $("#transactionInfoSplit").text(
            selectedRows[0].code + ' - ' + selectedRows[0].description
        );

        $('#modalSplitTransaction').modal('show');
    }

    function closeModalSplitTransaction() {
        $('#modalSplitTransaction').modal('hide');
    }

    $(document).on('click', '#btnSplitTransaction', function () {
        SplitTransaction();
    });

    /* =========================
     * INPUT FORMAT REALTIME
     * ========================= */
    $('#valueSplitTransaction').on('input', function () {
        formatCurrencyLive(this);

        const selectedType = $('input[name="typeDiscountSplit"]:checked').val();
        const value = $(this).val();
        const numValue = parseNumberWithComma(value);
        const amountTotal = parseNumberWithComma($('#amountTtoalSplit').text());

        if (selectedType == 1) { // %
            if (numValue > 100) {
                $(this).val('100');
            } else if (numValue < 0) {
                $(this).val('0');
            }
        } else { // Amount
            if (numValue > amountTotal) {
                $(this).val(formatNumberWithComma(amountTotal));
            } else if (numValue < 0) {
                $(this).val('0');
            }
        }
    });

    /* =========================
     * CHANGE TYPE
     * ========================= */
    $('input[name="typeDiscountSplit"]').on('change', function () {

        const selectedValue = $(this).val();
        const amountTotal = parseNumberWithComma($('#amountTtoalSplit').text());

        if (selectedValue == 1) {
            $('#valueSplitTransaction').val('');
        } else {
            $('#valueSplitTransaction').val(formatNumberWithComma(amountTotal));
        }

        // đổi đơn vị hiển thị nếu có
        if ($("#unitSplit").length) {
            $('#unitSplit').text(selectedValue == 1 ? '%' : 'VND');
        }
    });

    /* =========================
     * MAIN ACTION
     * ========================= */
    var isSplitting = false;
    function finishSplitRequest() {
        isSplitting = false;
        $('#btnSplitTransaction').prop('disabled', false);
    }

    function SplitTransaction() {
        if (isSplitting) return;
        isSplitting = true;

        const $btn = $('#btnSplitTransaction');
        $btn.prop('disabled', true);
        const selectedValue = $('input[name="typeDiscountSplit"]:checked').val();
        const inputVal = $('#valueSplitTransaction').val();

        const amountTotal = parseNumberWithComma($('#amountTtoalSplit').text());
        const inputNumber = parseNumberWithComma(inputVal);

        if (!inputVal || inputNumber <= 0) {
            finishSplitRequest();
            showToast('Warning', 'Please enter a value greater than zero', false);
            return;
        }

        let discountAmount = 0;
        let discountPercent = 0;

        if (selectedValue == 0) { // Amount
            discountAmount = inputNumber;

            if (discountAmount >= amountTotal) {
                finishSplitRequest();
                showToast('Error', 'Split amount must be less than transaction amount', false);
                return;
            }
        } else { // %
            discountPercent = inputNumber;

            if (discountPercent > 100 || discountPercent <= 0) {
                finishSplitRequest();
                showToast('Error', 'Percentage must be between 1 and 100', false);
                return;
            }
        }

        const userName = JSON.parse(localStorage.getItem("Loginname"));
        const userID = JSON.parse(localStorage.getItem("userID"));
        const shiftID = localStorage.getItem("shiftID");
        const shiftName = localStorage.getItem("shiftName");

        $.ajax({
            url: '/Billing/SplitTransaction',
            type: 'POST',
            contentType: 'application/json',
            dataType: 'json',
            data: JSON.stringify({
                FolioDetailID: parseInt(folioDetailID) || 0,
                DiscountAmount: parseFloat(discountAmount) || 0,
                DiscountPercent: parseFloat(discountPercent) || 0,
                Amount: parseFloat(amountTotal) || 0,
                UserName: userName || "",
                UserID: userID || "",
                ShiftID: parseInt(shiftID) || 0,
                ShiftName: shiftName || ""
            }),
            success: function (result) {
                if (result && result.code === 0) {
                    closeModalSplitTransaction();
                    clearSelectedRowsBilling();
                    if (typeof GetBalanceVND === 'function') {
                        GetBalanceVND(idReservation);
                    }
                    getFolioNo();
                    showToast('Success', result.msg, true);
                    return;
                }

                const errorMessage = result && result.msg ? result.msg : 'Split transaction failed';
                showToast('Error', errorMessage, false);
            },
            error: function (xhr) {
                if (xhr.status == 401) {
                    sessionTimeout();
                    return;
                }
                showToast('Error', 'System Error: Could not split transaction', false);
            },
            complete: function () {
                finishSplitRequest();
            }
        });
    }

    /* =========================
     * UTILS
     * ========================= */

    function formatNumberWithComma(num) {
        if (num === null || num === undefined || isNaN(num) || num === '') return '0,00';
        return parseFloat(num).toLocaleString('vi-VN', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });
    }
    
    function parseNumberWithComma(str) {
        if (!str) return 0;

        return Number(
            str
                .replace(/\s/g, '')
                .replace(/\./g, '')
                .replace(',', '.')
        ) || 0;
    }

    function formatCurrencyLive(input) {
        let selectionStart = input.selectionStart;
        let originalLength = input.value.length;

        let value = input.value;
        let isNegative = value.startsWith('-');

        let cleanValue = value.replace(/[^\d]/g, "");

        if (cleanValue === "") {
            input.value = isNegative ? "-" : "";
            return;
        }

        let formattedValue = new Intl.NumberFormat('vi-VN')
            .format(parseInt(cleanValue, 10));

        if (isNegative) formattedValue = "-" + formattedValue;

        if (input.value !== formattedValue) {
            input.value = formattedValue;

            let newLength = input.value.length;
            selectionStart = selectionStart + (newLength - originalLength);
            input.setSelectionRange(selectionStart, selectionStart);
        }
    }
</script>
