@* =========================
   PAK - Option A Refactor
   - All IDs + names prefixed with pak_
   - Main view is Bootstrap modal-xl
   - Module pattern (init/open/bindEvents/cleanup)
   - Preserve existing endpoints + business logic
   ========================= *@

<style>
    /* Keep minimal, avoid global overrides. Scope with pak_ where possible */
    .dx-tab {
        padding: 0px;
    }
    .dx-tab.dx-tab-selected, .dx-tab.dx-tab-selected .dx-icon {
        color: #009444;
    }
    
    .dx-tab.dx-tab-selected::before {
        background-color: #009444;
    }

    #pak_detailForm .ts-dropdown .ts-dropdown-content  {
    max-height: 100px !important;
    overflow-y: auto;
}

    /* Full-height detail grid inside 4:3 modal (same flex pattern as ItemCategory forms + modal-ratio .mui-card) */
    #pak_modalMain .pak_modalFill {
        flex: 1 1 auto;
        min-height: 0;
        display: flex;
        flex-direction: column;
    }
    #pak_modalMain .pak_tabForm[data-tab="0"] {
        flex: 0 1 auto;
    }
    #pak_modalMain .pak_tabForm[data-tab="1"] {
        flex: 1 1 auto;
        min-height: 0;
    }
    #pak_modalMain #pak_packageDetailForm .pak_detailSplit {
        flex: 1 1 auto;
        min-height: 0;
    }
    #pak_modalMain #pak_packageDetailGridHost {
        flex: 1 1 auto;
        min-height: 0;
        display: flex;
        flex-direction: column;
    }
    #pak_modalMain #pak_packageDetailGridHost .gridContainer {
        flex: 1 1 auto;
        min-height: 0;
        margin: 0;
    }

</style>

<!-- MAIN MODAL (XL) -->
<div class="modal fade" id="pak_modalMain" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Package</h5>
            </div>

            <div class="modal-body position-relative d-flex flex-column">

                <!-- ACTION BAR -->
                <div class="search-filter flex-shrink-0">
                    <button id="pak_btnSearch" type="button" class="mui-button mui-button-search">Search</button>
                    <button id="pak_btnNew" type="button" class="mui-button mui-button-new">New</button>
                    <button id="pak_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>

                    <button id="pak_btnSaveHeader" type="button" class="mui-button mui-button-export">Save</button>
                    <button id="pak_btnDeleteHeader" type="button" class="mui-button button-report-delete">Delete</button>

                    <button id="pak_btnRefreshDetail" type="button" class="mui-button mui-button-clear">Refresh</button>
                    <button id="pak_btnSaveDetail" type="button" class="mui-button mui-button-new">Save</button>
                    <button id="pak_btnDeleteDetail" type="button" class="mui-button button-report-delete">Delete</button>

                    <button id="pak_btnClose" type="button" class="mui-button mui-button-new ms-auto">Close</button>
                </div>

                <div class="pak_modalFill">
                <!-- TABS (DevExtreme) -->
                <div class="bg-white border-bottom mt-1 flex-shrink-0">
                    <div class="pak_tabsHost" id="pak_tabs"></div>
                </div>

                <!-- TAB 0: PACKAGE HEADER -->
                <div class="pak_tabForm pak_visible" data-tab="0" id="pak_packageForm">
                    <div class="pak_tabsContainer border p-3 mt-3 mx-auto">

                        <form id="pak_headerForm" novalidate>
                            <input type="hidden" id="pak_ID" name="pak_ID" />

                            <div class="row g-2">
                                <div class="col-12 col-md-6">
                                    <div class="row g-1 align-items-center">
                                        <label for="pak_txtCode" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                            Code
                                        </label>
                                        <div class="col-md-8">
                                            <input type="text" id="pak_txtCode" name="code" class="form-control" />
                                            <div class="invalid-feedback"></div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12 col-md-6">
                                    <div class="row g-1 align-items-center">
                                        <label for="pak_forecastGroup" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                            Forecast Group
                                        </label>
                                        <div class="col-md-8">
                                            <select class="tomselect-custom" name="forecastGroupID" id="pak_forecastGroup">
                                                <option value=""></option>
                                                @foreach (dynamic u in ViewBag.PackageForecastGroup)
                                                {
                                                    <option value="@u.ID">@u.Code / @u.Name</option>
                                                }
                                            </select>
                                            <div class="invalid-feedback"></div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12 col-md-6">
                                    <div class="row g-1 align-items-center">
                                        <label for="pak_type" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                            Type
                                        </label>
                                        <div class="col-md-8">
                                            <select id="pak_type" name="pak_type" class="tomselect-custom">
                                                <option value="0">Element</option>
                                                <option value="1">-- Calculation Rule --</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12 col-md-6">
                                    <div class="row g-1 align-items-center">
                                        <label  class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                            Transaction Code
                                        </label>
                                        <div class="col-md-8">
                                            <select class="tomselect-custom" name="transCode" id="pak_transactionCode">
                                                <option value=""></option>
                                                @foreach (dynamic u in ViewBag.TransactionList)
                                                {
                                                    <option value="@u.Code">@u.Code / @u.Description</option>
                                                }
                                            </select>
                                            <div class="invalid-feedback"></div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="row g-1 align-items-center">
                                        <label for="pak_txtDescription" class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                            Description
                                        </label>
                                        <div class="col-md-10">
                                            <input id="pak_txtDescription" name="description" type="text" class="form-control" />
                                            <div class="invalid-feedback"></div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="row g-1 align-items-center">
                                        <label for="pak_textInNightAudit" class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                            Display in Folio
                                        </label>
                                        <div class="col-md-10">
                                            <input id="pak_textInNightAudit" name="pak_textInNightAudit" type="text" class="form-control" />
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="row g-1 align-items-center">
                                        <label class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                            Active
                                        </label>
                                        <div class="col-md-10">
                                            <div class="form-check form-check-inline">
                                                <input type="checkbox" id="pak_chkActive" name="pak_chkActive" checked>
                                                <label class="form-check-label" for="pak_chkActive">Active</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Attributes + Meal Info -->
                                <div class="col-12">
                                    <div class="row g-2">
                                        <div class="col-12 col-md-6 border p-2 rounded">
                                            <div class="small fw-bold mb-1">Default Display</div>
                                            <div class="form-check">
                                                <input type="radio" name="pak_attr" value="1" id="pak_chkIncludedInRate" checked>
                                                <label class="form-check-label" for="pak_chkIncludedInRate">Included In Rate</label>
                                            </div>
                                            <div class="form-check">
                                                <input type="radio" name="pak_attr" value="0" id="pak_chkRateSeparateLine">
                                                <label class="form-check-label" for="pak_chkRateSeparateLine">Add Rate Separate Line</label>
                                            </div>
                                            <div class="invalid-feedback"></div>
                                        </div>

                                        <div class="col-12 col-md-6 border p-2 rounded">
                                            <div class="small fw-bold mb-1">Meal Info</div>
                                            <div class="form-check">
                                                <input type="checkbox" id="pak_breakfast" name="pak_breakfast" checked>
                                                <label class="form-check-label" for="pak_breakfast">Breakfast</label>
                                            </div>
                                            <div class="form-check">
                                                <input type="checkbox" id="pak_lunch" name="pak_lunch" checked>
                                                <label class="form-check-label" for="pak_lunch">Lunch</label>
                                            </div>
                                            <div class="form-check">
                                                <input type="checkbox" id="pak_dinner" name="pak_dinner" checked>
                                                <label class="form-check-label" for="pak_dinner">Dinner</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </form>

                    </div>
                </div>

                <!-- TAB 1: PACKAGE DETAIL -->
                <div class="pak_tabForm d-none" data-tab="1" id="pak_packageDetailForm">
                    <div class="row g-2 mt-2 align-items-stretch pak_detailSplit">

                        <!-- LEFT FORM -->
                        <div class="col-12 col-lg-4 d-flex flex-column">
                            <div class="border p-2 flex-grow-1">
                                <form id="pak_detailForm" novalidate>
                                    <input type="hidden" id="pak_packageID" name="pak_packageID" />
                                    <input type="hidden" id="pak_packageDetailID" name="pak_packageDetailID" />

                                    <div class="row g-2">

                                        <div class="col-12">
                                            <div class="row g-1 align-items-center">
                                                <label for="pak_targetCode" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                                    Header
                                                </label>
                                                <div class="col-md-8">
                                                    <input id="pak_targetCode" name="packageID" class="form-control form-control-sm pak_noReadOnly" disabled value="No target Package" />
                                                    <div class="invalid-feedback"></div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-12">
                                            <div class="row g-1 align-items-center">
                                                <label for="pak_seasonCode" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                                    Season
                                                </label>
                                                <div class="col-md-8">
                                                    <select class="tomselect-custom" name="pak_seasonCode" id="pak_seasonCode">
                                                        <option value=""></option>
                                                        @foreach (dynamic u in ViewBag.SeasonList)
                                                        {
                                                            <option value="@u.ID">@u.Code / @u.Name</option>
                                                        }
                                                    </select>
                                                    <div class="invalid-feedback"></div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-12">
                                            <div class="row g-1">
                                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                                    Start Date
                                                </label>
                                                <div class="col-md-8">
                                                    <div data-date-input data-format="DD/MM/YYYY" business-date data-name="pak_startDate">
                                                        <input type="text" class="date-ui form-control form-control-sm" placeholder="dd/mm/yyyy" autocomplete="off" id="pak_startDateUi" disabled />
                                                    </div>
                                                    <div class="invalid-feedback"></div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-12">
                                            <div class="row g-1">
                                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                                    End Date
                                                </label>
                                                <div class="col-md-8">
                                                    <div data-date-input data-format="DD/MM/YYYY" business-date data-name="pak_endDate">
                                                        <input type="text" class="date-ui form-control form-control-sm" placeholder="dd/mm/yyyy" autocomplete="off" id="pak_endDateUi" disabled />
                                                    </div>
                                                    <div class="invalid-feedback"></div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-12">
                                            <div class="row g-1 align-items-center">
                                                <label for="pak_transactionCodeDT" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                                    Trans. Code
                                                </label>
                                                <div class="col-md-8">
                                                    <select class="tomselect-custom" name="transCode" id="pak_transactionCodeDT">
                                                        <option value=""></option>
                                                        @foreach (dynamic u in ViewBag.TransactionList)
                                                        {
                                                            <option value="@u.Code">@u.Code / @u.Description</option>
                                                        }
                                                    </select>
                                                    <div class="invalid-feedback"></div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-12">
                                            <div class="row g-1 align-items-center">
                                                <label for="pak_currencyID" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                                    Currency
                                                </label>
                                                <div class="col-md-8">
                                                    <select class="tomselect-custom pak_noReadOnly" name="currencyID" id="pak_currencyID">
                                                        @foreach (dynamic u in ViewBag.CurrencyList)
                                                        {
                                                            <option value="@u.ID">@u.ID / @u.Description</option>
                                                        }
                                                    </select>
                                                    <div class="invalid-feedback"></div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-12">
                                            <div class="row g-1 align-items-center">
                                                <label for="pak_price" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                                    Price ++
                                                </label>
                                                <div class="col-md-8">
                                                    <input type="number" class="form-control" name="pak_price" id="pak_price" />
                                                    <div class="invalid-feedback"></div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-12">
                                            <div class="row g-1 align-items-center">
                                                <label for="pak_priceAfterTax" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                                    Price Net
                                                </label>
                                                <div class="col-md-8">
                                                    <input type="number" class="form-control" name="pak_priceAfterTax" id="pak_priceAfterTax" />
                                                    <div class="invalid-feedback"></div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-12">
                                            <div class="row g-1 align-items-center">
                                                <label for="pak_allowanceAmount" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                                    Allowance
                                                </label>
                                                <div class="col-md-8">
                                                    <input type="number" class="form-control" id="pak_allowanceAmount" name="pak_allowanceAmount" />
                                                    <div class="invalid-feedback"></div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-12">
                                            <div class="row g-1 align-items-center">
                                                <label for="pak_rhythmPostingID" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                                    Post. Rhythm
                                                </label>
                                                <div class="col-md-8">
                                                    <select class="tomselect-custom" name="rhythmPostingID" id="pak_rhythmPostingID">
                                                        @foreach (dynamic u in ViewBag.RhythmPostingList)
                                                        {
                                                            <option value="@u.ID">@u.Name</option>
                                                        }
                                                    </select>
                                                    <div class="invalid-feedback"></div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-12">
                                            <div class="row g-1 align-items-center">
                                                <label for="pak_calculationRuleID" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                                    Calc. Rule
                                                </label>
                                                <div class="col-md-8">
                                                    <select class="tomselect-custom" name="calculationRuleID" id="pak_calculationRuleID">
                                                        <option value="0">-- Calculation Rule --</option>
                                                        <option value="1">Per Person</option>
                                                        <option value="2">Per Adult</option>
                                                        <option value="3">Per Child</option>
                                                        <option value="4">Per Room</option>
                                                        <option value="5">Per Child1</option>
                                                        <option value="6">Per Child2</option>
                                                        <option value="7">Per Child3</option>
                                                        <option value="8">Per Adutl + C</option>
                                                        <option value="9">Per Adutl + C + C1</option>
                                                        <option value="10">Per Adutl + C1</option>
                                                        <option value="11">Per C + C1</option>
                                                    </select>
                                                    <div class="invalid-feedback"></div>
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </form>
                            </div>
                        </div>

                        <!-- RIGHT GRID -->
                        <div class="col-12 col-lg-8 d-flex flex-column" style="min-height:0">
                            <div class="mui-card flex-grow-1 d-flex flex-column" id="pak_packageDetailGridHost" style="min-height:0">
                                <div id="pak_packageDetailGrid" class="gridContainer flex-grow-1" style="min-height:0"></div>
                            </div>
                        </div>

                    </div>
                </div>

                </div>

                <!-- LOADING -->
                <div id="pak_loadingSpinner"
                    style="display:none;position:absolute;inset:0;z-index:999;background:rgba(255,255,255,0.55);
                    align-items:center;justify-content:center;">
                    <div class="spinner-border text-primary"></div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- SEARCH MODAL -->
<div class="modal fade" id="pak_modalSearch" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h6 class="modal-title">Search Package</h6>
            </div>

            <div class="modal-body d-flex flex-column">
                <div class="search-filter flex-shrink-0">
                    <div>
                        <button class="mui-button mui-button-new" data-bs-dismiss="modal" aria-label="Close">Close</button>
                    </div>
                    <div class="row mt-1 mb-2">
                        <div class="col-12 col-md-10">
                            <div class="row g-1 align-items-center">
                                <label for="pak_packageSearch" class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Search
                                </label>
                                <div class="col-md-8">
                                    <input type="text" id="pak_packageSearch" name="pak_packageSearch" class="form-control"
                                        placeholder="Enter code/description" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mui-card mt-1 flex-grow-1 d-flex flex-column" style="min-height:0">
                <div class="table-responsive gridContainer flex-grow-1" style="min-height:0">
                    <table class="table table-bordered table-hover table-sm mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th style="width:160px">Code</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody id="pak_packageTableBody">
                            @foreach (var u in ViewBag.PackageList)
                            {
                                <tr data-id="@u.ID" style="cursor:pointer">
                                    <td>@u.Code</td>
                                    <td>@u.Description</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                </div>

            </div>

        </div>
    </div>
</div>

<script>
    var pak_Module = (function () {

        let mainModal = null;
        let searchModal = null;
        let tabsInstance = null;
        let detailGridInstance = null;

        let selectedDetailRow = null;

        const sel = {
            modalMain: "#pak_modalMain",
            modalSearch: "#pak_modalSearch",
            loading: "#pak_loadingSpinner",

            tabs: "#pak_tabs",
            tabForms: ".pak_tabForm",

            // action bar
            btnSearch: "#pak_btnSearch",
            btnNew: "#pak_btnNew",
            btnEdit: "#pak_btnEdit",
            btnSaveHeader: "#pak_btnSaveHeader",
            btnDeleteHeader: "#pak_btnDeleteHeader",
            btnRefreshDetail: "#pak_btnRefreshDetail",
            btnSaveDetail: "#pak_btnSaveDetail",
            btnDeleteDetail: "#pak_btnDeleteDetail",
            btnClose: "#pak_btnClose",

            // header fields
            ID: "#pak_ID",
            packageID: "#pak_packageID",
            txtCode: "#pak_txtCode",
            targetCode: "#pak_targetCode",
            txtDescription: "#pak_txtDescription",
            textInNightAudit: "#pak_textInNightAudit",
            forecastGroup: "#pak_forecastGroup",
            type: "#pak_type",
            transactionCode: "#pak_transactionCode",
            chkActive: "#pak_chkActive",
            chkIncludedInRate: "#pak_chkIncludedInRate",
            chkRateSeparateLine: "#pak_chkRateSeparateLine",
            breakfast: "#pak_breakfast",
            lunch: "#pak_lunch",
            dinner: "#pak_dinner",

            // detail fields
            packageDetailID: "#pak_packageDetailID",
            seasonCode: "#pak_seasonCode",
            startDateHidden: "#pak_startDate",
            endDateHidden: "#pak_endDate",
            startDateUi: "#pak_startDateUi",
            endDateUi: "#pak_endDateUi",
            transactionCodeDT: "#pak_transactionCodeDT",
            currencyID: "#pak_currencyID",
            price: "#pak_price",
            priceAfterTax: "#pak_priceAfterTax",
            allowanceAmount: "#pak_allowanceAmount",
            rhythmPostingID: "#pak_rhythmPostingID",
            calculationRuleID: "#pak_calculationRuleID",

            // search
            searchInput: "#pak_packageSearch",
            searchTableBody: "#pak_packageTableBody",

            // grid
            detailGrid: "#pak_packageDetailGrid"
        };

        function init() {
            mainModal = bootstrap.Modal.getOrCreateInstance(document.querySelector(sel.modalMain), { backdrop: "static" });
            searchModal = bootstrap.Modal.getOrCreateInstance(document.querySelector(sel.modalSearch), { backdrop: "static" });

            $(sel.modalMain).off("shown.bs.modal.pak").on("shown.bs.modal.pak", async function () {
                initTomSelect(["#pak_forecastGroup","#pak_transactionCode","#pak_type","#pak_seasonCode","#pak_transactionCodeDT","#pak_currencyID","#pak_rhythmPostingID","#pak_calculationRuleID"]);
                bindEvents();
                initTabs();
                await ensureDateInputs();
                initDetailGrid([]);
                syncDerivedFields();
                setFormsReadOnly(true);
                applyTabMode(0);
                showLoading(false);
            });

            $(sel.modalMain).off("hidden.bs.modal.pak").on("hidden.bs.modal.pak", function () {
                cleanup();
            });
            
            $(sel.modalSearch).off("hidden.bs.modal.pak").on("hidden.bs.modal.pak", function () {
                $('#pak_modalMain .modal-content').removeClass('modal-blur');

            });

            // search table row click
            $(document).off("click.pak", `${sel.searchTableBody} tr`).on("click.pak", `${sel.searchTableBody} tr`, function () {
                const id = parseInt($(this).attr("data-id")) || 0;
                if (!id) return;
                selectPackage(id);
            });

            // search filter
            $(document).off("input.pak", sel.searchInput).on("input.pak", sel.searchInput, function () {
                filterSearchTable();
            });
        }

        function open() {
            mainModal.show();
        }

        function cleanup() {
            $(document).off(".pak");
            try { if (detailGridInstance) detailGridInstance.dispose(); } catch { }
            detailGridInstance = null;
            selectedDetailRow = null;
        }

        function showLoading(on) {
            if (on) $(sel.loading).css("display", "flex"); else $(sel.loading).hide();
        }

        async function ensureDateInputs() {
            if (typeof window.initDateInputs === "function") {
                await window.initDateInputs();
            }
        }

        // ---------- UI: tabs ----------
        function initTabs() {
            const tabsText = [{ text: "Package Header" }, { text: "Package Detail" }];

            tabsInstance = $(sel.tabs).dxTabs({
                dataSource: tabsText,
                selectedIndex: 0,
                keyExpr: "text",
                width: "40%",
                showNavButtons: false,
                stylingMode: "text",
                onSelectionChanged: function (e) {
                    applyTabMode(e.component.option("selectedIndex"));
                }
            }).dxTabs("instance");
        }

        function applyTabMode(index) {
            $(sel.tabForms).removeClass("pak_visible d-flex flex-column").addClass("d-none");
            const $panel = $(`${sel.tabForms}[data-tab="${index}"]`);
            $panel.removeClass("d-none").addClass("pak_visible");
            if (index === 1) {
                $panel.addClass("d-flex flex-column");
            }

            if (index === 1) {
                pakClearPackageHeaderFieldErrorIfResolved();

                $(sel.btnNew).hide();
                $(sel.btnSaveHeader).hide();
                $(sel.btnDeleteHeader).hide();

                $(sel.btnRefreshDetail).show();
                $(sel.btnSaveDetail).show();
                $(sel.btnDeleteDetail).show();

                setTimeout(function () {
                    try { if (detailGridInstance) detailGridInstance.updateDimensions(); } catch (e) { }
                }, 0);
            } else {
                $(sel.btnNew).show();
                $(sel.btnSaveHeader).show();
                $(sel.btnDeleteHeader).show();

                $(sel.btnRefreshDetail).hide();
                $(sel.btnSaveDetail).hide();
                $(sel.btnDeleteDetail).hide();
            }
        }

        // ---------- Readonly ----------
        function setFormsReadOnly(readOnly) {
            // Không disable hidden (pak_ID, pak_packageID, …) — tránh mất/khó đọc PackageID khi Save Detail
            $(sel.modalMain)
                .find("input:not([type='hidden']), textarea, select")
                .not(`${sel.type}, .pak_noReadOnly`)
                .prop("disabled", readOnly);

            $(sel.modalMain)
                .find('input[type="checkbox"], input[type="radio"]')
                .prop("disabled", readOnly);

            // keep forecastGroup disabled/enabled consistent with original behavior
            document.querySelectorAll(sel.modalMain + " .tomselect-custom")
                .forEach(el => {
                    if (!el.tomselect) return;
                    readOnly ? el.tomselect.disable() : el.tomselect.enable();
                });
        }

        function clearAll() {
            // clear header
            $(sel.ID).val("");
            $(sel.packageID).val("");
            $(sel.txtCode).val("");
            $(sel.targetCode).val("No target Package");
            $(sel.txtDescription).val("");
            $(sel.textInNightAudit).val("");
            $(sel.forecastGroup).val("0");
            clearTomSelect("#pak_type")
            $(sel.transactionCode).val("0");

            $(sel.chkActive).prop("checked", true);
            $(sel.chkIncludedInRate).prop("checked", true);
            $(sel.chkRateSeparateLine).prop("checked", false);

            $(sel.breakfast).prop("checked", true);
            $(sel.lunch).prop("checked", true);
            $(sel.dinner).prop("checked", true);

            // clear detail
            $(sel.packageDetailID).val("");
            $(sel.seasonCode).val("0");
            $(sel.startDateUi).val("");
            $(sel.endDateUi).val("");
            $(sel.transactionCodeDT).val("0");
            $(sel.currencyID).val($(sel.currencyID + " option:first").val() || "");
            $(sel.price).val("");
            $(sel.priceAfterTax).val("");
            $(sel.allowanceAmount).val("");
            $(sel.rhythmPostingID).val($(sel.rhythmPostingID + " option:first").val() || "0");
            if (typeof setTomSelectValue === "function") {
                setTomSelectValue(sel.calculationRuleID, "1");
            } else {
                $(sel.calculationRuleID).val("1");
            }

            selectedDetailRow = null;
            initDetailGrid([]);
        }

        // ---------- Derived fields ----------
        function syncDerivedFields() {
            // description -> display in folio
            $(document).off("input.pak", sel.txtDescription).on("input.pak", sel.txtDescription, function () {
                $(sel.textInNightAudit).val($(this).val());
            });

            // code -> target code
            $(document).off("input.pak", sel.txtCode).on("input.pak", sel.txtCode, function () {
                $(sel.targetCode).val($(this).val());
            });
        }

        // ---------- Events ----------
        function bindEvents() {
            $(document).off("click.pak", sel.btnClose).on("click.pak", sel.btnClose, function () {
                mainModal.hide();
            });

            $(document).off("click.pak", sel.btnSearch).on("click.pak", sel.btnSearch, function () {
                openSearch();
            });

            $(document).off("click.pak", sel.btnNew).on("click.pak", sel.btnNew, function () {
                clearAll();
                if (typeof window.applyValidationErrors === "function") applyValidationErrors([], "#pak_headerForm");
                setFormsReadOnly(false);
                applyTabMode(0);
                if (tabsInstance) tabsInstance.option("selectedIndex", 0);
            });

            $(document).off("click.pak", sel.btnEdit).on("click.pak", sel.btnEdit, function () {
                // toggle like original
                const nowDisabled = $(sel.txtCode).prop("disabled") === true;
                setFormsReadOnly(!nowDisabled); // if disabled -> enable, else disable
            });

            $(document).off("click.pak", sel.btnSaveHeader).on("click.pak", sel.btnSaveHeader, function () {
                saveHeader();
            });

            $(document).off("click.pak", sel.btnDeleteHeader).on("click.pak", sel.btnDeleteHeader, function () {
                deleteHeader();
            });

            $(document).off("click.pak", sel.btnSaveDetail).on("click.pak", sel.btnSaveDetail, function () {
                saveDetail();
            });

            $(document).off("click.pak", sel.btnRefreshDetail).on("click.pak", sel.btnRefreshDetail, function () {
                clearDetailOnly();
                if (typeof window.applyValidationErrors === "function") applyValidationErrors([], "#pak_detailForm");
            });

            $(document).off("click.pak", sel.btnDeleteDetail).on("click.pak", sel.btnDeleteDetail, function () {
                deleteDetail();
            });
        }

        function openSearch() {
            // reset filter
            $(sel.searchInput).val("");
            filterSearchTable();
            searchModal.show();
            $('#pak_modalMain .modal-content').addClass('modal-blur');
        }

        function filterSearchTable() {
            const keyword = ($(sel.searchInput).val() || "").toLowerCase();
            $(`${sel.searchTableBody} tr`).each(function () {
                const t = $(this).text().toLowerCase();
                $(this).toggle(t.includes(keyword));
            });
        }

        function clearDetailOnly() {
            $(sel.packageDetailID).val("");
            $(sel.seasonCode).val("0");
            $(sel.startDateUi).val("");
            $(sel.endDateUi).val("");
            $(sel.transactionCodeDT).val("0");
            $(sel.price).val("");
            $(sel.priceAfterTax).val("");
            $(sel.allowanceAmount).val("");
            selectedDetailRow = null;
            clearMultipleTomSelect([
                "#pak_seasonCode",
                "#pak_currencyID",
                "#pak_transactionCodeDT",
                "#pak_rhythmPostingID"
            ], true);
            if (typeof setTomSelectValue === "function") {
                setTomSelectValue(sel.calculationRuleID, "1");
            } else {
                $(sel.calculationRuleID).val("1");
            }
            reloadBusinessDate();

        }

        // ---------- Grid ----------
        function initDetailGrid(data) {
            try {
                if (detailGridInstance) detailGridInstance.dispose();
            } catch { }
            $(sel.detailGrid).empty();

            detailGridInstance = $(sel.detailGrid).dxDataGrid({
                dataSource: data || [],
                showBorders: true,
                selection: { mode: "single" },
                paging: { pageSize: 20 },
                pager: {
                    showPageSizeSelector: true,
                    allowedPageSizes: [20, 50, 100],
                    showInfo: true
                },
                height: "100%",
                filterRow: { visible: true, applyFilter: "auto" },
                scrolling: {
                    mode: "standard",
                    showScrollbar: "always",
                    scrollByContent: true
                },
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "transCode", caption: "Trans. Code", width: 90 },
                    { dataField: "transactionDescription", caption: "Description",cssClass: "col-description"},
                    { dataField: "price", caption: "Price ++", format: "#,##0", dataType: "number", width: 70 },
                    { dataField: "priceAfterTax", caption: "Price Net", format: "#,##0", dataType: "number", width: 70 },
                    { dataField: "currencyID", caption: "Currency", width: 80 },
                    { dataField: "startDate", caption: "Start Date", width: 80, dataType: "date", format: "dd/MM/yyyy" },
                    { dataField: "endDate", caption: "End Date", width: 80, dataType: "date", format: "dd/MM/yyyy" },
                    { dataField: "postingDay", caption: "Posting Day", width: 80 }
                ],
                onRowDblClick: function (e) {
                    selectedDetailRow = e.data || null;
                    if (selectedDetailRow) fillDetailForm(selectedDetailRow);
                },
                noDataText: "No records to display"
            }).dxDataGrid("instance");
        }

        function fillDetailForm(d) {
            $(sel.packageDetailID).val(d.id);
            setTomSelectValue(sel.seasonCode,d.seasonID ?? "");

            // original set input value with split('T')[0], keep it
            $(sel.startDateUi).val(d.startDate ? d.startDate.split("T")[0] : "");
            $(sel.endDateUi).val(d.endDate ? d.endDate.split("T")[0] : "");

            setTomSelectValue(sel.transactionCodeDT,d.transCode ?? "");
            setTomSelectValue(sel.currencyID,d.currencyID ?? "");

            $(sel.price).val(d.price);
            $(sel.priceAfterTax).val(d.priceAfterTax);
            $(sel.allowanceAmount).val(d.allowanceAmount);

            setTomSelectValue(sel.rhythmPostingID,d.rhythmPostingID ?? "");
            setTomSelectValue(sel.calculationRuleID,d.calculationRuleID ?? "");
            $(sel.calculationRuleID).val(d.calculationRuleID);

            setFormsReadOnly(true);
        }

        // ---------- API: select package ----------
        async function selectPackage(id) {
            try {
                showLoading(true);

                const resPackage = await $.ajax({
                    url: "/Administration/RateCode/GetByIDPackage",
                    method: "GET",
                    data: { id }
                });

                if (!resPackage?.success) {
                    showToast("Error", resPackage?.message || "Failed to load package.", false);
                    return;
                }

                const pkg = resPackage.data;

                $(sel.ID).val(pkg.id);
                $(sel.packageID).val(pkg.id);
                $(sel.txtCode).val(pkg.code);
                $(sel.targetCode).val(pkg.code || "No target Package");
                $(sel.txtDescription).val(pkg.description);
                setTomSelectValue(sel.forecastGroup,pkg.forecastGroupID ?? "")
//                setTomSelectValue(sel.transactionCode,pkg.transCodeAlt ?? "")
                setTomSelectValue(sel.type,pkg.type)

                $(sel.textInNightAudit).val(pkg.textInNightAudit);

                // original code referenced ids that didn't exist; keep only those that exist in this refactor
                $(sel.chkIncludedInRate).prop("checked", !!pkg.includedInRate);
                $(sel.chkRateSeparateLine).prop("checked", !!pkg.rateSeparateLine);
                $(sel.chkActive).prop("checked", !!pkg.active);

                $(sel.breakfast).prop("checked", !!pkg.breakfast);
                $(sel.lunch).prop("checked", !!pkg.lunch);
                $(sel.dinner).prop("checked", !!pkg.dinner);

                setFormsReadOnly(true);

                pakClearPackageHeaderFieldErrorIfResolved();

                const resDetail = await $.ajax({
                    url: "/Administration/RateCode/GetPackageDetailByIDPackage",
                    method: "GET",
                    data: { id }
                });

                if (!resDetail?.success) {
                    showToast("Error", resDetail?.message || "Failed to load package detail.", false);
                    return;
                }

                initDetailGrid(resDetail.data || []);
                setTimeout(function () {
                    try { if (detailGridInstance) detailGridInstance.updateDimensions(); } catch (e) { }
                }, 0);

                searchModal.hide();
            } catch (err) {
                console.error(err);
                showToast("Error", "Failed to load data.", false);
            } finally {
                showLoading(false);
            }
        }

        // Tom Select không sync vào jQuery .val() — phải đọc qua tomselect.getValue()
        function pakTsRaw(selector) {
            const el = typeof selector === "string" ? document.querySelector(selector) : null;
            if (!el) return "";
            if (el.tomselect) {
                const v = el.tomselect.getValue();
                if (v === null || v === undefined) return "";
                return Array.isArray(v) ? (v[0] ?? "") : v;
            }
            const jv = $(selector).val();
            return jv === null || jv === undefined ? "" : jv;
        }

        function pakParseIntOrNull(selector) {
            const raw = String(pakTsRaw(selector)).trim();
            if (raw === "") return null;
            const n = parseInt(raw, 10);
            return Number.isNaN(n) ? null : n;
        }

        function pakResolvePackageId() {
            const pkgEl = document.getElementById("pak_packageID");
            const idEl = document.getElementById("pak_ID");
            let pid = NaN;
            if (pkgEl && pkgEl.value) pid = parseInt(String(pkgEl.value).trim(), 10);
            if (Number.isNaN(pid) || pid <= 0) {
                if (idEl && idEl.value) pid = parseInt(String(idEl.value).trim(), 10);
            }
            if (!Number.isNaN(pid) && pid > 0 && pkgEl) {
                pkgEl.value = String(pid);
            }
            if (Number.isNaN(pid) || pid <= 0) return null;
            return pid;
        }

        /** Xóa viền đỏ ô Header (name=packageID) khi đã có Package ID — lỗi client không tự hết sau Save Header / Search */
        function pakClearPackageHeaderFieldErrorIfResolved() {
            if (!pakResolvePackageId()) return;
            const $field = $("#pak_detailForm [name='packageID']");
            if (!$field.length) return;
            $field.removeClass("is-invalid");
            $field.siblings(".invalid-feedback").text("").hide();
        }

        /** Placeholder Tom Select = 0 / rỗng → mặc định Per Person (1) trước khi lưu */
        function pakEnsureCalculationRuleOrDefault() {
            const raw = String(pakTsRaw(sel.calculationRuleID) || "").trim();
            const n = raw === "" ? NaN : parseInt(raw, 10);
            if (!Number.isNaN(n) && n > 0) return;
            setTomSelectValue(sel.calculationRuleID, "1");
            $(sel.calculationRuleID).val("1");
        }

        // ---------- Payload builders ----------
        function getHeaderPayload() {
            return {
                ID: parseInt($(sel.ID).val()) || 0,
                Code: ($(sel.txtCode).val() || "").trim(),
                ForecastGroupID: parseInt($(sel.forecastGroup).val()) || 0,
                Type: parseInt($(sel.type).val()) || 0,
                TransCode: $(sel.transactionCode).val() || "",
                Description: ($(sel.txtDescription).val() || "").trim(),
                DisplayInFolio: ($(sel.textInNightAudit).val() || "").trim(),
                DefaultDisplay: parseInt($('input[name="pak_attr"]:checked').val()) || 0,
                Breakfast: $(sel.breakfast).is(":checked"),
                Lunch: $(sel.lunch).is(":checked"),
                Dinner: $(sel.dinner).is(":checked"),
                Active: $(sel.chkActive).is(":checked"),
                UserInsertID: parseInt(localStorage.getItem("userID")) || 0,
                UserUpdateID: parseInt(localStorage.getItem("userID")) || 0
            };
        }

        function getDetailPayload() {
            const startIso = $(sel.startDateHidden).val() || null;
            const endIso = $(sel.endDateHidden).val() || null;
            const trans = (pakTsRaw(sel.transactionCodeDT) || "").trim();
            const cur = (pakTsRaw(sel.currencyID) || "").trim();
            const crRaw = pakTsRaw(sel.calculationRuleID);
            const crParsed = crRaw === "" ? NaN : parseInt(crRaw, 10);
            let calculationRuleID = Number.isNaN(crParsed) ? null : crParsed;
            if (calculationRuleID === null || calculationRuleID <= 0) calculationRuleID = 1;

            let rhythm = parseInt(String(pakTsRaw(sel.rhythmPostingID)).trim(), 10);
            if (Number.isNaN(rhythm)) rhythm = 0;

            const priceStr = $(sel.price).val();
            const priceNetStr = $(sel.priceAfterTax).val();
            const allowanceStr = $(sel.allowanceAmount).val();
            const price = priceStr === "" || priceStr === null ? null : parseFloat(priceStr);
            const priceAfterTax = priceNetStr === "" || priceNetStr === null ? null : parseFloat(priceNetStr);
            const allowanceAmount = allowanceStr === "" || allowanceStr === null ? null : parseFloat(allowanceStr);

            return {
                ID: parseInt($(sel.packageDetailID).val(), 10) || 0,
                PackageID: pakResolvePackageId(),
                SeasonID: pakParseIntOrNull(sel.seasonCode),
                StartDate: startIso || $(sel.startDateUi).val() || null,
                EndDate: endIso || $(sel.endDateUi).val() || null,
                TransCode: trans || null,
                Price: Number.isNaN(price) ? null : price,
                PriceAfterTax: Number.isNaN(priceAfterTax) ? null : priceAfterTax,
                CurrencyID: cur || null,
                AllowanceAmount: Number.isNaN(allowanceAmount) ? null : allowanceAmount,
                RhythmPostingID: rhythm,
                CalculationRuleID: calculationRuleID,
                UserInsertID: parseInt(localStorage.getItem("userID"), 10) || 0,
                UserUpdateID: parseInt(localStorage.getItem("userID"), 10) || 0
            };
        }

        // ---------- Save/Delete ----------
        function saveHeader() {
            showLoading(true);

            const payload = getHeaderPayload();

            $.ajax({
                url: "/Administration/RateCode/SavePackage",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(payload),
                success: function (res) {
                    if (res?.success) {
                        showToast("Success", res.message, true);
                        const id = res.data?.id;
                        if (id) {
                            selectPackage(id).catch(function () { }).finally(function () { showLoading(false); });
                            return;
                        }
                    } else {
                        if (typeof window.applyValidationErrors === "function") applyValidationErrors(res?.errors || [], "#pak_headerForm");
                        showToast("Error", res?.message || "Save failed.", false);
                    }
                    showLoading(false);
                },
                error: function (xhr) {
                    showLoading(false);
                    const errs = xhr.responseJSON?.errors;
                    if (Array.isArray(errs)) errs.forEach((m, i) => setTimeout(() => showToast("Error", m, false), i * 700));
                    else showToast("Error", xhr.responseJSON?.message || "Save failed.", false);
                }
            });
        }

        function deleteHeader() {
            const id = parseInt($(sel.ID).val()) || 0;
            if (!id) {
                showToast("Warning", "No package selected.", false);
                return;
            }
            showLoading(true);

            $.ajax({
                url: "/Administration/RateCode/PackageDelete",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify({ ID: id }),
                success: function (res) {
                    showLoading(false);
                    if (res?.success) {
                        showToast("Success", res.message, true);
                        clearAll();
                    } else {
                        showToast("Error", res?.message || "Delete failed.", false);
                    }
                },
                error: function (xhr) {
                    showLoading(false);
                    const errs = xhr.responseJSON?.errors;
                    if (Array.isArray(errs)) errs.forEach((m, i) => setTimeout(() => showToast("Error", m, false), i * 700));
                    else showToast("Error", xhr.responseJSON?.message || "Delete failed.", false);
                }
            });
        }

        function saveDetail() {
            pakResolvePackageId();
            const pid = pakResolvePackageId();
            if (!pid) {
                showToast("Warning", "Chưa gán Package: sang tab Package Header, nhập đủ và bấm Save; hoặc Search để mở package đã có.", false);
                if (typeof window.applyValidationErrors === "function") {
                    applyValidationErrors([{ field: "packageID", message: "Cần Package ID — lưu Header hoặc chọn package." }], "#pak_detailForm");
                }
                return;
            }

            pakEnsureCalculationRuleOrDefault();
            if (typeof window.applyValidationErrors === "function") {
                applyValidationErrors([], "#pak_detailForm");
            }

            showLoading(true);

            const payload = getDetailPayload();

            $.ajax({
                url: "/Administration/RateCode/SaveDetailPackage",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(payload),
                success: function (res) {
                    if (res?.success) {
                        showToast("Success", res.message, true);
                        applyValidationErrors(res?.errors || [], "#pak_detailForm");
                        const pkgId = parseInt($(sel.packageID).val(), 10) || 0;
                        if (pkgId) {
                            selectPackage(pkgId).catch(function () { }).finally(function () { showLoading(false); });
                            return;
                        }
                    } else {
                        if (typeof window.applyValidationErrors === "function") applyValidationErrors(res?.errors || [], "#pak_detailForm");
                        showToast("Error", res?.message || "Save failed.", false);
                    }
                    showLoading(false);
                },
                error: function (xhr) {
                    showLoading(false);
                    const errs = xhr.responseJSON?.errors;
                    if (Array.isArray(errs)) errs.forEach((m, i) => setTimeout(() => showToast("Error", m, false), i * 700));
                    else showToast("Error", xhr.responseJSON?.message || "Save failed.", false);
                }
            });
        }

        function deleteDetail() {
            const id = parseInt($(sel.packageDetailID).val()) || 0;
            if (!id) {
                showToast("Warning", "Please select a detail row to delete.", false);
                return;
            }

            showLoading(true);

            $.ajax({
                url: "/Administration/RateCode/PackageDetailDelete",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify({ ID: id }),
                success: function (res) {
                    if (res?.success) {
                        showToast("Success", res.message, true);
                        clearDetailOnly();
                        const pkgId = parseInt($(sel.packageID).val(), 10) || 0;
                        if (pkgId) {
                            selectPackage(pkgId).catch(function () { }).finally(function () { showLoading(false); });
                            return;
                        }
                    } else {
                        showToast("Error", res?.message || "Delete failed.", false);
                    }
                    showLoading(false);
                },
                error: function (xhr) {
                    showLoading(false);
                    const errs = xhr.responseJSON?.errors;
                    if (Array.isArray(errs)) errs.forEach((m, i) => setTimeout(() => showToast("Error", m, false), i * 700));
                    else showToast("Error", xhr.responseJSON?.message || "Delete failed.", false);
                }
            });
        }

        return { init, open };

    })();

    // Option A global entry
    window.openModalPak = function () {
        pak_Module.open();
    };

    $(document).ready(function () {
        pak_Module.init();
        // auto-open if desired:
        // window.openModalPak();
    });
</script>