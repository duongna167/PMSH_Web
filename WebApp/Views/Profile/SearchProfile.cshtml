

<div class="modal fade" id="pro_search_mainModal" tabindex="-1" aria-labelledby="pro_search_title" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content modal-full-height">

            <div id="pro_search_loadingSpinner" style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                                z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                                height: 100%;display: none;align-items: center;justify-content: center;">
                <div class="spinner-border text-primary" role="status"></div>
            </div>

            <div class="modal-header">
                <h3 class="modal-title" id="pro_search_title">Search Profile</h3>
            </div>

            <div class="modal-body d-flex flex-column" style="height: calc(100vh - 120px);">
                <div class="py-2">
                    <button id="pro_search_btnSearch" class="mui-button mui-button-new">Search</button>
                    <button id="pro_search_btnNew" class="mui-button mui-button-new">New</button>
                    <button id="pro_search_btnEdit" class="mui-button mui-button-new">Edit</button>
                    <button id="pro_search_btnClear" class="mui-button mui-button-new">Clear</button>
                    <button id="pro_search_btnOption" class="mui-button mui-button-new">Option</button>
                    <button id="pro_search_btnHistory" class="mui-button mui-button-new">History</button>
                    <button class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>
                <div class="mui-card mb-2 bg-light border-0 d-flex flex-column flex-grow-1 overflow-hidden">
                    <div class="p-3 flex-shrink-0 border-bottom">
                        <div class="row g-3 align-items-center">
                            <div class="col-md-3">
                                <div class="d-flex align-items-center">
                                    <label for="pro_search_txtType" class="col-form-label text-end me-2" style="width: 85px;">View By</label>
                                    <select id="pro_search_txtType" class="form-select flex-grow-1 form-select-sm">
                                        <option value="" selected>View by All</option>
                                        <option value="1">Travel Agent</option>
                                        <option value="2">Company</option>
                                        <option value="3">Source</option>
                                        <option value="0">Individual</option>
                                        <option value="4">Group</option>
                                        <option value="5">Contact</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="d-flex align-items-center">
                                    <label for="pro_search_txtCity" class="col-form-label text-end me-2" style="width: 85px;">City</label>
                                    <select id="pro_search_txtCity" class="form-select flex-grow-1 form-select-sm"></select>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="d-flex align-items-center">
                                    <label for="pro_search_txtArea" class="col-form-label text-end me-2" style="width: 85px;">Area</label>
                                    <select id="pro_search_txtArea" class="form-select flex-grow-1 form-select-sm" disabled>
                                        <option value="value">PMSh The Arena</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-check ms-2">
                                    <input type="checkbox" class="" id="pro_search_txtShowSaleInCharge">
                                    <label class="form-check-label shadow-none" for="pro_search_txtShowSaleInCharge" style="font-size: 0.9rem; white-space: nowrap;">
                                        Show Sale In Charge
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="row g-3 align-items-center">
                            <div class="col-md-3">
                                <div class="d-flex align-items-center">
                                    <label for="pro_search_txtAccount" class="col-form-label text-end me-2" style="width: 85px;">Name</label>
                                    <input type="text" id="pro_search_txtAccount" class="form-control form-control-sm flex-grow-1">
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="d-flex align-items-center">
                                    <label for="pro_search_txtKeyword" class="col-form-label text-end me-2" style="width: 85px;">Keyword</label>
                                    <input type="text" id="pro_search_txtKeyword" class="form-control form-control-sm flex-grow-1">
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="d-flex align-items-center">
                                    <label for="pro_search_txtFirstName" class="col-form-label text-end me-2" style="width: 85px;">First Name</label>
                                    <input type="text" id="pro_search_txtFirstName" class="form-control form-control-sm flex-grow-1">
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="d-flex align-items-center">
                                    <label for="pro_search_txtCode" class="col-form-label text-end me-2" style="width: 85px;">Code</label>
                                    <input type="text" id="pro_search_txtCode" class="form-control form-control-sm flex-grow-1">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="gridContainer mt-2 d-flex flex-column flex-grow-1 overflow-auto">
                        <div id="pro_search_gridContainer"></div>
                    </div>

                </div>
            </div>    
                  
        </div>
    </div>
</div>

<div class="modal fade" tabindex="-1" role="dialog" id="pro_search_modelReservation" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content modal-full-height">
            <div class="modal-header">
                <h5 class="modal-title">Reservation New</h5>
            </div>
            <div class="modal-body">
                <div style="height:1px;background-color:#ececec" class="mt-3"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                <button type="button" class="mui-button mui-button-new">Save changes</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="pro_search_modalOption" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Profile Options</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="toolbar-menu mt-2 row" id="pro_search_functionAndOption">
                    <a href="#" class="font-semibold col-md-6 mb-1" onclick="openModalChanges();">Changes</a>
                    <a href="#" class="font-semibold col-md-6 mb-1" onclick="deleteProfile();">Delete</a>
                    <a href="#" class="font-semibold col-md-6 mb-1" onclick="openModalFuture();">Future</a>
                    <a href="#" class="font-semibold col-md-6 mb-1" onclick="GetProfileHistory();">History</a>
                    <a href="#" class="font-semibold col-md-6 mb-1" onclick="openModalMembership();">Memberships</a>
                    <a href="#" class="font-semibold col-md-6 mb-1" onclick="openConfirmMerge();">Merge</a>
                    <a href="#" class="font-semibold col-md-6 mb-1" onclick="openNegRates();">Neg.Rates</a>
                    <a href="#" class="font-semibold col-md-6 mb-1" onclick="updateProfile();">Profile Update</a>
                    <a href="#" class="font-semibold col-md-6 mb-1" onclick="openRelationships();">Relationships</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="pro_search_modalHistory" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content modal-full-height">
            <div class="modal-header">
                <h5 class="modal-title">History</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <button class="mui-button mui-button-new" onclick="AttachAccompanying();">Attach</button>
                    <button class="mui-button mui-button-new" onclick="detach()">Detach</button>
                    <button class="mui-button mui-button-new" onclick="openModalViewProfile()">Profile</button>
                    <button class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>
                <div class="mui-card mt-2">
                    <div id="pro_search_gridContainerHistory" class="gridContainer"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("Options/Membership")
@await Html.PartialAsync("Options/Changes")
@await Html.PartialAsync("Options/Future")
@await Html.PartialAsync("~/Views/Profile/NewProfileModal/_ProfileIndividual.cshtml")
@await Html.PartialAsync("~/Views/Profile/NewProfileModal/_ProfileCompany.cshtml")
@await Html.PartialAsync("~/Views/Profile/NewProfileModal/_ProfileGroup.cshtml")
@await Html.PartialAsync("~/Views/Profile/NewProfileModal/_ProfileContact.cshtml")

<script>
    const pro_search_Module = {
        // --- State ---
        saleInChargeData: [],
        profileID: 0,
        profileType: 0,
        profileName: "",
        gridInstance: null,
        selectedCallback: null,

        // --- Khởi tạo ---
        init: function (callback) {
            this.selectedCallback = callback;
        
            this.bindEvents();
            this.initDOMEvents();
            
            this.loadInitialData();
        
            this.initializeDataGrid();
        },

        initDOMEvents: function () {
            const self = this;
        
            // Nút bấm trên thanh công cụ chính
            $("#pro_search_btnSearch").on("click", () => self.getAllProfiles());
            $("#pro_search_btnNew").on("click", () => self.editProfile('NEW'));
            $("#pro_search_btnEdit").on("click", () => self.editProfile('EDIT'));
            $("#pro_search_btnClear").on("click", () => self.clearSearchForm());
            $("#pro_search_btnOption").on("click", () => self.openModalOption());
            $("#pro_search_btnHistory").on("click", () => self.GetProfileHistory());
        
            // Các nút trong Modal Option (ví dụ dùng class hoặc id cụ thể)
            $("#pro_search_btnDelete").on("click", () => self.deleteProfile());
        
            // Nút Save trên các Modal nhập liệu (Profile Individual/Company...)
            // Giả sử các modal này có nút Save chung hoặc riêng
            $(".btn-save-profile").on("click", () => self.saveProfile());
        },

        bindEvents: function () {
            const self = this;
            // Prefix: pro_search_txtFullNameIndividual
            $('#pro_search_txtFullNameIndividual').off('blur').on('blur', function () {
                self.checkFullName({
                    fullNameSelector: '#pro_search_txtFullNameIndividual',
                    firstNameSelector: '#pro_search_txtFirstNameIndividual',
                    middleNameSelector: '#pro_search_txtMiddleNameIndividual',
                    lastNameSelector: '#pro_search_txtLastNameIndividual',
                    salutationSelector: '#pro_search_txtSalutationIndividual',
                    titleSelector: '#pro_search_txtTitleIndividual',
                    idForm: "#profile_individual" 
                });
            });

            $('#pro_search_txtFullNameContact').off('blur').on('blur', function () {
                self.checkFullName({
                    fullNameSelector: '#pro_search_txtFullNameContact',
                    firstNameSelector: '#pro_search_txtFirstNameContact',
                    middleNameSelector: '#pro_search_txtMiddleNameContact',
                    lastNameSelector: '#pro_search_txtLastContact',
                    salutationSelector: '#pro_search_txtSalulationContact',
                    titleSelector: '#pro_search_txtTitleContact',
                    idForm: "#profile_contact"
                });
            });

            $('#pro_search_txtMarketTypeCOM').off('change').on('change', function () {
                self.getMarket2();
            });
        },

        loadInitialData: function() {
            this.getAllCity();
            this.getAllLanguage2();
            this.getAllTitle2();
            this.getAllNationality2();
            this.getAllCountry2();
            this.getAllState2();
            this.getAllCity2();
            this.getAllVIP2();
            this.getAllOwner2();
            this.getAllTerritory2();
            this.getCompanyType2();
            this.getCurrency2();
            this.getMarketType2();
        }, 

        getAllProfiles: function () {
            $("#pro_search_loadingSpinner").show();
            if (this.gridInstance) {
                this.gridInstance.refresh();
            } else {
                this.initializeDataGrid();
            }
        },

        getAllCity: function () {
            $.ajax({
                url: '/Profile/GetAllCity',
                type: 'get',
                dataType: 'json',
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                success: function (result) {
                    if (result.length > 0) {
                        $('#pro_search_txtCity').empty(); // Prefix
                        var html = `<option value=''></option>`;
                        for (var i = 0; i < result.length; i++) {
                            html += `<option value='${result[i].name}'>${result[i].code} - ${result[i].name}</option>`
                        }
                        $('#pro_search_txtCity').append(html);
                    }
                }
            });
        },
    
        getAllLanguage2: function () {
            const self = this;
            $.ajax({
                url: '/Profile/GetAllLanguage',
                type: 'get',
                dataType: 'json',
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                success: function (result) {
                    if (result.length > 0) {
                        const targets = ['#pro_search_txtLanguageIndividual', '#pro_search_txtLanguageGroup', '#pro_search_txtLanguageContact'];
                        targets.forEach(selector => {
                            let ts = $(selector)[0]?.tomselect;
                            if (ts) {
                                ts.clearOptions();
                                result.forEach(item => {
                                    ts.addOption({ value: item.id, text: `${item.code} - ${item.name}` });
                                });
                                ts.setValue('0');
                            }
                        });
                    }
                }
            });
        },

        getAllTitle2: function () {
            $.ajax({
                url: '/Profile/GetAllTitle',
                type: 'get',
                dataType: 'json',
                success: function (result) {
                    const targets = ['#pro_search_txtTitleIndividual', '#pro_search_txtTitleContact'];
                    targets.forEach(selector => {
                        let ts = $(selector)[0]?.tomselect;
                        if (ts) {
                            ts.clearOptions();
                            result.forEach(item => {
                                ts.addOption({ value: item.id, text: `${item.code} - ${item.name}` });
                            });
                            ts.setValue('0');
                        }
                    });
                }
            });
        },

        getAllNationality2: function () {
            $.ajax({
                url: '/Profile/GetAllNationality',
                type: 'get',
                dataType: 'json',
                success: function (result) {
                    let ts = $('#pro_search_txtNationalityIndividual')[0]?.tomselect;
                    if (ts) {
                        ts.clearOptions();
                        result.forEach(item => {
                            ts.addOption({ value: item.id, text: `${item.code} - ${item.name}` });
                        });
                        ts.setValue('0');
                    }
                }
            });
        },

        getAllCountry2: function () {
            $.ajax({
                url: '/Profile/GetAllCountry',
                type: 'get',
                dataType: 'json',
                success: function (result) {
                    const targets = ['#pro_search_txtCountryIndividual', '#pro_search_txtCountryCOM', '#pro_search_txtCountryGroup', '#pro_search_txtCountryContact'];
                    targets.forEach(selector => {
                        let ts = $(selector)[0]?.tomselect;
                        if (ts) {
                            ts.clearOptions();
                            result.forEach(item => {
                                ts.addOption({ value: item.id, text: `${item.code} - ${item.name}` });
                            });
                        }
                    });
                }
            });
        },

        getAllState2: function () {
            $.ajax({
                url: '/Profile/GetAllState',
                type: 'get',
                dataType: 'json',
                success: function (result) {
                    const targets = ['#pro_search_txtStateIndividual', '#pro_search_txtStateCOM', '#pro_search_txtStateGroup', '#pro_search_txtStateContact'];
                    targets.forEach(selector => {
                        let ts = $(selector)[0]?.tomselect;
                        if (ts) {
                            ts.clearOptions();
                            result.forEach(item => {
                                ts.addOption({ value: item.id, text: item.stateName });
                            });
                        }
                    });
                }
            });
        },

        getAllCity2: function () {
            $.ajax({
                url: '/Profile/GetAllCity',
                type: 'get',
                dataType: 'json',
                success: function (result) {
                    const targets = ['#pro_search_txtCityIndividual', '#pro_search_txtCityCOM', '#pro_search_txtCityContact'];
                    targets.forEach(selector => {
                        let ts = $(selector)[0]?.tomselect;
                        if (ts) {
                            ts.clearOptions();
                            result.forEach(item => {
                                ts.addOption({ value: item.code, text: `${item.code} - ${item.name}` });
                            });
                        }
                    });
                }
            });
        },

        getAllVIP2: function () {
            $.ajax({
                url: '/Profile/GetAllVIP',
                type: 'get',
                dataType: 'json',
                success: function (result) {
                    const targets = ['#pro_search_txtVIPIndividual', '#pro_search_txtVipGroup'];
                    targets.forEach(selector => {
                        let ts = $(selector)[0]?.tomselect;
                        if (ts) {
                            ts.clearOptions();
                            result.forEach(item => {
                                ts.addOption({ value: item.id, text: `${item.code} - ${item.name}` });
                            });
                        }
                    });
                }
            });
        },

        getAllOwner2: function () {
            $.ajax({
                url: '/Profile/GetAllOwner',
                type: 'get',
                dataType: 'json',
                success: function (result) {
                    const targets = ['#pro_search_txtOwnerCOM', '#pro_search_txtOwnerContact'];
                    targets.forEach(selector => {
                        let ts = $(selector)[0]?.tomselect;
                        if (ts) {
                            ts.clearOptions();
                            result.forEach(item => {
                                ts.addOption({ value: item.id, text: `${item.code} - ${item.name}` });
                            });
                        }
                    });
                }
            });
        },

        getAllTerritory2: function () {
            $.ajax({
                url: '/Profile/GetAllTerritory',
                type: 'get',
                dataType: 'json',
                success: function (result) {
                    const targets = ['#pro_search_txtTerritoryCOM', '#pro_search_txtTerritoryContact'];
                    targets.forEach(selector => {
                        let ts = $(selector)[0]?.tomselect;
                        if (ts) {
                            ts.clearOptions();
                            result.forEach(item => {
                                ts.addOption({ value: item.id, text: `${item.code} - ${item.name}` });
                            });
                        }
                    });
                }
            });
        },

        getCompanyType2: function () {
            $.ajax({
                url: '/Profile/GetAllCompanyType',
                type: 'get',
                dataType: 'json',
                success: function (result) {
                    let ts = $('#pro_search_txtCompanyTypeCOM')[0]?.tomselect;
                    if (ts) {
                        ts.clearOptions();
                        result.forEach(item => {
                            ts.addOption({ value: item.id, text: `${item.code} - ${item.name}` });
                        });
                    }
                }
            });
        },

        getCurrency2: function () {
            $.ajax({
                url: '/Profile/GetAllCurrency',
                type: 'get',
                dataType: 'json',
                success: function (result) {
                    const targets = ['#pro_search_txtCurrencyCOM', '#pro_search_txtCurrencyGroup'];
                    targets.forEach(selector => {
                        let ts = $(selector)[0]?.tomselect;
                        if (ts) {
                            ts.clearOptions();
                            result.forEach(item => {
                                ts.addOption({ value: item.id, text: item.description });
                            });
                        }
                    });
                }
            });
        },

        getMarketType2: function () {
            const self = this;
            $.ajax({
                url: '/Profile/GetMarketType',
                type: 'get',
                dataType: 'json',
                success: function (result) {
                    let ts = $('#pro_search_txtMarketTypeCOM')[0]?.tomselect;
                    if (ts) {
                        ts.clearOptions();
                        result.forEach(item => {
                            ts.addOption({ value: item.id, text: item.description });
                        });
                    }
                }
            });
        },

        getMarket2: function () {
            $.ajax({
                url: '/Profile/GetMarketByFK',
                type: 'get',
                dataType: 'json',
                data: { marketTypeID: $('#pro_search_txtMarketTypeCOM').val() },
                success: function (result) {
                    let ts = $('#pro_search_txtMarketCOM')[0]?.tomselect;
                    if (ts) {
                        ts.clearOptions();
                        result.forEach(item => {
                            ts.addOption({ value: item.id, text: item.description });
                        });
                    }
                }
            });
        },

        initializeDataGrid: function () {
            const self = this;
            var dataSource = new DevExpress.data.CustomStore({
                key: "id",
                load: function (loadOptions) {
                    var d = $.Deferred();
                    var params = {
                        skip: loadOptions.skip || 0,
                        take: loadOptions.take || 20,
                        // Sử dụng tiền tố pro_search_ cho các selector lấy dữ liệu search
                        code: $('#pro_search_txtCode').val(),
                        account: $('#pro_search_txtAccount').val(),
                        firstName: $('#pro_search_txtFirstName').val(),
                        keyWord: $('#pro_search_txtKeyword').val(),
                        city: $('#pro_search_txtCity').val(),
                        type: $('#pro_search_txtType').val(),
                        showSaleInCharge: $("#pro_search_txtShowSaleInCharge").is(":checked")
                    };

                    $.ajax({
                        url: '/Profile/GetAllProfileTest',
                        type: 'GET',
                        dataType: 'json',
                        data: params,
                        cache: false,
                        success: function (result) {
                            d.resolve({
                                data: result.data,
                                totalCount: result.totalCount
                            });
                        },
                        error: function () {
                            d.reject("Error loading data from the server.");
                        }
                    });
                    return d.promise();
                }
            });

            var columnWidth = 150;
            var typeValue = $("#pro_search_txtType").val();

            var taxCodeColumn = {
                dataField: "taxCode",
                caption: "Tax Code",
                width: columnWidth - 30
            };

            // 1. Khởi tạo mảng columns cơ bản
            var columns = [
                { dataField: "id", caption: "ID", width: columnWidth - 80, visible: false },
                { dataField: "code", caption: "Code", width: columnWidth - 50 },
                {
                    dataField: "vip",
                    caption: "Vip",
                    width: columnWidth - 80,
                    visible: typeValue != "1"
                },
                { dataField: "account", caption: "Account", width: columnWidth * 2 },
            ];

            // 2. Thêm Tax Code nếu là Travel Agent (Type 1)
            if (typeValue === "1") {
                columns.push(taxCodeColumn);
            }

            // 3. Ghép các cột thông tin cá nhân/liên lạc
            columns = columns.concat([
                {
                    dataField: "dateOfBirth",
                    caption: "Date Of Birth",
                    width: columnWidth,
                    dataType: "date",
                    format: "dd/MM/yyyy",
                    visible: typeValue != "1",
                    calculateCellValue: function (data) {
                        if (!data.dateOfBirth) return null;
                        // Xử lý format chuỗi dd.MM.yyyy từ server
                        const parts = data.dateOfBirth.split(".");
                        if (parts.length === 3) {
                            return new Date(parts[2], parts[1] - 1, parts[0]);
                        }
                        return data.dateOfBirth;
                    }
                },
                { dataField: "passPort", caption: "PassPort", width: columnWidth, visible: typeValue != "1" },
                { dataField: "identityCard", caption: "Identity Card", width: columnWidth, visible: typeValue != "1" },
                { dataField: "city", caption: "City", width: columnWidth },
                { dataField: "nationality", caption: "Nat", width: columnWidth - 60 },
                { dataField: "address", caption: "Address", width: columnWidth + 50 },
                { dataField: "handPhone", caption: "HandPhone", width: columnWidth },
                { dataField: "telephone", caption: "Telephone", width: columnWidth },
                { dataField: "email", caption: "Email", width: columnWidth },
                { dataField: "website", caption: "Website", width: columnWidth }
            ]);

            // 4. Thêm Tax Code phía sau nếu không phải Type 1
            if (typeValue !== "1") {
                columns.push(taxCodeColumn);
            }

            // 5. Ghép các cột thông tin doanh nghiệp và quản lý
            columns = columns.concat([
                { dataField: "fullAccount", caption: "Company", width: columnWidth },
                { dataField: "homeAddress", caption: "Business Address", width: columnWidth + 30 },
                { dataField: "arNo", caption: "ARNo", width: columnWidth, visible: typeValue == "1" },
                { dataField: "postalCode", caption: "Postal Code", width: columnWidth },
                { dataField: "keyword", caption: "Keyword", width: columnWidth },
                { dataField: "acctContact", caption: "Acct.Contact", width: columnWidth, visible: typeValue == "1" },
