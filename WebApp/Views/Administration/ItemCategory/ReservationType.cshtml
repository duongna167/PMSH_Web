<!-- Main Modal -->
<div class="modal fade" id="resT_mainModal" tabindex="-1" aria-labelledby="resT_mainModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="resT_mainModalLabel">Reservation Type</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <button id="resT_btnView" type="button" class="mui-button mui-button-new">View</button>
                        <button id="resT_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="resT_btnUpdate" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="resT_btnDelete" type="button" class="mui-button mui-button-delete">Delete</button>
                        <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal" aria-label="Close">Close</button>
                    </div>
                </div>

                <div class="mui-card mt-1">
                    <div id="resT_gridContainer" class="gridContainer"></div>
                </div>

                <div id="resT_loadingSpinner"
                     style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                     z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                     height: 100%;display: flex;align-items: center;justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="resT_itemModal" tabindex="-1" aria-labelledby="resT_itemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="resT_itemModalLabel">Reservation Type Configuration</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <button type="button" id="resT_btnSave" class="mui-button mui-button-new">Save</button>
                    <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>

                <form id="resT_formContainer">
                    <div class="row g-2 mt-1 mb-2">
                        <div class="col-12 col-lg-3">
                            <div class="row g-2">
                                <label for="resT_code" class="col-md-3 col-lg-5 col-form-label col-form-label-sm text-md-end">
                                    Res. Type <span class="text-danger">*</span>
                                </label>
                                <div class="col-md-9 col-lg-7">
                                    <input id="resT_code"
                                           name="resT_code"
                                           type="text"
                                           class="form-control form-control-sm"
                                           placeholder="Enter code..."
                                           required />
                                    <div class="invalid-feedback">Code is required.</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-7">
                            <div class="row g-2">
                                <label for="resT_name" class="col-md-2 col-lg-3 col-form-label col-form-label-sm text-md-end">
                                    Description <span class="text-danger">*</span>
                                </label>
                                <div class="col-md-10 col-lg-9">
                                    <textarea id="resT_name"
                                              name="resT_name"
                                              rows="4"
                                              class="form-control form-control-sm"
                                              style="height:100px"
                                              placeholder="Enter description..."
                                              required></textarea>
                                    <div class="invalid-feedback">Description is required.</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-2">
                            <div class="row g-2">
                                <label for="resT_seq" class="col-md-3 col-lg-5 col-form-label col-form-label-sm text-md-end">
                                    Seq.
                                </label>
                                <div class="col-md-9 col-lg-7">
                                    <input id="resT_seq"
                                           name="resT_seq"
                                           type="number"
                                           min="0"
                                           max="999"
                                           value="0"
                                           class="form-control form-control-sm text-center" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-2 mt-1 mb-2">
                        <div class="col-12">
                            <div class="row g-2">
                                <label class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Settings
                                </label>
                                <div class="col-md-10">
                                    <div class="row g-2">
                                        <div class="col-12 col-lg-4">
                                            <div class="form-check d-inline-flex align-items-center gap-2">
                                                <input type="checkbox"
                                                       id="resT_deduct"
                                                       name="resT_deduct" />
                                                <label for="resT_deduct" class="form-check-label">
                                                    Deduct Inventory
                                                </label>
                                            </div>
                                        </div>

                                        <div class="col-12 col-lg-4">
                                            <div class="form-check d-inline-flex align-items-center gap-2">
                                                <input type="checkbox"
                                                       id="resT_arrivalTimeRequired"
                                                       name="resT_arrivalTimeRequired" />
                                                <label for="resT_arrivalTimeRequired" class="form-check-label">
                                                    Arrival Time Required
                                                </label>
                                            </div>
                                        </div>

                                        <div class="col-12 col-lg-4">
                                            <div class="form-check d-inline-flex align-items-center gap-2">
                                                <input type="checkbox"
                                                       id="resT_creditCardRequired"
                                                       name="resT_creditCardRequired" />
                                                <label for="resT_creditCardRequired" class="form-check-label">
                                                    Credit Card Required
                                                </label>
                                            </div>
                                        </div>

                                        <div class="col-12 col-lg-4">
                                            <div class="form-check d-inline-flex align-items-center gap-2">
                                                <input type="checkbox"
                                                       id="resT_depositRequired"
                                                       name="resT_depositRequired" />
                                                <label for="resT_depositRequired" class="form-check-label">
                                                    Deposit Required
                                                </label>
                                            </div>
                                        </div>

                                        <div class="col-12 col-lg-4">
                                            <div class="form-check d-inline-flex align-items-center gap-2">
                                                <input type="checkbox"
                                                       id="resT_inactive"
                                                       name="resT_inactive" />
                                                <label for="resT_inactive" class="form-check-label text-danger">
                                                    Inactive
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="resT_id" name="resT_id" value="0" />
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    var resT_Module = (() => {
        let resT_selectedRowData = null;

        const resT_selectors = {
            mainModal: "#resT_mainModal",
            itemModal: "#resT_itemModal",
            form: "#resT_formContainer",
            grid: "#resT_gridContainer",
            loading: "#resT_loadingSpinner",

            btnView: "#resT_btnView",
            btnNew: "#resT_btnNew",
            btnUpdate: "#resT_btnUpdate",
            btnDelete: "#resT_btnDelete",
            btnSave: "#resT_btnSave",

            modalLabel: "#resT_itemModalLabel",

            id: "#resT_id",
            code: "#resT_code",
            name: "#resT_name",
            seq: "#resT_seq",
            deduct: "#resT_deduct",
            arrivalTimeRequired: "#resT_arrivalTimeRequired",
            creditCardRequired: "#resT_creditCardRequired",
            depositRequired: "#resT_depositRequired",
            inactive: "#resT_inactive"
        };

        function resT_init() {
            resT_bindEvents();
            resT_resetForm();
            resT_loadGrid([]);
            resT_reloadGrid();
        }

        function resT_bindEvents() {
            $(document)
                .off("input change", `${resT_selectors.form} input, ${resT_selectors.form} select, ${resT_selectors.form} textarea`)
                .on("input change", `${resT_selectors.form} input, ${resT_selectors.form} select, ${resT_selectors.form} textarea`, function () {
                    if ($(this).hasClass("is-invalid")) {
                        $(this).removeClass("is-invalid");
                        $(this).next(".invalid-feedback").text("");
                    }
                });

            $(resT_selectors.itemModal)
                .off("hidden.bs.modal")
                .on("hidden.bs.modal", function () {
                    applyValidationErrors([], resT_selectors.form);
                });

            $(document)
                .off("click", resT_selectors.btnView)
                .on("click", resT_selectors.btnView, function () {
                    resT_reloadGrid();
                });

            $(document)
                .off("click", resT_selectors.btnNew)
                .on("click", resT_selectors.btnNew, function () {
                    resT_openAddModal();
                });

            $(document)
                .off("click", resT_selectors.btnUpdate)
                .on("click", resT_selectors.btnUpdate, function () {
                    resT_openEditModal();
                });

            $(document)
                .off("click", resT_selectors.btnSave)
                .on("click", resT_selectors.btnSave, function () {
                    resT_save();
                });

            $(document)
                .off("click", resT_selectors.btnDelete)
                .on("click", resT_selectors.btnDelete, function () {
                    resT_delete();
                });
        }

        function resT_showLoading() {
            $(resT_selectors.loading).show();
        }

        function resT_hideLoading() {
            $(resT_selectors.loading).hide();
        }

        function resT_resetForm() {
            const resT_form = $(resT_selectors.form)[0];
            if (resT_form) {
                resT_form.reset();
            }

            $(resT_selectors.id).val("0");
            $(resT_selectors.seq).val(0);
            applyValidationErrors([], resT_selectors.form);

            const resT_formElement = $(resT_selectors.form);
            resT_formElement.find("[data-bs-toggle='tooltip']").tooltip("dispose");
        }

        function resT_clearForm() {
            const resT_form = $(resT_selectors.form);
            resT_form.find("input[type='text'], input[type='textarea']").val("");
            $(resT_selectors.seq).val(0);
            resT_form.find("input[type='checkbox']").prop("checked", false);
            resT_form.find("select").prop("selectedIndex", 0);
            applyValidationErrors([], resT_selectors.form);
            resT_form.find("[data-bs-toggle='tooltip']").tooltip("dispose");
        }

        function resT_openAddModal() {
            const resT_form = $(resT_selectors.form)[0];
            if (resT_form) {
                resT_form.reset();
            }

            $(resT_selectors.id).val("0");
            $(resT_selectors.modalLabel).text("Add Reservation Type");
            $(resT_selectors.itemModal).modal("show");
        }

        function resT_openEditModal() {
            if (!resT_selectedRowData) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }

            $(resT_selectors.modalLabel).text("Edit Reservation Type");
            $(resT_selectors.itemModal).modal("show");
            resT_fillForm(resT_selectedRowData);
        }

        function resT_fillForm(resT_data) {
            $(resT_selectors.id).val(resT_data.id);
            $(resT_selectors.code).val(resT_data.code);
            $(resT_selectors.name).val(resT_data.name);
            $(resT_selectors.seq).val(resT_data.sequence);
            $(resT_selectors.inactive).prop("checked", resT_data.inactive);
            $(resT_selectors.deduct).prop("checked", resT_data.deduct);
            $(resT_selectors.arrivalTimeRequired).prop("checked", resT_data.arrivalTimeRequired);
            $(resT_selectors.creditCardRequired).prop("checked", resT_data.creditCardRequired);
            $(resT_selectors.depositRequired).prop("checked", resT_data.depositRequired);
        }

        function resT_getSaveModel() {
            const resT_id = parseInt($(resT_selectors.id).val()) || 0;
            let resT_loginName = (localStorage.getItem("Loginname") || "")
                .trim()
                .replace(/^"(.*)"$/, "$1");
            const resT_loginUser = parseInt(localStorage.getItem("userID")) || 0;

            return {
                id: resT_id,
                code: $(resT_selectors.code).val().trim(),
                name: $(resT_selectors.name).val().trim(),
                sequence: parseInt($(resT_selectors.seq).val()) || 0,
                inactive: $(resT_selectors.inactive).prop("checked"),
                deduct: $(resT_selectors.deduct).prop("checked"),
                arrivalTimeRequired: $(resT_selectors.arrivalTimeRequired).prop("checked"),
                creditCardRequired: $(resT_selectors.creditCardRequired).prop("checked"),
                depositRequired: $(resT_selectors.depositRequired).prop("checked"),
                userInsertID: resT_loginUser,
                userUpdateID: resT_loginUser
            };
        }

        function dxBoolCell(container, options) {
            const checked = (options.value === true || options.value === "True");
            $("<div>")
                .dxCheckBox({
                    value: checked,
                    readOnly: true
                })
                .css("transform", "scale(0.8)")
                .appendTo(container);
        }

        function resT_loadGrid(resT_data) {
            const resT_dataSource = resT_data || [];

            $(resT_selectors.grid).dxDataGrid({
                dataSource: resT_dataSource,
                width: "100%",
                columnAutoWidth: false,
                allowColumnResizing: true,
                selection: { mode: "single" },
                hoverStateEnabled: true,
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "code", caption: "Res.Type", width: "150" },
                    { dataField: "name", caption: "Description", minWidth: 120, cssClass: "col-description" },
                    { dataField: "sequence", caption: "Seq.", width: "60" },
                    { dataField: "deduct", caption: "Ded.Inv", width: "60", dataType: "boolean", cellTemplate: dxBoolCell},
                    { dataField: "arrivalTimeRequired", caption: "Arr.Time", width: "60", dataType: "boolean", cellTemplate: dxBoolCell},
                    { dataField: "creditCardRequired", caption: "CC", width: "60", dataType: "boolean", cellTemplate: dxBoolCell},
                    { dataField: "depositRequired", caption: "Deposit", width: "60", dataType: "boolean", cellTemplate: dxBoolCell},
                    { dataField: "inactive", caption: "Inactive", width: "60", dataType: "boolean", cellTemplate: dxBoolCell}
                ],
                filterRow: { visible: true, applyFilter: "auto" },
                paging: { pageSize: 20 },
                pager: {
                    showPageSizeSelector: true,
                    visible: true,
                    allowedPageSizes: [20, 50, "all"],
                    showInfo: true,
                    showNavigationButtons: true
                },
                onSelectionChanged: function (e) {
                    resT_selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
                }
            });
        }

        function resT_reloadGrid() {
            resT_showLoading();

            $.ajax({
                url: "/Administration/GetReservationType",
                type: "GET",
                dataType: "json",
                cache: false,
                success: function (resT_data) {
                    resT_loadGrid(resT_data);
                },
                error: function () {
                    showToast("Error", "Load data failed", false);
                },
                complete: function () {
                    resT_hideLoading();
                }
            });
        }

        function resT_save() {
            const resT_model = resT_getSaveModel();

            $.ajax({
                url: "/Administration/ReservationTypeSave",
                type: "POST",
                cache: false,
                contentType: "application/json",
                data: JSON.stringify(resT_model),
                success: function (resT_res) {
                    if (resT_res.success) {
                        showToast("Success", resT_res.message, true);
                        resT_reloadGrid();
                        resT_clearForm();
                        $(resT_selectors.itemModal).modal("hide");
                    } else {
                        if (resT_res.errors && resT_res.errors.length > 0) {
                            applyValidationErrors(resT_res.errors, resT_selectors.form);
                            let resT_generalError = resT_res.errors.find(x => x.field === "general");
                            let resT_toastMessage = resT_generalError ? resT_generalError.message : "Please check input fields.";

                            showToast("Warning", resT_toastMessage, false);
                        } else {
                            showToast("Error", resT_res.message || "Save failed", false);
                        }
                    }
                },
                error: function () {
                    showToast("Error", "Save failed", false);
                }
            });
        }

        function resT_delete() {
            if (!resT_selectedRowData) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }

            if (!confirm("Are you sure you want to delete this template?")) {
                return;
            }

            $.ajax({
                url: `/Administration/DeleteReservationType/` + resT_selectedRowData.id,
                type: "POST",
                success: function (resT_res) {
                    if (resT_res.success) {
                        showToast("Success", "Deleted successfully", true);
                        resT_reloadGrid();
                        $("#btnCancel").trigger("click");
                    } else {
                        showToast("Error", resT_res.message, false);
                    }
                }
            });
        }

        return {
            init: resT_init,
            reloadGrid: resT_reloadGrid,
            openAddModal: resT_openAddModal,
            openEditModal: resT_openEditModal
        };
    })();

    window.openModalReservationType = function () {
        if (typeof resT_Module !== "undefined" && resT_Module.init) {
            resT_Module.init();
        }
    };
</script>