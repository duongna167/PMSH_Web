@using DevExpress.XtraReports.UI
@{
    ViewBag.Title = ViewBag.ReportHeader;
    var zoneList = ViewBag.ZoneList;
    var roomtypeList = ViewBag.RoomTypeList;
}


<style>
    .containerhs {
        display: flex;
        width: 100%;
        gap: 8px;
        justify-content: center;
        padding: 5px;
    }

    .column-left, .column-right {
        width: 50%;
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    fieldset {
        border: 1px solid #e0e0e0;
        border-radius: 4px;
        padding: 5px 10px 8px 10px;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
        margin-bottom: 0;
    }

    legend {
        font-weight: 600;
        font-size: 14px; 
        color: #333;
        padding: 0 5px;
        width: auto;
        float: none;
        margin-bottom: 2px;
    }

    .form-row {
        display: flex;
        align-items: center;
        margin-bottom: 3px;
        gap: 5px;
    }

        .form-row label {
            width: 150px; 
            font-size: 14px; 
            flex-shrink: 0;
            margin-bottom: 0;
            color: #444;
        }

        .form-row input, .form-row select {
            padding: 2px 6px;
            font-size: 14px;
            height: 28px; 
            border: 1px solid #ddd;
            border-radius: 3px;
        }

    .search-flex-container {
        display: flex;
        gap: 15px;
        align-items: flex-start;
    }

    .search-inputs {
        flex: 1.2;
        border-right: 1px solid #eee;
        padding-right: 10px;
    }

    .print-options-box {
        flex: 1;
    }

        .print-options-box label.title {
            font-weight: bold;
            font-size: 14px;
            display: block;
            margin-bottom: 4px;
        }

    .form-check {
        min-height: auto;
        margin-bottom: 2px;
        padding-left: 1.5em;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .form-check-input {
        margin: 0;
        width: 16px;
        height: 16px;
    }

    .form-check-label {
        font-size: 14px; /* Cỡ chữ 14px */
        cursor: pointer;
        line-height: 1;
    }

    /* Cấu trúc 3 cột input (Rooms/Persons/VIP) */
    .form-row.triple-input input {
        width: 80px !important; /* Tăng nhẹ để font 14px hiển thị đẹp */
        flex: 0 0 75px;
    }

    .header-row label {
        font-weight: bold;
        text-align: center;
        font-size: 14px;
    }

        .header-row label:first-child {
            width: 150px;
            text-align: left;
        }

        .header-row label:not(:first-child) {
            width: 75px;
            margin-right: 20px; /* Bù khoảng cách cho icon */
        }

    .ellipsis-icon {
        font-size: 12px;
        width: 20px;
        color: #888;
        cursor: pointer;
        text-align: center;
    }

    /* Trạng thái màu sắc (Giữ nguyên logic) */
    .status-box {
        text-align: center;
        font-weight: 600;
        color: white;
        border-radius: 4px;
        padding: 2px 0;
    }

    .green {
        background-color: #28a745;
    }

    .red {
        background-color: #dc3545;
    }

    .pink {
        background-color: #ff00ff;
    }

    .gray {
        background-color: #6c757d;
    }


</style>

<div class="modal fade" id="houseStatusModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable modal-full-height"> 
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">House Status</h5>
            </div>

            <div class="modal-body">
                <div class="d-flex justify-content-start mb-1 gap-2 py-1">
                    <button id="btnPrint" class="mui-button mui-button-new">View</button>
                    @* <button id="btnExecutePrint" class="mui-button mui-button-export">Print</button> *@
                    <button id="close" class="mui-button mui-button-new" onclick="window.location.href='/Home/Index'">Close</button>
                </div>

                <div class="containerhs">
                    <div class="column-left">
                        <fieldset>
                            <legend>Room Summary</legend>
                            <div class="form-row">
                                <label for="totalRoom">Total Physical Room:</label>
                                <input type="text" id="totalRoom" style="width: 80px;" disabled>
                            </div>
                            <div class="form-row">
                                <label for="outOfOrder">Out of Order:</label>
                                <input type="text" id="outOfOrder" style="width: 80px;" class="status-box pink" disabled>
                                <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                            </div>
                            <div class="form-row">
                                <label for="roomToSell">Total Room to Sell:</label>
                                <input type="text" id="roomToSell" style="width: 80px;" disabled>
                            </div>
                            <div class="form-row">
                                <label for="outOfService">Out of Service:</label>
                                <input type="text" id="outOfService" style="width: 80px;" class="status-box gray" disabled>
                                <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                            </div>
                        </fieldset>

                        <fieldset>
                            <legend>End of Day Projection</legend>
                            <div class="form-row header-row">
                                <label></label>
                                <label>Rooms</label>
                                <label>Persons</label>
                                <label>VIP</label>
                            </div>
                            <div class="form-row triple-input">
                                <label>Occupancy:</label>
                                <input id="occupancyRoom" type="text" disabled>
                                <input id="occupancyPersons" type="text" disabled>
                                <input id="occupancyvVip" type="text" disabled>
                            </div>
                            <div class="form-row">
                                <label>% Occupancy:</label>
                                <input id="occupancyPercent" type="text" style="width: 80px;" disabled>
                            </div>
                            <div class="form-row">
                                <label>Min Available Tonight:</label>
                                <input id="minAvail" type="text" style="width: 80px;" disabled>
                            </div>
                            <div class="form-row triple-input">
                                <label>Max Occ Tonight:</label>
                                <input id="maxaccRoom" type="text" disabled>
                                <input id="maxaccPerson" type="text" disabled>
                                <input id="maxaccVip" type="text" disabled>
                            </div>
                            <div class="form-row">
                                <label>Max % Occ Tonight:</label>
                                <input id="maxpercentonight" type="text" style="width: 80px;" disabled>
                            </div>
                            <div class="form-row triple-input">
                                <label>Individuals:</label>
                                <input id="individualsRoom" type="text" disabled>
                                <input id="individualsPerson" type="text" disabled>
                                <input id="individualsVip" type="text" disabled>
                            </div>
                            <div class="form-row triple-input">
                                <label>Groups:</label>
                                <input id="groupRoom" type="text" disabled>
                                <input id="groupPerson" type="text" disabled>
                                <input id="groupVip" type="text" disabled>
                            </div>
                            <div class="form-row triple-input">
                                <label>Comp and HU:</label>
                                <input id="compGroup" type="text" disabled>
                                <input id="compPerson" type="text" disabled>
                                <input id="compVip" type="text" disabled>
                            </div>
                            <div class="form-row">
                                <label>Room Revenue:</label>
                                <input id="roomRevennue" type="text" style="width: 120px;" disabled>
                                <label style="width:40px; text-align:center">AVG:</label>
                                <input id="roomAVG" type="text" style="width: 100px;" disabled>
                            </div>
                        </fieldset>

                        <fieldset>
                            <legend>Search</legend>
                            <div class="search-flex-container">
                                <div class="search-inputs">
                                    <div class="form-row">
                                        <label>Room Type:</label>
                                        <select id="roomtype" style="width: 100%;" class="tomselect-custom">
                                            <option value="">--ALL--</option>
                                            @foreach (var item in roomtypeList)
                                            {
                                                <option value="@item.ID">@item.Code</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-row">
                                        <label>Date:</label>
                                        <input type="date" style="width: 100%;" id="datebunisess">
                                    </div>
                                    <div class="form-row">
                                        <label>Zone:</label>
                                        <select id="zone" style="width: 100%;" class="tomselect-custom">
                                            @foreach (var item in zoneList)
                                            {
                                                <option value="@item.ID">@item.Code</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                @* <div class="print-options-box">
                                    <label class="fw-bold mb-2" style="font-size: 0.9rem;">Print Options</label>
                                    <div class="d-flex flex-column gap-2">
                                        <div class="form-check d-flex align-items-center gap-2">
                                            <input class="form-check-input" type="radio" name="printType" id="radioFast" checked style="margin:0">
                                            <label class="form-check-label small" for="radioFast" style="width:auto">Save File and Print</label>
                                        </div>
                                        <div class="form-check d-flex align-items-center gap-2">
                                            <input class="form-check-input" type="radio" name="printType" id="radioSave" style="margin:0">
                                            <label class="form-check-label small" for="radioSave" style="width:auto">Fast Print</label>
                                        </div>
                                    </div>
                                </div> *@
                            </div>
                        </fieldset>
                    </div>

                    <div class="column-right">
                        <fieldset>
                            <legend>Activity</legend>
                            <div class="form-row header-row">
                                <label></label>
                                <label>Rooms</label>
                                <label>Persons</label>
                                <label>VIP</label>
                            </div>
                            <div class="form-row triple-input">
                                <label>Stayovers</label>
                                <input id="stayoverRoom" type="text">
                                <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                                <input id="stayoverPerson" type="text">
                                <input id="stayoverVip" type="text">
                            </div>
                            <div class="form-row triple-input">
                                <label>Departures Expected</label>
                                <input id="depExpectedRoom" type="text" disabled>
                                <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                                <input id="depExpectedPerson" type="text" disabled>
                                <input id="depExpectedVip" type="text" disabled>
                            </div>
                            <div class="form-row triple-input">
                                <label>Arrival Expected</label>
                                <input id="arrivalExpectedRoom" type="text" disabled>
                                <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                                <input id="arrivalExpectedPerson" type="text" disabled>
                                <input id="arrivalExpectedVip" type="text" disabled>
                            </div>
                            <div class="form-row triple-input">
                                <label>Extended Stays</label>
                                <input id="extendedStaysRoom" type="text" disabled>
                                <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                                <input id="extendedStaysPerson" type="text" disabled>
                                <input id="extendedStaysVip" type="text" disabled>
                            </div>
                            <div class="form-row triple-input">
                                <label>Day Use Rooms</label>
                                <input id="dayUseRoom" type="text" disabled>
                                <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                                <input id="dayUsePerson" type="text" disabled>
                                <input id="dayUseVip" type="text" disabled>
                            </div>
                            <div class="form-row triple-input">
                                <label>Walk In</label>
                                <input id="walkinRoom" type="text" disabled>
                                <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                                <input id="walkinPerson" type="text" disabled>
                                <input id="walkinVip" type="text" disabled>
                            </div>
                        </fieldset>

                        <fieldset>
                            <legend>House Keeping Room Status</legend>
                            <div class="form-row header-row">
                                <label></label>
                                <label>Vacant</label>
                                <label>Occupied</label>
                                <label>Total</label>
                            </div>
                            <div class="form-row triple-input">
                                <label>Clean</label>
                                <input id="cleanVacant" class="green" disabled>
                                <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                                <input id="cleanOccupied" class="green" disabled>
                                <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                                <input id="cleanTotal" disabled>
                            </div>
                            <div class="form-row triple-input">
                                <label>Dirty</label>
                                <input id="dirtyVacant" class="red" disabled>
                                <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                                <input id="dirtyOccupied" class="red" disabled>
                                <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                                <input id="dirtyTotal" disabled>
                            </div>
                            <div class="form-row triple-input">
                                <label>Due Out</label>
                                <input id="doeoutOccupied" disabled>
                                <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                                <span style="background:#f9f9f9; border:1px solid #ddd; border-radius:4px"></span>

                            </div>
                            <div class="form-row triple-input" style="border-top: 1px solid #eee; padding-top: 5px;">
                                <label>Total</label>
                                <input id="totalVacant" disabled>
                                <i class="ellipsis-icon"></i>
                                <input id="totalOccupied" disabled>
                                <i class="ellipsis-icon"></i>
                                <span></span>
                            </div>
                            <div class="form-row">
                                <label>Out of Order</label>
                                <input id="outoforderVacant" class="pink" style="width: 80px;" disabled>
                                <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                            </div>
                            <div class="form-row triple-input">
                                <label>Out of Service</label>
                                <input id="outofserviveVacant" class="gray" disabled>
                                <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                                <input id="outofserviveOccupied" class="gray" disabled>
                                <i class="fas fa-ellipsis-h ellipsis-icon"></i>
                            </div>
                        </fieldset>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="popupLogGrid" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Detail House Status</h5>

            </div>

            <div class="modal-body">

                <!-- Action buttons -->
                <div class="d-flex justify-content-start mb-3 gap-2">
                    <button id="btnExportExcel"
                            class="mui-button mui-button-new"
                            type="button">
                        Excel
                    </button>

                    <button class="mui-button mui-button-close"
                            data-bs-dismiss="modal">
                        Close
                    </button>
                </div>
                <div id="logGridContainer" class="gridContainer"></div>

            </div>

        </div>
    </div>
</div>


