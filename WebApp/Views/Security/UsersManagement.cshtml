                    </div>

                    <div class="row mb-2">
                        <div class="col-md-6">
                            <label class="form-label">Name:</label>
                            <input id="username"
                                   type="text"
                                   class="form-control form-control-sm"
                                   placeholder="Enter user name">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Point:</label>
