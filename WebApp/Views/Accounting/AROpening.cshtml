@using DevExpress.XtraReports.UI

@{
    var selectedReport = ViewBag.ReportHeader;
    var currencylist = ViewBag.CurrencyList;
}

<div class="modal fade" id="ar_opening_modal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-4by3">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">AR - Balance brought forward</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <button id="ar_opening_btnPrint" class="mui-button mui-button-search">View</button>
                    <button id="ar_opening_btnExportExcel" class="mui-button mui-button-export" type="button">Excel</button>
                    <button class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                </div>

                <div class="mui-card mt-1">
                    <div id="ar_opening_gridContainer" class="gridContainer"></div>
                    <div id="ar_opening_loadingSpinner"
                        style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                        z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                        height: 100%;display: flex;align-items: center;justify-content: center;">
                        <div class="spinner-border text-primary"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    var ar_opening_Module = {
        editingRowKey: null,
        selectedRowData: null,
        currencyList: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.CurrencyList ?? new List<object>())),

        init: function () {
            this.initEvents();
            this.initDOMEvents();
        },

        initEvents: function () {
            window.openModalAROpening = () => {
                $('#ar_opening_modal').modal('show');
                this.reloadData();
            };
        },

        initDOMEvents: function () {
            $("#ar_opening_btnPrint").on("click", () => this.reloadData());
            $("#ar_opening_btnExportExcel").on("click", () => this.exportExcel());

            // Reset khi đóng modal
            $('#ar_opening_modal').on('hidden.bs.modal', () => {
                this.selectedRowData = null;
            });
        },

        sortObjectKeysAlphabetically: function (dataArray) {
            return dataArray.map(obj => {
                const newObj = {};
                Object.keys(obj)
                    .sort((a, b) => a.localeCompare(b))
                    .forEach(key => {
                        const newKey = key.charAt(0).toLowerCase() + key.slice(1);
                        newObj[newKey] = obj[key];
                    });
                return newObj;
            });
        },

        reloadData: function () {
            $("#ar_opening_loadingSpinner").show();
            $.ajax({
                url: '/Accounting/AROpeningData',
                type: 'GET',
                headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() },
                success: (result) => {
                    if (result) {
                        const sortedKeysData = this.sortObjectKeysAlphabetically(result);

                        const dataWithTempKey = sortedKeysData.map((item, index) => ({
                            ...item,
                            __rowKey: item.id ?? `tmp_${index}_${Date.now()}`
                        }));

                        const sortedByAccountName = sortedKeysData.sort((a, b) =>
                            (a.accountName || "").localeCompare(b.accountName || "")
                        );
                        this.initializeGrid(dataWithTempKey);
                    }
                    $("#ar_opening_loadingSpinner").hide();
                },
                error: () => {
                    showToast('Error', "Không thể tải báo cáo.", false);
                    $("#ar_opening_loadingSpinner").hide();
                }
            });
        },

        initializeGrid: function (data) {
            const self = this;
            $("#ar_opening_gridContainer").dxDataGrid({
                dataSource: data,
                height: "100%",
                width: "100%",
                showBorders: true,
                keyExpr: "__rowKey",
                editing: { mode: "row", allowUpdating: true, },
                toolbar: {
                    visible: false
                },
                hoverStateEnabled: true,
                allowColumnResizing: true,
                columnResizingMode: "widget",
                columnAutoWidth: true,
                scrolling: {
                    mode: "standard",
                    showScrollbar: "always",
                    useNative: true
                },
                paging: { pageSize: 25 },
                pager: {
                    visible: true,
                    allowedPageSizes: [25, 50, 100],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: { visible: true, applyFilter: "auto" },
                columns: [
                    {
                        type: "buttons",
                        caption: "Action",
                        width: 80,
                        buttons: [
                            {
                                name: "edit",
                                onClick: (e) => {
                                    const grid = $("#ar_opening_gridContainer").dxDataGrid("instance");

                                    // lưu row hiện tại nếu bạn vẫn muốn giữ biến này

                                    // mở edit mode cho row đó
                                    grid.editRow(e.row.rowIndex);

                                    // chặn hành vi mặc định nếu cần
                                    e.event.preventDefault();
                                }
                            }
                        ]
                    },
                    { dataField: "id", visible: false },
                    { dataField: "accountName", caption: "Account Name", width: 200, allowEditing: false },
                    { dataField: "city", caption: "City", width: "80", allowEditing: false },
                    { dataField: "balance", caption: "Balance", width: "80",dataType: "number" ,format: "#,##0.##", allowEditing: true },
                    {
                        dataField: "currencyID",
                        caption: "Currency",
                        width: "100",
                        allowEditing: true,
                        lookup: {
                            dataSource: this.currencyList,
                            valueExpr: "ID",
                            displayExpr: "ID"
                        },
                        setCellValue: function (rowData, value) {
                            rowData.currencyID = value || null;
                            if (self.selectedRowData && self.selectedRowData.id === rowData.id) {
                                self.selectedRowData.currencyID = value || null;
                            }
                        }
                    },
                    { dataField: "contactName", caption: "Contact Name", width: "150", allowEditing: false },
                    { dataField: "type", caption: "Type", width: "70", allowEditing: false },
                    { dataField: "accountNo", caption: "Account No", width: "100", allowEditing: false },
                    { dataField: "createdBy", caption: "Created By", width: "80", allowEditing: false },
                    { dataField: "createdDate", caption: "Created Date", width: "100", dataType: "date", format: "dd/MM/yyyy", allowEditing: false },
                    { dataField: "updatedBy", caption: "Updated By", width: "80", allowEditing: false },
                    { dataField: "updatedDate", caption: "Updated Date", width: "100", dataType: "date", format: "dd/MM/yyyy", allowEditing: false },
                    { dataField: "arid", caption: "ARID", width: "50", allowEditing: false }
                ],
                onEditingStart: function (e) {
                    self.editingRowKey = e.key;                    
                },
                onSaving: function (e) {
                    // có thay đổi thì mới xử lý
                    if (!e.changes || !e.changes.length) return;

                    // chặn save mặc định của DevExtreme
                    e.cancel = true;

                    // gọi hàm save riêng của bạn
                    self.saveData();
                }
            });
        },

       saveData: function () {
            const grid = $("#ar_opening_gridContainer").dxDataGrid("instance");
            if (!grid) {
                showToast("Warning", "Grid not found.", false);
                return;
            }

            const visibleRows = grid.getVisibleRows();
            const editingRow = visibleRows.find(r => r.isEditing);

            if (!editingRow) {
                showToast("Warning", "Please click Edit on 1 row first.", false);
                return;
            }

            // lấy dữ liệu row hiện tại
            const rowData = { ...editingRow.data };

            // lấy các thay đổi chưa commit trong editor
            const editData = grid.option("editing.changes") || [];
            const currentChange = editData.find(c => c.type === "update" && c.key === editingRow.key);

            if (currentChange && currentChange.data) {
                Object.assign(rowData, currentChange.data);
            }

            const dataPost = {
                ...rowData,
                user: localStorage.getItem("Loginname")
            };
            if(dataPost.currencyID == null){
                showToast("Warning", "Currency must be selected!", false);
                return;
            }
            

            $("#ar_opening_loadingSpinner").show();

            $.ajax({
                url: '/Accounting/AROpeningSave',
                type: 'POST',
                data: dataPost,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val()
                },
                success: (result) => {
                    if (result.success) {
                        showToast('Success', result.message, true);
                        grid.cancelEditData();
                        this.reloadData();
                    } else {
                        showToast('Error', result.message || 'Save failed.', false);
                    }
                    $("#ar_opening_loadingSpinner").hide();
                },
                error: () => {
                    showToast('Error', "Lỗi hệ thống khi lưu.", false);
                    $("#ar_opening_loadingSpinner").hide();
                }
            });
        },

        exportExcel: function () {
            const grid = $("#ar_opening_gridContainer").dxDataGrid("instance");
            if (!grid) {
                showToast("Warning", "No data to export!", false);
                return;
            }
            const workbook = new ExcelJS.Workbook();
            const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const worksheet = workbook.addWorksheet("Sheet 1");

            // === Dòng 1: Tên công ty (merge theo 4 cột) ===
            worksheet.addRow([companyName]);
            worksheet.mergeCells('A1:D1');
            worksheet.getRow(1).font = { bold: true };
            worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

            // === Dòng 2: Ngày giờ xuất (Sửa lỗi hiển thị ở đây) ===
            const now = new Date();
            const exportDateStr = "Export Date: " + now.toLocaleString("vi-VN");
            const row2 = worksheet.getRow(2);
            row2.getCell(1).value = exportDateStr; // Gán vào ô đầu tiên của vùng merge (A2)
            worksheet.mergeCells('A2:D2');
            row2.alignment = { vertical: 'middle', horizontal: 'left' };
            row2.font = { italic: true };

            // === Dòng 3–4: trống
            worksheet.addRow([]);
            worksheet.addRow([]);

            // === Dòng 5: Tiêu đề báo cáo (ở giữa) ===
            const reportRow = worksheet.addRow(['AR - Balance brought forward']);
            worksheet.mergeCells('A5:D5');
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

            // === Dòng 6: trống
            worksheet.addRow([]);

            // === Xuất dữ liệu grid bắt đầu từ dòng 7 ===
            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                // Footer (sau cùng)
                const lastRow = worksheet.lastRow.number + 2;
                worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
                worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
                worksheet.getCell(`A${lastRow}`).font = { italic: true };

                // Ghi file
                let fileName = "AROpeningBalance.xlsx";
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
                });
            });
        },

    };

    $(document).ready(function () {
        ar_opening_Module.init();
        // Tự động View khi sẵn sàng (nếu modal mở sẵn)
        if ($('#ar_opening_modal').hasClass('show')) {
            ar_opening_Module.reloadData();
        }
    });
</script>
