@using DevExpress.XtraReports.UI

<!-- =========================
     BS5 MODAL (MAIN VIEW)
     Prefix = arpr_ 
     ========================= -->
<div class="modal fade" id="arpr_modal" tabindex="-1" aria-labelledby="arpr_modalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable modal-dialog-centered modal-4by3">
        <div class="modal-content">

            <div class="modal-header py-2">
                <h5 class="modal-title" id="arpr_modalLabel">AR Payment Report</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">

                    <div class="mt-2">
                        <button id="arpr_btnPrint" class="mui-button mui-button-new">View</button>
                        <button id="arpr_btnExportExcel" class="mui-button mui-button-new" type="button">Excel</button>
                        <button class="mui-button mui-button-new" data-bs-dismiss="modal" aria-label="Close">Close</button>

                    </div>

                    <div class="mt-2">
                        <div class="row g-2 px-1 align-items-center">

                            <!-- From -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2 col-xl-2">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 fw-bold mb-0 text-nowrap text-md-end">
                                        From Date:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <div data-date-input data-format="DD/MM/YYYY" data-name="arpr_fromDate" business-date>
                                            <input type="text"
                                                   id="arpr_ShowfromDate"
                                                   name="arpr_ShowfromDate"
                                                   class="date-ui form-control form-control-sm"
                                                   autocomplete="off"  />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- To -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2 col-xl-2">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 fw-bold mb-0 text-nowrap text-md-end">
                                        To Date:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <div data-date-input data-format="DD/MM/YYYY" data-name="arpr_toDate" business-date>
                                            <input type="text"
                                                   id="arpr_ShowtoDate"
                                                   name="arpr_ShowtoDate"
                                                   class="date-ui form-control form-control-sm"
                                                   autocomplete="off"  />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- AR No -->
                            <div class="col-12 col-sm-6 col-md-3 col-lg-2 col-xl-2">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 fw-bold mb-0 text-nowrap text-md-end">
                                        AR No:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <input type="text"
                                               id="arpr_aRNo"
                                               name="arpr_aRNo"
                                               class="form-control form-control-sm"
                                               placeholder="Enter AR No..." />
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Cashier -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl-3">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 fw-bold mb-0 text-nowrap text-md-end">
                                        Cashier:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <select id="arpr_cashier" name="arpr_cashier" class="tomselect-custom w-100" placeholder="Select zones...">
                                             <option value=""></option>
                                            @foreach (var sg in ViewBag.ListUsers)
                                            {
                                                <option value="@sg.ID">@sg.LoginName</option>
                                            }
                                            
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- View -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl-3">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 fw-bold mb-0 text-nowrap text-md-end">
                                        View By:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <select id="arpr_viewBy" name="arpr_viewBy" class="form-select form-select-sm">
                                            <option value="0">By Cashier Payment</option>
                                            <option value="1">By Payment Apply Invoice</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="mui-card">
                    <div class="gridContainer mt-2" id="arpr_gridContainer"></div>
                </div>

                <div id="arpr_loadingSpinner"
                     style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:1000;">
                    <i class="fa-solid fa-spinner fa-spin"></i>
                </div>

            </div>

        </div>
    </div>
</div>

<script>
    var arpr_Module = {

        gridInstance: null,

        init: function () {
            this.getBusinessDate();
            initTomSelect("#arpr_cashier");
            this.loadByCashierPayment();
            this.bindEvents();
        },

        destroy: function () {

            // Dispose DevExtreme grid
            try {
                if (this.gridInstance) {
                    this.gridInstance.dispose();
                }
            } catch (e) { }

            // Empty grid container
            try {
                $("#arpr_gridContainer").empty();
            } catch (e) { }

            // Null refs
            this.gridInstance = null;
        },

        getBusinessDate: function () {
            return $.ajax({
                url: '/Reservation/GetBusinessDate',
                type: 'get',
                dataType: 'json',
                crossDomain: false,
                headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
                success: function (result) {

                    // Gán vào input type="date"
                    $('#arpr_fromDate').val(result.split('T')[0]);
                    $('#arpr_toDate').val(result.split('T')[0]);

                },
                error: function (xhr, statusText, err) {
                    if (xhr.status == 401) {
                        sessionTimeout();
                    }
                }
            });
        },

        loadByCashierPayment: function (data) {
            $("#arpr_gridContainer").dxDataGrid({
                dataSource: data,
                columnAutoWidth: false, // Tắt tự động để các giá trị px bên dưới có hiệu lực
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                columns: [
                    { dataField: "AccountNo", caption: "AR No", width: 120 },
                    { dataField: "AccountName", caption: "Account Name", width: 180 },
                    { dataField: "TransactionCode", caption: "Trans. Code", width: 80,},
                    { dataField: "Description", caption: "Description", width: 250 },
                    { 
                        dataField: "TransactionDate", 
                        caption: "Trans. Date", 
                        dataType: "datetime", 
                        format: "dd/MM/yyyy HH:mm:ss",
                        width: 160 
                    },
                    { dataField: "UserName", caption: "Cashier", width: 100 },
                    { 
                        dataField: "AmountPaidVND", 
                        caption: "Amount (VND)", 
                        dataType: "number",
                        format: "#,##0",
                        width: 130,
                        // Nếu dữ liệu trả về là chuỗi "1200000,00", cần parse sang số:
                        calculateCellValue: function(data) {
                            return data.AmountPaidVND ? parseFloat(data.AmountPaidVND.replace(',', '.')) : 0;
                        }
                    },
                    { 
                        dataField: "AmountPaidUSD", 
                        caption: "Amount (USD)", 
                        dataType: "number",
                        format: "#,##0",
                        width: 110,
                        calculateCellValue: function(data) {
                            return data.AmountPaidUSD ? parseFloat(data.AmountPaidUSD.replace(',', '.')) : 0;
                        }
                    }
                ],                
                scrolling: {
                    mode: "standard",
                    showScrollbar: "always", // Luôn hiện thanh cuộn để user biết là có thể kéo ngang
                    scrollByContent: true,
                    useNative: true // Giúp thanh cuộn mượt hơn trên một số trình duyệt
                },
                paging: {
                    pageSize: 20
                },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 40, 'all'],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: {
                    visible: true,
                    applyFilter: "auto"
                },
                showBorders: true,
                wordWrapEnabled: false // Giữ dữ liệu trên một dòng để trigger scroll ngang tốt hơn
            });


            this.gridInstance = $("#arpr_gridContainer").dxDataGrid("instance");
        },
        loadByPaymentApplyInvoice: function (data) {
            $("#arpr_gridContainer").dxDataGrid({
                dataSource: data,
                height: "100%",
                width: "100%",
                columnAutoWidth: false,
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                grouping: {
                    autoExpandAll: true,
                },
                remoteOperations: false,
                columns: [
                    { 
                        dataField: "FullAccount", 
                        caption: "Account Information", 
                        width: 300,
                        groupIndex: 0,
                    },
                    { dataField: "AccountNo", caption: "Acct No.", width: 120 },
                    { dataField: "AccountName", caption: "Account Name", width: 200 },
                    { dataField: "TransactionCode", caption: "Code", width: 80, alignment: "center" },
                    { dataField: "Description", caption: "Description", width: 220 },
                    
                    { 
                        dataField: "TransactionDate", 
                        caption: "Date", 
                        dataType: "datetime", 
                        format: "dd/MM/yyyy HH:mm:ss", 
                        width: 160,
                        alignment: "center"
                    },
                    { 
                        dataField: "Amount", 
                        caption: "Total Amount", 
                        dataType: "number", 
                        format: "#,##0.00", 
                        width: 130,
                        alignment: "right",
                        calculateCellValue: function(data) {
                            return data.Amount ? parseFloat(data.Amount.replace(',', '.')) : 0;
                        }
                    },
                    { 
                        dataField: "AmountPaid", 
                        caption: "Paid", 
                        dataType: "number", 
                        format: "#,##0.00", 
                        width: 130,
                        alignment: "right",
                        calculateCellValue: function(data) {
                            return data.AmountPaid ? parseFloat(data.AmountPaid.replace(',', '.')) : 0;
                        }
                    },
                    { dataField: "CurrencyID", caption: "Curr", width: 70, alignment: "center" },
                    { dataField: "UserName", caption: "User", width: 100 },
                    { dataField: "FolioID", caption: "Folio", width: 80, alignment: "center" }
                ],
                scrolling: {
                    mode: "standard",
                    showScrollbar: "always",
                    scrollByContent: true,
                    useNative: false
                },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 40, 'all'],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: {
                    visible: true,
                    applyFilter: "auto"
                },
                showBorders: true,
                wordWrapEnabled: false
            });

            this.gridInstance = $("#arpr_gridContainer").dxDataGrid("instance");
        },

        bindEvents: function () {
            const self = this;

            $("#arpr_aRNo").off("input").on("input", function () {
                const value = $(this).val();
                const grid = $("#arpr_gridContainer").dxDataGrid("instance");

                grid.filter([
                    ["toPhoneNo", "contains", value]  // lọc theo cột telephone
                ]);
            });

            $(document).off("click", "#arpr_btnPrint").on("click", "#arpr_btnPrint", function () {
                $("#arpr_loadingSpinner").show();
                   const viewByUI = $("#arpr_viewBy").val();


                $.ajax({
                    url: '/Accounting/GETARPaymentReport',
                    type: 'GET',
                    data: {
                        fromDate: $("#arpr_fromDate").val(),
                        toDate: $("#arpr_toDate").val(),
                        accountNo: $("#arpr_aRNo").val(),
                        viewBy: viewByUI,
                        cashier: $("#arpr_cashier").val(),
                    },
                    success: function (data) {                        
                        if(viewByUI === "1"){
                            self.loadByPaymentApplyInvoice(data);
                        }
                        else{
                            self.loadByCashierPayment(data);
                        }
                        $("#arpr_loadingSpinner").hide();
                    },
                    error: function () {
                        alert("Không thể tải dữ liệu");
                        $("#arpr_loadingSpinner").hide();
                    },
                    complete: function(){
                        $("#arpr_loadingSpinner").hide();
                    }
                });
            });


            $("#arpr_viewBy").on("change", function () {
                const viewBy = $(this).val(); // "0" hoặc "1"

                // Nếu grid cũ đã tồn tại thì destroy trước khi render grid mới
                const $grid = $("#arpr_gridContainer");
                const gridInstance = $grid.dxDataGrid("instance");
                if (gridInstance) {
                    gridInstance.dispose();
                    $grid.empty();
                }

                if (viewBy === "0") {
                    // dataCashierPayment: dữ liệu cho grid By Cashier Payment
                    self.loadByCashierPayment(self.dataCashierPayment || []);
                } else if (viewBy === "1") {
                    // dataPaymentApplyInvoice: dữ liệu cho grid By Payment Apply Invoice
                    self.loadByPaymentApplyInvoice(self.dataPaymentApplyInvoice || []);
                }
            });
                
            $("#arpr_btnExportExcel").off("click").on("click", function () {
                const grid = $("#arpr_gridContainer").dxDataGrid("instance");   // 🔥 khai báo grid

                const workbook = new ExcelJS.Workbook();
                const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
                const worksheet = workbook.addWorksheet("Sheet 1");

                // === Dòng 1: Tên công ty (merge theo 4 cột) ===
                worksheet.addRow([companyName]);
                worksheet.mergeCells('A1:D1');
                worksheet.getRow(1).font = { bold: true };
                worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

                // === Dòng 2: Ngày giờ xuất (bên phải) ===
                const now = new Date();
                const exportDate = now.toLocaleString("vi-VN");
                worksheet.addRow(['', '', '', exportDate]);
                worksheet.mergeCells('D2:D2');  // cột D thôi
                worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

                // === Dòng 3–4: trống
                worksheet.addRow([]);
                worksheet.addRow([]);

                // === Dòng 5: Tiêu đề báo cáo (ở giữa) ===
                const reportRow = worksheet.addRow(['AR Payment Report']);
                worksheet.mergeCells('A5:D5');
                reportRow.font = { bold: true, size: 14 };
                reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

                // === Dòng 6: trống
                worksheet.addRow([]);

                // === Xuất dữ liệu grid bắt đầu từ dòng 7 ===
                DevExpress.excelExporter.exportDataGrid({
                    component: grid,
                    worksheet: worksheet,
                    autoFilterEnabled: true,
                    topLeftCell: { row: 7, column: 1 }
                }).then(function () {
                    // Footer (sau cùng)
                    const lastRow = worksheet.lastRow.number + 2;
                    worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
                    worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
                    worksheet.getCell(`A${lastRow}`).font = { italic: true };

                    // Ghi file
                    let fileName = "AR Payment Report.xlsx";

                    workbook.xlsx.writeBuffer().then(function (buffer) {
                        saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
                    });
                });
            });
        },
    };

    // Global entry points
    window.openModalarpr = function () {
        arpr_Module.init();
        $("#arpr_modal").modal("show");
    };

    // Automatic cleanup: ANY modal with ID starting with arpr_
    $(document).off("hidden.bs.modal.arpr_cleanup").on("hidden.bs.modal.arpr_cleanup", ".modal[id^='arpr_']", function () {
        arpr_Module.destroy();
    });
</script>
