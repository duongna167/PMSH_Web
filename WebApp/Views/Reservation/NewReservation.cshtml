@* <link href="~/css/pages/reservation.css" rel="stylesheet" asp-append-version="true"/> *@
<style>
    .form-control:not([readonly]):not(:disabled) {
        background: white !important;
    }

    .rate-currency-row .row {
        align-items: center;
    }

    .new-reservation-layout {
        background: transparent;
        border: 0;
        border-radius: 0;
        padding: .25rem 0;
    }

    .reservation-column {
        display: flex;
        flex-direction: column;
        gap: .35rem;
    }

    .reservation-panel {
        background: transparent;
        border: 0;
        border-radius: 0;
        padding: .1rem .35rem;
        overflow: visible;
    }

    .reservation-panel-top {
        min-height: 0;
    }

    .reservation-panel-bottom {
        min-height: 0;
        border-top: 1px solid #d9d9d9;
        margin-top: .15rem;
        padding-top: .55rem;
        padding-bottom: .35rem;
    }

    .reservation-panel-title {
        display: none;
    }

    .reservation-panel .section-new-reservation {
        margin: 0 !important;
    }

    .reservation-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        margin: .25rem 0 .5rem;
        color: #8b0000;
        font-weight: 700;
    }

    .reservation-divider::before,
    .reservation-divider::after {
        content: "";
        flex: 1;
        border-top: 1px solid #d7d7d7;
    }

    .reservation-divider span {
        padding: 0 .75rem;
        white-space: nowrap;
    }

    .reservation-column.border-end {
        border-color: #e5e7eb !important;
    }

    .container-new-reservation {
        padding-bottom: .15rem;
    }

    .form-grid-new-reservation.row {
        margin-left: 0 !important;
        margin-right: 0 !important;
    }


    .input-with-button {
        width: 100%;
        margin-left: 0 !important;
        margin-right: 0 !important;
    }

    .input-with-button > [class*='col-'] {
        min-width: 0;
    }

    .input-with-button .d-flex {
        width: 100%;
        min-width: 0;
    }

    .input-with-button .col-form-label {
        padding-top: .15rem;
        padding-bottom: .15rem;
        line-height: 1.2;
        font-size: .9rem;
    }

    .input-with-button .form-control,
    .input-with-button select,
    .input-with-button textarea {
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
    }

    .input-with-button .btn-search-icon,
    .input-with-button .btn-clear {
        flex: 0 0 auto;
    }

    #txtAddress {
        max-width: 95%;
    }

    .reservation-audit {
        margin-top: .45rem;
        padding: .55rem .35rem 0;
        border-top: 1px solid #d9d9d9;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        row-gap: .15rem;
        column-gap: .5rem;
        font-size: .82rem;
    }

    .reservation-audit span {
        white-space: normal;
        line-height: 1.25;
    }

    #actionButtonsContainer {
        position: static !important;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: .35rem;
        width: 100%;
        clear: both;
        margin-top: .35rem;
        padding: .35rem 0 !important;
        border-top: 1px solid #e5e7eb;
    }

    #actionButtonsContainer .mui-button-new {
        margin: 0 !important;
    }

    .new-reservation-checks {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .25rem .75rem;
        margin-top: .4rem !important;
        margin-bottom: .35rem;
    }

    .new-reservation-checks .form-check {
        display: flex;
        align-items: center;
        gap: .25rem;
        min-height: 24px;
        margin: 0;
    }

    .new-reservation-checks .form-check-label {
        font-size: .82rem;
        line-height: 1.1;
        color: #4b5563;
    }

    .new-reservation-checks input[type='checkbox'] {
        width: 14px;
        height: 14px;
        margin: 0;
    }

    .specials-section-new-reservation {
        min-height: 80px;
    }
</style>
<div>
    <div class="row">
        <div class="col-md-12">
            <div class="content-right">

                <!-- ACTION TOP -->
                <div class="mt-2">
                    <button class="mui-button mui-button-new" onclick="OkReservation(0)">Save</button>
                    <button class="mui-button mui-button-new" onclick="openModalOption();" id="btnOption">
                        Option
                    </button>
                    <button class="mui-button mui-button-new" onclick="openModalMoreFields();" id="btnOption">
                        More
                        fields
                    </button>
                    <button class="mui-button mui-button-new" onclick="resetForm()" id="btnClear">Clear</button>
                    <button class="mui-button mui-button-new" onclick="closeForm()">
                        Close
                    </button>
                </div>

                <div id="partial-content">
                    <div class="container-new-reservation mt-1 new-reservation-layout">

                        <!-- ROW CHA -->
                        <div class="row g-0">

                            <!-- COL 1 -->
                            <div class="col-12 col-lg-4 col-xl-4 pe-lg-2 border-end reservation-column">

                                <!-- bọc toàn bộ phần Guest + Stay của bạn -->
                                <div class="d-flex flex-column" style="height: auto;">

                                    <!-- Guest Profile -->
                                    <div class="px-1 py-1 reservation-panel reservation-panel-top">
                                        <div class="reservation-panel-title">Guest Information</div>
                                        <div class="section-new-reservation">
                                            <div class="form-grid-new-reservation row">
                                                <!-- Name -->
                                                <div class="form-group-new-reservation col-12">
                                                    <div class="input-with-button row g-0 align-items-start">
                                                        <label class="col-md-4 col-form-label text-start pe-0">
                                                            Name <span style="color:red">*</span>
                                                        </label>
                                                        <div class="col-md-7">
                                                            <div class="d-flex align-items-center">
                                                                <input type="text" id="txtName"
                                                                       class="form-control me-1"
                                                                       autocomplete="off"
                                                                       data-tooltip="Name format: Last name, First name (optional middle). Example: Smith, John Paul"
                                                                       aria-invalid="false" />
                                                                <button type="button" onclick="openProSearchForNewReservation()"
                                                                        class="btn-search-icon">
                                                                    <i class="fa-solid fa-arrow-down"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- First Name -->
                                                <div class="form-group-new-reservation col-12">
                                                    <div class="input-with-button row g-0 align-items-start">
                                                        <label class="col-md-4 col-form-label text-start pe-0"
                                                               for="txtFirstName">First Name</label>
                                                        <div class="col-md-7">
                                                            <input type="text" id="txtFirstName" class="form-control"
                                                                   readonly />
                                                        </div>
                                                    </div>
                                                </div>



                                                <!-- Identity Card -->
                                                <div class="form-group-new-reservation col-12">
                                                    <div class="input-with-button row g-0 align-items-start">
                                                        <label class="col-md-4 col-form-label text-start pe-0"
                                                               for="txtIdentityCard">ID.Card</label>
                                                        <div class="col-md-7">
                                                            <input type="text" id="txtIdentityCard"
                                                                   class="form-control" />
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Email -->
                                                <div class="form-group-new-reservation col-12">
                                                    <div class="input-with-button row g-0 align-items-start">
                                                        <label class="col-md-4 col-form-label text-start pe-0"
                                                               for="txtEmail">Email</label>
                                                        <div class="col-md-7">
                                                            <input type="email" id="txtEmail" class="form-control" />
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Title -->
                                                <div class="form-group-new-reservation col-12">
                                                    <div class="input-with-button row g-0 align-items-start">
                                                        <label class="col-md-4 col-form-label text-start pe-0"
                                                               for="txtTitle">Title</label>
                                                        <div class="col-md-7">
                                                            <select id="txtTitle" class="form-control"
                                                                    asp-items="ViewBag.cboTitle"></select>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Phone -->
                                                <div class="form-group-new-reservation col-12">
                                                    <div class="input-with-button row g-0 align-items-start">
                                                        <label class="col-md-4 col-form-label text-start pe-0"
                                                               for="txtPhone">Phone</label>
                                                        <div class="col-md-7">
                                                            <input type="text" id="txtPhone" class="form-control" />
                                                        </div>
                                                    </div>
                                                </div>


                                                <!-- Passport -->
                                                <div class="form-group-new-reservation col-12">
                                                    <div class="input-with-button row g-0 align-items-start">
                                                        <label class="col-md-4 col-form-label text-start pe-0"
                                                               for="txtPassport">Pass port</label>
                                                        <div class="col-md-7">
                                                            <input type="text" id="txtPassport" class="form-control" />
                                                        </div>
                                                    </div>
                                                </div>

                                                <input type="hidden" id="txtID" />
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Stay Details (GIỮ NGUYÊN) -->
                                    <div class="px-1 py-1 flex-grow-1 reservation-panel reservation-panel-bottom">
                                        <div class="reservation-panel-title">Stay Details</div>
                                        <div class="row g-1">
                                            <!-- LEFT COLUMN -->
                                            <div class="col-md-6">
                                                <!-- Arr. -->
                                                <div class="">
                                                    <div class="row g-0 align-items-center">
                                                        <label class="col-4 col-form-label text-start pe-0"
                                                               for="arrival">Arrival</label>
                                                        <div class="col-7">
                                                            <div data-date-input data-format="DD/MM/YYYY" business-date
                                                                 data-name="arrival">
                                                                <input type="text" class="date-ui form-control"
                                                                       placeholder="dd/mm/yyyy" autocomplete="off"
                                                                       id="arrivalShow" />
                                                            </div>
                                                            <span style="font-size:12px;color:#c53030;display:none"
                                                                  id="arrival-day"></span>
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Nights -->
                                                <div class="">
                                                    <div class="row g-0 align-items-center">
                                                        <label class="col-4 col-form-label text-start pe-0"
                                                               for="nights">Nights</label>
                                                        <div class="col-7">
                                                            <input type="number" id="nights" class="form-control"
                                                                   style="text-align:right" min="1">
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Adults / C -->
                                                <div class="">
                                                    <div class="row g-0 align-items-center">
                                                        <label class="col-4 col-form-label text-start pe-0"
                                                               for="adults">Adults</label>
                                                        <div class="col-3">
                                                            <input value="2" id="adults" class="form-control"
                                                                   style="text-align:right" />
                                                        </div>
                                                        <label class="col-1 col-form-label text-center pe-0"
                                                               for="c">C</label>
                                                        <div class="col-3">
                                                            <input value="0" id="c" class="form-control"
                                                                   style="text-align:right" />
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- No.Room -->
                                                <div class="">
                                                    <div class="row g-0 align-items-center">
                                                        <label class="col-4 col-form-label text-start pe-0"
                                                               for="numRooms">No.Room</label>
                                                        <div class="col-7">
                                                            <input id="numRooms" type="number" value="1" min="1"
                                                                   class="form-control" style="text-align:right" />
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- R.Type -->
                                                <div class="">
                                                    <div class="row g-0 align-items-center">
                                                        <label class="col-4 col-form-label text-start pe-0"
                                                               for="txtRoomType">
                                                            R.Type<span style="color:red">*</span>
                                                        </label>
                                                        <div class="col-7">
                                                            <select id="txtRoomType" class="form-control"
                                                                    asp-items="ViewBag.cboRoomType"></select>
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Room -->
                                                <div class="">
                                                    <div class="row g-0 align-items-center">
                                                        <label class="col-4 col-form-label text-start pe-0"
                                                               for="roomSelect">Room</label>
                                                        <div class="col-7">
                                                            <div class="d-flex align-items-center">
                                                                <input id="roomID" style="display:none" />
                                                                <input id="roomSelect" readonly
                                                                       class="form-control me-1" />
                                                                <button type="button"
                                                                        onclick="openModalSearchRoom(isInitial = true)"
                                                                        class="btn-search-icon">
                                                                    <i class="fa-solid fa-arrow-down"></i>
                                                                </button>
                                                                <div class="btn-clear" id="clearRoomNo"
                                                                     onclick="clearRoomNo()"></div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Rate+ -->
                                                <div class="">
                                                    <div class="row g-0 align-items-center">
                                                        <label class="col-4 col-form-label text-start pe-0"
                                                               for="txtRateAmount">Rate+</label>
                                                        <div class="col-7">
                                                            <input type="text" id="txtRateAmount" value="0"
                                                                   class="form-control" style="text-align:right" />
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Disc. -->
                                                <div class="">
                                                    <div class="row g-0 align-items-center">
                                                        <label class="col-4 col-form-label text-start pe-0"
                                                               for="txtDiscountAmount">Disc.</label>
                                                        <div class="col-7">
                                                            <input type="text" id="txtDiscountAmount" value="0"
                                                                   class="form-control" style="text-align:right" />
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- RIGHT COLUMN -->
                                            <div class="col-md-6">
                                                <!-- Departure-->
                                                <div class="">
                                                    <div class="row g-0 align-items-center">
                                                        <label class="col-4 col-form-label text-start pe-0"
                                                               for="departure">Departure</label>
                                                        <div class="col-7">
                                                            <div data-date-input data-format="DD/MM/YYYY" business-date
                                                                 data-name="departure">
                                                                <input type="text" class="date-ui form-control"
                                                                       placeholder="dd/mm/yyyy" autocomplete="off"
                                                                       id="departureShow" />
                                                            </div>
                                                            <span style="font-size:12px;color:#c53030;display:none"
                                                                  id="departure-day"></span>
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- C1 / C2 -->
                                                <div class="">
                                                    <div class="row g-0 align-items-center">
                                                        <label class="col-4 col-form-label text-start pe-0"
                                                               for="c1">C1</label>
                                                        <div class="col-3">
                                                            <input value="0" id="c1" class="form-control"
                                                                   style="text-align:right" />
                                                        </div>
                                                        <label class="col-1 col-form-label text-center pe-0"
                                                               for="c2">C2</label>
                                                        <div class="col-3">
                                                            <input value="0" id="c2" class="form-control"
                                                                   style="text-align:right" />
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- RN -->
                                                <div class="">
                                                    <div class="row g-0 align-items-center">
                                                        <label class="col-4 col-form-label text-start pe-0"
                                                               for="txtRN">RN</label>
                                                        <div class="col-7">
                                                            <input type="number" id="txtRN" value="1"
                                                                   class="form-control" style="text-align:right" />
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- RTC -->
                                                <div class="">
                                                    <div class="row g-0 align-items-center">
                                                        <label class="col-4 col-form-label text-start pe-0"
                                                               for="txtRTC">RTC</label>
                                                        <div class="col-7">
                                                            <select id="txtRTC" class="form-control"
                                                                    asp-items="ViewBag.cboRoomType"></select>
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Rate Code -->
                                                <div class="">
                                                    <div class="row g-0 align-items-center">
                                                        <label class="col-4 col-form-label text-start pe-0"
                                                               for="txtRateCode">R.Code</label>
                                                        <div class="col-7">
                                                            <div class="d-flex align-items-center">
                                                                <input id="txtRateCodeID" readonly
                                                                       style="display:none" />
                                                                <input id="txtRateCode" readonly
                                                                       class="form-control me-1"
                                                                       style="text-align:right" />
                                                                <button type="button" onclick="openModalRateCode()"
                                                                        class="btn-search-icon">
                                                                    <i class="fa-solid fa-arrow-down"></i>
                                                                </button>
                                                                <div class="btn-clear" id="clearRateCode"
                                                                     onclick="clearRateCode()"></div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Currency -->
                                                <div class=" rate-currency-row">
                                                    <div class="row g-0 align-items-center">
                                                        <label class="col-4 col-form-label text-start pe-0"
                                                               for="txtRateCurrency">Curr</label>
                                                        <div class="col-7">
                                                            <select id="txtRateCurrency" class="form-control"
                                                                    asp-items="ViewBag.cboCurrency"></select>
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Net -->
                                                <div class="">
                                                    <div class="row g-0 align-items-center">
                                                        <label class="col-4 col-form-label text-start pe-0"
                                                               for="txtNetAmount">Net</label>
                                                        <div class="col-7">
                                                            <input type="text" id="txtNetAmount" value="0"
                                                                   class="form-control" style="text-align:right" />
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Disc.% -->
                                                <div class="">
                                                    <div class="row g-0 align-items-center">
                                                        <label class="col-4 col-form-label text-start pe-0"
                                                               for="txtDiscountPercent">Disc.%</label>
                                                        <div class="col-7">
                                                            <input type="text" id="txtDiscountPercent" value="0"
                                                                   class="form-control" style="text-align:right" />
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>

                            <!-- COL 2 -->
                            <div class="col-12 col-lg-5 col-xl-5 px-lg-2 border-end reservation-column">

                                <div class="d-flex flex-column" style="height: auto;">

                                    <!-- Membership -->
                                    <div class="px-1 py-1 reservation-panel reservation-panel-top">
                                        <div class="reservation-panel-title">Profile Details</div>
                                        <div class="section-new-reservation" style="margin:5px">
                                            <div class="form-grid-new-reservation row">
                                                <!-- Address -->
                                                <div class="form-group-new-reservation col-12">
                                                    <div class="input-with-button row g-0 align-items-start">
                                                        <label class="col-md-2 col-form-label text-start pe-0"
                                                               for="txtAddress">Address</label>
                                                        <div class="col-md-10">
                                                            <input type="text" id="txtAddress" class="form-control" />
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Date of Birth -->
                                                <div class="form-group-new-reservation col-12 col-xl-6">
                                                    <div class="input-with-button row g-0 align-items-start">
                                                        <label class="col-md-4 col-form-label text-start pe-0"
                                                               for="txtDob">
                                                            Date of
                                                            Birth
                                                        </label>
                                                        <div class="col-md-7">
                                                            <div data-date-input data-format="DD/MM/YYYY" business-date
                                                                 data-name="txtDob">
                                                                <input type="text" class="date-ui form-control"
                                                                       placeholder="dd/mm/yyyy" autocomplete="off" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>



                                                <!-- Member Type -->
                                                <div class="form-group-new-reservation col-12 col-xl-6">
                                                    <div class="input-with-button row g-0 align-items-start">
                                                        <label class="col-md-4 col-form-label text-start pe-0"
                                                               for="txtMemberType">Type</label>
                                                        <div class="col-md-7">
                                                            <select id="txtMemberType" class="form-control"
                                                                    asp-items="ViewBag.cboMemberType"></select>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Card No. -->
                                                <div class="form-group-new-reservation col-12 col-xl-6">
                                                    <div class="input-with-button row g-0 align-items-start">
                                                        <label class="col-md-4 col-form-label text-start pe-0"
                                                               for="txtCardNo">
                                                            Card
                                                            No.
                                                        </label>
                                                        <div class="col-md-7">
                                                            <input type="text" id="txtCardNo" class="form-control" />
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Nationality -->
                                                <div class="form-group-new-reservation col-12 col-xl-6">
                                                    <div class="input-with-button row g-0 align-items-start">
                                                        <label class="col-md-4 col-form-label text-start pe-0"
                                                               for="txtNationality">
                                                            Nationality<span style="color:red">*</span>
                                                        </label>
                                                        <div class="col-md-7">
                                                            <select id="txtNationality" class="form-control"
                                                                    asp-items="ViewBag.cboNationality"></select>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- City -->
                                                <div class="form-group-new-reservation col-12 col-xl-6 ">
                                                    <div class="input-with-button row g-0 align-items-start">
                                                        <label class="col-md-4 col-form-label text-start pe-0"
                                                               for="txtCity">City</label>
                                                        <div class="col-md-7">
                                                            <select id="txtCity" class="form-control"
                                                                    asp-items="ViewBag.cboCity"></select>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- VIP -->
                                                <div class="form-group-new-reservation col-12 col-xl-6 ">
                                                    <div class="input-with-button row g-0 align-items-start">
                                                        <label class="col-md-4 col-form-label text-start pe-0"
                                                               for="txtVIP">VIP</label>
                                                        <div class="col-md-7">
                                                            <select id="txtVIP" class="form-control"
                                                                    asp-items="ViewBag.cboVIP"></select>
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Preferred Room -->
                                                <div class="form-group-new-reservation col-12 col-xl-6 ">
                                                    <div class="input-with-button row g-0 align-items-start">
                                                        <label class="col-md-4 col-form-label text-start pe-0"
                                                               for="txtPrefRoom">Prf.Room</label>
                                                        <div class="col-md-7">
                                                            <input type="text" id="txtPrefRoom" class="form-control" disabled />
                                                        </div>
                                                    </div>
