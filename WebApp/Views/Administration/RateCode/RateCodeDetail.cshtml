        function save(closeAfter) {
            const payload = buildPayload();
            const err = validatePayload(payload);
            if (err) {
                showToast("Error", err, false);
                return;
            }

            const anchorSnapshot = selectedGroupedRow;

            showLoading(true);

            $.ajax({
                url: "/Administration/RateCode/SaveRateCodeDetail",
                type: "POST",
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(payload),
                success: function (res) {
                    showLoading(false);
                    if (res?.success) {
                        showToast("Success", res.message || "Saved successfully", true);
                        if (closeAfter) upsertModal.hide();
                        const newId = res.data?.id ?? res.data?.Id;
                        reloadAll(false, {
                            preferredRateCodeId: payload.rateCodeId,
                            anchorGroup: anchorSnapshot,
                            highlightDetailId: newId
                        });
                    } else {
                        showToast("Error", res?.message || "Validation failed", false);
                    }
                },
                error: function (xhr) {
                    showLoading(false);
                    showToast("Error", xhr.responseJSON?.message || "An error occurred while saving", false);
                }
            });
        }

        // --------- DELETE / EXPORT ---------
        function doDelete() {
            deleteDetailRow();
        }

        function deleteDetailRow() {
            const grid = gridDetails;
            const row = grid?.getSelectedRowsData()?.[0];
            const id = parseInt(row?.id, 10) || 0;
            if (id <= 0) {
                showToast("Warning", "Please select one row in the Details grid to delete.", false);
                return;
            }
            if (!confirm("Delete this Rate Code Detail record?")) return;

            showLoading(true);
            $.ajax({
                url: "/Administration/RateCode/DeleteRateCodeDetail?id=" + encodeURIComponent(id),
                type: "POST",
                traditional: true,
                headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() },
                success: function (result) {
                    showLoading(false);
                    if (result?.success) {
                        showToast("Success", result.message || "Deleted successfully", true);
                        reloadAll(false, { preferredRateCodeId: selectedRateCodesRow?.idRateCode });
                    } else {
                        showToast("Error", result?.message || "Delete failed", false);
                    }
                },
                error: function (xhr) {
                    showLoading(false);
                    showToast("Error", xhr.responseJSON?.message || "Unable to delete record", false);
                }
            });
        }

        function exportExcel() {
            if (!selectedGroupedRow?.id) {
                showToast("Warning", "Please select a row in 'Rate Details Grouped' to export.", false);
                return;
            }
            showToast("Info", "Excel export is not yet implemented.", false);
        }

        return { init, open };

    })();

    // Option A global entry
    window.openModalRtCD = function () {
        rtCD_Module.open();
    };

    $(document).ready(function () {
        rtCD_Module.init();
        // auto-open if desired:
        // window.openModalRtCD();
    });
</script>