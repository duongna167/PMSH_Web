        $(document).on('compositionstart', '.js-input-price, .js-input-price-net, #amountAdjust, #amountAdjustNet', function () {
            isComposing = true;
        });

        $(document).on('compositionend', '.js-input-price, .js-input-price-net, #amountAdjust, #amountAdjustNet', function () {
            isComposing = false;

            formatCurrencyLive(this);
        });

        //  Khi Focus: Xóa "0,00" để nhập mới
        $(document).on('focus', '.js-input-price, .js-input-price-net', function() {
