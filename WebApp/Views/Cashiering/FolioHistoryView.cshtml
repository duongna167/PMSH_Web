@using DevExpress.XtraReports.UI
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewBag.Title = ViewBag.ReportHeader;
    var uList = ViewBag.UsersList;
}

<style>
    #fhv_modalMain .modal-body {
        padding: 0 12px 0 12px !important;
    }

    #fhv_modalMain .mui-card {
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1) !important;
        min-height: 50vh;
        padding: 10px;
    }
</style>

<!-- ========================= -->
<!-- MAIN VIEW (BS5 MODAL XL) -->
<!-- ========================= -->
<div class="modal fade" id="fhv_modalMain" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-16by9 modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header py-2">
                <h6 class="modal-title" id="fhv_reportTitle" style="font-size: 20px">Folio History</h6>
            </div>

            <div class="modal-body">

                <div class="search-filter">

                    <!-- ACTION BUTTONS -->
                    <div class="d-flex gap-2 mb-2 mt-2">
                        <button id="fhv_btnView" type="button" class="mui-button mui-button-new">View</button>
                        <button id="fhv_btnDetail" type="button" class="mui-button mui-button-new">Details</button>
                        <button id="fhv_btnExportExcel" type="button" class="mui-button mui-button-new">Excel</button>
                        <button class="mui-button mui-button-new" data-bs-dismiss="modal" aria-label="Close">Close</button>

                    </div>

                    <!-- FILTER CONTENT -->
                    <div class="row g-2 align-items-start">

                        <!-- DATE FILTER -->
                        <div class="col-lg-2 col-md-6">

                            <div class="d-flex align-items-center">
                                <label class="col-md-2 col-form-label me-2 text-end">From:</label>
                                <div class="col-md-10" data-date-input data-format="DD/MM/YYYY" business-date data-name="fhv_fromDate">
                                    <input type="text" id="fhv_fromDate" name="fhv_fromDate"
                                           class="date-ui form-control form-control-sm "
                                           placeholder="dd/mm/yyyy" autocomplete="off" />
                                </div>
                            </div>

                            <div class="d-flex align-items-center">
                                <label class="col-md-2 col-form-label me-2 text-end">To:</label>
                                <div class="col-md-10" data-date-input data-format="DD/MM/YYYY" business-date data-name="fhv_toDate">
                                    <input type="text" id="fhv_toDate" name="fhv_toDate"
                                           class="date-ui form-control form-control-sm "
                                           placeholder="dd/mm/yyyy" autocomplete="off" />
                                </div>
                            </div>
                        </div>

                        <!-- CARD CATEGORY -->
                        <div class="col-lg-4 col-md-6">

                            <!-- Folio -->
                            <div class="row g-1">
                                <div class="col-6 d-flex align-items-center">
                                    <label class="col-md-4 col-form-label me-2 text-end">From Folio:</label>
                                    <input type="text" id="fhv_fromFolio" name="fhv_fromFolio"
                                           class="form-control form-control-sm flex-grow-1">
                                </div>

                                <div class="col-6 d-flex align-items-center">
                                    <label class="col-md-4 col-form-label me-2 text-end">To Folio:</label>
                                    <input type="text" id="fhv_toFolio" name="fhv_toFolio"
                                           class="form-control form-control-sm flex-grow-1">
                                </div>
                            </div>

                            <!-- Room -->
                            <div class="row g-1 ">
                                <div class="col-6 d-flex align-items-center">
                                    <label class="col-md-4 col-form-label me-2 text-end">From Room:</label>
                                    <input type="text" id="fhv_fromRoom" name="fhv_fromRoom"
                                           class="form-control form-control-sm flex-grow-1">
                                </div>

                                <div class="col-6 d-flex align-items-center">
                                    <label class="col-md-4 col-form-label me-2 text-end">To Room:</label>
                                    <input type="text" id="fhv_toRoom" name="fhv_toRoom"
                                           class="form-control form-control-sm flex-grow-1">
                                </div>
                            </div>

                            <!-- Users -->
                            <div class="d-flex align-items-center">
                                <label class="col-md-2 col-form-label me-3 text-end">Users:</label>
                                <select id="fhv_users" name="fhv_users" class="tomselect-custom flex-grow-1 me-2" multiple style="width: 280px;">
                                    @foreach (var sg in ViewBag.UsersList)
                                    {
                                        <option value="@sg.LoginName">
                                            @sg.LoginName - @sg.LastName
                                        </option>
                                    }
                                </select>
                            </div>
                        </div>

                        <!-- ACTION -->
                        <div class="col-lg-6 col-md-12">
                            <div class="row g-1 ms-3">
                                <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                    <label class="small d-flex align-items-center gap-1">
                                        <input type="checkbox" id="fhv_allAction" name="fhv_allAction" value="" checked>
                                        All Action
                                    </label>
                                </div>
                            </div>
                            <hr class="my-2">
                            <div class="row g-1 ms-3" id="fhv_action">
                                <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                    <label class="small d-flex align-items-center gap-1">
                                        <input type="checkbox" id="fhv_nightPost" name="fhv_nightPost" value="2" checked>
                                        NIGHT_POST
                                    </label>
                                </div>
                                <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                    <label class="small d-flex align-items-center gap-1">
                                        <input type="checkbox" id="fhv_earlyCheckout" name="fhv_earlyCheckout" value="3" checked>
                                        EARLY_CHECKOUT
                                    </label>
                                </div>
                                <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                    <label class="small d-flex align-items-center gap-1">
                                        <input type="checkbox" id="fhv_tranferred" name="fhv_tranferred" value="7" checked>
                                        TRANSFERRED
                                    </label>
                                </div>

                                <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                    <label class="small d-flex align-items-center gap-1">
                                        <input type="checkbox" id="fhv_postGen" name="fhv_postGen" value="0" checked>
                                        POST_GEN
                                    </label>
                                </div>
                                <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                    <label class="small d-flex align-items-center gap-1">
                                        <input type="checkbox" id="fhv_advanceBill" name="fhv_advanceBill" value="4" checked>
                                        ADVANCE_BILL
                                    </label>
                                </div>
                                <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                    <label class="small d-flex align-items-center gap-1">
                                        <input type="checkbox" id="fhv_correct" name="fhv_correct" value="5" checked>
                                        CORRECT
                                    </label>
                                </div>

                                <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                    <label class="small d-flex align-items-center gap-1">
                                        <input type="checkbox" id="fhv_post" name="fhv_post" value="1" checked>
                                        POST
                                    </label>
                                </div>
                                <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                    <label class="small d-flex align-items-center gap-1">
                                        <input type="checkbox" id="fhv_split" name="fhv_split" value="6" checked>
                                        SPLIT
                                    </label>
                                </div>
                                <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                    <label class="small d-flex align-items-center gap-1">
                                        <input type="checkbox" id="fhv_deleted" name="fhv_deleted" value="8" checked>
                                        DELETED
                                    </label>
                                </div>

                                <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                    <label class="small d-flex align-items-center gap-1">
                                        <input type="checkbox" id="fhv_pay" name="fhv_pay" value="9" checked>
                                        PAY
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="fhv_loadingSpinnerRateCode" 
                    style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                        z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                        height: 100%;display: flex;align-items: center;justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>

                <div class="mui-card">
                    <!-- IMPORTANT: fixed height (not 100%) -->
                    <div id="fhv_gridContainerRateCode" class="mt-2 gridContainer" style="height: 500px;"></div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- ========================= -->
<!-- DETAIL MODAL (BS5 XL) -->
<!-- ========================= -->
<div class="modal fade" id="fhv_modaldetailGrid" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header py-2">
                <h6 class="modal-title">Transactions History Detail</h6>
            </div>

            <div class="modal-body">
                <div class="mb-2 mt-1">
                    <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>

                <div class="mui-card">
                    <div id="fhv_detailPopup" class="gridContainer" style="height:420px"></div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    // ================================
    // Folio History View - Module (Option A)
    // Prefix: fhv_
    // ================================
    var fhv_Module = (function () {

        DevExpress.localization.locale("vi");

        let selectedRowData = null;

        // DevExtreme instances
        let gridMainInstance = null;
        let gridDetailInstance = null;

        // Bootstrap modal instances
        let modalMainInstance = null;
        let modalDetailInstance = null;

        // TomSelect instance
        let tomUsers = null;

        // Flags
        let isMainModalShownOnce = false;

        function init() {
            initTomSelect(".tomselect-custom");
            // Cache modal instances
            const modalMainEl = document.getElementById("fhv_modalMain");
            const modalDetailEl = document.getElementById("fhv_modaldetailGrid");

            if (modalMainEl) {
                modalMainInstance = bootstrap.Modal.getOrCreateInstance(modalMainEl, {
                    backdrop: "static",
                    keyboard: false
                });

                // IMPORTANT: Grid init must be in shown.bs.modal
                $(modalMainEl).off("shown.bs.modal.fhv").on("shown.bs.modal.fhv", async function () {

                    // Prevent re-binding / re-initializing on repeated show
                    if (!isMainModalShownOnce) {
                        isMainModalShownOnce = true;

                        // When changing checkbox "All"
                        $("#fhv_allAction").change(function () {
                            var isChecked = $(this).is(":checked");
                            $("#fhv_action input[type='checkbox']").not(this).prop("checked", isChecked);
                        });

                        // When changing each child checkbox, if all checked then auto-check "All"
                        $("#fhv_action input[type='checkbox']").not("#fhv_allAction").change(function () {
                            var allChecked = $("#fhv_action input[type='checkbox']").not("#fhv_allAction").length ===
                                $("#fhv_action input[type='checkbox']:checked").not("#fhv_allAction").length;
                            $("#fhv_allAction").prop("checked", allChecked);
                        });

                        await window.initDateInputs();
                        await reloadGrid(isInitial = true);
                        // initializeTomSelects();

                        bindEvents();
                    } else {
                        // If modal opened again after hide, grid may need repaint
                        if (gridMainInstance) {
                            try { gridMainInstance.repaint(); } catch (e) { }
                        }
                    }
                });
            }

            if (modalDetailEl) {
                modalDetailInstance = bootstrap.Modal.getOrCreateInstance(modalDetailEl, {
                    backdrop: "static",
                    keyboard: false
                });
            }

            // Global cleanup listener: any modal id starting with fhv_
            //$(document).off("hidden.bs.modal.fhvGlobal").on("hidden.bs.modal.fhvGlobal", ".modal[id^='fhv_']", function () {
              //  fhv_Module.destroy();
            //});
        }

        function bindEvents() {

            $(document).off("click", "#fhv_btnDetail").on("click", "#fhv_btnDetail", function () {
                if (selectedRowData) {
                    showDetailPopup(selectedRowData);
                } else {
                    showToast("Warning", "Please choose 1 row ", false);
                }
            });

            $(document).off("click", "#fhv_btnView").on("click", "#fhv_btnView", function () {
                reloadGrid();
            });

            $(document).off("click", "#fhv_btnExportExcel").on("click", "#fhv_btnExportExcel", function () {
                const grid = $("#fhv_gridContainerRateCode").dxDataGrid("instance");   // 🔥 khai báo grid

                const workbook = new ExcelJS.Workbook();
                const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
                const worksheet = workbook.addWorksheet("Sheet 1");

                // === Dòng 1: Tên công ty (merge theo 4 cột) ===
                worksheet.addRow([companyName]);
                worksheet.mergeCells('A1:D1');
                worksheet.getRow(1).font = { bold: true };
                worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

                // === Dòng 2: Ngày giờ xuất (bên phải) ===
                const now = new Date();
                const exportDate = now.toLocaleString("vi-VN");
                worksheet.addRow(['', '', '', exportDate]);
                worksheet.mergeCells('D2:D2');  // cột D thôi
                worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

                // === Dòng 3–4: trống
                worksheet.addRow([]);
                worksheet.addRow([]);

                // === Dòng 5: Tiêu đề báo cáo (ở giữa) ===
                const reportRow = worksheet.addRow([' Folio History']);
                worksheet.mergeCells('A5:D5');
                reportRow.font = { bold: true, size: 14 };
                reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

                // === Dòng 6: trống
                worksheet.addRow([]);

                // === Xuất dữ liệu grid bắt đầu từ dòng 7 ===
                DevExpress.excelExporter.exportDataGrid({
                    component: grid,
                    worksheet: worksheet,
                    autoFilterEnabled: true,
                    topLeftCell: { row: 7, column: 1 }
                }).then(function () {
                    // Footer (sau cùng)
                    const lastRow = worksheet.lastRow.number + 2;
                    worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
                    worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
                    worksheet.getCell(`A${lastRow}`).font = { italic: true };

                    // Ghi file
                    let fileName = "Folio History.xlsx";
                    workbook.xlsx.writeBuffer().then(function (buffer) {
                        saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
                    });
                });
            });
        }

        function initializeTomSelects() {
            const selectors = ["#fhv_users"];

            for (const id of selectors) {
                const el = document.querySelector(id);
                if (!el) continue;

                // Nếu đã khởi tạo rồi thì destroy
                if (el.tomselect) el.tomselect.destroy();

                const ts = new TomSelect(el, {
                    plugins: ['remove_button'],
                    create: false,
                    maxItems: null,
                    allowEmptyOption: true,
                    placeholder: '',
                    persist: false,
                    render: {
                        option: function (data, escape) {
                            return `<div>${escape(data.text)}</div>`;
                        }
                    }
                });

                if (id === "#fhv_users") {
                    tomUsers = ts;
                }
            }
        }

        function loadGrid(data) {

            // Ensure container exists and has fixed height
            $("#fhv_gridContainerRateCode").css("height", "500px");

            gridMainInstance = $("#fhv_gridContainerRateCode").dxDataGrid({
                dataSource: data,
                height: 500,
                width: "100%",
                columnAutoWidth: true,
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                columns: [
                    { dataField: "property", caption: "Property", width: "10%" },
                    { dataField: "actionText", caption: "Action", width: "20%" },
                    { dataField: "moreInformation", caption: "More Information ", width: "10%" },
                    {
                        caption: "Date",
                        width: "11%",
                        calculateCellValue: function (rowData) {
                            if (!rowData.actionDate) return "";
                            let d = new Date(rowData.actionDate);
                            return d.toLocaleDateString("en-GB"); // dd/MM/yyyy
                        }
                    },
                    {
                        caption: "Time",
                        width: "11%",
                        calculateCellValue: function (rowData) {
                            if (!rowData.actionDate) return "";
                            let d = new Date(rowData.actionDate);
                            return d.toLocaleTimeString("en-GB", { hour: "2-digit", minute: "2-digit", second: "2-digit" });
                        }
                    },
                    { dataField: "fromRoom", caption: "F_Room", width: "11%" },
                    { dataField: "fromFolioID", caption: "F_Folio ", width: "11%" },
                    { dataField: "fromName", caption: "F_Guest ", width: "11%" },
                    { dataField: "toRoom", caption: "T_Room", width: "11%" },
                    { dataField: "toFolioID", caption: "T_Folio", width: "11%" },
                    { dataField: "toName", caption: "T_Guest", width: "11%" },
                    { dataField: "amountIncTax", caption: "Amount", width: "11%", dataType: "number", format: "#,##0.00" },
                    { dataField: "actionUser", caption: "User", width: "11%" },
                    { dataField: "machine", caption: "Machine", width: "11%" },
                ],
                filterRow: { visible: true, applyFilter: "auto" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, 'all'],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: { mode: "standard", showScrollbar: "always", scrollByContent: true },
                onRowClick: function (e) {
                    selectedRowData = e.data;
                    console.log("Selected Row:", selectedRowData);
                }
            }).dxDataGrid("instance");
        }

        function showDetailPopup(rowData) {
            let invoiceNo = rowData.invoiceNo;
            console.log("InvoiceNo:", invoiceNo);

            $.ajax({
                url: "/Cashiering/GetSearchPostingHistoryDetail",
                type: "GET",
                data: { invoiceNo: invoiceNo },
                success: function (data) {
                    loadDetailGrid(data);
                    modalDetailInstance.show();
                }
                ,
                error: function () {
                    console.error("Không thể tải dữ liệu chi tiết");
                }
            });
        }

        function loadDetailGrid(data) {

            // Ensure container exists and has fixed height
            $("#fhv_detailPopup").css("height", "500px");

            gridDetailInstance = $("#fhv_detailPopup").dxDataGrid({
                dataSource: data,
                height: 500,
                allowColumnResizing: true,
                selection: { mode: "single" },

                columns: [
                    { dataField: "actionText", caption: "Action" },
                    { dataField: "moreInformation", caption: "More Information" },
                    { dataField: "transactionDate", caption: "Trans. Date", dataType: "date", format: "dd/MM/yyyy" },
                    {
                        caption: "Date",
                        calculateCellValue: function (rowData) {
                            if (!rowData.actionDate) return "";
                            let d = new Date(rowData.actionDate);
                            return d.toLocaleDateString("en-GB");
                        }
                    },
                    {
                        caption: "Time",
                        calculateCellValue: function (rowData) {
                            if (!rowData.actionDate) return "";
                            let d = new Date(rowData.actionDate);
                            return d.toLocaleTimeString("en-GB", {
                                hour: "2-digit",
                                minute: "2-digit",
                                second: "2-digit"
                            });
                        }
                    }
                ],

                scrolling: {
                    mode: "standard", // Không dùng virtual để footer hiển thị đúng
                    showScrollbar: "always",
                    scrollByContent: true
                },
                paging: {
                    pageSize: 50
                },
                pager: {
                    visible: true,
                    allowedPageSizes: [50, 100, 'all'],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: {
                    visible: true,
                    applyFilter: "auto"
                },
                showBorders: true,
                width: "100%",

                onRowPrepared: function (e) {
                    if (e.data && e.data.isSubtotal) {
                        e.rowElement.css({ "font-weight": "bold" });
                    }
                    if (e.data && e.data.isGrandTotal) {
                        e.rowElement.css({ "font-weight": "bold" });
                    }
                },
                onRowClick: function (e) {
                    selectedRowData = e.data;
                    console.log('onRowClick:', selectedRowData);
                }
            }).dxDataGrid("instance");
        }

        // Reload grid với filter từ form
        async function reloadGrid(isInitial = false) {
            try {
                $("#fhv_loadingSpinnerRateCode").show();

                let fromDateISO = $("#fhv_fromDate").val() || '';
                let toDateISO = $("#fhv_toDate").val() || '';
                let usersParam = "";
                let selectedusers = $("#fhv_users").val();

                // Nếu là load lần đầu (initial) và fromDate chưa có → bắt buộc chờ business date
                if (isInitial && (!fromDateISO || !toDateISO)) {
                    fromDateISO = await waitForBusinessDate("fhv_fromDate", 10000); // timeout 10s để an toàn
                    toDateISO = await waitForBusinessDate("fhv_toDate", 10000); // timeout 10s để an toàn
                }

                // Nếu vẫn rỗng sau khi chờ → báo lỗi hoặc fallback (tùy yêu cầu)
                if (!fromDateISO || !toDateISO) {
                    console.log("Không tải được ngày mặc định. Vui lòng chọn From Date thủ công.");
                    $("#fhv_loadingSpinnerRateCode").hide();
                    return;
                }

                usersParam = selectedusers.map(r => r.replace("''")).join("','");
                var actionType = $("#fhv_action input[type='checkbox']:checked")
                    .map(function () { return this.value; })
                    .get()
                    .join(",");

                // Gửi ajax
                $.ajax({
                    url: '/Cashiering/GetFolioHistoryView',
                    type: 'POST',
                    data: {
                        fromDate: fromDateISO,   // YYYY-MM-DD an toàn
                        toDate: toDateISO,
                        fromFolioID: $("#fhv_fromFolio").val(),
                        toFolioID: $("#fhv_toFolio").val(),
                        fromRoom: $("#fhv_fromRoom").val(),
                        toRoom: $("#fhv_toRoom").val(),
                        actionType: actionType,
                        user: usersParam
                    },
                    success: function (data) {

                        // IMPORTANT: only render grid when success returns data
                        loadGrid(data);

                        console.log("Data trả về:", data);
                        $("#fhv_loadingSpinnerRateCode").hide();
                    },
                    error: function (xhr, status, error) {
                        alert("Không thể tải dữ liệu");
                        $("#fhv_loadingSpinnerRateCode").hide();
                    }
                });
            } catch (error) {
                console.error(error);
            }
        }

        function destroy() {

            // Dispose main grid
            try {
                const inst = $("#fhv_gridContainerRateCode").dxDataGrid("instance");
                if (inst) inst.dispose();
            } catch (e) { }
            try { $("#fhv_gridContainerRateCode").empty(); } catch (e) { }

            // Dispose detail grid
            try {
                const inst2 = $("#fhv_detailPopup").dxDataGrid("instance");
                if (inst2) inst2.dispose();
            } catch (e) { }
            try { $("#fhv_detailPopup").empty(); } catch (e) { }

            // Reset internal refs
            gridMainInstance = null;
            gridDetailInstance = null;
            selectedRowData = null;

            // Destroy TomSelect
            try {
                const el = document.querySelector("#fhv_users");
                if (el && el.tomselect) el.tomselect.destroy();
            } catch (e) { }
            tomUsers = null;

            // Reset flags
            isMainModalShownOnce = false;

            // Remove events
            $(document).off("click", "#fhv_btnDetail");
            $(document).off("click", "#fhv_btnView");
            $(document).off("click", "#fhv_btnExportExcel");

            $("#fhv_allAction").off("change");
            $("#fhv_action input[type='checkbox']").off("change");
        }

        // Global entry points (required)
        function openModal() {
            if (!modalMainInstance) {
                init();
            }
            modalMainInstance.show();
        }

        function openModalAuto() {
            openModal();
        }

        return {
            init: init,
            destroy: destroy,
            openModal: openModal,
            openModalAuto: openModalAuto
        };

    })();

    // Required global handlers
    window.openModalFhv = function () {
        fhv_Module.openModal();
    };

    window.openModalFhvAuto = function () {
        fhv_Module.openModalAuto();
    };

    // Auto-init module shell (safe)
    $(document).ready(function () {
        fhv_Module.init();
    });


</script>
