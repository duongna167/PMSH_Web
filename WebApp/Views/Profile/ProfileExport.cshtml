<style>
    #loadingSpinnerRateCode {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 999;
        background: rgba(255, 255, 255, 0.55);
        backdrop-filter: blur(2px);
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* modal-body phải là flex column */
    .modal-body {
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    /* card chứa filter + grid */
    .mui-card {
        display: flex;
        flex-direction: column;
        flex: 1 1 auto;
        min-height: 0;
    }

    /* vùng grid */
    .gridContainer {
        position: relative;
        flex: 1 1 auto;
        min-height: 0;
        /* CỰC QUAN TRỌNG */
    }

    .date-group {
        width: 150px;
        /* tổng width input + icon */
    }

    .date-group input {
        padding-right: 6px;
    }

    .calendar-btn {
        cursor: pointer;
        padding: 0 8px;
    }

    .datepicker {
        z-index: 1060 !important;
        padding: 6px;
        font-size: 13px;
    }

    .datepicker table {
        margin: 0;
    }

    .datepicker th,
    .datepicker td {
        width: 28px;
        height: 26px;
        padding: 0;
    }

    .datepicker-days table thead tr:nth-child(2) th {
        padding: 4px 0;
    }

    .datepicker .datepicker-switch,
    .datepicker .prev,
    .datepicker .next {
        padding: 4px 6px;
        font-weight: 600;
    }

    .datepicker tfoot tr th {
        padding: 4px 0;
    }
</style>
<link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/css/bootstrap-datepicker.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/js/bootstrap-datepicker.min.js"></script>

<div class="modal fade" id="reportMealModal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content report-meal-container modal-full-height">
            <div class="modal-header bg-light py-2">
                <h5 class="modal-title">Profile Export</h5>
            </div>

            <div class="modal-body">
                <div class="py-2">
                    <button class="mui-button mui-button-search" onclick="getAllProfilesSearch();">View</button>
                    <button class="mui-button mui-button-export" onclick="exportExcel();">Excel</button>
                    <button class="mui-button mui-button-export" onclick="exportXML();">XML</button>
                    <button id="close" class="mui-button mui-button-new"
                        onclick="window.location.href='/Home/Index'">Close</button>
                </div>
                <div class="mui-card mb-2 bg-light border-0">

                    <div class="d-flex gap-2 align-items-center mb-2">

                        <div class="d-flex align-items-center">
                            <label class="fw-bold me-2 mb-0">From</label>

                            <div class="input-group input-group-sm date-group">
                                <input id="fromDate" class="form-control date-bootstrap" placeholder="dd/mm/yyyy" />
                                <span class="input-group-text calendar-btn">
                                    <i class="fa-solid fa-calendar-days"></i>
                                </span>
                            </div>
                        </div>

                        <div class="d-flex align-items-center">
                            <label class="fw-bold me-2 mb-0">To</label>

                            <div class="input-group input-group-sm date-group">
                                <input id="toDate" class="form-control date-bootstrap" placeholder="dd/mm/yyyy" />
                                <span class="input-group-text calendar-btn">
                                    <i class="fa-solid fa-calendar-days"></i>
                                </span>
                            </div>
                        </div>

                    </div>



                    <div class="gridContainer">
                        <div id="gridContainer"></div>
                        <div id="loadingSpinnerRateCode" style="display: none;">
                            <div class="spinner-border text-primary" role="status"></div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        initBootstrapDatepicker('.date-bootstrap'); // bắt buộc trước khi load businessDate

        $('#reportMealModal')
            .modal('show')
            .on('shown.bs.modal', function () {
                loadBusinessDate(function () {
                    getAllProfilesSearch(); // chạy sau khi date đã set
                });
            });

    });

    $(document).on('click', '.input-group-text', function () {
        $(this).prev('input').datepicker('show');
    });

    function getAllProfilesSearch() {

        $.ajax({
            url: '/Profile/SearchProfileExport',
            type: 'get',
            dataType: 'json',
            data: {
                fromDate: getDateIso('#fromDate'),
                toDate: getDateIso('#toDate'),
            },
            beforeSend: function () {
                $("#loadingSpinnerRateCode").show();
                $("#gridContainer").css("opacity", "0.5");
            },
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                $("#loadingSpinnerRateCode").hide();
                $("#gridContainer").css("opacity", "1");
                initializeDataGrid(result);
            },
            error: function () {
                $("#loadingSpinnerRateCode").hide();
                $("#gridContainer").css("opacity", "1");
                showToast("Error", "Error loading service", false);
            }
        });
    }

    function exportXML() {
        const fromDate = $('#fromDate').val();
        const toDate = $('#toDate').val();

        window.location.href =
            `/Profile/ExportXML?fromDate=${fromDate}&toDate=${toDate}`;
    }

    function initializeDataGrid(data) {

        $("#gridContainer").dxDataGrid({

            dataSource: data,
            height: "100%",
            allowColumnResizing: true,
            columns: [
                { dataField: "Indexs", caption: "TT" },
                { dataField: "AccountName", caption: "Name" },
                { dataField: "ArrivalDate", caption: "Arrival" },
                { dataField: "DepartureDate", caption: "Deparure" },
                { dataField: "Nationality", caption: "Nationality" },
                { dataField: "DateOfBirth", caption: "Date Of Birth" },
                { dataField: "Address", caption: "Address" },
                { dataField: "HandPhone", caption: "HandPhone" },
                { dataField: "Telephone", caption: "Telephone" },
            ],
            paging: { pageSize: 20 },
            scrolling: {
                rowRenderingMode: 'virtual',
            },
            pager: {
                visible: true,
                allowedPageSizes: [20, 50, 100],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true,
            },

            selection: {
                mode: "multiple",
                showCheckBoxesMode: "none"
            },

            showBorders: false,
            onRowClick: function (e) {
                console.log("ID được click:", e.data.id);
            }

        });
    }

    function exportExcel() {
        const grid = $("#gridContainer").dxDataGrid("instance");


        const workbook = new ExcelJS.Workbook();
        const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
        const worksheet = workbook.addWorksheet("Sheet 1");

        // === Tạo header công ty (dòng 1) ===
        worksheet.addRow([companyName]);
        worksheet.mergeCells('A1:E1');
        worksheet.getRow(1).font = { bold: true };
        worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

        // === Dòng 2: Thời gian xuất (phải) ===
        const now = new Date();
        const exportDate = now.toLocaleString("vi-VN");
        worksheet.addRow(['', '', '', '', ' ' + exportDate]);
        worksheet.mergeCells('E2:H2');
        worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

        // === Dòng 3–4: Trống
        worksheet.addRow([]);
        worksheet.addRow([]);

        // === Dòng 5: Tên báo cáo ở giữa ===
        const reportRow = worksheet.addRow(['', '', 'Profile Export']);
        worksheet.mergeCells('C5:F5');
        reportRow.font = { bold: true, size: 14 };
        reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

        // === Dòng 6: Trống trước khi xuất dữ liệu
        worksheet.addRow([]);

        // === Export dữ liệu từ DevExtreme (bắt đầu từ dòng 7)
        DevExpress.excelExporter.exportDataGrid({
            component: grid,
            worksheet: worksheet,
            autoFilterEnabled: true,
            topLeftCell: { row: 7, column: 1 } // dữ liệu bắt đầu từ dòng 7
        }).then(function () {
            // Footer
            const lastRow = worksheet.lastRow.number + 2;
            worksheet.mergeCells(`A${lastRow}:F${lastRow}`);
            worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
            worksheet.getCell(`A${lastRow}`).font = { italic: true };

            // Ghi file
            let fileName = "ProfilExport" + ".xlsx";
            workbook.xlsx.writeBuffer().then(function (buffer) {
                saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
            });
        });
    }


</script>
