        //mặc định hiển thị (Dòng cha - PostType = 3 và IsVisible = 1)
        let displayData = data.filter(item => item.isVisible == 1);

        $("#gridTransactionDetail").dxDataGrid({
            dataSource: displayData,
            keyExpr: "id",
            showBorders: true,
            showRowLines: true,
            columnAutoWidth: true,
            rowAlternationEnabled: true,
            height: 280,
            paging: { enabled: false },
            columns: [
                { dataField: "date", caption: "Date", width: 90, dataType: "date", format: "dd/MM/yyyy" },
                {
                    dataField: "code", caption: "Code", width: 60, alignment: "center",
                    cellTemplate: function (container, options) {
                        let item = options.data;
                        let isExpanded = item._isExpanded || false;
                        let displayCode = item.code;

                        // Nếu dòng này có thể mở
                        if (item.isSplit == true || item.isSplit == 1) {
                            displayCode = isExpanded ? item.code.replace('+', '-') : item.code;

                            $("<a>")
                                .text(displayCode)
                                .css({ "cursor": "pointer", "font-weight": "bold", "color": "blue" })
                                .on("click", function () {
                                    toggleExpandRow(item);
                                })
                                .appendTo(container);
                        } else {
                            $("<span>").text(displayCode).appendTo(container);
                        }
                    }
                },
                { dataField: "description", caption: "Description", minWidth: 150 },
                {
                    dataField: "amount",
                    caption: "Amount",
                    format: { type: "fixedPoint", precision: 2 },
                    width: 110,
                    cssClass: "fw-bold text-end",
                    cellTemplate: function (container, options) {
                        let val = options.value || 0;
                        let color = val < 0 ? "red" : "blue";
                        $("<span>").css("color", color).text(options.text).appendTo(container);
                    }
                },
                { dataField: "currency", caption: "$", width: 50, alignment: "center" },
                { dataField: "supplement", caption: "Supplement" },
                { dataField: "reference", caption: "Reference" },
                { dataField: "userName", caption: "User", width: 80 },
                {
                    dataField: "time", caption: "Time", width: 80, customizeText: function (e) {
                        const d = new Date(e.value);
                        return d.toLocaleTimeString('en-US', {
                            hour: '2-digit',
                            minute: '2-digit',
                            hour12: true
                        });
                    }
                },
                { dataField: "groupCode", caption: "Grp.Code", width: 70 },
                { dataField: "subgroupCode", caption: "Sub.Code", width: 70 },
                { dataField: "shiftID", caption: "Shift", width: 60 },
                { dataField: "invoiceNo", caption: "Inv.No", width: 70 },
                { dataField: "transactionNo", caption: "Trn.No", width: 80 }
            ]
        });
    }

    function toggleExpandRow(clickedItem) {
        let grid = $("#gridTransactionDetail").dxDataGrid("instance");
        let currentData = grid.option("dataSource");

        clickedItem._isExpanded = !clickedItem._isExpanded;

        if (clickedItem._isExpanded) {
            let children = fullTransactionData.filter(d =>
                d.transactionNo === clickedItem.transactionNo && d.isVisible == 0
            );

            let index = currentData.findIndex(d => d.id === clickedItem.id);
            if (index !== -1) {
                currentData.splice(index + 1, 0, ...children);
            }
        } else {
            currentData = currentData.filter(d =>
                !(d.transactionNo === clickedItem.transactionNo && d.isVisible == 0)
            );
        }

        grid.option("dataSource", currentData);
    }

    //end view transaction detail

</script>
