        $('#txtSalutationIndividual').val(selectedRowData.salutation ?? '');
        $('#txtReasonIndividual').val(selectedRowData.vipReason ?? '');

        // ===== DOB =====
        var dobValue = selectedRowData.dateOfBirth;

        // Nếu có ngày sinh hợp lệ (không phải null/empty)
        if (dobValue) {
            // 1. Gọi hàm set giá trị (Hàm này sẽ lo việc parse chuỗi ISO)
            UI.setHiddenDate("txtDobIndividual", dobValue);
