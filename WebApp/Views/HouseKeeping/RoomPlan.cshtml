                if (response.success) {
                    // Chuyển hướng đến trang chỉnh sửa
                   // window.location.href = '/Reservation/NewReservation?key=' + encodeURIComponent(response.encryptedId);
                    $.ajax({
                        url: '/Reservation/NewReservation',
                        type: 'GET',
                        data: { key: response.encryptedId },
