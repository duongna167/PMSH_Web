@using Newtonsoft.Json
@using Reservation.Dto
@model List<ReservationSearchDTO>

<div class="modal fade" id="groupAdminModal" tabindex="-1" aria-labelledby="groupAdminModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-4by3">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="groupAdminModalLabel">Group Admin</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <a href="#" onclick="loadGroupData()" class="mui-button mui-button-new">Search</a>
                        <a href="javascript:void(0);" class="mui-button mui-button-new"
                            onclick="openModalSplit();">Split</a>
                        <div class="btn-group">
                            <a href="#" class="mui-button mui-button-new dropdown-toggle" data-bs-toggle="dropdown">Room
                                Assignment</a>
                            <div class="dropdown-menu">
                                <a class="dropdown-item" href="#" onclick="openRoomAssignment();"
                                    id="assignRoom">Assignment</a>
                                <a class="dropdown-item" href="#" onclick="openConfirmRoomUnAssign();"
                                    id="unAssignRoom">UnAssign</a>
                                <a class="dropdown-item" href="#" onclick="openModalAutoRoomAssignment();">Auto
                                    Room Assignment</a>
                            </div>
                        </div>

                        <div class="btn-group">
                            <a href="#" class="mui-button mui-button-new dropdown-toggle"
                                data-bs-toggle="dropdown">Check In</a>
                            <div class="dropdown-menu">
                                <a class="dropdown-item" href="#" onclick="checkIn();">Check In</a>
                                <a class="dropdown-item" href="#" onclick="openModalGroupCheckIn();">Group Check
                                    In</a>
                            </div>
                        </div>

                        <a href="#" class="mui-button mui-button-new" onclick="roomSharer();">Room Sharer</a>

                        <div class="btn-group">
                            <a href="#" class="mui-button mui-button-new dropdown-toggle"
                                data-bs-toggle="dropdown">Display</a>
                            <div class="dropdown-menu">
                                <a class="dropdown-item" href="#" onclick="filterDisplay(2)">Reservation</a>
                                <a class="dropdown-item" href="#" onclick="filterDisplay(1)">Guest In House</a>
                                <a class="dropdown-item" href="#" onclick="filterDisplay(6)">Checked Out</a>
                                <a class="dropdown-item" href="#" onclick="filterDisplay(7)">Cancellation</a>
                                <a class="dropdown-item" href="#" onclick="filterDisplay(9)">Wait List</a>
                                <a class="dropdown-item" href="#" onclick="filterDisplay(8)">NoShow</a>
                                <a class="dropdown-item" href="#" onclick="filterDisplay(0)">General</a>
                            </div>
                        </div>
                        <a href="#" onclick="closeGroupAdmin()" class="mui-button mui-button-new">Close</a>

                    </div>
                    <div class="mt-1">
                        <div class="row g-2 mt-1 align-items-center">

                            <!-- Confirmation No -->
                            <div class="col-12 col-sm-6 col-md-3 col-lg-2 col-xl-2">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 text-md-end mb-0 text-nowrap" for="gra_name">
                                        Name
                                    </label>
                                    <div class="col-8">
                                        <input type="text" id="gra_name" name="gra_name"
                                            class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>

                            <!-- Room No -->
                            <div class="col-12 col-sm-6 col-md-3 col-lg-2 col-xl-2">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 text-md-end mb-0 text-nowrap" for="gra_roomNo">
                                        Room No
                                    </label>
                                    <div class="col-8">
                                        <input type="text" id="gra_roomNo" name="gra_roomNo"
                                            class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>

                            <!-- Sorting -->
                            <div class="col-12 col-sm-12 col-md-6 col-lg-4 col-xl-4">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 text-md-end mb-0 text-nowrap" for="gra_sorting">
                                        Sorting
                                    </label>
                                    <div class="col-8">
                                        <select id="gra_sorting" name="gra_sorting" class="form-select form-select-sm">
                                            <option value="0">All</option>
                                            <option value="1">Room No</option>
                                            <option value="2">Room Type</option>
                                            <option value="3">Guest Name</option>
                                            <option value="4">Arrival</option>
                                            <option value="5">Departure</option>
                                            <option value="6">Reservation Type</option>
                                            <option value="7">Package</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
                <div class="mui-card">
                    <div id="gra_gridContainer" class="gridContainer">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@await Html.PartialAsync("GroupAdmin/GroupCheckIn")
@await Html.PartialAsync("Options/RoomAssignment")
<script>
    // Khai báo biến toàn cục
    // Function để MỞ modal (Sửa lại tên gọi cho đồng nhất)
    function openGroupAdmin() {
        if(confirmationNo <=0){
            showToast("Warning", "Please select a row again to edit.", false);
            return
        }
        $('#groupAdminModal').modal('show');
        loadGroupData();
    }

    // Function để ĐÓNG modal
    function closeGroupAdmin() {
        $('#groupAdminModal').modal('hide');
        searchReservation();
    }

    function loadGroupData() {
        $.ajax({
            url: '/Reservation/SearchGroupAdmin',
            type: 'GET',
            data: {
                confirmationNo: confirmationNo || 0,
                sorting: $("#gra_sorting").val() || 1,
                name: $("#gra_name").val() || "",
                roomNo: $("#gra_roomNo").val() || "",
            },
            success: function (res) {
                // Giờ res đã là một mảng DTO chuẩn
                initializeDataGridSearchGRA(res);
            }
        });
    }

    window.openGroupAdmin = openGroupAdmin;

    var idReservation = 0;
    var isPseudo = 0;
    var roomID = 0;
    var shareRoom = 0;
    var reservationStatus = 0;
    var noOfRoom = 0;
    var mg = '';
    var status = '';
    var roomStatus = '';
    var roomNo = '';
    var arivalDate = '';
    var departureDate = '';
    var confirmationNo = '';
    var night = 0;
    var rateAmount = 0;
    var lastname = '';
    var listDataGrAD = [];
    var roomType = '';
    $(document).ready(async function () {
        // Khởi tạo cho standalone page (khi navigate trực tiếp /Reservation/GroupAdmin?key=...)
        var serverData = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.Reservation ?? new System.Collections.Generic.List<object>()));
        if (serverData && serverData.length > 0) {
            // Lấy confirmationNo từ dữ liệu server
            var firstRow = serverData[0];
            if (firstRow && firstRow.ConfirmationNo) {
                confirmationNo = String(firstRow.ConfirmationNo);
            }
            // Auto-mở modal và load data
            $('#groupAdminModal').modal('show');
            initializeDataGridSearchGRA(serverData);
        }
    });
    function getSelectedCheckboxes(name) {
        const checkboxes = document.querySelectorAll(`input[type="checkbox"][name="${name}"]:checked`);
        const values = Array.from(checkboxes).map(checkbox => checkbox.value);
        return values.join(","); // Trả về chuỗi dạng 'a,c,v,c'
    }



    function getSelectedRadio(name) {
        const radio = document.querySelector(`input[type="radio"][name="${name}"]:checked`);
        return radio ? radio.value : null;
    }

