@{
    ViewBag.Title = ViewBag.ReportHeader;
    var listatt = ViewBag.hkpAttendantList;
}

<style>
    #adp_modalForm.ts-wrapper:not(.form-control,.form-select).single .ts-control {
    background-image: none !important;
    }
</style>

<!-- ========================= -->
<!-- MAIN MODAL (XL REQUIRED) -->
<!-- ========================= -->
<div class="modal fade" id="adp_modalMain" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header py-2">
                <h5 class="modal-title" id="adp_reportTitle">Attendant Point</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">
                    <!-- ACTION BUTTONS -->
                    <div class="mb-2">
                        <button id="adp_btnView" class="mui-button mui-button-view">View</button>
                        <button id="adp_btnExportExcel" class="mui-button button-report-excel">Excel</button>
                        <button id="adp_btnNew" class="mui-button mui-button-new">New</button>
                        <button id="adp_btnEdit" class="mui-button mui-button-edit">Edit</button>
                        <button id="adp_btnDelete" class="mui-button mui-button-delete">Delete</button>
                        <button class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>

                    </div>

                   <!-- FILTER -->
                    <div class="mt-1">
                        <div class="row g-2 px-1 align-items-center">

                            <!-- From -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2 col-xl-2">
                                <div class="d-flex align-items-center gap-2">

                                    <label class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 
                                                small fw-bold mb-0 text-nowrap text-md-end">
                                        From:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8" data-date-input data-format="DD/MM/YYYY" business-date data-name="adp_fromDate">
                                        <input type="text"
                                            class="date-ui form-control form-control-sm "
                                            placeholder="dd/mm/yyyy" autocomplete="off" />
                                    </div>

                                </div>
                            </div>

                            <!-- To -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2 col-xl-2">
                                <div class="d-flex align-items-center gap-2">

                                    <label class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 
                                                small fw-bold mb-0 text-nowrap text-md-end">
                                        To:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8" data-date-input data-format="DD/MM/YYYY" business-date data-name="adp_toDate">
                                        <input type="text"
                                            class="date-ui form-control form-control-sm "
                                            placeholder="dd/mm/yyyy" autocomplete="off" />
                                    </div>

                                </div>
                            </div>

                            <!-- Attendant -->
                            <div class="col-12 col-sm-6 col-md-8 col-lg-4 col-xl-4">
                                <div class="d-flex align-items-center gap-2">

                                    <label class="col-4 col-sm-4 col-md-3 col-lg-4 col-xl-4 
                                                small fw-bold mb-0 text-nowrap text-md-end">
                                        Attendant ID:
                                    </label>

                                    <div class="col-8 col-sm-8 col-md-9 col-lg-8 col-xl-8">
                                        <select id="adp_attendant"
                                                name="adp_attendant"
                                                class="tomselect-custom w-100"
                                                multiple>
                                            @foreach (var item in listatt)
                                            {
                                                <option value="@item.ID">@item.Name</option>
                                            }
                                        </select>
                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- LOADING -->
                <div id="adp_loadingSpinner" style="display:none; text-align:center;">
                    <div class="spinner-border"></div>
                </div>

                <!-- GRID (FIXED HEIGHT) -->
                <div class="mui-card">
                    <div id="adp_gridContainer" class="gridContainer" style="height:500px;"></div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- ========================= -->
<!-- NEW / EDIT MODAL -->
<!-- ========================= -->
<div class="modal fade" id="adp_modalForm" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">

            <div class="modal-header py-2">
                <h5 class="modal-title" id="adp_formTitle">New AttendantPoint</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">
                    <button id="adp_btnSave" class="mui-button mui-button-search">Save</button>
                    <button class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>

                <input type="hidden" id="adp_txtid" name="adp_txtid">

                <div class="container-fluid">

                    <!-- ROW 1 -->
                    <div class="row g-2 mb-2">

                        <div class="col-12 col-md-6">
                            <div class="row align-items-center g-2">
                                <label for="adp_fromDatenew"
                                    class="col-4 col-form-label col-form-label-sm text-md-end">
                                    Date
                                </label>
                                <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8" data-date-input data-format="DD/MM/YYYY" business-date data-name="adp_fromDatenew">
                                    <input type="text"
                                        class="date-ui form-control form-control-sm "
                                        placeholder="dd/mm/yyyy" autocomplete="off" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="row align-items-center g-2">
                                <label for="adp_attendantnew"
                                    class="col-5 col-form-label col-form-label-sm text-md-end">
                                    Attendant ID
                                </label>
                                <div class="col-7">
                                    <select id="adp_attendantnew"
                                            name="adp_attendantnew"
                                            class="tomselect-custom">
                                        <option value=""></option>
                                        @foreach (var item in listatt)
                                        {
                                            <option value="@item.ID">@item.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ROW 2 -->
                    <div class="row g-2 mb-2">

                        <div class="col-12 col-md-6">
                            <div class="row align-items-center g-2">
                                <label for="adp_username"
                                    class="col-4 col-form-label col-form-label-sm text-md-end">
                                    Name
                                </label>
                                <div class="col-8">
                                    <input id="adp_username"
                                        class="form-control form-control-sm" readonly>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="row align-items-center g-2">
                                <label for="adp_point"
                                    class="col-5 col-form-label col-form-label-sm text-md-end">
                                    Point
                                </label>
                                <div class="col-7">
                                    <input id="adp_point"
                                        class="form-control form-control-sm">
                                </div>
                            </div>
                        </div>

                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<script>
    // ======================================
    // Attendant Point - Option A (adp_)
    // ======================================
    var adp_Module = (function () {

        let gridInstance = null;
        let selectedRowData = null;
        let modalMain = null;
        let modalForm = null;
        let tomAttendant = null;
        let parsedBusinessDate = null;
        let isInitialized = false;

        function init() {

            modalMain = bootstrap.Modal.getOrCreateInstance(
                document.getElementById("adp_modalMain"),
                { backdrop: "static", keyboard: false }
            );

            modalForm = bootstrap.Modal.getOrCreateInstance(
                document.getElementById("adp_modalForm"),
                { backdrop: "static", keyboard: false }
            );

            $("#adp_modalMain").off("shown.bs.modal").on("shown.bs.modal", async function () {

                if (!isInitialized) {
                    isInitialized = true;

                    await getBusinessDate();
                    initializeTomSelect();
                    initTomSelect('#adp_attendantnew', {

                        render: {
                            option(data, escape) {
                                // Dropdown vẫn hiển thị Name
                                return `<div>${escape(data.text)}</div>`;
                            },

                            item(data, escape) {
                                // Sau khi chọn hiển thị ID
                                return `<div>${escape(data.value)}</div>`;
                            }
                        },

                        onChange: function (value) {
                            const input = document.querySelector('#adp_username');

                            if (!value) {
                                input.value = '';
                                return;
                            }

                            const option = this.options[value];
                            input.value = option.text || '';
                        }

                    });
                    bindEvents();
                }

                if (gridInstance) {
                    gridInstance.repaint();
                }
            });

            $(document).on("hidden.bs.modal", ".modal[id^='adp_modalMain']", function () {
                destroy();
            });
        }

        async function getBusinessDate() {
            return $.ajax({
                url: '/Reservation/GetBusinessDate',
                type: 'GET',
                success: function (result) {
                    const fromDateStr = result.split('T')[0];
                    parsedBusinessDate = new Date(fromDateStr);
                    $("#adp_fromDate").val(fromDateStr);
                    $("#adp_toDate").val(fromDateStr);
                    $("#adp_fromDatenew").val(fromDateStr);
                    loadGridData();
                }
            });
        }

        function initializeTomSelect() {
            const el = document.querySelector("#adp_attendant");
            if (el.tomselect) el.tomselect.destroy();

            tomAttendant = new TomSelect(el, {
                plugins: ['remove_button'],
                maxItems: null
            });
        }

        function bindEvents() {

            $("#adp_btnView").off().on("click", loadGridData);

            $("#adp_btnNew").off().on("click", function () {
                resetForm();
                $("#adp_formTitle").text("New AttendantPoint");
                initDateInputs();
                modalForm.show();
            });

            $("#adp_btnEdit").off().on("click", function () {
                initDateInputs();
                if (!selectedRowData) {
                    showToast("Warning", "Please select a row before Edit.", false);
                    return;
                }

                $("#adp_txtid").val(selectedRowData.id);
                console.log('attendantID',selectedRowData.attendantDate);
                
                UI.setHiddenDate("adp_fromDatenew", selectedRowData.attendantDate);
                setTomSelectValue("#adp_attendantnew",selectedRowData.attendantID);
                $("#adp_point").val(selectedRowData.points);

                $("#adp_formTitle").text("Edit AttendantPoint");
                modalForm.show();
            });

            $("#adp_btnDelete").off().on("click", deleteRow);

            $("#adp_btnSave").off().on("click", saveRow);

            $("#adp_btnExportExcel").off().on("click", exportExcel);
        }

        function loadGridData() {

            $("#adp_loadingSpinner").show();

            $.ajax({
                url: '/HouseKeeping/AttendantPointData',
                type: 'GET',
                data: {
                    fromDate: $("#adp_fromDate").val(),
                    toDate: $("#adp_toDate").val(),
                    attendant: $("#adp_attendant").val()
                },
                traditional: true,
                success: function (result) {
                    renderGrid(result);
                    $("#adp_loadingSpinner").hide();
                },
                error: function () {
                    $("#adp_loadingSpinner").hide();
                }
            });
        }

        function renderGrid(data) {

            if (gridInstance) {
                gridInstance.dispose();
                $("#adp_gridContainer").empty();
            }

            gridInstance = $("#adp_gridContainer").dxDataGrid({
                dataSource: data,
                height: 500,
                selection: { mode: "single" },
                columns: [
                    { dataField: "attendantDate", caption: "Date", dataType: "date", format: "dd/MM/yyyy" },
                    { dataField: "attendantID", caption: "Attendant ID" },
                    { dataField: "points", caption: "Points" },
                    { dataField: "updatedBy", caption: "Updated By" },
                    { dataField: "updatedDate", caption: "Updated Date", dataType: "date", format: "dd/MM/yyyy" },
                    { dataField: "createdBy", caption: "Created By" },
                    { dataField: "createdDate", caption: "Created Date", dataType: "date", format: "dd/MM/yyyy" }
                ],
                paging: { pageSize: 25 },
                filterRow: { visible: true },
                showBorders: true,
                onRowClick: function (e) {
                    selectedRowData = e.data;
                }
            }).dxDataGrid("instance");
        }

        function deleteRow() {
            if (!selectedRowData) {
                showToast("Warning", "Select row before delete.", false);
                return;
            }

            $.post('/HouseKeeping/DeleteAttendantPoint',
                { ID: selectedRowData.id },
                function (res) {
                    if (res.success) {
                        showToast("Success", res.message, true);
                        loadGridData();
                    }
                });
        }

        function saveRow() {

            const payload = {
                ID: $("#adp_txtid").val(),
                Date: $("#adp_fromDatenew").val(),
                AttendantID: $("#adp_attendantnew").val(),
                UserName: $("#adp_username").val(),
                Point: $("#adp_point").val(),
                loginName: JSON.parse(localStorage.getItem("Loginname")),
            };

            $.post('/HouseKeeping/UpdateAttendantPoint',
                payload,
                function (res) {
                    if (res.success) {
                        showToast("Success", res.message, true);
                        modalForm.hide();
                        loadGridData();
                    }
                    else{
                        showToast("Error", res.message, false);

                    }
                });
        }

        function exportExcel() {

            const grid = $("#adp_gridContainer").dxDataGrid("instance");
            const workbook = new ExcelJS.Workbook();
            const worksheet = workbook.addWorksheet("Sheet 1");

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                topLeftCell: { row: 1, column: 1 }
            }).then(function () {
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer]), "AttendantPoint.xlsx");
                });
            });
        }

        function resetForm() {
            $("#adp_txtid").val('');
            $("#adp_attendantnew").val('');
            $("#adp_username").val('');
            $("#adp_point").val('');
            $("#adp_fromDatenew").val(parsedBusinessDate ?
                parsedBusinessDate.toISOString().split('T')[0] : '');
        }

        function destroy() {

            if (gridInstance) {
                gridInstance.dispose();
                $("#adp_gridContainer").empty();
                gridInstance = null;
            }

            if (tomAttendant) {
                tomAttendant.destroy();
                tomAttendant = null;
            }

            selectedRowData = null;
            isInitialized = false;
        }

        function openModal() {
            if (!modalMain) init();
            modalMain.show();
        }

        return {
            init,
            openModal,
            destroy
        };

    })();

    window.openModalAdp = function () {
        adp_Module.openModal();
    };

    $(document).ready(function () {
        adp_Module.init();
    });
</script>