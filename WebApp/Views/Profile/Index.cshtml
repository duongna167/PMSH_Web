        const companyInputs = [
            "#pro_search_idCOM", "#pro_search_txtCodeCOM", "#pro_search_txtAccountCOM", "#pro_search_txtAddressCOM",
            "#pro_search_txtPostalCOM", "#pro_search_txtCompanyCOM", "#pro_search_txtTaxCOM", "#pro_search_txtBusAddressCOM",
