<style>
    #modalProfileIndividual .modal-body {
        flex: 1 1 auto; 
        overflow-y: auto; 
        overflow-x: hidden;
        display: flex;
        flex-direction: column;
    }

    #pro_ind_formContainer {
        flex-grow: 1;
    }

    @@media (max-width: 991.98px) {
        #modalProfileIndividual .mui-card
        {
            min-height: auto !important;
            margin-bottom: 15px;
            padding: 10px;
        }
    }

    @@media (max-width: 767.98px) {
        #modalProfileIndividual .col-form-label
        {
            text-align: left !important; 
            margin-bottom: 0;
        }
    }

    #modalProfileIndividual .row.mb-2 {
        margin-bottom: 0.4rem !important;
    }

    #modalProfileIndividual .col-form-label {
        font-size: 12px !important;
        font-weight: 500;
        line-height: 1.2;
        padding-top: 5px;
        padding-bottom: 5px;
    }

    /* Container full height */
    #pro_ind_formContainer {
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        /* Row chính phải giãn full */
        #pro_ind_formContainer > .row {
            flex: 1;
            align-items: stretch;
        }

            /* Các column phải giãn */
            #pro_ind_formContainer > .row > div {
                display: flex;
            }

                /* Wrapper bên trong column */
                #pro_ind_formContainer > .row > div > div {
                    display: flex;
                    flex-direction: column;
                    width: 100%;
                }

        /* Đẩy các section bên trong giãn đều */
        #pro_ind_formContainer h8 {
            margin-top: 4px;
        }

    /* Grid search bên trái giãn xuống đáy */
    #ind_quick_grid {
        height: 100%;
    }

    /* phần search list giãn */
    #pro_ind_formContainer .border.rounded.bg-light {
        flex-grow: 1;
    }

    /* phần history bên phải đẩy xuống đáy */
    #pro_ind_formContainer .mt-auto {
        margin-top: auto !important;
    }

    .section-title {
        font-weight: 600;
        color: #198754;
        font-size: 13px;
    }

    #ind_txtBlackListReason {
        background-color: #fff !important;
        color: #000 !important;
        border: 1px solid #ced4da !important;
        transition: all 0.2s ease;
    }

        /* Khi kích hoạt Blacklist: Nền đen, chữ trắng */
        #ind_txtBlackListReason.black-active {
            background-color: #000 !important;
            color: #fff !important;
            border-color: #000 !important;
        }
</style>

