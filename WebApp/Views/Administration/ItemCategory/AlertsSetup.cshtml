<!-- Main Modal -->
<div class="modal fade" id="alSp_mainModal" tabindex="-1" aria-labelledby="alSp_mainModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="alSp_mainModalLabel">Alerts Setup</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <button id="alSp_btnView" type="button" class="mui-button mui-button-search">View</button>
                        <button id="alSp_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="alSp_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="alSp_btnDelete" type="button" class="mui-button mui-button-delete">Delete</button>
                        <button id="alSp_btnExportExcel" type="button" class="mui-button mui-button-export">Excel</button>
                        <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal" aria-label="Close">Close</button>
                    </div>

                    <div class="row g-2 mt-1">
                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label for="alSp_filterCode" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Code
                                </label>
                                <div class="col-md-8">
                                    <input id="alSp_filterCode"
                                           name="alSp_filterCode"
                                           type="text"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label for="alSp_filterName" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Name
                                </label>
                                <div class="col-md-8">
                                    <input id="alSp_filterName"
                                           name="alSp_filterName"
                                           type="text"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Status
                                </label>
                                <div class="col-md-8">
                                    <div class="d-flex align-items-center h-100">
                                        <div class="form-check d-flex align-items-center gap-2">
                                            <span class="status-color-box color-clean-uncheck"></span>
                                            <input type="checkbox" id="alSp_chkShowInactive" name="alSp_chkShowInactive">
                                            <label class="form-check-label" for="alSp_chkShowInactive">Show Inactive</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mui-card mt-1">
                    <div id="alSp_gridContainer" class="gridContainer"></div>
                </div>

                <div id="alSp_loadingSpinner"
                     style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                     z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                     height: 100%;display: flex;align-items: center;justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="alSp_itemModal" tabindex="-1" aria-labelledby="alSp_itemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="alSp_itemModalLabel">Add Alerts Setup</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <button type="button" id="alSp_btnSave" class="mui-button mui-button-new">Save</button>
                    <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>

                <form id="alSp_formContainer">
                    <div class="row g-2 mt-1 mb-2">
                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label for="alSp_code" class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Code
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <input id="alSp_code"
                                           name="alSp_code"
                                           type="text"
                                           class="form-control form-control-sm" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Status
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <div class="form-check d-inline-flex align-items-center gap-2">
                                        <input id="alSp_inactive"
                                               name="alSp_inactive"
                                               type="checkbox" />
                                        <label for="alSp_inactive" class="form-check-label text-danger">
                                            Inactive
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="alSp_name" class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Name
                                </label>
                                <div class="col-md-10">
                                    <input id="alSp_name"
                                           name="alSp_name"
                                           type="text"
                                           class="form-control form-control-sm" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="alSp_description" class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Description
                                </label>
                                <div class="col-md-10">
                                    <textarea id="alSp_description"
                                              name="alSp_description"
                                              rows="4"
                                              class="form-control form-control-sm"
                                              style="height:100px;"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="alSp_id" name="alSp_id" value="0" />
                </form>
            </div>

        </div>
    </div>
</div>

<script>
    var alSp_Module = (() => {
        let alSp_selectedRowData = null;

        const alSp_selectors = {
            mainModal: "#alSp_mainModal",
            itemModal: "#alSp_itemModal",
            form: "#alSp_formContainer",
            grid: "#alSp_gridContainer",
            loading: "#alSp_loadingSpinner",

            filterCode: "#alSp_filterCode",
            filterName: "#alSp_filterName",
            chkShowInactive: "#alSp_chkShowInactive",

            btnView: "#alSp_btnView",
            btnNew: "#alSp_btnNew",
            btnEdit: "#alSp_btnEdit",
            btnDelete: "#alSp_btnDelete",
            btnExportExcel: "#alSp_btnExportExcel",
            btnSave: "#alSp_btnSave",

            modalLabel: "#alSp_itemModalLabel",

            id: "#alSp_id",
            code: "#alSp_code",
            name: "#alSp_name",
            description: "#alSp_description",
            inactive: "#alSp_inactive"
        };

        function alSp_init() {
            alSp_bindEvents();
            alSp_resetForm();
            alSp_loadGrid([]);
            alSp_loadData();
        }

        function alSp_bindEvents() {
            $(document)
                .off("input change", `${alSp_selectors.form} input, ${alSp_selectors.form} select, ${alSp_selectors.form} textarea`)
                .on("input change", `${alSp_selectors.form} input, ${alSp_selectors.form} select, ${alSp_selectors.form} textarea`, function () {
                    if ($(this).hasClass("is-invalid")) {
                        $(this).removeClass("is-invalid");
                        $(this).next(".invalid-feedback").text("");
                    }
                });

            $(alSp_selectors.itemModal)
                .off("hidden.bs.modal")
                .on("hidden.bs.modal", function () {
                    alSp_resetForm();
                    applyValidationErrors([], alSp_selectors.form);
                });

            $(document)
                .off("click", alSp_selectors.btnView)
                .on("click", alSp_selectors.btnView, function () {
                    alSp_loadData();
                });

            $(document)
                .off("click", alSp_selectors.btnNew)
                .on("click", alSp_selectors.btnNew, function () {
                    alSp_openAddModal();
                });

            $(document)
                .off("click", alSp_selectors.btnEdit)
                .on("click", alSp_selectors.btnEdit, function () {
                    alSp_openEditModal();
                });

            $(document)
                .off("click", alSp_selectors.btnSave)
                .on("click", alSp_selectors.btnSave, function () {
                    alSp_save();
                });

            $(document)
                .off("click", alSp_selectors.btnDelete)
                .on("click", alSp_selectors.btnDelete, function () {
                    alSp_delete();
                });

            $(document)
                .off("click", alSp_selectors.btnExportExcel)
                .on("click", alSp_selectors.btnExportExcel, function () {
                    alSp_exportExcel();
                });
        }

        function alSp_resetForm() {
            const alSp_form = $(alSp_selectors.form)[0];
            if (alSp_form) {
                alSp_form.reset();
            }

            $(alSp_selectors.id).val("0");
            $(alSp_selectors.modalLabel).text("Add Alerts Setup");
            alSp_selectedRowData = null;
        }

        function alSp_openAddModal() {
            alSp_resetForm();
            $(alSp_selectors.modalLabel).text("Add Alerts Setup");
            $(alSp_selectors.itemModal).modal("show");
        }

        function alSp_openEditModal() {
            if (!alSp_selectedRowData) {
                showToast("Warning", "Please select a row first!", true);
                return;
            }

            alSp_fillForm(alSp_selectedRowData);
            $(alSp_selectors.modalLabel).text("Update Alerts Setup");
            $(alSp_selectors.itemModal).modal("show");
        }

        function alSp_fillForm(alSp_data) {
            $(alSp_selectors.id).val(alSp_data.id);
            $(alSp_selectors.code).val(alSp_data.code);
            $(alSp_selectors.name).val(alSp_data.description);
            $(alSp_selectors.description).val(alSp_data.description);
            $(alSp_selectors.inactive).prop("checked", alSp_data.inactive);
        }

        function alSp_getSearchModel() {
            return {
                code: $(alSp_selectors.filterCode).val(),
                name: $(alSp_selectors.filterName).val(),
                inactive: $(alSp_selectors.chkShowInactive).prop("checked") ? 1 : 0
            };
        }

        function alSp_getSaveModel() {
            const alSp_id = parseInt($(alSp_selectors.id).val()) || 0;
            let alSp_loginName = (localStorage.getItem("Loginname") || "")
                .trim()
                .replace(/^"(.*)"$/, "$1");
            const alSp_loginUser = parseInt(localStorage.getItem("userID")) || 0;

            return {
                ID: alSp_id,
                Code: $(alSp_selectors.code).val(),
                Description: $(alSp_selectors.name).val(),
                Inactive: $(alSp_selectors.inactive).prop("checked"),
                CreatedBy: alSp_loginName,
                UpdatedBy: alSp_loginName,
                UserInsertID: alSp_loginUser,
                UserUpdateID: alSp_loginUser
            };
        }

        function alSp_showLoading() {
            $(alSp_selectors.loading).show();
        }

        function alSp_hideLoading() {
            $(alSp_selectors.loading).hide();
        }

        function alSp_loadData() {
            alSp_showLoading();

            $.ajax({
                url: "/Administration/GetAlertsSetup",
                type: "GET",
                cache: false,
                data: alSp_getSearchModel(),
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (alSp_data) {
                    alSp_loadGrid(alSp_data || []);
                    alSp_hideLoading();
                },
                error: function () {
                    showToast("Error", "Unable to load data", false);
                    alSp_hideLoading();
                }
            });
        }

        function alSp_loadGrid(alSp_data) {
            $(alSp_selectors.grid).dxDataGrid({
                dataSource: alSp_data,
                height: 500,
                width: "100%",
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                hoverStateEnabled: true,
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "code", caption: "Code", width: "10%" },
                    { dataField: "name", caption: "Name", width: "20%" },
                    { dataField: "description", caption: "Description", width: "30%" },
                    { dataField: "inactive", caption: "Inactive", width: "6%",
                        cellTemplate: function (container, options) {
                            $("<div>")
                                .dxCheckBox({
                                    value: options.value == 1 || options.value === true,
                                    readOnly: true
                                })
                                .css("transform", "scale(0.8)")
                                .appendTo(container);
                        }
                    },
                    { dataField: "createdBy", caption: "Created By", width: "8%" },
                    { dataField: "createdDate", caption: "Created Date", dataType: "date", width: "9%" },
                    { dataField: "updatedBy", caption: "Updated By", width: "8%" },
                    { dataField: "updatedDate", caption: "Updated Date", dataType: "date", width: "9%" }
                ],
                filterRow: { visible: true, applyFilter: "auto" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: { mode: "standard", showScrollbar: "always" },
                onSelectionChanged: function (e) {
                    alSp_selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
                }
            });
        }

        function alSp_save() {
            applyValidationErrors([], alSp_selectors.form);

            const alSp_model = alSp_getSaveModel();

            $.ajax({
                url: "/Administration/AlertsSetupSave",
                type: "POST",
                contentType: "application/json",
                cache: false,
                data: JSON.stringify(alSp_model),
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (alSp_res) {
                    if (alSp_res.success) {
                        showToast("Success", alSp_res.message, true);
                        $(alSp_selectors.itemModal).modal("hide");
                        alSp_loadData();
                        return;
                    }

                    if (alSp_res.errors && alSp_res.errors.length > 0) {
                        applyValidationErrors(alSp_res.errors, alSp_selectors.form);

                        let alSp_generalError = alSp_res.errors.find(x => x.field === "general");
                        let alSp_toastMessage = alSp_generalError ? alSp_generalError.message : "Please check input fields.";

                        showToast("Warning", alSp_toastMessage, false);
                        return;
                    }

                    showToast("Error", alSp_res.message || "Save failed", false);
                },
                error: function () {
                    showToast("Error", "Request error!", false);
                    $(alSp_selectors.itemModal).modal("hide");
                }
            });
        }

        function alSp_delete() {
            if (!alSp_selectedRowData || alSp_selectedRowData.id === 0) {
                showToast("Warning", "Select 1 row, please!", true);
                return;
            }

            if (!confirm("Are you sure you want to delete this record? This action cannot be undone.")) {
                return;
            }

            $.ajax({
                url: `/Administration/DeleteAlertsSetup/` + alSp_selectedRowData.id,
                type: "POST",
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (alSp_result) {
                    if (alSp_result.success) {
                        alSp_loadData();
                        showToast("Success", "Delete Successfully!", true);
                        return;
                    }

                    showToast("Error", alSp_result.message, false);
                },
                error: function () {
                    showToast("Error", "Delete failed!", false);
                    $("#loadingSpinner").hide();
                }
            });
        }

        function alSp_exportExcel() {
            const alSp_grid = $(alSp_selectors.grid).dxDataGrid("instance");

            const alSp_workbook = new ExcelJS.Workbook();
            const alSp_companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const alSp_worksheet = alSp_workbook.addWorksheet("Sheet 1");

            alSp_worksheet.addRow([alSp_companyName]);
            alSp_worksheet.mergeCells("A1:D1");
            alSp_worksheet.getRow(1).font = { bold: true };
            alSp_worksheet.getRow(1).alignment = { vertical: "middle", horizontal: "left" };

            const alSp_now = new Date();
            const alSp_exportDate = alSp_now.toLocaleString("vi-VN");
            alSp_worksheet.addRow(["", "", "", alSp_exportDate]);
            alSp_worksheet.mergeCells("D2:D2");
            alSp_worksheet.getRow(2).alignment = { vertical: "middle", horizontal: "right" };

            alSp_worksheet.addRow([]);
            alSp_worksheet.addRow([]);

            const alSp_reportRow = alSp_worksheet.addRow(["Alerts Setup"]);
            alSp_worksheet.mergeCells("A5:D5");
            alSp_reportRow.font = { bold: true, size: 14 };
            alSp_reportRow.alignment = { vertical: "middle", horizontal: "center" };

            alSp_worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: alSp_grid,
                worksheet: alSp_worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const alSp_lastRow = alSp_worksheet.lastRow.number + 2;
                alSp_worksheet.mergeCells(`A${alSp_lastRow}:D${alSp_lastRow}`);
                alSp_worksheet.getCell(`A${alSp_lastRow}`).alignment = { horizontal: "center" };
                alSp_worksheet.getCell(`A${alSp_lastRow}`).font = { italic: true };

                let alSp_fileName = "Alerts Setup.xlsx";
                alSp_workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), alSp_fileName);
                });
            });
        }

        return {
            init: alSp_init,
            loadData: alSp_loadData,
            openAddModal: alSp_openAddModal,
            openEditModal: alSp_openEditModal
        };
    })();

    $(document).ready(function () {
        alSp_Module.init();
    });

    window.openModalAlertsSetup = function () {
        $("#alSp_mainModal").modal("show");
        alSp_Module.loadData();
    };
</script>