<!-- Main Modal -->
<div class="modal fade" id="orig_mainModal" tabindex="-1" aria-labelledby="orig_mainModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="orig_mainModalLabel">Origin</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <button id="orig_btnView" type="button" class="mui-button mui-button-search">View</button>
                        <button id="orig_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="orig_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="orig_btnDelete" type="button" class="mui-button mui-button-delete">Delete</button>
                        <button id="orig_btnExportExcel" type="button" class="mui-button mui-button-export">Excel</button>
                        <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal" aria-label="Close">Close</button>
                    </div>

                    <div class="row g-2 mt-1">
                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label for="orig_filterCode" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Code
                                </label>
                                <div class="col-md-8">
                                    <input id="orig_filterCode"
                                           name="orig_filterCode"
                                           type="text"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label for="orig_filterName" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Name
                                </label>
                                <div class="col-md-8">
                                    <input id="orig_filterName"
                                           name="orig_filterName"
                                           type="text"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Status
                                </label>
                                <div class="col-md-8">
                                    <div class="d-flex align-items-center h-100">
                                        <div class="form-check d-flex align-items-center gap-2">
                                            <span class="status-color-box color-clean-uncheck"></span>
                                            <input type="checkbox" id="orig_chkShowInactive" name="orig_chkShowInactive">
                                            <label class="form-check-label" for="orig_chkShowInactive">Show Inactive</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mui-card mt-1">
                    <div id="orig_gridContainer" class="gridContainer"></div>
                </div>

                <div id="orig_loadingSpinner"
                     style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                     z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                     height: 100%;display: flex;align-items: center;justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="orig_itemModal" tabindex="-1" aria-labelledby="orig_itemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="orig_itemModalLabel">Add Origin</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <button type="button" id="orig_btnSave" class="mui-button mui-button-new">Save</button>
                    <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>

                <form id="orig_formContainer">
                    <div class="row g-2 mt-1 mb-2">
                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label for="orig_code" class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Code
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <input id="orig_code"
                                           name="orig_code"
                                           type="text"
                                           class="form-control form-control-sm" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Status
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <div class="form-check d-inline-flex align-items-center gap-2">
                                        <input id="orig_inactive"
                                               name="orig_inactive"
                                               type="checkbox" />
                                        <label for="orig_inactive" class="form-check-label text-danger">
                                            Inactive
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="orig_name" class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Name
                                </label>
                                <div class="col-md-10">
                                    <input id="orig_name"
                                           name="orig_name"
                                           type="text"
                                           class="form-control form-control-sm" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="orig_description" class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Description
                                </label>
                                <div class="col-md-10">
                                    <textarea id="orig_description"
                                              name="orig_description"
                                              rows="4"
                                              class="form-control form-control-sm"
                                              style="height:100px;"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="orig_id" name="orig_id" value="0" />
                </form>
            </div>

        </div>
    </div>
</div>

<script>
    var orig_Module = (() => {
        let orig_selectedRowData = null;

        const orig_selectors = {
            mainModal: "#orig_mainModal",
            itemModal: "#orig_itemModal",
            form: "#orig_formContainer",
            grid: "#orig_gridContainer",
            loading: "#orig_loadingSpinner",

            filterCode: "#orig_filterCode",
            filterName: "#orig_filterName",
            chkShowInactive: "#orig_chkShowInactive",

            btnView: "#orig_btnView",
            btnNew: "#orig_btnNew",
            btnEdit: "#orig_btnEdit",
            btnDelete: "#orig_btnDelete",
            btnExportExcel: "#orig_btnExportExcel",
            btnSave: "#orig_btnSave",

            modalLabel: "#orig_itemModalLabel",

            id: "#orig_id",
            code: "#orig_code",
            name: "#orig_name",
            description: "#orig_description",
            inactive: "#orig_inactive"
        };

        function orig_init() {
            orig_bindEvents();
            orig_resetForm();
            orig_loadGrid([]);
            orig_loadData();
        }

        function orig_bindEvents() {
            $(document)
                .off("input change", `${orig_selectors.form} input, ${orig_selectors.form} select, ${orig_selectors.form} textarea`)
                .on("input change", `${orig_selectors.form} input, ${orig_selectors.form} select, ${orig_selectors.form} textarea`, function () {
                    if ($(this).hasClass("is-invalid")) {
                        $(this).removeClass("is-invalid");
                        $(this).next(".invalid-feedback").text("");
                    }
                });

            $(orig_selectors.itemModal)
                .off("hidden.bs.modal")
                .on("hidden.bs.modal", function () {
                    applyValidationErrors([], orig_selectors.form);
                });

            $(document)
                .off("click", orig_selectors.btnView)
                .on("click", orig_selectors.btnView, function () {
                    orig_loadData();
                });

            $(document)
                .off("click", orig_selectors.btnNew)
                .on("click", orig_selectors.btnNew, function () {
                    orig_openAddModal();
                });

            $(document)
                .off("click", orig_selectors.btnEdit)
                .on("click", orig_selectors.btnEdit, function () {
                    orig_openEditModal();
                });

            $(document)
                .off("click", orig_selectors.btnSave)
                .on("click", orig_selectors.btnSave, function () {
                    orig_save();
                });

            $(document)
                .off("click", orig_selectors.btnDelete)
                .on("click", orig_selectors.btnDelete, function () {
                    orig_delete();
                });

            $(document)
                .off("click", orig_selectors.btnExportExcel)
                .on("click", orig_selectors.btnExportExcel, function () {
                    orig_exportExcel();
                });
        }

        function orig_resetForm() {
            const orig_form = $(orig_selectors.form)[0];
            if (orig_form) {
                orig_form.reset();
            }

            $(orig_selectors.id).val("0");
            $(orig_selectors.modalLabel).text("Add Origin");
            orig_selectedRowData = null;
        }

        function orig_openAddModal() {
            orig_resetForm();
            $(orig_selectors.modalLabel).text("Add Origin");
            $(orig_selectors.itemModal).modal("show");
        }

        function orig_openEditModal() {
            if (!orig_selectedRowData) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }

            orig_fillForm(orig_selectedRowData);
            $(orig_selectors.modalLabel).text("Update Origin");
            $(orig_selectors.itemModal).modal("show");
        }

        function orig_fillForm(orig_data) {
            $(orig_selectors.id).val(orig_data.id);
            $(orig_selectors.code).val(orig_data.code);
            $(orig_selectors.name).val(orig_data.name);
            $(orig_selectors.description).val(orig_data.description);
            $(orig_selectors.inactive).prop("checked", orig_data.inactive);
        }

        function orig_getSearchModel() {
            return {
                code: $(orig_selectors.filterCode).val(),
                name: $(orig_selectors.filterName).val(),
                inactive: $(orig_selectors.chkShowInactive).prop("checked") ? 1 : 0
            };
        }

        function orig_getSaveModel() {
            const orig_id = parseInt($(orig_selectors.id).val()) || 0;
            let orig_loginName = (localStorage.getItem("Loginname") || "")
                .trim()
                .replace(/^"(.*)"$/, "$1");
            const orig_loginUser = parseInt(localStorage.getItem("userID")) || 0;

            return {
                ID: orig_id,
                Code: $(orig_selectors.code).val(),
                Name: $(orig_selectors.name).val(),
                Description: $(orig_selectors.description).val(),
                Inactive: $(orig_selectors.inactive).prop("checked"),
                CreatedBy: orig_loginName,
                UpdatedBy: orig_loginName,
                UserInsertID: orig_loginUser,
                UserUpdateID: orig_loginUser
            };
        }

        function orig_showLoading() {
            $(orig_selectors.loading).show();
        }

        function orig_hideLoading() {
            $(orig_selectors.loading).hide();
        }

        function orig_loadData() {
            orig_showLoading();

            $.ajax({
                url: "/Administration/GetOrigin",
                type: "GET",
                cache: false,
                data: orig_getSearchModel(),
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (orig_data) {
                    orig_loadGrid(orig_data || []);
                    orig_hideLoading();
                },
                error: function () {
                    showToast("Error", "Unable to load data", false);
                    orig_hideLoading();
                }
            });
        }

        function orig_loadGrid(orig_data) {
            $(orig_selectors.grid).dxDataGrid({
                dataSource: orig_data,
                height: 500,
                width: "100%",
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                hoverStateEnabled: true,
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "code", caption: "Code", width: "100" },
                    { dataField: "name", caption: "Name", width: "150" },
                    { dataField: "description", caption: "Description", minWidth: 120, cssClass: "col-description"},
                    { dataField: "inactive", caption: "Inactive", width: "60",
                        cellTemplate: function (container, options) {
                            $("<div>")
                                .dxCheckBox({
                                    value: options.value == 1 || options.value === true,
                                    readOnly: true
                                })
                                .css("transform", "scale(0.8)")
                                .appendTo(container);
                        }
                    },
                    { dataField: "createdBy", caption: "Created By", width: "80" },
                    { dataField: "createdDate", caption: "Cre.Date", dataType: "date", width: "80" },
                    { dataField: "updatedBy", caption: "Updated By", width: "80" },
                    { dataField: "updatedDate", caption: "Upd.Date", dataType: "date", width: "80" }
                ],
                filterRow: { visible: true, applyFilter: "auto" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: { mode: "standard", showScrollbar: "always" },
                onSelectionChanged: function (e) {
                    orig_selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
                }
            });
        }

        function orig_save() {
            const orig_model = orig_getSaveModel();

            $.ajax({
                url: "/Administration/OriginSave",
                type: "POST",
                contentType: "application/json",
                cache: false,
                data: JSON.stringify(orig_model),
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (orig_res) {
                    if (orig_res.success) {
                        showToast("Success", orig_res.message, true);
                        $(orig_selectors.itemModal).modal("hide");
                        orig_loadData();
                        return;
                    }

                    if (orig_res.errors && orig_res.errors.length > 0) {
                        applyValidationErrors(orig_res.errors, orig_selectors.form);

                        const orig_generalError = orig_res.errors.find(x => x.field === "general");
                        const orig_toastMessage = orig_generalError
                            ? orig_generalError.message
                            : "Please check input fields.";

                        showToast("Warning", orig_toastMessage, false);
                        return;
                    }

                    showToast("Error", orig_res.message || "Save failed", false);
                },
                error: function () {
                    showToast("Error", "Request error!", false);
                    $(orig_selectors.itemModal).modal("hide");
                }
            });
        }

        function orig_delete() {
            if (!orig_selectedRowData || orig_selectedRowData.id === 0) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }

            if (!confirm("Are you sure you want to delete this record? This action cannot be undone.")) {
                return;
            }

            $.ajax({
                url: `/Administration/DeleteOrigin/` + orig_selectedRowData.id,
                type: "POST",
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (orig_result) {
                    if (orig_result.success) {
                        orig_loadData();
                        showToast("Success", "Delete Successfully!", true);
                        return;
                    }

                    showToast("Error", orig_result.message, false);
                },
                error: function () {
                    console.log("delete " + orig_selectedRowData.id);
                    showToast("Error", "Delete failed!", false);
                    $("#loadingSpinner").hide();
                }
            });
        }

        function orig_exportExcel() {
            const orig_grid = $(orig_selectors.grid).dxDataGrid("instance");

            const orig_workbook = new ExcelJS.Workbook();
            const orig_companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const orig_worksheet = orig_workbook.addWorksheet("Sheet 1");

            orig_worksheet.addRow([orig_companyName]);
            orig_worksheet.mergeCells("A1:D1");
            orig_worksheet.getRow(1).font = { bold: true };
            orig_worksheet.getRow(1).alignment = { vertical: "middle", horizontal: "left" };

            const orig_now = new Date();
            const orig_exportDate = orig_now.toLocaleString("vi-VN");
            orig_worksheet.addRow(["", "", "", orig_exportDate]);
            orig_worksheet.mergeCells("D2:D2");
            orig_worksheet.getRow(2).alignment = { vertical: "middle", horizontal: "right" };

            orig_worksheet.addRow([]);
            orig_worksheet.addRow([]);

            const orig_reportRow = orig_worksheet.addRow(["Origin"]);
            orig_worksheet.mergeCells("A5:D5");
            orig_reportRow.font = { bold: true, size: 14 };
            orig_reportRow.alignment = { vertical: "middle", horizontal: "center" };

            orig_worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: orig_grid,
                worksheet: orig_worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const orig_lastRow = orig_worksheet.lastRow.number + 2;
                orig_worksheet.mergeCells(`A${orig_lastRow}:D${orig_lastRow}`);
                orig_worksheet.getCell(`A${orig_lastRow}`).alignment = { horizontal: "center" };
                orig_worksheet.getCell(`A${orig_lastRow}`).font = { italic: true };

                let orig_fileName = "Origin.xlsx";
                orig_workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), orig_fileName);
                });
            });
        }

        return {
            init: orig_init,
            loadData: orig_loadData,
            openAddModal: orig_openAddModal,
            openEditModal: orig_openEditModal
        };
    })();

    window.openModalOrigin = function () {
        const modalEl = document.querySelector("#orig_mainModal");
        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

        $(modalEl).one("shown.bs.modal", function () {
            orig_Module.init();
        });
        modal.show();
    };
</script>