        // ---------------------------
        // utilities
        // ---------------------------
        function showLoading(show) {
            if (show) $(SEL.spinner).show();
            else $(SEL.spinner).hide();
        }

        function csrfHeaders() {
            return { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() };
        }

        function disposeGrid(selector) {
            try {
                const inst = $(selector).dxDataGrid("instance");
                if (inst) inst.dispose();
            } catch (e) { /* ignore */ }
            $(selector).empty();
        }

        // Safe setter for TomSelect
        function setTomSelectValue(selector, value) {
            const el = document.querySelector(selector);
            const ts = el?.tomselect;
            if (!ts) return;
            ts.setValue(value ? String(value) : '');
        }

        // ---------------------------
        // main search: subgroup filter by group
        // ---------------------------
        function filterSubGroupOptions() {
            const groupId = $(SEL.group).val();

            $(`${SEL.subgroup} option`).each(function () {
                const subgroupGroupId = $(this).data("groupid");
                if (!groupId || subgroupGroupId == groupId || $(this).val() === "") $(this).show();
                else $(this).hide();
            });

            $(SEL.subgroup).val("");
        }

        // ---------------------------
        // edit: enable/disable checkbox panels depending on group type
        // ---------------------------
        function applyGroupTypeUI(groupType) {
            console.log('groupType',groupType);
            
            // default
            $(SEL.memberShip).prop("disabled", true);
            $(SEL.generateInclusive).prop("disabled", true);
            $(SEL.trackNights).prop("disabled", true);
            $(SEL.interHotelSales).prop("disabled", true);
            $(SEL.eft).prop("disabled", true);
            $(SEL.manual).prop("disabled", true);

            if (groupType === 0) {
                $(SEL.frontOfficePayments).prop("disabled", true);
                $(SEL.arPayments).prop("disabled", true);
                $(SEL.depositPayments).prop("disabled", true);

                $(SEL.creditCard).prop("disabled", true);
                $(SEL.cash).prop("disabled", true);
                $(SEL.check).prop("disabled", true);
                $(SEL.others).prop("disabled", true);

                $(SEL.revenueGroup).prop("disabled", false);
                $(SEL.manualPosting).prop("disabled", false);
                $(SEL.paidOut).prop("disabled", false);

                $(SEL.transType).prop("disabled", false).prop("selectedIndex", 0);
                $(SEL.arAccount).prop("disabled", true).val("");
            }
            else if (groupType === 1) {
                $(SEL.frontOfficePayments).prop("disabled", false);
                $(SEL.arPayments).prop("disabled", false);
                $(SEL.depositPayments).prop("disabled", false);

                $(SEL.creditCard).prop("disabled", false);
                $(SEL.cash).prop("disabled", false);
                $(SEL.check).prop("disabled", false);
                $(SEL.others).prop("disabled", false);

                $(SEL.revenueGroup).prop("disabled", true).prop("checked", false);
                $(SEL.manualPosting).prop("disabled", true).prop("checked", false);
                $(SEL.paidOut).prop("disabled", true).prop("checked", false);

                $(SEL.transType).prop("disabled", true);
                $(SEL.transType).prop("selectedIndex", $(SEL.transType + " option").length - 1);

                $(SEL.arAccount).prop("disabled", false);
            }
            else if (groupType === 2) {
                $(SEL.frontOfficePayments).prop("disabled", false);
                $(SEL.arPayments).prop("disabled", false);
                $(SEL.depositPayments).prop("disabled", false);

                $(SEL.creditCard).prop("disabled", false);
                $(SEL.cash).prop("disabled", false);
                $(SEL.check).prop("disabled", false);
                $(SEL.others).prop("disabled", false);

                $(SEL.transType).prop("disabled", true);
                $(SEL.transType).prop("selectedIndex", $(SEL.transType + " option").length - 1);

                $(SEL.arAccount).prop("disabled", true).val("");
            }
        }

        // ---------------------------
        // TomSelect: init + bind change ONCE (do not re-init on change)
        // ---------------------------
        function ensureSubGroupTomSelectReady() {
            initTomSelect('#trans_transactionNewSubGroupList', {
                placeholder: 'Please choose Group',
                render: {
                    option(data, escape) { return `<div>${escape(data.text)}</div>`; },
                    item(data, escape) { return `<div>${escape(data.value)}</div>`; }
                }
            });

            const ts = document.querySelector('#trans_transactionNewSubGroupList')?.tomselect;
            if (!ts) return;

            if (!ts._boundChange) {
                ts._boundChange = true;

                ts.on('change', function (value) {
                    syncSubGroupToInputs(ts, value);
                });
            }
        }

        function syncSubGroupToInputs(ts, value) {            
            const input = document.querySelector('#trans_groupnew');
            if (!input) return;

            if (!value) {
                console.log('value',value);
                
                input.value = '';
                $(SEL.groupnew).val("").removeData("groupid");
                $(SEL.generateID).val("");
                $(SEL.groupType).val("");
                $(SEL.groupCode).val("");
                $(SEL.transactionGroupID).val("");
                applyGroupTypeUI(null);
                return;
            }

            const opt = ts.options[value];
            input.value = opt?.text || '';

            $(SEL.groupnew).val(opt?.Description ?? "").data("groupid", opt?.TransactionGroupID ?? "");
            $(SEL.generateID).val(opt?.GenerateID ?? "");
            $(SEL.groupType).val(opt?.GroupType ?? opt?.Type ?? "");
            $(SEL.groupCode).val(opt?.Code ?? "");
            $(SEL.transactionGroupID).val(opt?.TransactionGroupID ?? "");

            applyGroupTypeUI(opt?.GroupType ?? opt?.Type ?? null);
        }

        // ---------------------------
        // validation
        // ---------------------------
        function validateEdit() {
            const codeNew = ($(SEL.codenew).val() || "").trim();
            const descNew = ($(SEL.descriptionnew).val() || "").trim();
            const subgroup = $(SEL.newSubGroup).val() || "";
            const dfprice = ($(SEL.price).val() || "").trim();
            const currency = $(SEL.currency).val() || "";
            const transType = $(SEL.transType).val() || "";
            const adjustCode = ($(SEL.adjNew).val() || "").trim();

            if (codeNew === "") { showToast("Error", "Code is not empty.", false); $(SEL.codenew).focus(); return false; }
            if (descNew === "") { showToast("Error", "Description is not empty.", false); $(SEL.descriptionnew).focus(); return false; }
            if (subgroup === "") { showToast("Error", "Subgroup is not empty.", false); $(SEL.newSubGroup).focus(); return false; }
            if (dfprice === "" || isNaN(parseFloat(dfprice))) { showToast("Error", "Price must be a valid number and cannot be empty.", false); $(SEL.price).focus(); return false; }
            if (currency === "" || currency === "0") { showToast("Warning", "Please select a currency.", false); $(SEL.currency).focus(); return false; }
            if (transType === "" || transType === "-1") { showToast("Warning", "Please select a transaction type.", false); $(SEL.transType).focus(); return false; }
            if (adjustCode !== "" && adjustCode === codeNew) {
                showToast("Warning", "Adjust code not equal Trans. Code. Please choose another Adjust code.", false);
                $(SEL.adjNew).focus();
                return false;
            }

            return true;
        }

        // ---------------------------
        // main grid
        // ---------------------------
        function initMainGrid(data) {
            disposeGrid(SEL.grid);
            _selectedMain = null;

            _gridMain = $(SEL.grid).dxDataGrid({
                dataSource: data || [],
                showBorders: true,
                selection: { mode: "single" },
                columnAutoWidth: true,
                filterRow: { visible: true, applyFilter: "auto" },
                scrolling: { mode: "standard", showScrollbar: "always", scrollByContent: true, useNative: true },
                paging: { pageSize: 50 },
                pager: {
                    visible: true,
                    allowedPageSizes: [50, 100, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },

                columns: [
                    { dataField: "ID", caption: "ID", visible: false },
                    {
                        dataField: "IsActive",
                        caption: "Active",
                        dataType: "boolean",
                        cellTemplate: function (container, options) {
                            const isChecked = options.value === "True" || options.value === true;
                            $("<input>")
                                .attr("type", "checkbox")
                                .prop("checked", isChecked)
                                .prop("disabled", true)
                                .css({ width: "15px", height: "15px" })
                                .appendTo(container);
                        }
                    },
                    { dataField: "GroupCode", caption: "Group Code", width: "90" },
                    { dataField: "SubgroupCode", caption: "Sub Group Code", width: "100" },
                    { dataField: "Code", caption: "Code", width: "100" },
                    { dataField: "Description", caption: "Description", minWidth: 120,cssClass: "col-description" },
                    { dataField: "DefaultPrice", caption: "Default Price", format: "#,##0.00", dataType: "number", width: "100" },
                    { dataField: "CurrencyID", caption: "Cur", width: "50" },
                    { dataField: "AdjustmentCode", caption: "Adj.Code", width: "80" },
                    { dataField: "TransactionTypeName", caption: "Trans. Type", width: "100" },

                    booleanCol("RevenueGroup", "Rev.Grp"),
                    booleanCol("ManualPosting", "Man.Post"),
                    booleanCol("TaxInclude", "Tax Inc."),
                    booleanCol("FOPayments", "FO Pay"),
                    booleanCol("ARPayments", "AR Pay"),
                    booleanCol("DepositPayments", "Dep.Pay"),
                    booleanCol("Paidout", "Paid Out"),

                    { dataField: "PaymentTypeName", caption: "Payment Type", width: 100 }
                ],

                onRowClick: function (e) {
                    _selectedMain = e.data || null;
                }
            }).dxDataGrid("instance");

            function booleanCol(field, caption) {
                return {
                    dataField: field,
                    caption: caption,
                    dataType: "boolean",
                    width: 65,
                    cellTemplate: function (container, options) {
                        const isChecked = options.value === "True" || options.value === true;
                        $("<input>")
                            .attr("type", "checkbox")
                            .prop("checked", isChecked)
                            .prop("disabled", true)
                            .css({ width: "30px", height: "15px" })
                            .appendTo(container);
                    }
                };
            }
        }

