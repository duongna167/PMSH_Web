<script>
    function parseReservationDateToIso(value) {
        if (!value) return null;
        const raw = String(value).trim().split(' ')[0];
        if (!raw) return null;

        // ISO yyyy-MM-dd
        if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw;

        // dd/MM/yyyy or dd/MM/yy
        const m = raw.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2}|\d{4})$/);
        if (m) {
            const dd = String(m[1]).padStart(2, '0');
            const mm = String(m[2]).padStart(2, '0');
            let yy = String(m[3]);
            if (yy.length === 2) {
                // assume 20xx
                yy = String(2000 + parseInt(yy, 10));
            }
            return `${yy}-${mm}-${dd}`;
        }

        // fallback: let Date parse attempt (rare)
        const d = new Date(raw);
        if (!isNaN(d.getTime())) {
            const yyyy = d.getFullYear();
            const mm = String(d.getMonth() + 1).padStart(2, '0');
            const dd = String(d.getDate()).padStart(2, '0');
            return `${yyyy}-${mm}-${dd}`;
        }
        return null;
    }

    function getHiddenDateValue(name) {
        const v = $(`input[type="hidden"][name="${name}"]`).val();
        return v ? String(v).trim() : '';
    }

    function parseLocalizedNumber(value) {
        if (value == null) return 0;
        if (typeof value === 'number') return isNaN(value) ? 0 : value;
        const s = String(value).trim();
        if (!s) return 0;

        // remove spaces
        const normalized = s.replace(/\s/g, '');

        // If both '.' and ',' exist -> assume '.' thousands and ',' decimal (vi/de)
        if (normalized.includes('.') && normalized.includes(',')) {
            const n = Number(normalized.replace(/\./g, '').replace(',', '.'));
            return isNaN(n) ? 0 : n;
        }
        // Only ',' -> decimal comma
        if (normalized.includes(',')) {
            const n = Number(normalized.replace(',', '.'));
            return isNaN(n) ? 0 : n;
        }
        // Only '.' could be thousands or decimal. If it's 1-3 groups of 3 digits -> thousands.
        if (/^-?\d{1,3}(\.\d{3})+$/.test(normalized)) {
            const n = Number(normalized.replace(/\./g, ''));
            return isNaN(n) ? 0 : n;
        }
        const n = Number(normalized);
        return isNaN(n) ? 0 : n;
    }

    function openModalDeposit() {
        if (idReservation === 0) {
            showToast('Warning', 'Please choose booking', false);
            return;
        }
        GetDepositRequestByReservationID(idReservation);
        localStorage.setItem("currentFromID", "modalDeposit");
        const crashierLogin = localStorage.getItem("crashierLogin");
        if (crashierLogin == "NotYet") {
            openModalShilftLogin();

