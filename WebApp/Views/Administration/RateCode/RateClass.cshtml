@using DevExpress.XtraReports.UI

@{
    var selectedReport = @ViewBag.ReportHeader;
}

<div class="modal fade" id="rtClass_modalMain" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-centered ">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="rtClass_modalTitle">Rate Class</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">
                        <!-- ACTIONS -->
                    <div>
                        <button id="rtClass_btnView" type="button" class="mui-button mui-button-new">View</button>
                        <button id="rtClass_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="rtClass_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="rtClass_btnDelete" type="button" class="mui-button button-report-delete">Delete</button>
                        <button id="rtClass_btnExportExcel" type="button" class="mui-button mui-button-export">Excel</button>
                        <button id="rtClass_btnClose" type="button" class="mui-button mui-button-new ms-auto">Close</button>
                    </div>

                    <!-- FILTER (Bootstrap 5 ERP-style: dense, nested rows, right-aligned labels, compact spacing) -->
                    <div class="mt-1">
                        <div class="row g-2 align-items-center">

                            <!-- Code -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-4 col-xl-3">
                                <div class="row g-1 align-items-center">
                                    <label for="rtClass_codeInput"
                                        class="col-4 col-sm-4 col-md-4 col-lg-3 col-xl-3 col-form-label col-form-label-sm text-md-end mb-0 text-nowrap">
                                        Code
                                    </label>
                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <input type="text"
                                            id="rtClass_codeInput"
                                            name="rtClass_codeInput"
                                            class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>

                            <!-- Name -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-4 col-xl-3">
                                <div class="row g-1 align-items-center">
                                    <label for="rtClass_nameInput"
                                        class="col-4 col-sm-4 col-md-4 col-lg-4 col-xl-4 col-form-label col-form-label-sm text-md-end mb-0 text-nowrap">
                                        Name
                                    </label>
                                    <div class="col-8 col-sm-8 col-md-8 col-lg-8 col-xl-8">
                                        <input type="text"
                                            id="rtClass_nameInput"
                                            name="rtClass_nameInput"
                                            class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>

                            <!-- Show Inactive -->
                            <div class="col-12 col-sm-6 col-md-4 col-lg-4 col-xl-3">
                                <div class="row g-1 align-items-center">
                                    <label for="rtClass_chkShowInactive"
                                        class="col-4 col-sm-4 col-md-6 col-lg-4 col-xl-4 col-form-label col-form-label-sm text-md-end mb-0 text-nowrap">
                                        Show Inactive
                                    </label>
                                    <div class="col-8 col-sm-8 col-md-6 col-lg-8 col-xl-8">
                                        <div class="form-check mb-0 d-flex align-items-center gap-2">
                                            <input class="ms-2"
                                                type="checkbox"
                                                id="rtClass_chkShowInactive"
                                                name="rtClass_chkShowInactive">
                                            <label class="form-check-label mb-0" for="rtClass_chkShowInactive">Yes</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- GRID -->
                <div class="mui-card">
                    <div id="rtClass_gridContainer" class="gridContainer" style="height: 520px;"></div>
                </div>

                <!-- LOADING -->
                <div id="rtClass_loadingSpinner"
                    style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                    z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                    height: 100%;display: flex;align-items: center;justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- UPSERT MODAL (XL per requirement) -->
<div class="modal fade" id="rtClass_modalUpsert" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h6 class="modal-title" id="rtClass_upsertTitle">Rate Class</h6>
            </div>

            <div class="modal-body mb-2">

                <div class="search-filter">
                    <button type="button" id="rtClass_btnSave" class="mui-button mui-button-save">Save</button>
                    <button type="button" id="rtClass_btnCloseUpsert" data-bs-dismiss="modal" class="mui-button mui-button-close">Close</button>
                </div>

                <form id="rtClass_form" novalidate>
                    <input type="hidden" id="rtClass_id" name="rtClass_id" value="0" />

                    <div class="row g-2">

                        <div class="col-12 col-lg-6">
                            <div class="row g-1 align-items-center">
                                <label for="rtClass_code" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Code <span class="text-danger">*</span>
                                </label>
                                <div class="col-md-8">
                                    <input type="text" id="rtClass_code" name="code" class="form-control form-control-sm" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-1 align-items-center">
                                <label for="rtClass_inactive" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Inactive
                                </label>
                                <div class="col-md-8">
                                    <div class="form-check mb-0">
                                        <input type="checkbox" id="rtClass_inactive" name="inactive" class="form-check-input mt-0" />
                                        <label class="form-check-label text-danger" for="rtClass_inactive">Yes</label>
                                    </div>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-1 align-items-center">
                                <label for="rtClass_name" class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Name <span class="text-danger">*</span>
                                </label>
                                <div class="col-md-10">
                                    <input type="text" id="rtClass_name" name="name" class="form-control form-control-sm" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-1 align-items-start">
                                <label for="rtClass_description" class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Description
                                </label>
                                <div class="col-md-10">
                                    <textarea id="rtClass_description" name="description" class="form-control form-control-sm" rows="3" style="height: 100px;"></textarea>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                    </div>

                </form>

            </div>

        </div>
    </div>
</div>

<script>
    var rtClass_Module = (function () {

        let mainModal = null;
        let upsertModal = null;

        let gridInstance = null;
        let selectedRow = null;

        const sel = {
            modalMain: "#rtClass_modalMain",
            modalUpsert: "#rtClass_modalUpsert",

            btnView: "#rtClass_btnView",
            btnNew: "#rtClass_btnNew",
            btnEdit: "#rtClass_btnEdit",
            btnDelete: "#rtClass_btnDelete",
            btnExportExcel: "#rtClass_btnExportExcel",
            btnClose: "#rtClass_btnClose",

            codeInput: "#rtClass_codeInput",
            nameInput: "#rtClass_nameInput",
            chkShowInactive: "#rtClass_chkShowInactive",

            grid: "#rtClass_gridContainer",
            loading: "#rtClass_loadingSpinner",

            form: "#rtClass_form",
            id: "#rtClass_id",
            code: "#rtClass_code",
            name: "#rtClass_name",
            description: "#rtClass_description",
            inactive: "#rtClass_inactive",

            upsertTitle: "#rtClass_upsertTitle",
            btnSave: "#rtClass_btnSave"
        };

        function init() {
            DevExpress.localization.locale("vi");

            mainModal = bootstrap.Modal.getOrCreateInstance(document.querySelector(sel.modalMain), { backdrop: "static" });
            upsertModal = bootstrap.Modal.getOrCreateInstance(document.querySelector(sel.modalUpsert), { backdrop: "static" });

            $(sel.modalMain).off("shown.bs.modal.rtClass").on("shown.bs.modal.rtClass", function () {
                bindEvents();
                reloadGrid();
            });

            $(sel.modalMain).off("hidden.bs.modal.rtClass").on("hidden.bs.modal.rtClass", function () {
                cleanup();
            });

            $(sel.modalUpsert).off("hidden.bs.modal.rtClass").on("hidden.bs.modal.rtClass", function () {
                clearForm();
                if (typeof window.applyValidationErrors === "function") applyValidationErrors([], sel.form);
            });
        }

        function open() {
            mainModal.show();
        }

        function bindEvents() {
            $(document).off("click.rtClass", sel.btnView).on("click.rtClass", sel.btnView, function () {
                reloadGrid();
            });

            $(document).off("change.rtClass", sel.chkShowInactive).on("change.rtClass", sel.chkShowInactive, function () {
                reloadGrid();
            });

            // Optional: auto-search on enter
            $(document).off("keydown.rtClass", sel.codeInput).on("keydown.rtClass", sel.codeInput, function (e) {
                if (e.key === "Enter") reloadGrid();
            });
            $(document).off("keydown.rtClass", sel.nameInput).on("keydown.rtClass", sel.nameInput, function (e) {
                if (e.key === "Enter") reloadGrid();
            });

            $(document).off("click.rtClass", sel.btnNew).on("click.rtClass", sel.btnNew, function () {
                openNew();
            });

            $(document).off("click.rtClass", sel.btnEdit).on("click.rtClass", sel.btnEdit, function () {
                openEdit();
            });

            $(document).off("click.rtClass", sel.btnDelete).on("click.rtClass", sel.btnDelete, function () {
                doDelete();
            });

            $(document).off("click.rtClass", sel.btnExportExcel).on("click.rtClass", sel.btnExportExcel, function () {
                exportExcel();
            });

            $(document).off("click.rtClass", sel.btnClose).on("click.rtClass", sel.btnClose, function () {
                mainModal.hide();
            });

            $(document).off("click.rtClass", sel.btnSave).on("click.rtClass", sel.btnSave, function () {
                save();
            });
        }

        function showLoading(on) {
            if (on) $(sel.loading).show(); else $(sel.loading).hide();
        }

        function getFilterPayload() {
            return {
                code: $(sel.codeInput).val(),
                name: $(sel.nameInput).val(),
                inactive: $(sel.chkShowInactive).is(":checked") ? 1 : 0
            };
        }

        function reloadGrid() {
            showLoading(true);

            $.ajax({
                url: "/Administration/RateCode/GetAllRateClass",
                type: "GET",
                data: getFilterPayload(),
                headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() },
                success: function (result) {
                    const rows = result?.data || [];
                    renderGrid(rows);

                    if (!rows.length) showToast("Warning", "No records found.", false);
                    showLoading(false);
                },
                error: function () {
                    showToast("Error", "Unable to load data.", false);
                    showLoading(false);
                    destroyGrid();
                }
            });
        }

        function destroyGrid() {
            try {
                if (gridInstance) {
                    gridInstance.dispose();
                    gridInstance = null;
                }
            } catch { }
            $(sel.grid).empty();
            selectedRow = null;
        }

        function renderGrid(data) {
            destroyGrid();

            gridInstance = $(sel.grid).dxDataGrid({
                dataSource: data,
                showBorders: true,
                height: "100%",
                width: "100%",

                allowColumnResizing: true,
                columnAutoWidth: true,
                selection: { mode: "single" },

                paging: { pageSize: 50 },
                pager: {
                    visible: true,
                    allowedPageSizes: [50, 100, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: { visible: true, applyFilter: "auto" },

                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "code", caption: "Code", width: 120 },
                    { dataField: "name", caption: "Name", width: 200 },
                    { dataField: "description", caption: "Description", minWidth: 260 },
                    { dataField: "createdBy", caption: "Created By", width: 140 },
                    {
                        dataField: "inactive",
                        caption: "Inactive",
                        width: 110,
                        alignment: "center",
                        cellTemplate: function (container, options) {
                            $("<div>").dxCheckBox({ value: options.value == 1, readOnly: true }).appendTo(container);
                        }
                    },
                    { dataField: "createdDate", caption: "Created Date", width: 140, dataType: "date", format: "dd/MM/yyyy" },
                    { dataField: "updatedBy", caption: "Updated By", width: 140 },
                    { dataField: "updatedDate", caption: "Updated Date", width: 140, dataType: "date", format: "dd/MM/yyyy" }
                ],

                onRowClick: function (e) {
                    selectedRow = e.data;
                },
                onSelectionChanged: function (e) {
                    selectedRow = e.selectedRowsData[0] || null;
                }
            }).dxDataGrid("instance");
        }

        function clearForm() {
            $(sel.id).val(0);
            $(sel.code).val("");
            $(sel.name).val("");
            $(sel.description).val("");
            $(sel.inactive).prop("checked", false);
        }

        function openNew() {
            clearForm();
            if (typeof window.applyValidationErrors === "function") applyValidationErrors([], sel.form);
            $(sel.upsertTitle).text("New Rate Class");
            upsertModal.show();
        }

        function openEdit() {
            if (!selectedRow) {
                showToast("Warning", "Please select 1 row to update.", false);
                return;
            }

            clearForm();
            if (typeof window.applyValidationErrors === "function") applyValidationErrors([], sel.form);

            $(sel.id).val(selectedRow.id);
            $(sel.code).val(selectedRow.code);
            $(sel.name).val(selectedRow.name);
            $(sel.description).val(selectedRow.description);
            $(sel.inactive).prop("checked", selectedRow.inactive == 1);

            $(sel.upsertTitle).text("Edit Rate Class");
            upsertModal.show();
        }

        function save() {
            showLoading(true);

            $.ajax({
                url: "/Administration/RateCode/RateClassSave",
                type: "POST",
                data: {
                    idRateClass: $(sel.id).val(),
                    codeClass: $(sel.code).val(),
                    nameClass: $(sel.name).val(),
                    descriptionaccty: $(sel.description).val(),
                    inactive: $(sel.inactive).is(":checked") ? 1 : 0,
                    user: localStorage.getItem("Loginname")
                },
                headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() },
                success: function (result) {
                    showLoading(false);

                    if (result?.success) {
                        showToast("Success", result.message, true);
                        upsertModal.hide();
                        reloadGrid();
                    } else {
                        if (typeof window.applyValidationErrors === "function") {
                            applyValidationErrors(result?.errors || [], sel.form);
                        } else {
                            showToast("Error", result?.message || "Save failed.", false);
                        }
                    }
                },
                error: function (xhr) {
                    showLoading(false);
                    showToast("Error", xhr.responseJSON?.message || "Save failed.", false);
                }
            });
        }

        function doDelete() {
            if (!selectedRow) {
                showToast("Error", "Please select 1 row to delete.", false);
                return;
            }

            if (!confirm("Are you sure you want to delete this record?")) return;

            showLoading(true);

            $.ajax({
                url: "/Administration/RateCode/RateClassDelete",
                type: "POST",
                data: { id: selectedRow.id },
                headers: { "X-CSRF-TOKEN-HEADERNAME": $("input[name='__RequestVerificationToken']").val() },
                success: function (result) {
                    showLoading(false);

                    if (result?.success) {
                        showToast("Success", result.message, true);
                        reloadGrid();
                    } else {
                        showToast("Error", result?.message || "Delete failed.", false);
                    }
                },
                error: function (xhr) {
                    showLoading(false);
                    showToast("Error", xhr.responseJSON?.message || "Delete failed.", false);
                }
            });
        }

        function exportExcel() {
            const grid = $(sel.grid).dxDataGrid("instance");
            if (!grid) {
                showToast("Warning", "Grid is not ready.", false);
                return;
            }

            const workbook = new ExcelJS.Workbook();
            const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const worksheet = workbook.addWorksheet("Sheet 1");

            worksheet.addRow([companyName]);
            worksheet.mergeCells('A1:D1');
            worksheet.getRow(1).font = { bold: true };
            worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

            const now = new Date();
            const exportDate = now.toLocaleString("vi-VN");
            worksheet.addRow(['', '', '', exportDate]);
            worksheet.mergeCells('D2:D2');
            worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

            worksheet.addRow([]);
            worksheet.addRow([]);

            const reportRow = worksheet.addRow(['Rate Class']);
            worksheet.mergeCells('A5:D5');
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

            worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const lastRow = worksheet.lastRow.number + 2;
                worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
                worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
                worksheet.getCell(`A${lastRow}`).font = { italic: true };

                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "RateClass.xlsx");
                });
            });
        }

        function cleanup() {
            $(document).off(".rtClass");
            destroyGrid();
        }

        return { init, open };

    })();

    // Option A global entry
    window.openModalRtClass = function () {
        rtClass_Module.open();
    };

    $(document).ready(function () {
        rtClass_Module.init();
        // Auto-open if needed:
        // window.openModalRtClass();
    });
</script>