@using DevExpress.XtraReports.UI

@{
    var selectedReport = ViewBag.ReportHeader;
    var listSection = ViewBag.hkpSection;
}

<!-- =========================
     MAIN MODAL (modal-xl)
     ========================= -->
<div class="modal fade" id="lAFQ_modalMain" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Lost And Found Quality</h5>
            </div>

            <div class="modal-body">

                <!-- Toolbar -->
                <div class="search-filter">
                    <button id="lAFQ_btnView" type="button" class="mui-button button-report-view">View</button>
                    <button id="lAFQ_btnNew" type="button" class="mui-button mui-button-new">New</button>
                    <button id="lAFQ_btnUpdate" type="button" class="mui-button mui-button-edit">Edit</button>
                    <button id="lAFQ_btnDelete" type="button" class="mui-button button-report-delete">Delete</button>
                    <button id="lAFQ_btnExportExcel" type="button" class="mui-button mui-button-export">Excel</button>
                    <button id="lAFQ_btnClose" type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                </div>

                <!-- No filter fields in original -->
                <div class="mui-card mt-1">
                    <div id="lAFQ_gridContainer" class="gridContainer"></div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- =========================
     EDIT / NEW MODAL (modal-xl)
     ========================= -->
<div class="modal fade" id="lAFQ_modalEdit" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="lAFQ_modalEditTitle">Lost And Found Quality Screen</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">
                    <button id="lAFQ_btnSave" type="button" class="mui-button mui-button-advance">Ok</button>
                    <button id="lAFQ_btnEditClose" type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                </div>

                <form id="lAFQ_formEdit" novalidate class="mt-1 mb-2">
                    <input type="hidden" id="lAFQ_idzone" name="lAFQ_idzone" />

                    <div class="row g-2">

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end"
                                       for="lAFQ_codenew">Code</label>
                                <div class="col-md-8">
                                    <input type="text"
                                           id="lAFQ_codenew"
                                           name="lAFQ_codenew"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <div class="col-md-4"></div>
                                <div class="col-md-8">
                                    <div class="form-check">
                                        <input
                                               type="checkbox"
                                               id="lAFQ_isActivenew"
                                               name="lAFQ_isActivenew"
                                               value="1"
                                               checked>
                                        <label class="form-check-label" for="lAFQ_isActivenew">Inactive</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-8">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-3 col-form-label col-form-label-sm text-md-end"
                                       for="lAFQ_descriptionnew">Name</label>
                                <div class="col-md-9">
                                    <input type="text"
                                           id="lAFQ_descriptionnew"
                                           name="lAFQ_descriptionnew"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

<div id="lAFQ_loadingSpinner"
    style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
    z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
    height: 100%;display: flex;align-items: center;justify-content: center;">
    <div class="spinner-border text-primary"></div>
</div>

<script>
    var lAFQ_Module = (function () {
        "use strict";

        const SEL = {
            modalMain: "#lAFQ_modalMain",
            modalEdit: "#lAFQ_modalEdit",
            spinner: "#lAFQ_loadingSpinner",

            btnView: "#lAFQ_btnView",
            btnNew: "#lAFQ_btnNew",
            btnUpdate: "#lAFQ_btnUpdate",
            btnDelete: "#lAFQ_btnDelete",
            btnExportExcel: "#lAFQ_btnExportExcel",
            btnSave: "#lAFQ_btnSave",

            grid: "#lAFQ_gridContainer",

            formEdit: "#lAFQ_formEdit",
            modalEditTitle: "#lAFQ_modalEditTitle",

            idzone: "#lAFQ_idzone",
            codenew: "#lAFQ_codenew",
            descriptionnew: "#lAFQ_descriptionnew",
            isActivenew: "#lAFQ_isActivenew"
        };

        let _gridInstance = null;
        let _selectedRowData = null;
        let _bound = false;

        function showLoading(show) {
            if (show) $(SEL.spinner).show();
            else $(SEL.spinner).hide();
        }

        function csrfHeaders() {
            return {
                "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
            };
        }

        function disposeGrid() {
            try {
                const inst = $(SEL.grid).dxDataGrid("instance");
                if (inst) inst.dispose();
            } catch (e) { }

            _gridInstance = null;
            _selectedRowData = null;
            $(SEL.grid).empty();
        }

        function clearForm() {
            $(SEL.codenew).val("");
            $(SEL.descriptionnew).val("");
            $(SEL.idzone).val("");
            $(SEL.isActivenew).prop("checked", false);
        }

        function fillFormFromRow(row) {
            $(SEL.idzone).val(row.ID || "");
            $(SEL.codenew).val(row.Code || "");
            $(SEL.descriptionnew).val(row.Name || "");
            $(SEL.isActivenew).prop("checked", row.Inactive === true || row.Inactive === "True" || row.Inactive === 1);
        }

        function validateForm() {
            const codeNew = $(SEL.codenew).val().trim();
            const descriptionNew = $(SEL.descriptionnew).val().trim();

            if (codeNew === "") {
                showToast("Error", "Code cannot be blank.", false);
                $(SEL.codenew).focus();
                return false;
            }

            if (descriptionNew === "") {
                showToast("Error", "Description cannot be blank.", false);
                $(SEL.descriptionnew).focus();
                return false;
            }

            return true;
        }

        function getSavePayload() {
            return {
                id: $(SEL.idzone).val(),
                codenew: $(SEL.codenew).val(),
                descriptionnew: $(SEL.descriptionnew).val(),
                user: localStorage.getItem("Loginname"),
                isActive: $(SEL.isActivenew).is(":checked") ? 1 : 0
            };
        }

        function dxBoolCell(container, options) {
            const checked = (options.value === true || options.value === "True");
            $("<div>")
                .dxCheckBox({
                    value: checked,
                    readOnly: true
                })
                .css("transform", "scale(0.8)")
                .appendTo(container);
        }

        function initGrid(data) {
            disposeGrid();

            _gridInstance = $(SEL.grid).dxDataGrid({
                dataSource: data || [],
                showBorders: true,
                selection: { mode: "single" },
                height: 500,

                columns: [
                    { dataField: "Id", caption: "ID", width: 80, visible: false },
                    { dataField: "Code", caption: "Code", width: 120 },
                    { dataField: "Name", caption: "Name"},
                    { dataField: "Inactive", caption: "Inactive",width: 80,cellTemplate: dxBoolCell},
                    { dataField: "UpdatedBy", caption: "Updated By", width: 120 },
                    { dataField: "UpdateDate", caption: "Updated Date", dataType: "date", format: "dd/MM/yyyy"},
                    { dataField: "CreatedBy", caption: "Created By", width: 120 },
                    { dataField: "CreatedDate", caption: "Created Date", dataType: "date", format: "dd/MM/yyyy"}
                ],

                scrolling: {
                    mode: "standard",
                    showScrollbar: "always",
                    scrollByContent: true
                },
                paging: {
                    pageSize: 50
                },
                pager: {
                    visible: true,
                    allowedPageSizes: [50, 100, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: {
                    visible: true,
                    applyFilter: "auto"
                },

                onSelectionChanged: function (e) {
                    _selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
                },
                onRowClick: function (e) {
                    _selectedRowData = e.data || null;
                }
            }).dxDataGrid("instance");
        }

        function loadData() {
            showLoading(true);

            $.ajax({
                url: "/HouseKeepingAdmin/LostAndFoundQualityData",
                type: "GET",
                data: {},
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (result) {
                    initGrid(result);
                    showLoading(false);
                },
                error: function () {
                    showLoading(false);
                    showToast("Error", "Không thể tải báo cáo.", false);
                }
            });
        }

        function openNew() {
            clearForm();
            $(SEL.modalEditTitle).text("Lost And Found Quality Screen");
            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).show();
        }

        function openEdit() {
            if (!_selectedRowData) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }

            clearForm();
            fillFormFromRow(_selectedRowData);
            $(SEL.modalEditTitle).text("Lost And Found Quality Screen");
            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).show();
        }

        function save() {
            if (!validateForm()) return;

            showLoading(true);

            $.ajax({
                url: "/HouseKeepingAdmin/LostAndFoundQualitySave",
                type: "POST",
                data: getSavePayload(),
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (result) {
                    showLoading(false);

                    if (result.success) {
                        showToast("Success", result.message, true);
                        bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).hide();
                        loadData();
                        clearForm();
                    } else {
                        showToast("Error", "Please select before saving.", false);
                    }
                },
                error: function () {
                    showLoading(false);
                    showToast("Error", "Không thể tải báo cáo.", false);
                }
            });
        }

        function removeSelected() {
            if (!_selectedRowData) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }

            if (!confirm("Are you sure you want to delete item?")) {
                return;
            }

            $.ajax({
                url: "/HouseKeepingAdmin/LostAndFoundQualityDelete",
                type: "POST",
                data: {
                    id: _selectedRowData.ID
                },
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (result) {
                    if (result.success) {
                        showToast("Success", result.message, true);
                        loadData();
                    } else {
                        showToast("Error", result.message, false);
                    }
                },
                error: function () {
                    showToast("Error", "Không thể tải báo cáo.", false);
                    showLoading(false);
                }
            });
        }

        function exportExcel() {
            const grid = $(SEL.grid).dxDataGrid("instance");
            if (!grid) {
                showToast("Error", "No grid data to export.", false);
                return;
            }

            const workbook = new ExcelJS.Workbook();
            const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const worksheet = workbook.addWorksheet("Sheet 1");

            worksheet.addRow([companyName]);
            worksheet.mergeCells("A1:D1");
            worksheet.getRow(1).font = { bold: true };
            worksheet.getRow(1).alignment = { vertical: "middle", horizontal: "left" };

            const now = new Date();
            const exportDate = now.toLocaleString("vi-VN");
            worksheet.addRow(["", "", "", exportDate]);
            worksheet.mergeCells("D2:D2");
            worksheet.getRow(2).alignment = { vertical: "middle", horizontal: "right" };

            worksheet.addRow([]);
            worksheet.addRow([]);

            const reportRow = worksheet.addRow(["Lost And Found Quality"]);
            worksheet.mergeCells("A5:D5");
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { vertical: "middle", horizontal: "center" };

            worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const lastRow = worksheet.lastRow.number + 2;
                worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
                worksheet.getCell(`A${lastRow}`).alignment = { horizontal: "center" };
                worksheet.getCell(`A${lastRow}`).font = { italic: true };

                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "LostAndFoundQuality.xlsx");
                });
            });
        }

        function bindEventsOnce() {
            if (_bound) return;
            _bound = true;

            $(document)
                .off("click.lAFQ", SEL.btnView).on("click.lAFQ", SEL.btnView, loadData)
                .off("click.lAFQ", SEL.btnNew).on("click.lAFQ", SEL.btnNew, openNew)
                .off("click.lAFQ", SEL.btnUpdate).on("click.lAFQ", SEL.btnUpdate, openEdit)
                .off("click.lAFQ", SEL.btnDelete).on("click.lAFQ", SEL.btnDelete, removeSelected)
                .off("click.lAFQ", SEL.btnExportExcel).on("click.lAFQ", SEL.btnExportExcel, exportExcel)
                .off("click.lAFQ", SEL.btnSave).on("click.lAFQ", SEL.btnSave, save);

            $(SEL.modalEdit)
                .off("shown.bs.modal.lAFQ")
                .on("shown.bs.modal.lAFQ", function () {
                })
                .off("hidden.bs.modal.lAFQ")
                .on("hidden.bs.modal.lAFQ", function () {
                    clearForm();
                    showLoading(false);
                });

            $(SEL.modalMain)
                .off("hidden.bs.modal.lAFQ")
                .on("hidden.bs.modal.lAFQ", function () {
                    disposeGrid();
                    showLoading(false);
                });
        }

        function init() {
            bindEventsOnce();
        }

        function open() {
            init();
            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalMain)).show();
            loadData();
        }

        return { init, open };
    })();

    window.openModalLAFQ = function () {
        lAFQ_Module.open();
    };

    $(document).ready(function () {
        window.openModalLAFQ();
    });
</script>