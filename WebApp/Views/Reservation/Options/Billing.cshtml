    // function Print
    function numberToWords(amount) {
        const words = {
          0: "Zero",
          1: "One",
          2: "Two",
          3: "Three",
          4: "Four",
          5: "Five",
          6: "Six",
          7: "Seven",
          8: "Eight",
          9: "Nine",
          10: "Ten",
          11: "Eleven",
          12: "Twelve",
          13: "Thirteen",
          14: "Fourteen",
          15: "Fifteen",
          16: "Sixteen",
          17: "Seventeen",
          18: "Eighteen",
          19: "Nineteen",
          20: "Twenty",
          30: "Thirty",
          40: "Forty",
          50: "Fifty",
          60: "Sixty",
          70: "Seventy",
          80: "Eighty",
          90: "Ninety",
        };

        function convert(n) {
          if (n < 20) return words[n];
          if (n < 100)
            return (
              words[Math.floor(n / 10) * 10] +
              (n % 10 !== 0 ? " " + words[n % 10] : "")
            );
          if (n < 1000)
            return (
              words[Math.floor(n / 100)] +
              " Hundred" +
              (n % 100 !== 0 ? " " + convert(n % 100) : "")
            );
          if (n < 1000000)
            return (
              convert(Math.floor(n / 1000)) +
              " Thousand" +
              (n % 1000 !== 0 ? " " + convert(n % 1000) : "")
            );
          if (n < 1000000000)
            return (
              convert(Math.floor(n / 1000000)) +
              " Million" +
              (n % 1000000 !== 0 ? " " + convert(n % 1000000) : "")
            );
          return n;
        }

        return convert(amount) + " Dong Only";
      }

    function arrayBufferToBase64(buffer) {
        let binary = '';
        const bytes = new Uint8Array(buffer);
        const len = bytes.byteLength;
        for (let i = 0; i < len; i++) {
            binary += String.fromCharCode(bytes[i]);
        }
        return window.btoa(binary);
    }

    async function registerFont(doc, fontPath, fontName, fontStyle) {
        try {
          const fontBytes = await fetch(fontPath).then((res) => {
            if (!res.ok) throw new Error("Font not found: " + fontPath);
            return res.arrayBuffer();
          });
          const fontBase64 = arrayBufferToBase64(fontBytes);
          doc.addFileToVFS(`${fontName}-${fontStyle}.ttf`, fontBase64);
          doc.addFont(`${fontName}-${fontStyle}.ttf`, fontName, fontStyle);
        } catch (e) {
          console.error("Lỗi đăng ký font:", e);
        }
      }

    async function setupFonts(doc) {
        await registerFont(doc, "@Url.Content("~/fonts/Roboto/Roboto-Regular.ttf")", "Roboto", "normal");
        await registerFont(doc, "@Url.Content("~/fonts/Roboto/Roboto-Bold.ttf")", "Roboto", "bold");
        await registerFont(doc, "@Url.Content("~/fonts/Roboto/Roboto-Italic.ttf")", "Roboto", "italic");
    }                               

    async function PrintAndPreview(style) {
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF("p", "mm", "a4");

        // 1. Khởi tạo Font
        await setupFonts(doc);
        doc.setFont("Roboto", "normal");

        // 2. Lấy dữ liệu từ Grid
        const grid = $("#gridContainerBilling").dxDataGrid("instance");
        let rows = (style === 2) ? grid.getSelectedRowsData() : grid.option("dataSource");
        if (!rows || rows.length === 0) return showToast("Warning","Please select the data from the table to print.",true);

       // 3. TÍNH TOÁN TỔNG CỘNG TRỰC TIẾP TỪ DỮ LIỆU BẢNG 
        const totalBalance = rows.reduce((sum, r) => sum + parseFloat(r.amount || 0), 0);

        // --- 4. VẼ HEADER ---
        const now = new Date();
        const dateStr = now.toLocaleDateString("en-GB");
        const timeStr = now.toLocaleTimeString("en-GB", { hour: "2-digit", minute: "2-digit", hour12: true }).toUpperCase();

        doc.setFontSize(9);
        doc.setFont("Roboto", "italic");
        doc.text(`Printed on: ${dateStr} ${timeStr}`, 190, 15, { align: "right" });
        doc.text(`Page 1 of 1`, 190, 20, { align: "right" });

        // Logo ( thẻ <img id="logoSource"> ẩn)
        const img = document.getElementById("logoSource");
        if (img) doc.addImage(img, "PNG", 20, 10, 25, 25);

        doc.setFontSize(14);
        doc.setFont("Roboto", "bold");
        doc.text("BILLING INFORMATION", 105, 45, { align: "center" });

        doc.setFontSize(10);
        doc.setFont("Roboto", "normal");
        doc.text(`Guest: ${lastname || ''}`, 20, 60);
        doc.text(`Arrival Date: ${arivalDate ? arivalDate.split(' ')[0] : ''}`, 20, 65);
        doc.text(`Departure Date: ${departureDate ? departureDate.split(' ')[0] : ''}`, 20, 70);

        doc.text(`Folio No: ${folioNoID || ''}`, 140, 60);
        doc.text(`Confirmation No: ${confirmationNo || ''}`, 140, 65);
        doc.text(`Room No: ${roomNo || ''}`, 140, 70);

        // --- 5. VẼ BẢNG DỮ LIỆU ---
        const tableData = rows.map((r, i) => {
            let dateVal = '';

            if (r.date) {
                const datePart = r.date.split(' ')[0];
                const parts = datePart.split('/');

                if (parts.length === 3) {
                    const day   = parts[0].padStart(2, '0');
                    const month = parts[1].padStart(2, '0');
                    const year  = parts[2];

                    dateVal = `${day}/${month}/${year}`;
                }
            }

            return [
                i + 1,
                dateVal,
                r.description,
                parseFloat(r.amount || 0).toLocaleString("en-US", { minimumFractionDigits: 0 })
            ];
        });


        doc.autoTable({
            startY: 80,
            head: [["No.", "Date", "Description", "VND"]],
            body: tableData,
            theme: "plain",
            styles: { font: "Roboto", fontSize: 9, fontStyle: "bold" }, 
            headStyles: { fontStyle: "bold", borderBottom: 0.5 },
            columnStyles: { 3: { halign: "right" } },
        });

        // --- 6. VẼ TỔNG TIỀN ---
        let finalY = doc.lastAutoTable.finalY + 10;

        const drawLine = (label, value, isBold = false) => {
            if (isBold) doc.setFont("Roboto", "bold");
            else doc.setFont("Roboto", "normal");

            doc.text(label, 140, finalY);
            doc.text(parseFloat(value || 0).toLocaleString("en-US"), 190, finalY, { align: "right" });
            finalY += 6;
        };

        doc.setFontSize(11);
        drawLine("Balance in VND:", totalBalance, true);

        // Dòng tiền bằng chữ
        finalY += 2;
        doc.setFont("Roboto", "italic");
        doc.setFontSize(9);
        if (typeof numberToWords === "function") {
            doc.text("In words: " + numberToWords(totalBalance), 20, finalY);
        }

        // --- 7. CHỮ KÝ ---
        finalY += 20;
        doc.setFont("Roboto", "italic");
        doc.text("Guest's Signature", 45, finalY, { align: "center" });
        doc.text("Cashier's Signature", 155, finalY, { align: "center" });

        finalY += 15;
        doc.setFont("Roboto", "normal");
        doc.text("..........................................", 45, finalY, { align: "center" });
        doc.text("ones", 155, finalY, { align: "center" });

        // Chân trang
        const pageHeight = doc.internal.pageSize.height;
        doc.setFont("Roboto", "bold");
        doc.setFontSize(14);
        doc.text("Thank you for your stay at The Arena Complex", 105, pageHeight - 15, { align: "center" });

        window.open(doc.output("bloburl"), "_blank");
    }
