    function parseBillingAmount(value) {
        if (value === null || value === undefined || value === '') {
            return null;
        }

        if (typeof value === 'number') {
            return isNaN(value) ? null : value;
        }

        const raw = value.toString().trim();
        if (!raw || raw.toLowerCase() === 'null' || raw.toLowerCase() === 'undefined') {
            return null;
        }

        const normalized = raw.replace(/\s/g, '');

        if (normalized.includes('.') && normalized.includes(',')) {
            const localized = Number(normalized.replace(/\./g, '').replace(',', '.'));
            return isNaN(localized) ? null : localized;
        }

        if (normalized.includes(',')) {
            const localized = Number(normalized.replace(',', '.'));
            return isNaN(localized) ? null : localized;
        }

        if (/^-?\d{1,3}(\.\d{3})+$/.test(normalized)) {
            const thousands = Number(normalized.replace(/\./g, ''));
            return isNaN(thousands) ? null : thousands;
        }

        const parsed = Number(normalized);
        return isNaN(parsed) ? null : parsed;
    }
    function formatBillingAmount(value) {
        const parsed = parseBillingAmount(value);
        if (parsed === null) {
            return '0';
        }

        return parsed.toLocaleString('vi-VN', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });
    }
    function normalizeSearchReservationRows(data) {
        if (Array.isArray(data)) return data;
