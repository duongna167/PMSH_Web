@using DevExpress.XtraReports.UI

@{
    ViewBag.Title = ViewBag.ReportHeader;
    var zoneList = ViewBag.ZoneList;
    var restyList = ViewBag.ReservationType;
}

<style>
   
</style>

<div class="modal fade" id="reportModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <!-- Modal Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="reportTitle" style="font-size:20px">Room Availability</h5>
            </div>

            <!-- Modal Body -->
            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <button id="btnPrint" class="mui-button mui-button-new">View</button>
                        <button id="btnExportExcel" class="mui-button mui-button-new" type="button"> Excel</button>
                        <button id="btnCloseAva" class="mui-button mui-button-new" type="button"> Close</button>
                    </div>
                    <div class="d-flex flex-wrap align-items-center gap-2 mt-1 filter-panel">
                        <!-- From Date -->

                        <div class="container-fluid px-0">
                            <div class="row g-2 align-items-center">

                            <div class="d-flex align-items-center">
                                <div class="d-flex align-items-center me-3">
                                    <label class="me-2 mb-0">From :</label>
                                    <div data-date-input data-format="DD/MM/YYYY"  data-name="fromDate">
                                        <input type="text" class="date-ui " placeholder="dd/mm/yyyy"
                                            autocomplete="off" />
                                    </div>
                                </div>

                                <!-- Display No of Days -->
                                <div class="col-auto">
                                    <label class="col-form-label mb-0">Display No of Days:</label>
                                </div>
                                <div class="col-auto">
                                    <select id="displayofday" name="displayofday" class="form-control form-control-sm">
                                        <option value="0"></option>
                                        <option value="1">1</option>
                                        <option value="2">2</option>
                                        <option value="3">3</option>
                                        <option value="4">4</option>
                                        <option value="5">5</option>
                                        <option value="10">10</option>
                                        <option value="15">15</option>
                                        <option value="20">20</option>
                                        <option value="28">28</option>
                                        <option value="30">30</option>
                                        <option value="31">31</option>
                                    </select>
                                </div>

                                <!-- Zone -->
                                <div class="col-auto">
                                    <label class="col-form-label mb-0">Zone:</label>
                                </div>
                                <div class="col-md-3 col-sm-6">
                                    <select id="zone" name="zone" class="tomselect-custom" multiple>
                                        @foreach (var item in zoneList)
                                        {
                                            if (item == zoneList[0])
                                            {
                                                <option value="@item.Code" selected>@item.Code</option>
                                            }
                                            else
                                            {
                                                <option value="@item.Code">@item.Code</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <!-- Res.Type -->
                                <div class="col-auto">
                                    <label class="col-form-label mb-0">Res.Type:</label>
                                </div>
                                <div class="col-md-3 col-sm-6">
                                    <select id="restype" name="restype" class="tomselect-custom" multiple>
                                        @foreach (var item in restyList)
                                        {
                                            <option value="@item.ID">@item.Name</option>
                                        }
                                    </select>
                                </div>

                            </div>
                        </div>

                        <div class="container-fluid px-0 mt-2">
                            <div class="row g-3">

                                <div class="col-auto d-flex align-items-center gap-2">
                                    <span class="status-color-box color-clean-uncheck"></span>
                                    <input type="checkbox" id="showNonDeduct" name="includeOptions" value="1">
                                    <label class="form-check-label mb-0" for="showNonDeduct">Show Non Deduct</label>
                                </div>

                                <div class="col-auto d-flex align-items-center gap-2">
                                    <input type="checkbox" id="showOcc3" name="includeOptions" value="1">
                                    <label class="form-check-label mb-0" for="showOcc3">Show %Occ3</label>
                                </div>

                                <div class="col-auto d-flex align-items-center gap-2">
                                    <input type="checkbox" id="showRoomNight" name="includeOptions" value="1">
                                    <label class="form-check-label mb-0" for="showRoomNight">Show Room Night</label>
                                </div>

                                <div class="col-auto d-flex align-items-center gap-2">
                                    <input type="checkbox" id="includeOutOfOrder" name="includeOptions" value="1"
                                        checked>
                                    <label class="form-check-label mb-0" for="includeOutOfOrder">
                                        Include Out of Order
                                    </label>
                                </div>

                                <div class="col-auto d-flex align-items-center gap-2">
                                    <input type="checkbox" id="includeOverbooking" name="includeOptions" value="1">
                                    <label class="form-check-label mb-0" for="includeOverbooking">
                                        Include Overbooking
                                    </label>
                                </div>

                                <div class="col-auto d-flex align-items-center gap-2">
                                    <input type="checkbox" id="includeAllotment" name="includeOptions" value="1"
                                        checked>
                                    <label class="form-check-label mb-0" for="includeAllotment">
                                        Include Allotment
                                    </label>
                                </div>

                            </div>
                        </div>

                    </div>
                </div>

                <div class="mui-card">
                    <div id="gridContainer" class="gridContainer mt-2"></div>
                </div>
                <div id="loadingSpinner"
                    style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:1000;">
                    <i class="fa-solid fa-spinner fa-spin"></i>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    function formatDate(date) {
        let year = date.getFullYear();
        let month = (date.getMonth() + 1).toString().padStart(2, '0'); // Ð?m b?o có 2 ch? s?
        let day = date.getDate().toString().padStart(2, '0'); // Ð?m b?o có 2 ch? s?
        return `${year}-${month}-${day}`;
    }
    let parsedBusinessDate = null;

    $(document).ready(function () {
                initializeTomSelects();

          getBusinessDate();

        $('#reportModal').modal('show');
        

    });
    $(document).on('click', '#btnCloseAva', function () {
        window.location.href = '/Home/Index';
    });





    $(document).off("click", "#btnPrint").on("click", "#btnPrint", function () {
         let fromDate = $('#fromDate').val() || '';
         const zone = $("#zone").val();
         if (!zone || zone.length === 0) {
             showToast('Error', "Please select a Zone before printing!", false);
             return; // dừng không gọi AJAX
         }
         $("#loadingSpinner").show();
         $.ajax({
             url: '/HouseKeeping/RoomAvailabilityData',
             type: 'GET',
             data: {
                 fromDate: fromDate,
                 zone: $("#zone").val().join(","),
                 restype: $("#restype").val().join(","),

                 displayofday: $("#displayofday").val(),
                 showNonDeduct: $("#showNonDeduct").val(),
                 showOcc3: $("#showOcc3").val(),
                 showRoomNight: $("#showRoomNight").val(),
                 includeOutOfOrder: $("#includeOutOfOrder").val(),
                 includeOverbooking: $("#includeOverbooking").val(),
                 includeAllotment: $("#includeAllotment").val(),
             },
             traditional: true,
             crossDomain: false,
             headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
             success: function (result) {
                 // $("#reportViewerContainer").html(result);
                 // $("#loadingSpinner").hide();
                 console.log(result);
                 initializeReservationSummaryGrid(result.data, result.fromDate, result.toDate);
                 $("#loadingSpinner").hide();
             },
             error: function () {
                 alert("Không th? t?i báo cáo.");
                 $("#loadingSpinner").hide();
             }
         })
    });
    function generateDateColumns(fromDate, toDate) {
        const columns = [];
        const start = new Date(fromDate);
        const end = new Date(toDate);

        let index = 1; // bắt đầu từ Date1

        while (start <= end) {
            const day = start.getDate().toString().padStart(2, '0');
            const month = start.toLocaleString('en-US', { month: 'short' }); // "Jul"
            const weekday = start.toLocaleString('en-US', { weekday: 'short' }); // "Mon"
            const weekNumber = getWeekNumber(start); // CW

            const captionHtml = `${day}-${month}<br>${weekday}<br>CW${weekNumber}`;

            columns.push({
                dataField: `date${index}`,   // ví dụ: date1, date2 ...
                width: 80,
                dataType: "number",  // <-- báo cho grid đây là số
                cellTemplate: function (container, options) {
                    let value = options.value;
                    let num = parseFloat(value);

                    // Format số (1,000; 1,234,567 ...)
                    const formatNumber = (val) =>
                        new Intl.NumberFormat("en-US").format(val);

                    if (options.data.roomType === "% OCC") {
                        if (value !== null && value !== undefined && value !== "") {
                            let num = parseFloat(value);
                            if (!isNaN(num)) {
                                container.text(num + " %");
                            } else {
                                container.text(value + " %");
                            }
                        } else {
                            container.text("");
                        }
                    }

                    else if (options.data.roomType === "R.Night") {
                        if (!num || num === 0) {
                            container.text("0").css("color", "red");
                        } else {
                            container.text(formatNumber(num));
                        }
                    }
                    else if (options.data.roomType === "Allotment") {
                        container.text(num ? formatNumber(num) : "0");
                    }
                    else {
                        if (!isNaN(num)) {
                            if (num <= 0) {
                                container.text(formatNumber(num)).css("color", "red");
                            } else {
                                container.text(formatNumber(num));
                            }
                        } else {
                            container.text("");
                        }
                    }
                },
                headerCellTemplate: function (container) {
                    container.html(
                        `<div style="white-space: normal; text-align:center; font-size:11px;">${captionHtml}</div>`
                    );
                }
            });

            start.setDate(start.getDate() + 1);
            index++;
        }

        return columns;
    }






    function getWeekNumber(date) {
        const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
        const dayNum = d.getUTCDay() || 7;
        d.setUTCDate(d.getUTCDate() + 4 - dayNum);
        const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
        return Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
    }



    function initializeReservationSummaryGrid(data, fromDate, toDate) {
        const columnWidth = 120;


        let hasPassedBookedRoom = false;
        const dateColumns = generateDateColumns(fromDate, toDate);

        $("#gridContainer").dxDataGrid({
            dataSource: data,
            allowColumnResizing: true,
            columnAutoWidth: true,
            columns: [
                { dataField: "roomType", caption: "Room Type", width: columnWidth - 10 },

                {
                    dataField: "totalRooms",
                    caption: "Total Rooms",
                    width: 100, dataType: "number",
                    cellTemplate: function (container, options) {
                        let value = options.value;

                        // Nếu RoomType = Allotment hoặc BookedRoom
                        if (options.data.roomType === "Allotment" || options.data.roomType === "BookedRoom") {
                            if (value === null || value === undefined || value === "") {
                                container.text("0"); // hiển thị 0
                            } else {
                                container.text(value);
                            }
                        } else {
                            container.text(value ?? "");
                        }
                    }
                },
                ...dateColumns
            ],

            paging: { pageSize: 25 },
            scrolling: {
                useNative: true,
                showScrollbar: "always"
            },
            pager: {
                visible: true,
                allowedPageSizes: [25, 50, 'all'],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },
            filterRow: { visible: true, applyFilter: "auto" },
            headerFilter: { visible: true },
            selection: { mode: "multiple", showCheckBoxesMode: "none" },
            showBorders: true,
            onRowPrepared: function (e) {
                if (e.rowType === "data") {
                    if (e.data.roomType === "Allotment") {
                        hasPassedBookedRoom = true;
                    }

                    // Apply green background if we've passed "BookedRoom" or are on it
                    if (hasPassedBookedRoom) {
                        e.rowElement.css({
                            "background-color": "#bdf8fc" // Light green background
                        });
                    }

                    if (e.data?.isTotal) {
                        e.rowElement.css({
                            "font-weight": "bold",
                            "background-color": "#f6f6f6" // Override with total row style if isTotal
                        });
                    }
                }
            }
        });
    }




    $("#btnExportExcel").click(function () {
        const grid = $("#gridContainer").dxDataGrid("instance");
        const selectedReport = "RoomAvailability";
        const workbook = new ExcelJS.Workbook(); const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
        const worksheet = workbook.addWorksheet("Sheet 1");

        // === T?o header công ty (dòng 1) ===
        worksheet.addRow([companyName]);
        worksheet.mergeCells('A1:E1');
        worksheet.getRow(1).font = { bold: true };
        worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

        // === Dòng 2: Th?i gian xu?t (ph?i) ===
        const now = new Date();
        const exportDate = now.toLocaleString("vi-VN");
        worksheet.addRow(['', '', '', '', ' ' + exportDate]);
        worksheet.mergeCells('E2:H2');
        worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

        // === Dòng 3–4: Tr?ng
        worksheet.addRow([]);
        worksheet.addRow([]);

        // === Dòng 5: Tên báo cáo ? gi?a ===
        const reportRow = worksheet.addRow(['', '', selectedReport]);
        worksheet.mergeCells('C5:F5');
        reportRow.font = { bold: true, size: 14 };
        reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

        // === Dòng 6: Tr?ng tru?c khi xu?t d? li?u
        worksheet.addRow([]);

        // === Export d? li?u t? DevExtreme (b?t d?u t? dòng 7)
        DevExpress.excelExporter.exportDataGrid({
            component: grid,
            worksheet: worksheet,
            autoFilterEnabled: true,
            topLeftCell: { row: 7, column: 1 } // d? li?u b?t d?u t? dòng 7
        }).then(function () {
            // Footer
            const lastRow = worksheet.lastRow.number + 2;
            worksheet.getCell(`A${lastRow}`).value = "--- END  ---";
            worksheet.mergeCells(`A${lastRow}:F${lastRow}`);
            worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
            worksheet.getCell(`A${lastRow}`).font = { italic: true };

            // Ghi file
            let fileName = selectedReport + ".xlsx";
            workbook.xlsx.writeBuffer().then(function (buffer) {
                saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
            });
        });
    });



    // Nút xu?t PDF
    $("#btnExportPdf").click(function () {
        const { jsPDF } = window.jspdf; // ?? B? sung dòng này

        const doc = new jsPDF();

        DevExpress.pdfExporter.exportDataGrid({
            jsPDFDocument: doc,
            component: $("#gridContainer").dxDataGrid("instance"),
            autoTableOptions: {
                styles: { cellPadding: 2, fontSize: 8 },
                margin: { top: 20 }
            }
        }).then(() => {
            doc.save("BaoCao.pdf");
        });
    });
</script>
