<style>


</style>
<link href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
<div class="text-center" id="reportTitle" style="font-size: 20px">Posting Minibar</div>
<div class="sticky-header bg-white p-2 shadow-sm z-3">


    <div class="">
        <button id="btnPrint" class="mui-button mui-button-new">View</button>

        <button id="btnExportExcel" class="mui-button mui-button-new" type="button">  Excel</button>
        <button id="btnExportPdf" class="mui-button mui-button-new" type="button">
