        const allInputs = [...individualInputs, ...companyInputs, ...groupInputs, ...contactInputs];
        allInputs.forEach(id => {
            const $el = $(id);
            if ($el.length) $el.val("");
        }); 

        // 2. Reset các Checkbox
        const allCheckboxes = [...individualCheckboxes, ...companyCheckboxes, ...groupCheckboxes, ...contactCheckboxes];
        allCheckboxes.forEach(id => {
            const $el = $(id);
            if ($el.length) $el.prop("checked", false);
        }); 

        // 3. Reset các TomSelect (Dọn dẹp giá trị đang chọn)
        const allTomSelects = [...individualTomSelects, ...companyTomSelects, ...groupTomSelects, ...contactTomSelects];
        allTomSelects.forEach(id => {
            const $el = $(id);
            if ($el.length && $el[0].tomselect) {
                $el[0].tomselect.clear();
            }
        }); 

        // 4. Các trường hợp mặc định đặc biệt
