    async function setTomSelect() {
        const ids = [
         /*    "#txtItemInventory", */ "#profileAllotmentSearch"

        ];

        for (const id of ids) {
            const el = document.querySelector(id);
            if (!el || el.tomselect) continue;
            const tag = (el.tagName || "").toUpperCase();
            if (tag !== "SELECT" && tag !== "INPUT") continue;
            new TomSelect(el, {
                allowEmptyOption: true,
                create: true
            });
        }
    }
    $('#txtName').on('blur', function () {
        const txtIDNewPF = $("#txtID").val();
        if(txtIDNewPF != "0" && txtIDNewPF != ""){
            return;
        }
        var input = $(this).val().trim();
        // Regex: "LastName [, parts], FirstName [middle...]" — khớp thông báo lỗi phía dưới ô
        var regex = /^[a-zA-ZÀ-ỹ]+(?:\s[a-zA-ZÀ-ỹ]+)*,\s*[a-zA-ZÀ-ỹ]+(?:\s[a-zA-ZÀ-ỹ]+)*$/i;

        if (input === '') {
            $(this).removeClass('is-valid is-invalid').attr('aria-invalid', 'false');
            return;
        }

        if (regex.test(input)) {
            $(this).removeClass('is-invalid').addClass('is-valid').attr('aria-invalid', 'false');

            var parts = input.split(',');
            var lastName = parts[0].trim();
            var firstMiddlePart = parts[1].trim();
            var nameTokens = firstMiddlePart.split(/\s+/);

            var firstName = nameTokens[0];
            var middleName = nameTokens.slice(1).join(' ');

            $('#txtFirstName').val(firstName);
            CreateProfile(input, lastName, firstName, middleName);

        } else {
            $(this).removeClass('is-valid').addClass('is-invalid').attr('aria-invalid', 'true');
            $('#txtFirstName').val('');
            var msg = 'Name format: Last name, First name (optional middle). Example: Smith, John Paul or Nguyễn Văn, Tuấn Anh';
            if (typeof showToast === 'function') {
                showToast('Warning', msg, false);
            }
        }
    });
    function CreateProfile(account, lastName, firstName, middleName) {
        var formData = new FormData();
        const userID = JSON.parse(localStorage.getItem("userID"));
        formData.append('AccountIndividual', account);
        formData.append('LastNameIndivdual', lastName);
        formData.append('FirstNameIndividual', firstName);
        formData.append('MiddleNameIndividual', middleName);
        formData.append('userID', userID);


        $.ajax({
            url: '/Profile/SaveProfileInReservation',
            type: 'POST',
            processData: false,
            contentType: false,
            data: formData,
            success: function (data) {
                if (data.code == 0) {
                    showToast('Success', data.msg, true);
                    $('#txtID').val(data.id);
                    $('#txtItemInventory').prop('disabled', false);

                } else {
                    showToast('Error', data.msg, false);
                }

            },
            error: function (xhr, statusText, err) {

            }
        });

    }
