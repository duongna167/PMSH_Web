
<div class="text-center" id="reportTitle" style="font-size: 20px">Card Management</div>
<div class="sticky-header bg-white p-2 shadow-sm z-3">
    <div class="py-1">

        <button id="btnNew" class="mui-button mui-button-new"
                type="button">
            New
        </button>
        <button class="mui-button mui-button-edit" id="btnEdit" ctype="button">
            Edit
        </button>
        <button class="mui-button button-report-delete" id="btnDelete" type="button">
            Delete
        </button>
        <button class="mui-button mui-button-advance" id="btnSave" type="button">
            Save
        </button>
    </div>
    <div class="d-flex align-items-center gap-3 p-2" >

        <div class="d-flex align-items-center">
            <label for="cardID" class="me-2 mb-0">CardID</label>
            <input type="text" name="cardID" id="cardID" class="form-control form-control-sm" style="width: 100px;" />
            <div class="invalid-feedback"></div>
        </div>
        <div class="d-flex align-items-center gap-2 d-none" id="scanCounter">
            <span>Count: <strong id="cardCount">0</strong></span>
            <button type="button" class="btn btn-sm btn-light" id="btnResetCount">
                <i class="dx-icon-refresh"></i>
            </button>
        </div>

        <div class="d-flex align-items-center me-3">
            <label class="me-2 mb-0">Card Type:</label>
            <select id="cardType" name="cardType" class="form-control form-control-sm w-auto">
                <option value="0">Card Hotel</option>
            </select>
        </div>
        <div class="d-flex align-items-center me-3">
            <label class="me-2 mb-0">Status:</label>
            <select id="status" name="status" class="form-control form-control-sm w-auto">
                <option value="1">Active</option>
                <option value="0">Inactive</option>
                <option value="2">Other</option>
            </select>
        </div>
    </div>
    
</div>

<div class="mui-card">
    <div id="gridCardManagement" class="mt-2 gridContainer"></div>
</div>
<div id="loadingSpinnerRateCode" style="display: none; text-align: center; padding: 20px;">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
</div>

<script>
    var selectedRow;
    var connection;
    var cardCount = 0;

    $(document).ready(function () {
        connection = new signalR.HubConnectionBuilder()
            .withUrl("/tagScanHub")
            .build();

        // Khi server gửi code RFID về
        connection.on("ReceiveCode", function (code) {
            $("#cardID").val(code).trigger("change");
        });


        // Bắt đầu kết nối
        connection.start()
            .then(function () {
                console.log("✅ Kết nối SignalR thành công!");
            })
            .catch(function (err) {
                console.error("❌ Lỗi kết nối SignalR:", err);
            });

            
        $("#cardID").on("keydown", function (e) {
         let value = $(this).val();
            if (e.key === "Enter") {
                e.preventDefault();
                // Kiểm tra nếu đủ 8 số và toàn là số
                if (value.length === 8 && /^\d+$/.test(value)) {
                    insertCard(value);
                }
            }
        });

        reloadGrid();
    });

    $("#btnNew").on("click", function () {
        enterNewMode();
    });
        
    $("#btnEdit").on("click", function () {
        if (!selectedRow) {
            showToast("Warning", "Please select a line to edit.", false);
            return;
        }

        enterEditMode();

        $("#cardID").val(selectedRow.id);
        $("#cardType").val(selectedRow.cardTypeID);
        $("#status").val(selectedRow.status);
    });

    function resetCount() {
        cardCount = 0;
        $("#cardCount").text(cardCount);
    }

    $("#btnResetCount").on("click", resetCount);

        
    function enterNewMode() {
        $("#scanCounter").removeClass("d-none");
        resetCount();

        $("#cardID")
            .prop("readonly", false)
            .val("")
            .focus();

        selectedRow = null;
    }

    function enterEditMode() {
        $("#scanCounter").addClass("d-none");

        $("#cardID")
            .prop("readonly", true);
    }

    function appendToGrid(item) {
        let grid = $("#gridCardManagement").dxDataGrid("instance");
        let store = grid.getDataSource().store();

        store.push([{
            type: "insert",
            data: item
        }]);
    }

    $("#btnDelete").on("click", function () {
        if (!selectedRow) {
            showToast("Warning","Please select a line to delete.", false);
            return;
        }

        if (!confirm("Are you sure you want to delete this record? This action cannot be undone.")) {
                return;
        }
        
        $.ajax({
            url: "/Miscellaneous/DeleteCard",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify({ ID: selectedRow.id }), // phải đúng property tên ID
            success: function (res) {
                if (res.deleted > 0 || res.success) {
                    showToast("Success", "Deleted successfully!", true);
                    reloadGrid();
                    selectedRow = null;
                } else {
                    showToast("Error", "Delete failed!", false);
                }
            },
            error: function (xhr) {
                console.error("Delete error:", xhr.responseText);
                showToast("Error", "Delete error!", false);
            }
        });
    });

    $("#btnSave").on("click", function () {

        let payload = {
            ID: $("#cardID").val(),
            CardTypeID: parseInt($("#cardType").val()),
            Status: parseInt($("#status").val()),
            CanSell: false
        };

        $.ajax({
            url: "/Miscellaneous/SaveCard",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(payload),
            success: function (res) {

                if (!res.success) {
                    showToast("Error", res.message || "Save failed", false);
                    return;
                }

                let grid = $("#gridCardManagement").dxDataGrid("instance");
                let store = grid.getDataSource().store();

                // ===== INSERT =====
                if (!selectedRow) {
                    store.push([{
                        type: "insert",
                        data: res.data   // 🔥 server phải trả row vừa insert
                    }]);

                    cardCount++;
                    $("#cardCount").text(cardCount);
                    $("#cardID").val("").focus();
                }
                // ===== UPDATE =====
                else {
                    store.push([{
                        type: "update",
                        key: selectedRow.id,
                        data: res.data
                    }]);

                    selectedRow = null;
                }

                showToast("Success", res.message, true);
            }
        });
    });


    function reloadGrid() {
        $("#loadingSpinnerRateCode").show();

        $.ajax({
            url: "/Miscellaneous/GetCardManagement",
            type: "GET",
            success: function (data) {

                $("#gridCardManagement").dxDataGrid({
                    dataSource: {
                        load: function () {
                            return $.getJSON("/Miscellaneous/GetCardManagement");
                        }
                    },
                    keyExpr: "id", // phải dùng keyExpr thay cho key
                    remoteOperations: false,
                    height: 500,
                    width: "100%",
                    showBorders: true,
                    columnAutoWidth: true,
                    allowColumnResizing: true,
                    columnResizingMode: "widget",
                    selection: { mode: "single" },
                    columns: [
                        { dataField: "id", caption: "ID" },
                        { dataField: "cardType", caption: "Card Type" },
                        { dataField: "statusText", caption: "Status" },
                        { dataField: "createdBy", caption: "Created By" },
                        { dataField: "createdDate", caption: "Created Date", dataType: "date", format: "dd/MM/yyyy HH:mm" },
                        { dataField: "updatedBy", caption: "Updated By" },
                        { dataField: "updatedDate", caption: "Updated Date", dataType: "date", format: "dd/MM/yyyy HH:mm" },
                    ],
                    scrolling: {
                        mode: "standard", // Không dùng virtual để footer hiển thị đúng
                        showScrollbar: "always",
                        scrollByContent: true
                    },
                    paging: {
                        pageSize: 20
                    },
                    pager: {
                        visible: true,
                        allowedPageSizes: [20, 50, 'all'],
                        showPageSizeSelector: true,
                        showInfo: true,
                        showNavigationButtons: true
                    },
                    columnAutoWidth: true,
                    filterRow: { visible: true, applyFilter: "auto" },

                    onSelectionChanged: function (e) {
                        selectedRow = e.selectedRowsData[0]; // lấy dòng đã chọn
                    }
                });

                console.log(data);
                $("#loadingSpinnerRateCode").hide();
            },
            error: function () {
                alert("Không thể tải dữ liệu");
                $("#loadingSpinnerRateCode").hide();
            }
        });
    }

</script>
