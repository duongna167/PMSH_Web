@{
    var city_listctry = ViewBag.CountryList;
}

<!-- Main Modal -->
<div class="modal fade" id="city_mainModal" tabindex="-1" aria-labelledby="city_mainModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="city_mainModalLabel">City</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <button id="city_btnView" type="button" class="mui-button mui-button-search">View</button>
                        <button id="city_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="city_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="city_btnDelete" type="button" class="mui-button mui-button-delete">Delete</button>
                        <button id="city_btnExportExcel" type="button" class="mui-button mui-button-export">Excel</button>
                        <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal" aria-label="Close">Close</button>
                    </div>

                    <div class="row g-2 mt-1">
                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label for="city_filterCode" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Code
                                </label>
                                <div class="col-md-8">
                                    <input id="city_filterCode"
                                            name="city_filterCode"
                                            type="text"
                                            class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label for="city_filterName" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Name
                                </label>
                                <div class="col-md-8">
                                    <input id="city_filterName"
                                            name="city_filterName"
                                            type="text"
                                            class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4 col-lg-3">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Status
                                </label>
                                <div class="col-md-8">
                                    <div class="d-flex align-items-center h-100">
                                        <div class="form-check d-flex align-items-center gap-2">
                                            <span class="status-color-box color-clean-uncheck"></span>
                                            <input type="checkbox" id="city_chkShowInactive" name="city_chkShowInactive">
                                            <label class="form-check-label" for="city_chkShowInactive">Show Inactive</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mui-card mt-1">
                    <div id="city_gridContainer" class="gridContainer"></div>
                </div>

                <div id="city_loadingSpinner" 
                    style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                    z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                    height: 100%;display: flex;align-items: center;justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="city_itemModal" tabindex="-1" aria-labelledby="city_itemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="city_itemModalLabel">Add City</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <button type="button" id="city_btnSave" class="mui-button mui-button-new">Save</button>
                    <button type="button" class="mui-button mui-button-new" data-bs-dismiss="modal">Close</button>
                </div>

                <form id="city_formContainer">
                    <div class="row g-2 mt-1 mb-2">
                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label for="city_code" class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Code
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <input id="city_code"
                                            name="city_code"
                                            type="text"
                                            class="form-control form-control-sm" />
                                    <div class="invalid-feedback" id="city_codeError"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Status
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <div class="form-check d-inline-flex align-items-center gap-2">
                                        <input id="city_inactive"
                                                name="city_inactive"
                                                type="checkbox"/>
                                        <label for="city_inactive" class="form-check-label text-danger">
                                            Inactive
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label for="city_name" class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Name
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <input id="city_name"
                                            name="city_name"
                                            type="text"
                                            class="form-control form-control-sm" />
                                    <div class="invalid-feedback" id="city_nameError"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label for="city_countryID" class="col-md-2 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Country
                                </label>
                                <div class="col-md-10 col-lg-8">
                                    <select id="city_countryID"
                                            name="city_countryID"
                                            class="tomselect-custom">
                                        <option value="">-- Select country --</option>
                                        @foreach (var city_country in city_listctry)
                                        {
                                            <option value="@city_country.ID" data-code="@city_country.Code">
                                                @city_country.Code - @city_country.Name
                                            </option>
                                        }
                                    </select>
                                    <div class="invalid-feedback" id="city_countryIDError"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="city_description" class="col-md-2 col-form-label col-form-label-sm text-md-end">
                                    Description
                                </label>
                                <div class="col-md-10">
                                    <textarea id="city_description"
                                                name="city_description"
                                                rows="4"
                                                class="form-control form-control-sm"
                                                style="height:100px;"></textarea>
                                    <div class="invalid-feedback" id="city_descriptionError"></div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <input type="hidden" id="city_id" name="city_id" value="0" />
                </form>
            </div>

        </div>
    </div>
</div>

<script>
    var city_Module = (() => {
        let city_selectedRowData = null;

        const city_selectors = {
            mainModal: "#city_mainModal",
            itemModal: "#city_itemModal",
            form: "#city_formContainer",
            grid: "#city_gridContainer",
            loading: "#city_loadingSpinner",

            filterCode: "#city_filterCode",
            filterName: "#city_filterName",
            chkShowInactive: "#city_chkShowInactive",

            btnView: "#city_btnView",
            btnNew: "#city_btnNew",
            btnEdit: "#city_btnEdit",
            btnDelete: "#city_btnDelete",
            btnExportExcel: "#city_btnExportExcel",
            btnSave: "#city_btnSave",

            modalLabel: "#city_itemModalLabel",

            id: "#city_id",
            code: "#city_code",
            name: "#city_name",
            description: "#city_description",
            inactive: "#city_inactive",
            countryID: "#city_countryID"
        };

        function city_init() {
            city_bindEvents();
            city_resetForm();
            city_loadGrid([]);
            city_loadData();
        }

        function city_bindEvents() {
            initTomSelect(".tomselect-custom");
            $(document)
                .off("input change", `${city_selectors.form} input, ${city_selectors.form} select, ${city_selectors.form} textarea`)
                .on("input change", `${city_selectors.form} input, ${city_selectors.form} select, ${city_selectors.form} textarea`, function () {
                    if ($(this).hasClass("is-invalid")) {
                        $(this).removeClass("is-invalid");
                        $(this).next(".invalid-feedback").text("");
                    }
                });

            $(city_selectors.itemModal)
                .off("hidden.bs.modal")
                .on("hidden.bs.modal", function () {
                    city_resetForm();
                    applyValidationErrors([], city_selectors.form);
                });

            $(document)
                .off("click", city_selectors.btnView)
                .on("click", city_selectors.btnView, function () {
                    city_loadData();
                });

            $(document)
                .off("click", city_selectors.btnNew)
                .on("click", city_selectors.btnNew, function () {
                    city_openAddModal();
                });

            $(document)
                .off("click", city_selectors.btnEdit)
                .on("click", city_selectors.btnEdit, function () {
                    city_openEditModal();
                });

            $(document)
                .off("click", city_selectors.btnSave)
                .on("click", city_selectors.btnSave, function () {
                    city_save();
                });

            $(document)
                .off("click", city_selectors.btnDelete)
                .on("click", city_selectors.btnDelete, function () {
                    city_delete();
                });

            $(document)
                .off("click", city_selectors.btnExportExcel)
                .on("click", city_selectors.btnExportExcel, function () {
                    city_exportExcel();
                });
        }

        function city_resetForm() {
            const city_form = $(city_selectors.form)[0];
            if (city_form) {
                city_form.reset();
            }
            clearTomSelect(city_selectors.countryID);
            $(city_selectors.id).val("0");

            $(city_selectors.modalLabel).text("Add City");
            city_selectedRowData = null;
        }

        function city_openAddModal() {
            city_resetForm();
            $(city_selectors.modalLabel).text("Add City");
            $(city_selectors.itemModal).modal("show");
        }

        function city_openEditModal() {
            if (!city_selectedRowData) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }

            city_fillForm(city_selectedRowData);
            $(city_selectors.modalLabel).text("Update City");
            $(city_selectors.itemModal).modal("show");
        }

        function city_fillForm(city_data) {
            $(city_selectors.id).val(city_data.id || 0);
            $(city_selectors.code).val(city_data.code || "");
            $(city_selectors.name).val(city_data.name || "");
            $(city_selectors.description).val(city_data.description || "");
            $(city_selectors.inactive).prop("checked", city_data.inactive == 1 || city_data.inactive === true);

            const city_countryCode = city_data.country || "";
            const select = document.querySelector(city_selectors.countryID).tomselect;
            const city_option = $(`${city_selectors.countryID} option[data-code='${city_countryCode}']`);

            if (city_option.length) {
                select.setValue(city_option.val());
            } else {
                select.clear();
            }
        }

        function city_getSearchModel() {
            return {
                code: $(city_selectors.filterCode).val(),
                name: $(city_selectors.filterName).val(),
                inactive: $(city_selectors.chkShowInactive).prop("checked") ? 1 : 0
            };
        }

        function city_getSaveModel() {
            const city_id = parseInt($(city_selectors.id).val()) || 0;
            const city_loginName = (localStorage.getItem("Loginname") || "")
                .trim()
                .replace(/^"(.*)"$/, "$1");
            const city_loginUser = parseInt(localStorage.getItem("userID")) || 0;

            return {
                ID: city_id,
                Code: $(city_selectors.code).val(),
                Name: $(city_selectors.name).val(),
                Description: $(city_selectors.description).val(),
                Inactive: $(city_selectors.inactive).prop("checked"),
                CountryID: $(city_selectors.countryID).val(),
                CreatedBy: city_loginName,
                UpdatedBy: city_loginName,
                UserInsertID: city_loginUser,
                UserUpdateID: city_loginUser
            };
        }

        function city_showLoading() {
            $(city_selectors.loading).show();
        }

        function city_hideLoading() {
            $(city_selectors.loading).hide();
        }

        function city_loadData() {
            city_showLoading();

            $.ajax({
                url: "/Administration/GetCity",
                type: "GET",
                cache: false,
                data: city_getSearchModel(),
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (city_data) {
                    city_loadGrid(city_data || []);
                    city_hideLoading();
                },
                error: function () {
                    showToast("Error", "Unable to load data", false);
                    city_hideLoading();
                }
            });
        }

        function city_loadGrid(city_data) {
            $(city_selectors.grid).dxDataGrid({
                dataSource: city_data,
                width: "100%",
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                hoverStateEnabled: true,
                columns: [
                    { dataField: "id", visible: false },
                    { dataField: "code", caption: "Code", width: 100 },
                    { dataField: "name", caption: "Name", width: 150 },
                    { dataField: "country", caption: "Country", width: 100 },
                    { dataField: "description", caption: "Description", minWidth: 120, cssClass: "col-description"},
                    {
                        dataField: "inactive",
                        caption: "Inactive",
                        alignment: "center",
                        width: 60,
                        cellTemplate: function (container, options) {
                            $("<div>")
                                .dxCheckBox({
                                    value: options.value == 1 || options.value === true,
                                    readOnly: true
                                })
                                .css("transform", "scale(0.8)")
                                .appendTo(container);
                        }
                    },
                    { dataField: "createdBy", caption: "Created By", width: 80 },
                    {
                        dataField: "createdDate",
                        caption: "Cre.Date",
                        dataType: "date",
                        format: "dd/MM/yyyy",
                        width: 80
                    },
                    { dataField: "updatedBy", caption: "Updated By", width: 80 },
                    {
                        dataField: "updatedDate",
                        caption: "Upd.Date",
                        dataType: "date",
                        format: "dd/MM/yyyy",
                        width: 80
                    }
                ],
                filterRow: { visible: true, applyFilter: "auto" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: { mode: "standard", showScrollbar: "always" },
                onSelectionChanged: function (e) {
                    city_selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
                }
            });
        }

        function city_save() {
            const city_model = city_getSaveModel();

            $.ajax({
                url: "/Administration/CitySave",
                type: "POST",
                contentType: "application/json",
                cache: false,
                data: JSON.stringify(city_model),
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (city_res) {
                    if (city_res.success) {
                        showToast("Success", city_res.message, true);
                        $(city_selectors.itemModal).modal("hide");
                        city_loadData();
                        return;
                    }

                    if (city_res.errors && city_res.errors.length > 0) {
                        applyValidationErrors(city_res.errors, city_selectors.form);

                        const city_generalError = city_res.errors.find(x => x.field === "general");
                        const city_toastMessage = city_generalError
                            ? city_generalError.message
                            : "Please check input fields.";

                        showToast("Warning", city_toastMessage, false);
                        return;
                    }

                    showToast("Error", city_res.message || "Save failed", false);
                },
                error: function () {
                    showToast("Error", "Request error!", false);
                }
            });
        }

        function city_delete() {
            if (!city_selectedRowData || city_selectedRowData.id === 0) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }

            if (!confirm("Are you sure you want to delete this record? This action cannot be undone.")) {
                return;
            }

            $.ajax({
                url: `/Administration/DeleteCity/${city_selectedRowData.id}`,
                type: "POST",
                traditional: true,
                crossDomain: false,
                headers: {
                    "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
                },
                success: function (city_result) {
                    if (city_result.success) {
                        city_loadData();
                        showToast("Success", "Delete Successfully!", true);
                        return;
                    }

                    showToast("Error", city_result.message, false);
                },
                error: function () {
                    showToast("Error", "Delete failed!", false);
                }
            });
        }

        function city_exportExcel() {
            const city_grid = $(city_selectors.grid).dxDataGrid("instance");
            if (!city_grid) {
                showToast("Warning", "No grid data to export.", true);
                return;
            }

            const city_workbook = new ExcelJS.Workbook();
            const city_companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const city_worksheet = city_workbook.addWorksheet("Sheet 1");

            city_worksheet.addRow([city_companyName]);
            city_worksheet.mergeCells("A1:D1");
            city_worksheet.getRow(1).font = { bold: true };
            city_worksheet.getRow(1).alignment = { vertical: "middle", horizontal: "left" };

            const city_now = new Date();
            const city_exportDate = city_now.toLocaleString("vi-VN");
            city_worksheet.addRow(["", "", "", city_exportDate]);
            city_worksheet.getRow(2).alignment = { vertical: "middle", horizontal: "right" };

            city_worksheet.addRow([]);
            city_worksheet.addRow([]);

            const city_reportRow = city_worksheet.addRow(["City"]);
            city_worksheet.mergeCells("A5:D5");
            city_reportRow.font = { bold: true, size: 14 };
            city_reportRow.alignment = { vertical: "middle", horizontal: "center" };

            city_worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: city_grid,
                worksheet: city_worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const city_lastRow = city_worksheet.lastRow.number + 2;
                city_worksheet.mergeCells(`A${city_lastRow}:D${city_lastRow}`);
                city_worksheet.getCell(`A${city_lastRow}`).alignment = { horizontal: "center" };
                city_worksheet.getCell(`A${city_lastRow}`).font = { italic: true };

                city_workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(
                        new Blob([buffer], { type: "application/octet-stream" }),
                        "City.xlsx"
                    );
                });
            });
        }

        return {
            init: city_init,
            loadData: city_loadData,
            openAddModal: city_openAddModal,
            openEditModal: city_openEditModal
        };
    })();

    window.openModalCity = function () {
        if (typeof city_Module !== "undefined" && city_Module.init) {
            city_Module.init();
        }
    };
</script>