@{
    var listRateCode = ViewBag.RateCodeList;
    var listLanguage = ViewBag.LanguageList;
}

<style>
    #cfT_editor + .ck-editor .ck-editor__editable {
    min-height: 300px;
}
</style>
<div class="modal fade" id="cfT_mainModal" tabindex="-1" aria-labelledby="cfT_mainModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="cfT_mainModalLabel">Confirmation Template Config</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <button id="cfT_btnNew" type="button" class="mui-button mui-button-new">New</button>
                    <button id="cfT_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                    <button id="cfT_btnDelete" type="button" class="mui-button mui-button-delete">Delete</button>
                    <button type="button" class="mui-button mui-button-delete" data-bs-dismiss="modal" aria-label="Close">Close</button>
                </div>

                <div class="mui-card mt-1">
                    <div id="cfT_gridContainer" class="gridContainer"></div>
                </div>

                <div id="cfT_loadingSpinner"
                    style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                    z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                    height: 100%;display: flex;align-items: center;justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="cfT_itemModal" tabindex="-1" aria-labelledby="cfT_itemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="cfT_itemModalLabel">Add Confirmation Template</h5>
            </div>

            <div class="search-filter">
                <button type="button" id="cfT_btnSave" class="mui-button mui-button-save">Save</button>
                <button type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
            </div>

            <div class="modal-body">
                <form id="cfT_form">
                    <div class="row g-2 mt-1 mb-2">
                        <div class="col-12 col-lg-4">
                            <div class="row g-2 align-items-center">
                                <label for="cfT_rateCodeID" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Rate Code
                                </label>
                                <div class="col-md-8">
                                    <select id="cfT_rateCodeID" name="cfT_rateCodeID" class="tomselect-custom">
                                        <option value="">-- Select Rate Code --</option>
                                        @if (listRateCode != null)
                                        {
                                            foreach (var item in listRateCode)
                                            {
                                                <option value="@item.ID">@item.RateCode</option>
                                            }
                                        }
                                    </select>
                                    <div class="invalid-feedback" id="cfT_rateCodeIDError"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-4">
                            <div class="row g-2 align-items-center">
                                <label for="cfT_letterName" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Letter Name
                                </label>
                                <div class="col-md-8">
                                    <input id="cfT_letterName"
                                            name="letterNameInput"
                                            type="text"
                                            class="form-control form-control-sm">
                                    <div class="invalid-feedback" id="cfT_letterNameError"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-4">
                            <div class="row g-2 align-items-center">
                                <label for="cfT_nationality" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                    Language
                                </label>
                                <div class="col-md-8">
                                    <select id="cfT_nationality" name="cfT_nationality" class="tomselect-custom">
                                        <option value="">-- Select Language --</option>
                                        @if (listLanguage != null)
                                        {
                                            foreach (var item in listLanguage)
                                            {
                                                <option value="@item.Code">@item.Name</option>
                                            }
                                        }
                                    </select>
                                    <div class="invalid-feedback" id="cfT_nationalityError"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2">
                                <label for="cfT_editor" class="col-md-2 col-lg-2 col-form-label col-form-label-sm text-md-end">
                                    Template
                                </label>
                                <div class="col-md-10 col-lg-10">
                                    <textarea id="cfT_editor" name="cfT_editor"  style="height: 200px;"></textarea>
                                    <div class="invalid-feedback d-block" id="cfT_templateError"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="cfT_id" name="cfT_id" value="0" />
                </form>
            </div>
        </div>
    </div>
</div>

<div id="cfT_loadingSpinnerEditor" 
    style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
    z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
    height: 100%;display: flex;align-items: center;justify-content: center;">
    <div class="spinner-border text-primary"></div>
</div>

<script>

    var cfT_Module = (function () {
        let selectedRowData = null;
        let editorInstance = null;

        const selectors = {
            mainModal: "#cfT_mainModal",
            itemModal: "#cfT_itemModal",
            form: "#cfT_form",
            grid: "#cfT_gridContainer",
            loading: "#cfT_loadingSpinner",
            itemModalLabel: "#cfT_itemModalLabel",

            btnNew: "#cfT_btnNew",
            btnEdit: "#cfT_btnEdit",
            btnDelete: "#cfT_btnDelete",
            btnSave: "#cfT_btnSave",

            id: "#cfT_id",
            rateCodeID: "#cfT_rateCodeID",
            letterName: "#cfT_letterName",
            nationality: "#cfT_nationality",
            editor: "#cfT_editor"
        };

        const endpoints = {
            getList: "/Administration/GetConfirmationTemp",
            save: "/Administration/ConfirmationTempSave",
            delete: "/Administration/ConfirmationTempDelete/"
        };

        function init() {
            initEditor();
            bindEvents();
            loadGrid();
        }

        function initEditor() {
            ClassicEditor
                .create(document.querySelector(selectors.editor), {
                    toolbar: [
                        "heading", "|", "bold", "italic", "link", "bulletedList", "numberedList",
                        "blockQuote", "insertTable", "undo", "redo", "alignment", "fontColor", "fontSize"
                    ]
                })
                .then(editor => {
                    editorInstance = editor;
                })
                .catch(error => {
                    console.error(error);
                });
        }

        function bindEvents() {
            initTomSelect(".tomselect-custom");
            $(selectors.btnNew).off("click").on("click", openAddModal);
            $(selectors.btnEdit).off("click").on("click", openEditModal);
            $(selectors.btnDelete).off("click").on("click", deleteRecord);
            $(selectors.btnSave).off("click").on("click", saveRecord);

            $(selectors.form).off("input change", "input, select, textarea").on("input change", "input, select, textarea", function () {
                clearFieldError(this);
            });

            $(selectors.itemModal).off("hidden.bs.modal").on("hidden.bs.modal", function () {
                resetForm();
                applyValidationErrors([], selectors.form);
            });
        }

        function loadGrid() {
            $(selectors.loading).show();

            $.ajax({
                url: endpoints.getList,
                type: "GET",
                dataType: "json",
                cache: false,
                success: function (data) {
                    renderGrid(data || []);
                },
                error: function () {
                    showToast("Error", "Load data failed", false);
                },
                complete: function () {
                    $(selectors.loading).hide();
                }
            });
        }

        function renderGrid(data) {
            $(selectors.grid).dxDataGrid({
                dataSource: data,
                keyExpr: "id",
                width: "100%",
                wordWrapEnabled: true,
                columnAutoWidth: true,
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                hoverStateEnabled: true,
                filterRow: { visible: true, applyFilter: "auto" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    showPageSizeSelector: true,
                    allowedPageSizes: [20, 50, "all"],
                    showInfo: true,
                    showNavigationButtons: true
                },
                columns: [
                    { dataField: "id", caption: "ID", visible: false },
                    { dataField: "letterName", caption: "Letter Name", width: "20%" },
                    { dataField: "rateCodeID", caption: "Rate Code ID", visible: false },
                    { dataField: "rateCode", caption: "Rate Code", width: "15%" },
                    { dataField: "nationality", caption: "Language", width: "15%" },
                    {
                        dataField: "template",
                        caption: "Template",
                        width: "50%",
                        encodeHtml: false
                    }
                ],
                onSelectionChanged: function (e) {
                    selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
                }
            });
        }

        function openAddModal() {
            resetForm();
            $(selectors.id).val("0");
            $(selectors.itemModalLabel).text("Add Confirmation Template");
            $(selectors.itemModal).modal("show");
        }

        function openEditModal() {
            if (!selectedRowData) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }

            resetForm();
            fillForm(selectedRowData);
            $(selectors.itemModalLabel).text("Edit Confirmation Template");
            $(selectors.itemModal).modal("show");
        }

        function fillForm(data) {
            $(selectors.id).val(data.id || 0);
            setTomSelectValue(selectors.rateCodeID,data.rateCodeID || "")
            setTomSelectValue(selectors.nationality,data.nationality ?? "")
            $(selectors.letterName).val(data.letterName ?? "");

            if (editorInstance) {
                editorInstance.setData(data.template ?? "");
            }
        }

        function resetForm() {
            $(selectors.form)[0].reset();
            $(selectors.id).val("0");

            if (editorInstance) {
                editorInstance.setData("");
            }

            applyValidationErrors([], selectors.form);
            $("#cfT_templateError").text("");
            clearMultipleTomSelect([selectors.rateCodeID,selectors.nationality]);
        }

        function saveRecord() {
            const id = parseInt($(selectors.id).val()) || 0;
            const loginName = (localStorage.getItem("Loginname") || "").trim().replace(/^"(.*)"$/, "$1");

            const model = {
                id: id,
                rateCodeID: parseInt($(selectors.rateCodeID).val()) || 0,
                letterName: $(selectors.letterName).val().trim(),
                nationality: ($(selectors.nationality).val() || "").trim(),
                template: editorInstance ? editorInstance.getData() : "",
                createdBy: loginName,
                updatedBy: loginName
            };

            $.ajax({
                url: endpoints.save,
                type: "POST",
                cache: false,
                contentType: "application/json",
                data: JSON.stringify(model),
                success: function (res) {
                    if (res.success) {
                        showToast("Success", res.message, true);
                        $(selectors.itemModal).modal("hide");
                        loadGrid();
                        return;
                    }

                    if (res.errors && res.errors.length > 0) {
                        applyValidationErrors(res.errors, selectors.form);

                        const generalError = res.errors.find(x => x.field === "general");
                        const toastMessage = generalError ? generalError.message : "Please check input fields.";

                        showToast("Warning", toastMessage, false);
                        return;
                    }

                    showToast("Error", res.message || "Save failed", false);
                },
                error: function () {
                    showToast("Error", "Save failed", false);
                }
            });
        }

        function deleteRecord() {
            if (!selectedRowData) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }

            if (!confirm("Are you sure you want to delete this template?")) {
                return;
            }

            $.ajax({
                url: endpoints.delete + selectedRowData.id,
                type: "POST",
                success: function (res) {
                    if (res.success) {
                        selectedRowData = null;
                        showToast("Success", "Deleted successfully", true);
                        loadGrid();
                    } else {
                        showToast("Error", res.message || "Delete failed", false);
                    }
                },
                error: function () {
                    showToast("Error", "Delete failed", false);
                }
            });
        }

        function clearFieldError(element) {
            const $element = $(element);

            if ($element.hasClass("is-invalid")) {
                $element.removeClass("is-invalid");
            }

            const $feedback = $element.siblings(".invalid-feedback");
            if ($feedback.length) {
                $feedback.text("");
            }
        }

        return {
            init: init,
            loadGrid: loadGrid,
            openAddModal: openAddModal,
            openEditModal: openEditModal
        };
    })();

    window.openModalConfirmationTemplateConfig = function () {
        $("#cfT_mainModal").modal("show");
        cfT_Module.init();
    };
</script>