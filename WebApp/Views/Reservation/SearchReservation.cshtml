<script>
    function toggleLeftMenu() {
        const leftMenu = $('#leftMenu');
        const rightContent = $('#rightContent');
        const toggleIcon = $('#toggleLeftMenu');
        const toggleLeftWrapper = $('#toggleLeftWrapper');

        // Kiểm tra trạng thái hiện tại (nếu đang ẩn thì chuẩn bị hiện và ngược lại)
        const isCurrentlyVisible = leftMenu.is(':visible');

        if (isCurrentlyVisible) {
            leftMenu.hide();
            rightContent.removeClass('col-md-9 col-md-8').addClass('col-md-12');
            toggleIcon.removeClass('fa-solid fa-filter-circle-xmark').addClass('fa-solid fa-filter');

            // Cập nhật tooltip thành "Hiện"
            toggleLeftWrapper.attr('data-tooltip', 'Show left menu');
        } else {
            leftMenu.show();
            rightContent.removeClass('col-md-12 col-md-8').addClass('col-md-9');
            toggleIcon.removeClass('fa-solid fa-filter').addClass('fa-solid fa-filter-circle-xmark');

            // Cập nhật tooltip thành "Ẩn"
            toggleLeftWrapper.attr('data-tooltip', 'Hide left menu');
        }

        if(typeof UI !== 'undefined' && UI.refreshTooltips) UI.refreshTooltips();
    }

    if (document.getElementById('btnViewIndividual')) bindIndividualSearchButton();

    function setupDefaultCaret() {
        $('#caretDownFunctionAndOption').hide();
        $('#caretDownFilter').hide();
    }
    function clickCaretDownFunctionAndOption() {
        $('#caretUpFunctionAndOption').show();
        $('#caretDownFunctionAndOption').hide();
        $('#functionAndOption').show();
    }
    function clickCaretUpFunctionAndOption() {
        $('#caretUpFunctionAndOption').hide();
        $('#caretDownFunctionAndOption').show();
        $('#functionAndOption').hide();
    }
    function clickCaretDownFilter() {
        $('#caretUpFilter').show();
        $('#caretDownFilter').hide();
        $('#filter').show();
    }
    function clickCaretUpFilter() {
        $('#caretUpFilter').hide();
        $('#caretDownFilter').show();
        $('#filter').hide();
    }
    function openVisibleColumns() {
        // Call updateColumnList from within initializeDataGridSearch when grid is initialized
        const offcanvasElement = document.getElementById('columnOffcanvas');
        const offcanvas = new bootstrap.Offcanvas(offcanvasElement);
        offcanvas.show();
    }
    $(document).ready(async function () {
        await getBusinessDate();
        setupDefaultCaret();
        const urlParams = new URLSearchParams(window.location.search);
        const type = urlParams.get("type");
        const leftMenu = $('#leftMenu');
        const toggleLeftWrapper = $('#toggleLeftWrapper');

        // Khởi tạo trạng thái Tooltip ban đầu dựa trên thực tế hiển thị
        const initialVisible = leftMenu.is(':visible');
        toggleLeftWrapper.attr('data-tooltip', initialVisible ? 'Hide left menu' : 'Show left menu');

        $('#setttingGrid').attr('data-tooltip', 'Setting table');
        $('#exportExcelReservation').attr('data-tooltip', 'Export Excel');

        // ===== Mapping type -> searchType =====
        const typeMapping = {
            guestInHouse: "1",
            dueInCheckedIn: "3",
            checkedIn: "4",
            dueout: "5",
            checkedOut: "6",
            arrivalCheckedInToday: "12",
            checkedOutToday: "13",
            all: "14"
        };

        if (type && typeMapping[type]) {
            $("#searchType").val(typeMapping[type]).trigger("change");
        }
        await searchReservation(isInitial = true);
        $('#listFunction').hide();
        $('#searchType, #name, #firstName, #resvHolder, #confirmationNo, #crsNo, #roomNo, #roomType, #package, #zone, #arrivalForm, #departureForm, #roomShare, #owner').on('keypress', async function (e) {
            if (e.which === 13) {
                e.preventDefault();
                await searchReservation();
            }
        });
    });
    async function getBusinessDate() {
        window.initDateInputs();
        await window.businessDateReady;

        $('#dateTraces').val(dateSystem);
        $('#fromDateAddNewTrace').val(dateSystem);
        $('#toDateAddNewTrace').val(dateSystem);

        // Chỉ set giá trị nếu các trường ngày trống
        if (!$('#arrivalForm').val()) {

            const vadsda = $('#arrivalForm').val();

            UI.setHiddenDate("arrivalForm", dateSystem);
            console.log('arrivalForm', vadsda);
            console.log('departureIsodateSystem', dateSystem);
            $('#expDatePaymentBilling').val(dateSystem);
            $('#transDatePaymentBilling').val(dateSystem);
            $('#fromDateSelectOption').val(dateSystem);
            $('#toDateSelectOption').val(dateSystem);



        }
