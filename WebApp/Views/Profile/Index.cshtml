            "#pro_search_txtMarketTypeCOM"
        ]; 

        // --- 3. RESET CHO GROUP (Nhóm) ---
        const groupInputs = [
            "#pro_search_idGroup", "#pro_search_txtCodeGroup", "#pro_search_txtGroupNameGroup", "#pro_search_txtHomeAddressGroup",
            "#pro_search_txtAddressGroup", "#pro_search_txtCityGroup", "#pro_search_txtPostalCodeGroup",
