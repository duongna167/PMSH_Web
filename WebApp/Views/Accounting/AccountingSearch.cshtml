<div class="modal fade" id="aras_modalMain" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header py-2">
                <h5 class="modal-title" id="aras_title">Accounting Search</h5>
            </div>

            <div class="modal-body">

             

                <!-- FILTER -->
                <div class="search-filter">
                    <!-- ACTIONS -->
                    <div class="mb-1 mt-1">
                        <button class="mui-button mui-button-new" id="aras_btnSearch" type="button">Search</button>
                        <button class="mui-button mui-button-new" id="aras_btnOverCreditLimit" type="button">Over Credit Limit</button>
                        <button class="mui-button mui-button-new" id="aras_btnNew" type="button">New</button>
                        <button class="mui-button mui-button-new" id="aras_btnAR" type="button">AR</button>
                        <button class="mui-button mui-button-new" id="aras_btnEdit" type="button">Edit</button>
                        <button class="mui-button mui-button-new" data-bs-dismiss="modal" aria-label="Close">Close</button>
                    </div>
                    <div class="row g-2 mt-1 align-items-center">

                        <!-- Account Name -->
                        <div class="col-12 col-sm-6 col-md-4 col-lg-4 col-xl-3">
                            <div class="row g-1 align-items-center">
                                <label class="col-4 text-end mb-0 text-nowrap" for="aras_accountName">Account Name</label>
                                <div class="col-8">
                                    <input type="text" id="aras_accountName" name="aras_accountName"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <!-- AccountNo -->
                        <div class="col-12 col-sm-6 col-md-4 col-lg-4 col-xl-2">
                            <div class="row g-1 align-items-center">
                                <label class="col-4 text-end mb-0 text-nowrap" for="aras_accountNo">AccountNo</label>
                                <div class="col-8">
                                    <input type="text" id="aras_accountNo" name="aras_accountNo"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <!-- Account Type -->
                        <div class="col-12 col-sm-12 col-md-4 col-lg-4 col-xl-3">
                            <div class="row g-1 align-items-center">
                                <label class="col-4 text-end mb-0 text-nowrap" for="aras_accountType">Account Type</label>
                                <div class="col-8">
                                    <select id="aras_accountType" name="aras_accountType"
                                            asp-items="ViewBag.cboAccountType"
                                            class="tomselect-custom"></select>
                                </div>
                            </div>
                        </div>

                        <!-- Search Type -->
                        <div class="col-12 col-md-12 col-lg-5 col-xl-5">
                            <div class="row g-1 align-items-center">
                                <label class="col-md-2 col-1 text-end mb-0 fw-semibold text-nowrap">Type:</label>
                                <div class="col-md-10 col-11 d-flex flex-wrap gap-2">

                                    <div class="form-check form-check-inline mb-0 ">
                                        <input type="radio" id="aras_typeAll" name="aras_searchType" value="" checked>
                                        <label class="form-check-label" for="aras_typeAll">All</label>
                                    </div>

                                    <div class="form-check form-check-inline mb-0">
                                        <input type="radio" id="aras_typeOpenBalance" name="aras_searchType" value="0">
                                        <label class="form-check-label" for="aras_typeOpenBalance">Open Balance</label>
                                    </div>

                                    <div class="form-check form-check-inline mb-0">
                                        <input type="radio" id="aras_typeNoBalance" name="aras_searchType" value="3">
                                        <label class="form-check-label" for="aras_typeNoBalance">No Balance</label>
                                    </div>

                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- LOADING -->
                <div id="aras_loading" class="text-center py-2" style="display:none;">
                    <div class="spinner-border" role="status"></div>
                </div>

                <!-- GRID (fixed height) -->
                <div class="mui-card mt-2">
                    <div id="aras_gridContainer" class="gridContainer" style="height:500px;"></div>
                </div>

            </div>
        </div>
    </div>
</div>

