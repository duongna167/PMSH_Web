@using DevExpress.XtraReports.UI
@{
    var listzone = ViewBag.ZoneList;
}
<style>
    .filter-box {
        border: 1px solid #ced4da;
        border-radius: 6px;
        padding: 8px;
        background: #fff;
    }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 6px 8px;
    }

    .filter-item label {
        font-size: 11px;
        font-weight: 600;
        margin-bottom: 2px;
        display: block;
        color: #555;
    }

    .filter-item input,
    .filter-item select {
        height: 28px;
        font-size: 13px;
    }

    .filter-inline {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .filter-checks {
        display: flex;
        gap: 16px;
        margin-top: 4px;
        font-size: 13px;
    }

    /*css tomselect */

    /* Wrapper select để khống chế chiều cao */
    .filter-item .ts-wrapper {
        width: 100%;
    }

    /* Khung TomSelect  */
    .ts-control {
        height: 28px !important;
        min-height: 28px !important;
        padding: 2px 6px !important;
        font-size: 13px !important;
        display: flex !important;
        align-items: center !important;
        flex-wrap: wrap !important;
        overflow-x: hidden !important;
        overflow-y: auto !important;
    }

        /* Thẻ Item đã chọn  */
        .ts-control .item {
            height: 20px !important;
            padding: 0 6px !important;
            margin: 2px 4px 2px 0 !important;
            font-size: 12px !important;
            line-height: 20px !important;
            background: #f1f1f1 !important;
            border: 1px solid #ddd !important;
            border-radius: 3px !important;
            display: inline-flex !important;
            align-items: center !important;
        }


            /* Nút X xóa từng item (nếu dùng plugin remove_button) */
            .ts-control .item .remove {
                margin-left: 4px !important;
                padding-left: 4px !important;
                border-left: 1px solid #ccc !important;
            }

    /* Nút X xóa toàn bộ (Custom Clear Button) */
    .tomselect-custom-wrapper {
        position: relative !important;
        width: 100%;
    }

    .clear-button {
        position: absolute !important;
        right: 8px !important;
        top: 50% !important;
        transform: translateY(-50%) !important;
        cursor: pointer !important;
        font-size: 1.1rem !important;
        color: #bbb !important;
        z-index: 10 !important;
        background: none !important;
        border: none !important;
        padding: 0 5px !important;
        transition: color 0.2s !important;
    }

    /* Đệm bên phải để text không đè lên nút Clear */
    .ts-wrapper.tomselect-custom .ts-control {
        padding-right: 28px !important;
    }

        .ts-control input {
            height: 20px !important;
            font-size: 12px !important;
            padding-left: 2px !important;
        }

    /* Dropdown menu */
    .ts-dropdown {
        z-index: 1060 !important;
        font-size: 13px !important;
    }

    /* Tùy chỉnh thanh cuộn nhỏ  */
    .ts-control::-webkit-scrollbar {
        width: 4px;
    }

    .ts-control::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 4px;
    }
    /*end css tomselect */
</style>


<div class="text-center" id="reportTitle" style="font-size: 20px">
    Issuing Card To Guests
</div>
<!-- ================= BUTTONS ================= -->
<div class="py-2 d-flex flex-wrap gap-2 align-items-center">
    <button class="mui-button button-report-view" id="btnView">View</button>
    <button class="mui-button button-report-view" id="btnOK">OK</button>
    <button class="mui-button button-report-delete" id="btnCancelCard">Cancel Card</button>

    <div class="d-flex align-items-center ms-auto">
        <label class="filter-label">Input CardID</label>
        <input id="cardID" name="cardID" class="form-control" style="width:180px">
    </div>
</div>

<!-- ================= FILTER AREA ================= -->
<div class="row g-2">

    <!-- FILTER -->
    <div class="col-md-8">
        <div class="filter-box">
            <div class="filter-grid">

                <div class="filter-item">
                    <label>Fst.Name</label>
                    <input id="firstName" class="form-control">
                </div>

                <div class="filter-item">
                    <label>Conf.No</label>
                    <input id="confNo" class="form-control">
                </div>

                <div class="filter-item">
                    <label>CRS/GC</label>
                    <input id="crsNoorGC" class="form-control">
                </div>

                <div class="filter-item">
                    <label>Room No</label>
                    <input id="roomNo" class="form-control">
                </div>

                <div class="filter-item">
                    <label>Zone</label>
                    <select id="zone" name="zone" multiple>
                        @foreach (var sg in ViewBag.ZoneList)
                        {
                            <option value="@sg.Code">@sg.Code</option>
                        }
                    </select>
                </div>

                <div class="filter-item">
                    <label>CardID</label>
                    <input id="searchcardID" class="form-control">
                </div>

                <div class="filter-item">
                    <label>Arr.From</label>
                    <div class="filter-inline">
                        <input type="date" id="fromDate" class="form-control">
                        <input type="checkbox" id="chkfromDate" checked>
                    </div>
                </div>

                <div class="filter-item">
                    <label>Arr.To</label>
                    <div class="filter-inline">
                        <input type="date" id="toDate" class="form-control">
                        <input type="checkbox" id="chktoDate" checked>
                    </div>
                </div>

                <div class="filter-item">
                    <label>Name</label>
                    <input id="name" class="form-control">
                </div>

                <div class="filter-item">
                    <label>Resv</label>
                    <input id="resvHolder" class="form-control">
                </div>

                <div class="filter-item">
                    <label>Type</label>
                    <input id="searchType" class="form-control">
                </div>

            </div>

            <div class="filter-checks">
                <label><input type="checkbox" id="roomSharer" checked> Sharer</label>
                <label><input type="checkbox" id="guesthascard" checked> Show guest has card</label>
                <label><input type="checkbox" id="bycardIDfromCardReader"> Card reader</label>
            </div>
        </div>
    </div>


    <div class="col-md-2">
        <div class="filter-box">
            <label><input type="checkbox" id="addCard" checked> Add Card</label><br>
            <label><input type="checkbox" id="cutKey" disabled> Cut Key</label>
        </div>
    </div>

    <div class="col-md-2">
        <div class="filter-box" style="font-size:12px">
            <div>1. Select guest</div>
            <div>2. Insert card</div>
            <div>3. Choose option</div>
            <div>4. Click OK</div>
        </div>
    </div>

</div>


<!-- ================= GRID ================= -->
<div class="mui-card mt-3">
    <div id="gridContainerRateCode" class="gridContainer"></div>
</div>

<!-- Loading Spinner -->
<div id="loadingSpinnerRateCode" style="display: none; text-align: center; padding: 20px;">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
</div>

<script>
     const statusMap = {
        "Done": 1,
        "Pending": 2,
        "Transferred": 3
        };

        // Map QualityType code -> ID
        const qualityTypeMap = {
            "NV": 1, // None Value
            "V": 2  // Value
        };



    DevExpress.localization.locale("vi");
    var selectedRowsData = [];

      function formatDate(date) {
            let year = date.getFullYear();
            let month = (date.getMonth() + 1).toString().padStart(2, '0'); // Đảm bảo có 2 chữ số
            let day = date.getDate().toString().padStart(2, '0'); // Đảm bảo có 2 chữ số
            return `${year}-${month}-${day}`;
        }

      $(document).ready(function () {
            // Khởi tạo kết nối tới SignalR Hub
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/tagScanHub")
                .build();

            // Khi server gửi code RFID về
            connection.on("ReceiveCode", function (code) {
                console.log("Mã quét được:", code);

                // Gán giá trị vào ô input
                $("#cardID")
                .val(code)
                .trigger("change") // 🔥 Thêm dòng này để on("change") hoạt động
                .addClass("border-success")
                .fadeOut(100)
        .fadeIn(100);

          
            });

            // Bắt đầu kết nối
            connection.start()
                .then(function () {
                    console.log("✅ Kết nối SignalR thành công!");
                })
                .catch(function (err) {
                    console.error("❌ Lỗi kết nối SignalR:", err);
                });

                const today = new Date();
                const firstDayOfMonth = new Date(today.getFullYear(), today.getMonth(), 1);
                // Lấy ngày cuối cùng của tháng
                const lastDayOfMonth = new Date(today.getFullYear(), today.getMonth() + 1, 0);
              // Định dạng theo local time
                const formattedFirstDay = formatDate(firstDayOfMonth);
                const formattedLastDay = formatDate(lastDayOfMonth);
                console.log(formattedFirstDay); // Kiểm tra giá trị đúng chưa
                console.log(formattedLastDay); // Kiểm tra giá trị đúng chưa
                // Gán giá trị cho input date
                document.getElementById('fromDate').value = formattedFirstDay;
                document.getElementById('toDate').value = formattedLastDay;

                    $("#fromDate").prop("disabled", !$("#chkfromDate").is(":checked"));
                    $("#toDate").prop("disabled", !$("#chktoDate").is(":checked"));

                    // Sự kiện change
                    $("#chkfromDate").change(function () {
                        if ($(this).is(":checked")) {
                            $("#fromDate").prop("disabled", false);
                            $("#fromDate").val(new Date().toISOString().split('T')[0]);
                        } else {
                            $("#fromDate").prop("disabled", true).val("");
                        }
                    });

                    $("#chktoDate").change(function () {
                        if ($(this).is(":checked")) {
                            $("#toDate").prop("disabled", false);
                            $("#toDate").val(new Date().toISOString().split('T')[0]);
                        } else {
                            $("#toDate").prop("disabled", true).val("");
                        }
                    });
                     $("#cardID").on("change", function () {
                        let value = $(this).val();

                        // Kiểm tra nếu đủ 8 số và toàn là số
                        if (value.length === 8 && /^\d+$/.test(value)) {
                            insertCard(value);
                        }
                    });


                initializeTomSelects();
                reloadGrid();
        });
         function initializeTomSelects() {
                const selectors = ["#zone"];

            selectors.forEach(selector => {
            const el = document.querySelector(selector);
            if (el) {
                 if (el.tomselect) el.tomselect.destroy();
                    new TomSelect(el, {
                        plugins: {
                        'remove_button': { title: 'Deselect' },
                        'dropdown_input': {},
                        'clear_button': { title: 'Clear all' },
                    },
                    dropdownParent: 'body',
                    create: false,
                    maxItems: null,
                    valueField: 'value',
                    labelField: 'text',
                    searchField: ['text'],
                    placeholder: ' Enter or select options...',
                    onClear: function() {
                    const self = this;
                    setTimeout(() => {
                        self.close();
                        self.blur();
                    }, 10);
                },
                    render: {
                        option: function(data, escape) {
                            return `<div class="p-2"> ${escape(data.text)} </div>`;
                        },
                        item: function(data, escape) {
                            return '<div title="' + escape(data.text) + '">' + escape(data.text) + '</div>';
                        }
                    }

                });
            }
        });
        }

              function loadGrid(data) {
        $("#gridContainerRateCode").dxDataGrid({
            dataSource: data,
            height: 500,
            width: "100%",
            columnAutoWidth: true,
            allowColumnResizing: true,
            columnResizingMode: "widget",
            selection: { mode: "multiple" },
            columns: [        
                { dataField: "cardID", caption: "CardID", width: "11%" },
                { dataField: "confirmationNo", caption: "Conf.No", width: "11%" },

                { dataField: "mainGuest", caption: "M", width: "11%" },
                { dataField: "nat", caption: "Nat", width: "11%" },

                { dataField: "title", caption: "Title", width:"11%" },
                { dataField: "account", caption: "Guest Name", width: "11%" },

                { dataField: "dateOfBirth", caption: "Date Of Birth", dataType: "date", format: "dd/MM/yyyy", width: "11%" },
                { dataField: "passPort", caption: "Pass Port", width: "11%" },

                { dataField: "identityCard", caption: "Identity Card", width: "11%" },
                { dataField: "roomNo", caption: "Ro.No", width: "11%" },

                { dataField: "roomType", caption: "Ro.Type", width: "11%" },
                { dataField: "arrivalDate", caption: "Arr.Date", dataType: "date", format: "dd/MM/yyyy", width: "11%" },

                { dataField: "noOfNight", caption: "N", width: "11%" },
                { dataField: "departureDate", caption: "Dep.Date", dataType: "date", format: "dd/MM/yyyy", width: "11%" },

                { dataField: "package", caption: "Package", width: "11%" },
                { dataField: "noOfAdult", caption: "A", width: "11%" },

                { dataField: "noOfChild", caption: "C", width: "11%" },
                { dataField: "noOfChild1", caption: "C1", width: "11%" },

                { dataField: "noOfChild2", caption: "C2", width: "11%" },
                { dataField: "statusText", caption: "Status", width: "11%" },

                { dataField: "reservationHolder", caption: "Reservation Holder", width: "11%" },
                { dataField: "address", caption: "Address", width: "11%" },
            ],
            filterRow: { visible:true, applyFilter:"auto" },
            paging: { pageSize:20 },
            pager: {
                visible:true,
                allowedPageSizes:[20,50,'all'],
                showPageSizeSelector:true,
                showInfo:true,
                showNavigationButtons:true
            },
            scrolling: { mode:"standard", showScrollbar:"always", scrollByContent:true },
            onSelectionChanged: function(e){
                selectedRowsData = e.selectedRowsData || [];
                console.log("Selected Rows:", selectedRowsData);
            }
        });
    }

        // Reload grid với filter từ form
        function reloadGrid() {
            $("#loadingSpinnerRateCode").show();
                    let fromDate = $("#chkfromDate").is(":checked") ? $("#fromDate").val() : null;
                    let toDate   = $("#chktoDate").is(":checked") ? $("#toDate").val() : null;
            $.ajax({
                url: '/Miscellaneous/GetIssuingCardToGuests',
                type: 'GET',
                data: {
                    firstName: $("#firstName").val(),
                    confirmationNo: $("#confNo").val(),
                    crsNo: $("#crsNoorGC").val(),
                    roomNo: $("#roomNo").val(),
                    zone: $("#zone").val(),
                    guestName: $("#name").val(),
                    rsvHolder: $("#resvHolder").val(),
                    isShowRS: $("#roomSharer").is(":checked") ? "" : "Y",
                    isShowCard: $("#guesthascard").is(":checked") ? "" : "Y",
                    arrFrom:    fromDate,
                    arrTo: toDate,
                    status: $("#searchType").val(),
                    findCardID: $("#cardID").val(),

               },
                success: function(data){
                    console.log(data);
                    loadGrid(data);
                    $("#loadingSpinnerRateCode").hide();
                },
                error: function(xhr, status, error){
                    alert("Không thể tải dữ liệu");
                    $("#loadingSpinnerRateCode").hide();
                }
            });
        }

        // Nút view click
        $("#btnView").click(function(){
            reloadGrid();
        });
            // Hàm gọi AddCard API
        function insertCard(cardID) {
        if (!selectedRowsData || selectedRowsData.length === 0) {
            showToast('Warning', 'Please select 1 guest from the list before adding a card!', false);
            return;
        }

        const target = selectedRowsData[0]; // chỉ lấy row đầu tiên
        const gridData = $("#gridContainerRateCode").dxDataGrid("instance").option("dataSource");
        const exists = Array.isArray(gridData) && gridData.some(row => String(row.cardID) === String(cardID));
        if (exists) {
               showToast('Warning', 'This CardID already exists in the list. Please check again!', false);
 
            return;
        }

        const requestData = {
            Reservation: {
                ID: target.reservationID,
                CardId: cardID
            },
        };

        $("#loadingSpinnerRateCode").show();

        $.ajax({
            url: '/Miscellaneous/AddCard',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(requestData),
            success: function(response) {
                $("#loadingSpinnerRateCode").hide();
                if (response && response.success) {
                    // ✅ Khi thêm thành công
                    showToast("Success", response.message || "Card added successfully!", true);
                    $("#cardID").val('');
                    reloadGrid();
                } else {
                    // ⚠️ Khi server trả về success = false nhưng không lỗi HTTP
                    showToast("Error", response.message || "Có lỗi xảy ra khi thêm thẻ.", false);
                }
            },
            error: function(xhr, status, error) {
                $("#loadingSpinnerRateCode").hide();
                showToast("Error", "Card added error!", false);
            }
        });
    }

            function CancelCard() {
        if (!selectedRowsData || selectedRowsData.length === 0) {
            alert("Vui lòng chọn ít nhất 1 guest trong danh sách trước khi hủy card!");
            return;
        }

        $("#loadingSpinnerRateCode").show();

        let requests = selectedRowsData.map(row => {
            return $.ajax({
                url: '/Miscellaneous/CancelCard',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    Reservation: {
                        ID: row.reservationID,
                        CardId: row.cardID
                    }
                })
            });
        });

        $.when.apply($, requests).done(function () {
            $("#loadingSpinnerRateCode").hide();
            showToast("Success", "Card Canceled successfully!", true);
            reloadGrid();
        }).fail(function () {
            $("#loadingSpinnerRateCode").hide();
            showToast("Error", "Card Canceled error!", false);
        });
    }


    $("#btnCancelCard").click(function() {
        CancelCard();
        reloadGrid();
    });


</script>