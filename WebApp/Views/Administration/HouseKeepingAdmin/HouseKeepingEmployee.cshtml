@using DevExpress.XtraReports.UI

@{
    var selectedReport = ViewBag.ReportHeader;
    var listEmployee = ViewBag.hkpEmployee;
}


<!-- =========================
     MAIN MODAL (modal-xl)
     ========================= -->
<div class="modal fade" id="hKE_modalMain" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">House Keeping Employee</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">
                    <!-- Toolbar -->
                    <div>
                        <button id="hKE_btnView" type="button" class="mui-button button-report-view">View</button>
                        <button id="hKE_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="hKE_btnUpdate" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="hKE_btnDelete" type="button" class="mui-button button-report-delete">Delete</button>
                        <button id="hKE_btnExportExcel" type="button" class="mui-button mui-button-export">Excel</button>
                        <button id="hKE_btnClose" type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                    </div>

                    <!-- ERP Search Filter -->

                    <div class="row g-2 mt-1 mb-2">

                        <input type="hidden" id="hKE_filterId" name="hKE_filterId" />

                        <div class="col-12 col-lg-4">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end"
                                       for="hKE_description">Name</label>
                                <div class="col-md-8">
                                    <input type="text"
                                           id="hKE_description"
                                           name="hKE_description"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-4">
                            <div class="row g-2 align-items-center">
                                <div class="col-md-4"></div>
                                <div class="col-md-8">
                                    <div class="form-check">
                                        <input 
                                               type="checkbox"
                                               id="hKE_showInactive"
                                               name="hKE_showInactive"
                                               value="1">
                                        <label class="form-check-label" for="hKE_showInactive">Show Inactive</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Grid -->
                <div class="mui-card">
                    <div id="hKE_gridContainer" class="gridContainer"></div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- =========================
     EDIT / NEW MODAL (modal-xl)
     ========================= -->
<div class="modal fade" id="hKE_modalEdit" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="hKE_modalEditTitle">Employee Screen</h5>
            </div>

            <div class="modal-body">

                <div class="search-filter">
                    <button id="hKE_btnSave" type="button" class="mui-button mui-button-advance">Ok</button>
                    <button id="hKE_btnEditClose" type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                </div>

                <form id="hKE_formEdit" novalidate class="mt-1 mb-2">
                    <input type="hidden" id="hKE_idHouseKeepingEmployee" name="hKE_idHouseKeepingEmployee" />

                    <div class="row g-2">

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-4 col-form-label col-form-label-sm text-md-end"
                                       for="hKE_codenew">Name</label>
                                <div class="col-md-8">
                                    <input type="text"
                                           id="hKE_codenew"
                                           name="hKE_codenew"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="row g-2 align-items-center">
                                <div class="col-md-4"></div>
                                <div class="col-md-8">
                                    <div class="form-check">
                                        <input 
                                               type="checkbox"
                                               id="hKE_isActivenew"
                                               name="hKE_isActivenew"
                                               value="1"
                                               checked>
                                        <label class="form-check-label" for="hKE_isActivenew">Inactive</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2 align-items-start">
                                <label class="col-md-2 col-form-label col-form-label-sm text-md-end"
                                       for="hKE_descriptionnew">Description</label>
                                <div class="col-md-10">
                                    <textarea id="hKE_descriptionnew"
                                              name="hKE_descriptionnew"
                                              class="form-control form-control-sm"
                                              rows="4" style="height: 100px;"></textarea>
                                </div>
                            </div>
                        </div>

                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

<div id="hKE_loadingSpinner"
    style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
    z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
    height: 100%;display: flex;align-items: center;justify-content: center;">
    <div class="spinner-border text-primary"></div>
</div>

<script>
    var hKE_Module = (function () {
        "use strict";

        const SEL = {
            modalMain: "#hKE_modalMain",
            modalEdit: "#hKE_modalEdit",
            spinner: "#hKE_loadingSpinner",

            btnView: "#hKE_btnView",
            btnNew: "#hKE_btnNew",
            btnUpdate: "#hKE_btnUpdate",
            btnDelete: "#hKE_btnDelete",
            btnExportExcel: "#hKE_btnExportExcel",
            btnSave: "#hKE_btnSave",

            filterId: "#hKE_filterId",
            description: "#hKE_description",
            showInactive: "#hKE_showInactive",

            grid: "#hKE_gridContainer",

            formEdit: "#hKE_formEdit",
            modalEditTitle: "#hKE_modalEditTitle",
            idHouseKeepingEmployee: "#hKE_idHouseKeepingEmployee",
            codenew: "#hKE_codenew",
            descriptionnew: "#hKE_descriptionnew",
            isActivenew: "#hKE_isActivenew"
        };

        let _gridInstance = null;
        let _selectedRowData = null;
        let _bound = false;

        function showLoading(show) {
            if (show) $(SEL.spinner).show();
            else $(SEL.spinner).hide();
        }

        function csrfHeaders() {
            return {
                "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val()
            };
        }

        function disposeGrid() {
            try {
                const inst = $(SEL.grid).dxDataGrid("instance");
                if (inst) inst.dispose();
            } catch (e) { }

            _gridInstance = null;
            _selectedRowData = null;
            $(SEL.grid).empty();
        }

        function clearForm() {
            $(SEL.idHouseKeepingEmployee).val("");
            $(SEL.codenew).val("");
            $(SEL.descriptionnew).val("");
            $(SEL.isActivenew).prop("checked", false);
        }

        function fillFormFromRow(row) {
            const localListEmployee = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.hkpEmployee ?? new List<object>()));
            const selectedId = parseInt(row.ID, 10);
            const selectedItem = localListEmployee.find(x => x.ID === selectedId);

            if (!selectedItem) {
                showToast("Error", "No matching data found!", false);
                return false;
            }

            $(SEL.idHouseKeepingEmployee).val(selectedItem.ID);
            $(SEL.codenew).val(selectedItem.Name || "");
            $(SEL.descriptionnew).val(selectedItem.Description || "");
            $(SEL.isActivenew).prop("checked", selectedItem.Inactive === true || selectedItem.Inactive === "True" || selectedItem.inactive === 1);

            return true;
        }

        function validateForm() {
            const nameValue = $(SEL.codenew).val().trim();
            const descriptionValue = $(SEL.descriptionnew).val().trim();

            if (nameValue === "") {
                showToast("Error", "Code cannot be blank.", false);
                $(SEL.codenew).focus();
                return false;
            }

            if (descriptionValue === "") {
                showToast("Error", "Description cannot be blank.", false);
                $(SEL.descriptionnew).focus();
                return false;
            }

            return true;
        }

        function getSavePayload() {
            return {
                id: $(SEL.idHouseKeepingEmployee).val(),
                codenew: $(SEL.codenew).val(),
                descriptionnew: $(SEL.descriptionnew).val(),
                user: localStorage.getItem("Loginname"),
                isActive: $(SEL.isActivenew).is(":checked") ? 1 : 0
            };
        }

        function initGrid(data) {
            disposeGrid();

            _gridInstance = $(SEL.grid).dxDataGrid({
                dataSource: data || [],
                showBorders: true,
                selection: { mode: "single" },
                columns: [
                    { dataField: "ID", caption: "ID", width: 100, visible: false },
                    { dataField: "Name", caption: "Name", width: 150 },
                    { dataField: "Description", caption: "Description", minWidth: 120, cssClass: "col-description"},
                    { dataField: "Inactive", caption: "Inactive", width: 60 ,
                        cellTemplate: function (container, options) {
                            $("<div>")
                                .dxCheckBox({
                                    value: !!options.value,
                                    readOnly: true
                                })
                                .css("transform", "scale(0.8)")
                                .appendTo(container);
                        }
                    },
                    { dataField: "CreatedBy", caption: "Created By", width: 80 },
                    { dataField: "CreatedDate", caption: "Cre.Date", dataType: "date", format: "dd/MM/yyyy", width: 80 },
                    { dataField: "UpdatedBy", caption: "Updated By", width: 80 },
                    { dataField: "UpdatedDate", caption: "Upd.Date", dataType: "date", format: "dd/MM/yyyy", width: 80 },
                ],

                scrolling: {
                    mode: "standard",
                    showScrollbar: "always",
                    scrollByContent: true
                },
                paging: {
                    pageSize: 50
                },
                pager: {
                    visible: true,
                    allowedPageSizes: [50, 100, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: {
                    visible: true,
                    applyFilter: "auto"
                },

                onSelectionChanged: function (e) {
                    _selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;
                },
                onRowClick: function (e) {
                    _selectedRowData = e.data || null;
                }
            }).dxDataGrid("instance");
        }

        function loadData() {
            const isActive = $(SEL.showInactive).is(":checked") ? 1 : 0;

            showLoading(true);

            $.ajax({
                url: "/HouseKeepingAdmin/HouseKeepingEmployeeData",
                type: "GET",
                data: {
                    description: $(SEL.description).val(),
                    isActive: isActive
                },
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (result) {
                    initGrid(result);
                    showLoading(false);
                },
                error: function () {
                    showLoading(false);
                    showToast("Error", "Không thể tải báo cáo.", false);
                }
            });
        }

        function openNew() {
            clearForm();
            $(SEL.modalEditTitle).text("Employee Screen");
            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).show();
        }

        function openEdit() {
            if (!_selectedRowData) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }

            clearForm();
            const ok = fillFormFromRow(_selectedRowData);
            if (!ok) return;

            $(SEL.modalEditTitle).text("Employee Screen");
            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).show();
        }

        function save() {
            if (!validateForm()) return;

            showLoading(true);

            $.ajax({
                url: "/HouseKeepingAdmin/HouseKeepingEmployeeSave",
                type: "POST",
                data: getSavePayload(),
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (result) {
                    showLoading(false);

                    if (result.success) {
                        showToast("Success", result.message, true);
                        bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).hide();
                        loadData();
                        clearForm();
                    } else {
                        showToast("Error", "Please select before saving.", false);
                    }
                },
                error: function () {
                    showLoading(false);
                    showToast("Error", "Không thể tải báo cáo.", false);
                }
            });
        }

        function removeSelected() {
            if (!_selectedRowData) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }

            if (!confirm("Are you sure you want to delete item?")) {
                return;
            }

            $.ajax({
                url: "/HouseKeepingAdmin/HouseKeepingEmployeeDelete",
                type: "POST",
                data: {
                    id: _selectedRowData.ID
                },
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (result) {
                    if (result.success) {
                        showToast("Success", result.message, true);
                        loadData();
                    } else {
                        showToast("Error", result.message, false);
                    }
                },
                error: function () {
                    showToast("Error", "Không thể tải báo cáo.", false);
                    showLoading(false);
                }
            });
        }

        function exportExcel() {
            const grid = $(SEL.grid).dxDataGrid("instance");
            if (!grid) {
                showToast("Error", "No grid data to export.", false);
                return;
            }

            const workbook = new ExcelJS.Workbook();
            const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const worksheet = workbook.addWorksheet("Sheet 1");

            worksheet.addRow([companyName]);
            worksheet.mergeCells("A1:D1");
            worksheet.getRow(1).font = { bold: true };
            worksheet.getRow(1).alignment = { vertical: "middle", horizontal: "left" };

            const now = new Date();
            const exportDate = now.toLocaleString("vi-VN");
            worksheet.addRow(["", "", "", exportDate]);
            worksheet.mergeCells("D2:D2");
            worksheet.getRow(2).alignment = { vertical: "middle", horizontal: "right" };

            worksheet.addRow([]);
            worksheet.addRow([]);

            const reportRow = worksheet.addRow(["House Keeping Employee"]);
            worksheet.mergeCells("A5:D5");
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { vertical: "middle", horizontal: "center" };

            worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const lastRow = worksheet.lastRow.number + 2;
                worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
                worksheet.getCell(`A${lastRow}`).alignment = { horizontal: "center" };
                worksheet.getCell(`A${lastRow}`).font = { italic: true };

                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "HouseKeepingEmployee.xlsx");
                });
            });
        }

        function bindEventsOnce() {
            if (_bound) return;
            _bound = true;

            $(document)
                .off("click.hKE", SEL.btnView).on("click.hKE", SEL.btnView, loadData)
                .off("click.hKE", SEL.btnNew).on("click.hKE", SEL.btnNew, openNew)
                .off("click.hKE", SEL.btnUpdate).on("click.hKE", SEL.btnUpdate, openEdit)
                .off("click.hKE", SEL.btnDelete).on("click.hKE", SEL.btnDelete, removeSelected)
                .off("click.hKE", SEL.btnExportExcel).on("click.hKE", SEL.btnExportExcel, exportExcel)
                .off("click.hKE", SEL.btnSave).on("click.hKE", SEL.btnSave, save);

            $(SEL.modalEdit)
                .off("shown.bs.modal.hKE")
                .on("shown.bs.modal.hKE", function () {
                })
                .off("hidden.bs.modal.hKE")
                .on("hidden.bs.modal.hKE", function () {
                    clearForm();
                    showLoading(false);
                });

            $(SEL.modalMain)
                .off("hidden.bs.modal.hKE")
                .on("hidden.bs.modal.hKE", function () {
                    $(SEL.filterId).val("");
                    $(SEL.description).val("");
                    $(SEL.showInactive).prop("checked", false);

                    disposeGrid();
                    showLoading(false);
                });
        }

        function init() {
            bindEventsOnce();
        }

        function open() {
            init();

            const modalEl = document.querySelector(SEL.modalMain);
            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

            $(modalEl).one("shown.bs.modal", function () {
                loadData();
            });

            modal.show();
        }

        return { init, open };
    })();

    window.openModalHKE = function () {
        hKE_Module.open();
    };
</script>