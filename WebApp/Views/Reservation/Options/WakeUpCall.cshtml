                                            </div>
                                        </div>
                                    </div>

                                    <!-- To Date -->
                                    <div class="col-12">
                                        <div class="row g-1 align-items-center">
                                            <label class="col-4 col-form-label col-form-label-sm text-md-end">
                                                To Date
                                            </label>
                                            <div class="col-7">
                                                <div data-date-input data-format="DD/MM/YYYY"
                                                    business-date data-name="toDate">
                                                    <input id="toDateUi"
                                                        name="toDateUi"
                                                        type="text"
                                                        class="date-ui form-control form-control-sm"
                                                        placeholder="dd/mm/yyyy"
                                                        autocomplete="off" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- RIGHT: View panel -->
                    <div class="group-box mb-3" id="viewWakeupcall">
                         <div class="row g-2 align-items-center">
                            <!-- Name -->
                            <div class="col-12">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 col-form-label col-form-label-sm text-md-end">
                                        Name
                                    </label>
                                    <div class="col-8">
                                        <input type="text" id="nameView" class="form-control form-control-sm">
                                    </div>
                                </div>
                            </div>

                            <!-- Group -->
                            <div class="col-12">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 col-form-label col-form-label-sm text-md-end">
                                        Group
                                    </label>
                                    <div class="col-8">
                                        <input type="text" id="groupName" class="form-control form-control-sm">
                                    </div>
                                </div>
                            </div>

                            <!-- Room -->
                            <div class="col-12">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 col-form-label col-form-label-sm text-md-end">
                                        Room
                                    </label>
                                    <div class="col-8">
                                        <select id="roomview" asp-items="ViewBag.cboRoom"></select>
                                    </div>
                                </div>
                            </div>

                            <!-- From Date -->
                            <div class="col-12">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 col-form-label col-form-label-sm text-md-end">
                                        From Date
                                    </label>
                                    <div class="col-8">
                                        <div data-date-input data-format="DD/MM/YYYY" business-date data-name="fromDateview">
                                            <input id="fromDateviewUi"
                                                name="fromDateviewUi"
                                                type="text"
                                                class="date-ui form-control form-control-sm"
                                                placeholder="dd/mm/yyyy"
                                                autocomplete="off" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Time + Radio -->
                            <div class="col-12">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 col-form-label col-form-label-sm text-md-end">
                                        Time
                                    </label>
                                    <div class="col-8">
                                        <div class="d-flex align-items-center gap-2">
                                            <input type="time"
                                                id="timeDailyview"
                                                value="07:00"
                                                class="form-control form-control-sm">
                                            <div class="form-check mb-0">
                                                <input class="form-check-input"
                                                    type="radio"
                                                    name="timeView"
                                                    id="rdoTimeView">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- To Date -->
                            <div class="col-12">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 col-form-label col-form-label-sm text-md-end">
                                        To Date
                                    </label>
                                    <div class="col-8">
                                        <div data-date-input data-format="DD/MM/YYYY" business-date data-name="toDateview">
                                            <input id="toDateviewUi"
                                                name="toDateviewUi"
                                                type="text"
                                                class="date-ui form-control form-control-sm"
                                                placeholder="dd/mm/yyyy"
                                                autocomplete="off" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Room Class -->
                            <div class="col-12">
                                <div class="row g-1 align-items-center">
                                    <label class="col-4 col-form-label col-form-label-sm text-md-end">
                                        Room Class
                                    </label>
                                    <div class="col-8">
                                        <select id="roomClass" 
                                                asp-items="ViewBag.cboRoomClass"></select>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div><!-- wake-container -->
            </div><!-- modal-body -->
        </div>
    </div>
</div>

