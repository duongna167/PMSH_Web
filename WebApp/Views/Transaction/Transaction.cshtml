        // ---------------------------
        // actions: search
        // ---------------------------
        function search() {
            showLoading(true);

            $.ajax({
                url: "/Transaction/SearchTransaction",
                type: "GET",
                data: {
                    code: $(SEL.code).val(),
                    description: $(SEL.desc).val(),
                    groupID: $(SEL.group).val(),
                    subGroupID: $(SEL.subgroup).val()
                },
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (result) {
                    initMainGrid(result);
                    showLoading(false);
                },
                error: function () {
                    showLoading(false);
                    showToast("Error", "Cannot load report.", false);
                }
            });
        }

        // ---------------------------
        // load subgroup options (RETURN jqXHR)
        // ---------------------------
        function getTransactionSubGroup() {
            return $.ajax({
                url: "/Transaction/GetTransactionSubGroup",
                type: "GET",
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders()
                }).
                done(function (result) {
                    ensureSubGroupTomSelectReady();

                    const ts = document.querySelector('#trans_transactionNewSubGroupList')?.tomselect;
                    if (!ts) return;

                    ts.clearOptions();

                    const rows = Array.isArray(result) ? result : (result ? [result] : []);
                    const formatted = rows.map(i => ({
                        ...i,
                        value: String(i.ID),
                        text: `${i.Code}`
                }));

                ts.addOptions(formatted);
                ts.refreshOptions(false);
                ts.setValue('');
            }).fail(function () {
                showToast("Error", "Cannot load report.", false);
            });
        }

        function getTransactionsList() {
            return $.ajax({
                url: "/Transaction/GetTransactionsList",
                type: "GET",
                dataType: "json",
                headers: csrfHeaders()
            })
            .done(function (result) {
                let el = getTomSelect('#trans_transactionsGernew');
                // Nếu đã init rồi thì destroy trước
                if (el) {
                el.destroy();
                }
                initTomSelect('#trans_transactionsGernew', {
                placeholder: 'Please choose Group',
                // giữ mặc định value/text cho hợp wrapper
                searchField: ['text', 'description'],
                render: {
                    option(data, escape) {
                    return `<div><b>${escape(data.value ?? '')}</b> - ${escape(data.description)}</div>`;
                    },
                    item(data, escape) {
                    return `<div>${escape(data.value ?? '')}</div>`;
                    }
                }
                });

                el = document.querySelector('#trans_transactionsGernew');
                const ts = el?.tomselect;
                if (!ts) return;

                const rows = Array.isArray(result) ? result : [];
                const formatted = rows.map(x => {
                    const code = x.code ;
                    const des  = x.description ;
                    return {
                        value: code,
                        text: des ? `${code} - ${des}` : code,  // ✅ text hiển thị trong dropdown
                        code: code,
                        description: des
                    };
                }).filter(x => x.value);

                ts.clear(true);
                ts.clearOptions();
                ts.addOptions(formatted);
                ts.setTextboxValue('');
                ts.refreshOptions(false);
            })
            .fail(function () {
                showToast("Error", "Cannot load report.", false);
            });
        }
        // ---------------------------
        // open New/Edit with correct ordering
        // ---------------------------
        function openNew() {
            clearEdit();
            $("#trans_modalEditTitle").text("New Transaction");

            const modal = bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit));
            modal.show();

            // after modal shown -> tomselect ready -> load options
            $(SEL.modalEdit).one("shown.bs.modal", function () {
                ensureSubGroupTomSelectReady();
                getTransactionSubGroup();
            });
        }

        function openEdit() {
            if (!_selectedMain) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }

            clearEdit();
            $("#trans_modalEditTitle").text("Edit Transaction");

            const modal = bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit));
            modal.show();

            // after modal shown -> load options -> fill
            $(SEL.modalEdit).one("shown.bs.modal", function () {
                ensureSubGroupTomSelectReady();

                getTransactionSubGroup().done(function () {
                    fillEditFromRow(_selectedMain);
                });
            });
        }

        // ---------------------------
        // fill edit
        // ---------------------------
        function fillEditFromRow(row) {
            $(SEL.id).val(row.ID ?? "");
            $(SEL.codenew).val(row.Code ?? "");
            $(SEL.descriptionnew).val(row.Description ?? "");
            $(SEL.price).val(row.DefaultPrice ?? "");
            $(SEL.groupnew).val(row.GroupCode ?? "");
            $(SEL.generateID).val(row.GenerateID ?? "");

            setTomSelectValue("#trans_transactionNewSubGroupList", row.TransactionSubGroupID ?? "");
            // gọi sync trực tiếp 
            const ts = document.querySelector('#trans_transactionNewSubGroupList')?.tomselect;
            setTomSelectValue("#trans_vatinfor", row.VatTypeID ?? "");

            setTomSelectValue("#trans_transactionsListnew",row.AdjustmentCode ?? "");
            setTomSelectValue("#trans_currList", row.CurrencyID ?? "");
            setTomSelectValue("#trans_listARAccountList",row.ARNo ?? "");


            $(SEL.isTaxInclude).prop("checked", row.TaxInclude === "True" || row.TaxInclude === true);
            $(SEL.revenueGroup).prop("checked", row.RevenueGroup === "True" || row.RevenueGroup === true);
            $(SEL.memberShip).prop("checked", row.MemberShip === "True" || row.MemberShip === true);
            $(SEL.manualPosting).prop("checked", row.ManualPosting === "True" || row.ManualPosting === true);
            $(SEL.paidOut).prop("checked", row.Paidout === "True" || row.Paidout === true);
            $(SEL.generateInclusive).prop("checked", row.GenerateInclusive === "True" || row.GenerateInclusive === true);
            $(SEL.trackNights).prop("checked", row.TrackNights === "True" || row.TrackNights === true);
            $(SEL.frontOfficePayments).prop("checked", row.FOPayments === "True" || row.FOPayments === true);
            $(SEL.arPayments).prop("checked", row.ARPayments === "True" || row.ARPayments === true);
            $(SEL.depositPayments).prop("checked", row.DepositPayments === "True" || row.DepositPayments === true);
            $(SEL.interHotelSales).prop("checked", row.InterHotelSales === "True" || row.InterHotelSales === true);

            setPaymentTypeByValue(row.PaymentType);

            $(SEL.inactive).prop("checked", row.IsActive === "False" || row.IsActive === false);
            setTomSelectValue("#trans_transactionTypeList", row.TransactionType ?? "");
        }

        function setPaymentTypeByValue(paymentType) {
            $(SEL.creditCard + "," + SEL.cash + "," + SEL.check + "," + SEL.others).prop("checked", false);

            if (paymentType == "1" || paymentType == 1) $(SEL.creditCard).prop("checked", true);
            else if (paymentType == "2" || paymentType == 2) $(SEL.cash).prop("checked", true);
            else if (paymentType == "3" || paymentType == 3) $(SEL.check).prop("checked", true);
            else if (paymentType == "4" || paymentType == 4) $(SEL.others).prop("checked", true);
        }

        function getPaymentTypeValue() {
            if ($(SEL.creditCard).is(":checked")) return 1;
            if ($(SEL.cash).is(":checked")) return 2;
            if ($(SEL.check).is(":checked")) return 3;
            if ($(SEL.others).is(":checked")) return 4;
            return 0;
        }

        function clearEdit() {
            $(SEL.formEdit).find(".is-invalid").removeClass("is-invalid");
            $(SEL.formEdit).find(".invalid-feedback").remove();

            $(SEL.id).val("");
            $(SEL.generateID).val("");
            $(SEL.transactionGroupID).val("");
            $(SEL.groupType).val("");
            $(SEL.groupCode).val("");

            // TomSelect: clear after it exists (safe)
            clearTomSelect("#trans_transactionNewSubGroupList");
            $(SEL.newSubGroup).val("");

            $(SEL.groupnew).val("").removeData("groupid");
            clearTomSelect("#trans_vatinfor");
            $(SEL.vatinfor).val("");
            clearTomSelect("#trans_transactionTypeList");
            $(SEL.codenew).val("");
            $(SEL.descriptionnew).val("");
            clearTomSelect("#trans_transactionsListnew");
            $(SEL.adjNew).val("");
            $(SEL.price).val("");
            clearTomSelect("#trans_currList");
            clearTomSelect("#trans_listARAccountList");

            $(SEL.isTaxInclude).prop("checked", false);
            $(SEL.inactive).prop("checked", false);

            $(SEL.revenueGroup).prop("checked", false);
            $(SEL.memberShip).prop("checked", false);
            $(SEL.manualPosting).prop("checked", false);
            $(SEL.paidOut).prop("checked", false);
            $(SEL.generateInclusive).prop("checked", false);
            $(SEL.trackNights).prop("checked", false);

            $(SEL.frontOfficePayments).prop("checked", false);
            $(SEL.arPayments).prop("checked", false);
            $(SEL.depositPayments).prop("checked", false);
            $(SEL.interHotelSales).prop("checked", false);

            $(SEL.creditCard + "," + SEL.cash + "," + SEL.check + "," + SEL.others + "," + SEL.eft + "," + SEL.manual).prop("checked", false);

            applyGroupTypeUI(null);
            $(SEL.arAccount).prop("disabled", true);
        }

        // ---------------------------
        // save / delete (kept)
        // ---------------------------
        function save(closeAfter) {
            if (!validateEdit()) return;

            const inactive = $(SEL.inactive).is(":checked") ? 0 : 1;
            const paymentType = getPaymentTypeValue();

            showLoading(true);

            $.ajax({
                url: "/Transaction/TransactionListSave",
                type: "POST",
                data: {
                    ID: $(SEL.id).val(),
                    Code: $(SEL.codenew).val(),
                    Description: $(SEL.descriptionnew).val(),
                    DefaultPrice: $(SEL.price).val(),
                    CurrencyID: $(SEL.currency).val(),
                    GroupID: $(SEL.groupnew).val(),
                    TransactionSubGroupID: $(SEL.newSubGroup).val(),
                    AdjustmentCode: $(SEL.adjNew).val(),
                    SubgroupCode: $(SEL.newSubGroup + " option:selected").text(),
                    GroupCode: $(SEL.groupCode).val(),
                    GroupType: $(SEL.groupType).val(),
                    TransactionGroupID: $(SEL.transactionGroupID).val(),
                    TransactionType: $(SEL.transType).val(),
                    GenerateID: $(SEL.generateID).val(),
                    DepositPayments: $(SEL.depositPayments).is(":checked"),
                    FOPayments: $(SEL.frontOfficePayments).is(":checked"),
                    ARPayments: $(SEL.arPayments).is(":checked"),
                    PaymentType: paymentType,
                    RevenueGroup: $(SEL.revenueGroup).is(":checked"),
                    ManualPosting: $(SEL.manualPosting).is(":checked"),
                    Paidout: $(SEL.paidOut).is(":checked"),
                    TaxInclude: $(SEL.isTaxInclude).is(":checked"),
                    IsActive: inactive,
                    VatTypeID: $(SEL.vatinfor).val(),
                    ARNo: $(SEL.arAccount).val(),
                    CreatedBy: localStorage.getItem("Loginname"),
                    UserInsertID: localStorage.getItem("userID")
                },
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (result) {
                    showLoading(false);

                    if (result && result.success) {
                        showToast("Success", result.message, true);
                        search();
                        clearEdit();

                        if (closeAfter) {
                            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).hide();
                        }
                    } else {
                        showToast("Error", (result && result.message) ? result.message : "Please select before saving.", false);
                    }
                },
                error: function () {
                    showLoading(false);
                    showToast("Error", "Cannot save.", false);
                }
            });
        }

        function deleteSelected() {
            if (!_selectedMain) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }
            if (!confirm("Are you sure you want to delete item?")) return;

            showLoading(true);

            $.ajax({
                url: "/Transaction/TransactionDelete",
                type: "POST",
                data: { id: _selectedMain.ID },
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (result) {
                    showLoading(false);
                    if (result && result.success) {
                        showToast("Success", (result && result.message) ? result.message : "Delete complete.",true);
                        search();
                        clearEdit();
                    } else {
                        showToast("Error", (result && result.message) ? result.message : "Delete failed.", false);
                    }
                },
                error: function () {
                    showLoading(false);
                    showToast("Error", "Cannot delete.", false);
                }
            });
        }

        // ---------------------------
        // Generate flow (kept)
        // ---------------------------
        function openGenerateList() {
            if (!_selectedMain) {
                showToast("Warning", "Please select 1 row.", false);
                return;
            }
            $(SEL.titleGenerateList).text("Generate For " + (_selectedMain.Code || ""));
            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalGenerateList)).show();

            loadGenerateData(_selectedMain.Code);
        }

        function loadGenerateData(code) {
            showLoading(true);

            $.ajax({
                url: "/Transaction/SearchGenerate",
                type: "GET",
                data: { code: code },
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (result) {
                    initGenerateGrid(result);
                    showLoading(false);
                },
                error: function () {
                    showLoading(false);
                    showToast("Error", "Không thể tải báo cáo.", false);
                }
            });
        }

        function openGenerateNew() {
            getTransactionsList();
            clearGenerateEdit();
            $(SEL.titleGenerateEdit).text("Generate - New");
            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalGenerateEdit)).show();
        }

        function openGenerateEdit() {
            if (!_selectedGenerate) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }
            getTransactionsList();
            clearGenerateEdit();
            $(SEL.titleGenerateEdit).text("Generate - Edit");
            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalGenerateEdit)).show();
            const pList = getTransactionsList();

            showLoading(true);
            const pDetail = $.ajax({
                url: "/Transaction/SearchGenerateDetail",
                type: "GET",
                data: { id: _selectedGenerate.id },
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders()
            });
            $.when(pList, pDetail).done(function (_listRes, detailRes) {
                showLoading(false);

                const result = detailRes[0]; // jQuery: [data, status, xhr]
                if (!result || !result.length) return;
                const item = result[0];

                $(SEL.generateDetailId).val(item.id ?? _selectedGenerate.id);

                if (item.percentage && item.percentage !== "0") {
                    $(SEL.percentageRadio).prop("checked", true);
                    $(SEL.percentagetext).val(item.percentage);
                    setTomSelectValue("#trans_percengegre",item.baseAmount)
                    console.log('percentage');
                    
                }

                if (item.amount && item.amount !== "0,000") {
                    $(SEL.amountRadio).prop("checked", true);
                    $(SEL.amountPer).val(item.amount);
                                        console.log('amountRadio');

                }

                if (item.udfFunction || item.UDFFunction) {
                    $(SEL.formularRadio).prop("checked", true);
                    $(SEL.formular).val(item.udfFunction || item.UDFFunction);
                                        console.log('formularRadio');

                }

                $(SEL.subTotal1).prop("checked", item.subtotal1 == "True" || item.subtotal1 === true);
                $(SEL.subTotal2).prop("checked", item.subtotal2 == "True" || item.subtotal2 === true);
                $(SEL.subTotal3).prop("checked", item.subtotal3 == "True" || item.subtotal3 === true);

                setTomSelectValue("#trans_transactionsGernew",item.transactionCodeDetail)
                
            }).fail(function () {
                showLoading(false);
                showToast("Error", "Cannot load generate detail.", false);
            });
        }

        function clearGenerateEdit() {
            $(SEL.generateDetailId).val("");
            clearMultipleTomSelect("#trans_transactionsGernew")

            $(SEL.percentageRadio).prop("checked", true);
            $(SEL.percentagetext).val("");
            clearMultipleTomSelect("#trans_percengegre");

            $(SEL.amountRadio).prop("checked", false);
            $(SEL.amountPer).val("");

            $(SEL.formularRadio).prop("checked", false);
            $(SEL.formular).val("");

            $(SEL.subTotal1).prop("checked", false);
            $(SEL.subTotal2).prop("checked", false);
            $(SEL.subTotal3).prop("checked", false);
        }

        function getPercenOptionValue() {
            if ($(SEL.percentageRadio).is(":checked")) return 1;
            if ($(SEL.amountRadio).is(":checked")) return 2;
            if ($(SEL.formularRadio).is(":checked")) return 3;
            return 0;
        }

        function saveGenerate() {
            const transactionsGernew = $(SEL.transactionsGernew).val();
            console.log('transactionsGernew',transactionsGernew);
            
            showLoading(true);

            $.ajax({
                url: "/Transaction/GenerateSave",
                type: "POST",
                data: {
                    ID: $(SEL.generateDetailId).val(),
                    transactionsGernew: _selectedMain.Code || "",
                    transactionsDetailGernew: $(SEL.transactionsGernew).val(),
                    percentagetext: $(SEL.percentagetext).val(),
                    percengegre: $(SEL.percengegre).val(),
                    amountPer: $(SEL.amountPer).val(),
                    formular: $(SEL.formular).val(),
                    percenOption: getPercenOptionValue(),
                    CreatedBy: localStorage.getItem("Loginname"),
                    UserInsertID: localStorage.getItem("userID"),
                    subTotal1: $(SEL.subTotal1).is(":checked") ? 1 : 0,
                    subTotal2: $(SEL.subTotal2).is(":checked") ? 1 : 0,
                    subTotal3: $(SEL.subTotal3).is(":checked") ? 1 : 0
                },
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (result) {
                    showLoading(false);

                    if (result && result.success) {
                        showToast("Success", result.message, true);
                        bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalGenerateEdit)).hide();

                        if (_selectedMain && _selectedMain.Code) loadGenerateData(_selectedMain.Code);
                    } else {
                        showToast("Error", (result && result.message) ? result.message : "Save failed.", false);
                    }
                },
                error: function () {
                    showLoading(false);
                    showToast("Error", "Cannot save generate.", false);
                }
            });
        }

        function deleteGenerate() {
            if (!_selectedGenerate) {
                showToast("Warning", "Please select 1 row to delete.", false);
                return;
            }
            if (!confirm("Are you sure you want to delete item?")) return;

            showLoading(true);

            $.ajax({
                url: "/Transaction/TransactionGenerateDelete",
                type: "POST",
                data: { id: _selectedGenerate.id },
                traditional: true,
                crossDomain: false,
                headers: csrfHeaders(),
                success: function (result) {
                    showLoading(false);

                    if (result && result.success) {
                        if (_selectedMain && _selectedMain.Code) loadGenerateData(_selectedMain.Code);
                    } else {
                        showToast("Error", (result && result.message) ? result.message : "Delete failed.", false);
                    }
                },
                error: function () {
                    showLoading(false);
                    showToast("Error", "Cannot delete generate.", false);
                }
            });
        }

        // ---------------------------
        // Excel export (kept)
        // ---------------------------
        function exportExcel() {
            const grid = $(SEL.grid).dxDataGrid("instance");
            if (!grid) { showToast("Warning", "No grid data to export.", false); return; }

            const workbook = new ExcelJS.Workbook();
            const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const worksheet = workbook.addWorksheet("Sheet 1");

            worksheet.addRow([companyName]);
            worksheet.mergeCells("A1:D1");
            worksheet.getRow(1).font = { bold: true };
            worksheet.getRow(1).alignment = { vertical: "middle", horizontal: "left" };

            const now = new Date();
            const exportDate = now.toLocaleString("vi-VN");
            worksheet.addRow(["", "", "", exportDate]);
            worksheet.mergeCells("D2:D2");
            worksheet.getRow(2).alignment = { vertical: "middle", horizontal: "right" };

            worksheet.addRow([]);
            worksheet.addRow([]);

            const reportRow = worksheet.addRow(["Transaction"]);
            worksheet.mergeCells("A5:D5");
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { vertical: "middle", horizontal: "center" };

            worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const lastRow = worksheet.lastRow.number + 2;
                worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
                worksheet.getCell(`A${lastRow}`).alignment = { horizontal: "center" };
                worksheet.getCell(`A${lastRow}`).font = { italic: true };

                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "Transaction.xlsx");
                });
            });
        }

        // ---------------------------
        // event binding (namespaced, bind once)
        // ---------------------------
        function bindEventsOnce() {
            if (_bound) return;
            _bound = true;

            $(document)
                .off("change.trans", SEL.group).on("change.trans", SEL.group, filterSubGroupOptions);

            $(document)
                .off("change.trans", '[name="trans_paymentType"]')
                .on("change.trans", '[name="trans_paymentType"]', function () {
                    $('[name="trans_paymentType"]').not(this).prop("checked", false);
                });

            $(document)
                .off("change.trans", '[name="trans_percenOption"]')
                .on("change.trans", '[name="trans_percenOption"]', function () {
                    $('[name="trans_percenOption"]').not(this).prop("checked", false);
                });

            // toolbar
            $(document)
                .off("click.trans", SEL.btnView).on("click.trans", SEL.btnView, search)
                .off("click.trans", SEL.btnNew).on("click.trans", SEL.btnNew, openNew)
                .off("click.trans", SEL.btnEdit).on("click.trans", SEL.btnEdit, openEdit)
                .off("click.trans", SEL.btnDelete).on("click.trans", SEL.btnDelete, deleteSelected)
                .off("click.trans", SEL.btnExcel).on("click.trans", SEL.btnExcel, exportExcel);

            // edit actions
            $(document)
                .off("click.trans", SEL.btnOk).on("click.trans", SEL.btnOk, function () { save(true); })
                .off("click.trans", SEL.btnSave).on("click.trans", SEL.btnSave, function () { save(false); })
                .off("click.trans", SEL.btnDeleteAuto).on("click.trans", SEL.btnDeleteAuto, deleteSelected)
                .off("click.trans", SEL.btnGenerate).on("click.trans", SEL.btnGenerate, openGenerateList);

            // generate list actions
            $(document)
                .off("click.trans", SEL.btnNewGenerate).on("click.trans", SEL.btnNewGenerate, openGenerateNew)
                .off("click.trans", SEL.btnEditGenerate).on("click.trans", SEL.btnEditGenerate, openGenerateEdit)
                .off("click.trans", SEL.btnDeleteGenerate).on("click.trans", SEL.btnDeleteGenerate, deleteGenerate);

            // generate edit save
            $(document)
                .off("click.trans", SEL.btnOkGenerate).on("click.trans", SEL.btnOkGenerate, saveGenerate);

            // blur handling (kept)
            $(SEL.modalEdit)
                .off("shown.bs.modal.trans").on("shown.bs.modal.trans", function () {
                    $('#trans_modalMain .modal-content').addClass('modal-blur');
                })
                .off("hidden.bs.modal.trans").on("hidden.bs.modal.trans", function () {
                    $('#trans_modalMain .modal-content').removeClass('modal-blur');
                    showLoading(false);
                });

            $(SEL.modalGenerateList)
                .off("shown.bs.modal.trans").on("shown.bs.modal.trans", function () {
                    $('#trans_modalEdit .modal-content').addClass('modal-blur');
                })
                .off("hidden.bs.modal.trans").on("hidden.bs.modal.trans", function () {
                    $('#trans_modalEdit .modal-content').removeClass('modal-blur');
                    showLoading(false);
                    _selectedGenerate = null;
                    disposeGrid(SEL.gridGenerate);
                });

            $(SEL.modalGenerateEdit)
                .off("shown.bs.modal.trans").on("shown.bs.modal.trans", function () {
                    $('#trans_modalGenerateList .modal-content').addClass('modal-blur');
                })
                .off("hidden.bs.modal.trans").on("hidden.bs.modal.trans", function () {
                    $('#trans_modalGenerateList .modal-content').removeClass('modal-blur');
                    showLoading(false);
                    clearGenerateEdit();
                });

            // main modal cleanup
            $(SEL.modalMain)
                .off("hidden.bs.modal.trans")
                .on("hidden.bs.modal.trans", function () {
                    _selectedMain = null;

                    $(SEL.group).val("");
                    $(SEL.subgroup).val("");
                    $(SEL.code).val("");
                    $(SEL.adj).val("");
                    $(SEL.desc).val("");

                    disposeGrid(SEL.grid);
                    disposeGrid(SEL.gridGenerate);
                    showLoading(false);
                });
        }

        function init() {
            bindEventsOnce();
        }

        function open() {
            initTomSelect(".tomselect-custom");
            init();

            const modalEl = document.querySelector(SEL.modalMain);
            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

            $(modalEl).one("shown.bs.modal", function () {
                search();
            });

            modal.show();
        }

        return { init, open };
    })();

    // required global entry
    window.openModalTrans = function () {
        trans_Module.open();
    };

</script>