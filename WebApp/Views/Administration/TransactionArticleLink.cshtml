@* =========================================
   Transaction Article Link (transArL_)
   Refactor: modal-xl main + modal-xl create + modal-xl edit
   Pattern: Option A module, bind once, cleanup on hidden
   Layout: ERP-style dense filter (right-aligned labels, nested rows)
   Keep: DevExtreme AspNet store, remote ops, Excel export, TomSelect validation sync
   ========================================= *@
<!-- =========================
     MAIN MODAL (modal-xl)
     ========================= -->
<div class="modal fade" id="transArL_modalMain" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Transaction Article Link</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <!-- Toolbar -->
                    <div>
                        <button id="transArL_btnView" type="button" class="mui-button mui-button-new">View</button>
                        <button id="transArL_btnNew" type="button" class="mui-button mui-button-new">New</button>
                        <button id="transArL_btnEdit" type="button" class="mui-button mui-button-edit">Edit</button>
                        <button id="transArL_btnDelete" type="button" class="mui-button button-report-delete">Delete</button>
                        <button id="transArL_btnExportExcel" type="button" class="mui-button mui-button-export">Excel</button>
                        <button id="transArL_btnClose" type="button" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                    </div>

                    <!-- ERP Search Filter -->
                    <div class="row g-2 m-1">

                        <div class="col-12 col-lg-4">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-3 col-lg-5 col-form-label col-form-label-sm text-md-end"
                                    for="transArL_transCode">Transaction Code</label>
                                <div class="col-md-8 col-lg-7">
                                    <input id="transArL_transCode" name="transArL_transCode" type="text"
                                        class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-8">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-3 col-lg-4 col-form-label col-form-label-sm text-md-end"
                                    for="transArL_transDes">Transaction Description</label>
                                <div class="col-md-8 col-lg-8">
                                    <input id="transArL_transDes" name="transArL_transDes" type="text"
                                        class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-4">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-3 col-lg-5 col-form-label col-form-label-sm text-md-end"
                                    for="transArL_articleCode">Article Code</label>
                                <div class="col-md-8 col-lg-7">
                                    <input id="transArL_articleCode" name="transArL_articleCode" type="text"
                                        class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-8">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-3 col-lg-4 col-form-label col-form-label-sm text-md-end"
                                    for="transArL_articleDes">Article Description</label>
                                <div class="col-md-8 col-lg-8">
                                    <input id="transArL_articleDes" name="transArL_articleDes" type="text"
                                        class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>

                    </div>

                </div>
                <!-- Grid -->
                <div class="mui-card">
                    <div id="transArL_gridTransactionArticleLink" class="gridContainer"></div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- =========================
     CREATE MODAL (modal-xl)
     TomSelect multi
     ========================= -->
<div class="modal fade" id="transArL_modalNew" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">New Item</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <button type="button" id="transArL_btnSaveNew" class="mui-button mui-button-save">Save</button>
                    <button type="button" id="transArL_btnRefreshNew" class="mui-button mui-button-close">Refresh</button>
                    <button type="button" id="transArL_btnCloseNew" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                </div>

                <div id="transArL_itemForm">
                    <input type="hidden" id="transArL_modalItemId" name="transArL_modalItemId" value="0" />

                    <div class="row g-2 mt-1 mb-2">

                        <div class="col-12">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-3 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Transaction Code <span class="text-danger">*</span>
                                </label>
                                <div class="col-md-9 col-lg-8">
                                    <select id="transArL_transactionListSelect"
                                            name="selectedTransactions"
                                            class="tomselect-custom"
                                            multiple>
                                        @foreach (dynamic u in ViewBag.TransactionList)
                                        {
                                            <option value="@u.Code">@u.Code - @u.Description</option>
                                        }
                                    </select>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-3 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Article Code <span class="text-danger">*</span>
                                </label>
                                <div class="col-md-9 col-lg-8">
                                    <select id="transArL_articleCodeSelect"
                                            name="selectedArticles"
                                            class="tomselect-custom"
                                            multiple>
                                        @foreach (dynamic u in ViewBag.ArticleList)
                                        {
                                            <option value="@u.Code">@u.Code - @u.Description</option>
                                        }
                                    </select>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- =========================
     EDIT MODAL (modal-xl)
     Single select
     ========================= -->
<div class="modal fade" id="transArL_modalEdit" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Edit Item</h5>
            </div>
            <div class="modal-body">
                <div class="search-filter">
                    <button type="button" id="transArL_btnSaveEdit" class="mui-button mui-button-save">Save</button>
                    <button type="button" id="transArL_btnRefreshEdit" class="mui-button mui-button-close">Refresh</button>
                    <button type="button" id="transArL_btnCloseEdit" class="mui-button mui-button-close" data-bs-dismiss="modal">Close</button>
                </div>

                <div id="transArL_itemFormEdit">
                    <input type="hidden" id="transArL_ID" name="transArL_ID" />
                    <div class="row g-2 mt-1 mb-2">

                        <div class="col-12">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-3 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Transaction Code <span class="text-danger">*</span>
                                </label>
                                <div class="col-md-9 col-lg-8">
                                    <select id="transArL_transactionEdit" name="editTransactions" class="tomselect-custom">
                                        @foreach (dynamic u in ViewBag.TransactionList)
                                        {
                                            <option value="@u.Code">@u.Code - @u.Description</option>
                                        }
                                    </select>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-2 align-items-center">
                                <label class="col-md-3 col-lg-4 col-form-label col-form-label-sm text-md-end">
                                    Article Code <span class="text-danger">*</span>
                                </label>
                                <div class="col-md-9 col-lg-8">
                                    <select id="transArL_articleEdit" name="editArticles" class="tomselect-custom">
                                        @foreach (dynamic u in ViewBag.ArticleList)
                                        {
                                            <option value="@u.Code">@u.Code - @u.Description</option>
                                        }
                                    </select>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Loading Spinner -->
<div id="transArL_loadingSpinner" style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:2000;">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
</div>

<script>
    // ==========================================
    // Transaction Article Link Module (Option A)
    // ==========================================
    var transArL_Module = (function () {
        "use strict";

        const SEL = {
            // modals
            modalMain: "#transArL_modalMain",
            modalNew: "#transArL_modalNew",
            modalEdit: "#transArL_modalEdit",
            spinner: "#transArL_loadingSpinner",

            // toolbar
            btnView: "#transArL_btnView",
            btnNew: "#transArL_btnNew",
            btnEdit: "#transArL_btnEdit",
            btnDelete: "#transArL_btnDelete",
            btnExportExcel: "#transArL_btnExportExcel",

            // filter inputs
            transCode: "#transArL_transCode",
            transDes: "#transArL_transDes",
            articleCode: "#transArL_articleCode",
            articleDes: "#transArL_articleDes",

            // grid
            grid: "#transArL_gridTransactionArticleLink",

            // create form
            articleCodeSelect: "#transArL_articleCodeSelect",
            transactionListSelect: "#transArL_transactionListSelect",
            btnSaveNew: "#transArL_btnSaveNew",
            btnRefreshNew: "#transArL_btnRefreshNew",

            // edit form
            ID: "#transArL_ID",
            transactionEdit: "#transArL_transactionEdit",
            articleEdit: "#transArL_articleEdit",
            btnSaveEdit: "#transArL_btnSaveEdit",
            btnRefreshEdit: "#transArL_btnRefreshEdit",
        };

        let _bound = false;
        let _gridInstance = null;
        let _selectedRowData = null;

        // TomSelect instances (key by selector)
        let _tomSelected = {};

        function showLoading(show) {
            if (show) $(SEL.spinner).show();
            else $(SEL.spinner).hide();
        }

        function csrfHeaders() {
            return { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() };
        }

        function addMainBlur() {
            $(`${SEL.modalMain} .modal-content`).addClass("modal-blur");
        }
        function removeMainBlur() {
            $(`${SEL.modalMain} .modal-content`).removeClass("modal-blur");
        }

        // -----------------------
        // TomSelect init + validation sync
        // -----------------------
        function ensureTomSelect(selector, options) {
            const el = document.querySelector(selector);
            if (!el) return null;

            // destroy old instance (safe)
            if (el.tomselect) el.tomselect.destroy();

            const ts = new TomSelect(el, options);
            _tomSelected[selector] = ts;
            return ts;
        }

        function syncTomSelectValidation(containerSelector, errors = null) {
            $(`${containerSelector} select`).each(function () {
                const $select = $(this);
                const $wrapper = $select.next(".ts-wrapper");
                const $feedback = $select.siblings(".invalid-feedback");

                if ($select.hasClass("is-invalid")) {
                    $wrapper.addClass("is-invalid");

                    if (!$feedback.text().trim() && errors) {
                        const fieldName = $select.attr("name");
                        const fieldError = errors.find(err => err.field === fieldName);
                        if (fieldError) $feedback.text(fieldError.message).show();
                        else $feedback.show();
                    } else {
                        $feedback.show();
                    }
                } else {
                    $wrapper.removeClass("is-invalid");
                    $feedback.hide().text("");
                }
            });
        }

        function clearNewModal() {
            // clear tomselect selections
            clearTomSelect(SEL.articleCodeSelect);
            clearTomSelect(SEL.transactionListSelect);

            // reset validation UI
            if (typeof applyValidationErrors === "function") {
                applyValidationErrors([], SEL.modalNew);
            }
            syncTomSelectValidation(SEL.modalNew);
        }

        function clearEditModal() {
            // clear tomselect selections
            clearTomSelect(SEL.articleEdit);
            clearTomSelect(SEL.transactionEdit);
            // reset validation UI
            if (typeof applyValidationErrors === "function") {
                applyValidationErrors([], SEL.modalEdit);
            }
            syncTomSelectValidation(SEL.modalEdit);
        }

        // -----------------------
        // Grid
        // -----------------------
        function disposeGrid() {
            try {
                const inst = $(SEL.grid).dxDataGrid("instance");
                if (inst) inst.dispose();
            } catch (e) { /* ignore */ }

            _gridInstance = null;
            _selectedRowData = null;
            $(SEL.grid).empty();
        }

        function initGrid() {
            disposeGrid();

            _gridInstance = $(SEL.grid).dxDataGrid({
                dataSource: DevExpress.data.AspNet.createStore({
                    loadUrl: "/Administration/Transaction/GetAllTransactionArticleLink",
                    onBeforeSend: function (method, ajaxOptions) {
                        ajaxOptions.data.transCode = $(SEL.transCode).val();
                        ajaxOptions.data.transDes = $(SEL.transDes).val();
                        ajaxOptions.data.articleCode = $(SEL.articleCode).val();
                        ajaxOptions.data.articleDes = $(SEL.articleDes).val();
                    }
                }),
                remoteOperations: { filtering: true, sorting: true, paging: true, grouping: true },

                showBorders: true,
                selection: { mode: "single" },

                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, 100],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },

                groupPanel: { visible: true },

                columns: [
                    { dataField: "id", caption: "ID", allowGrouping: false, visible: false },
                    { dataField: "transactionCode", caption: "Trans", width: "100px" },
                    { dataField: "transactionDescription", caption: "Transaction Description", allowGrouping: false },
                    { dataField: "articleCode", caption: "Article Code", width: "100px" },
                    { dataField: "articleDescription", caption: "Article Description", allowGrouping: false }
                ],

                grouping: { autoExpandAll: true },
                summary: { groupItems: [{ column: "id", summaryType: "count" }] },

                onToolbarPreparing: function (e) {
                    e.toolbarOptions.items.unshift({
                        location: "before",
                        widget: "dxButton",
                        options: {
                            icon: "refresh",
                            onClick: function () { e.component.refresh(); }
                        }
                    });
                },

                onRowClick: function (e) {
                    _selectedRowData = e.data || null;
                }
            }).dxDataGrid("instance");
        }

        function refreshGrid() {
            const grid = $(SEL.grid).dxDataGrid("instance");
            if (grid) grid.refresh();
        }

        // -----------------------
        // CRUD calls
        // -----------------------
        function openNew() {
            clearNewModal();
            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalNew)).show();
        }

        function openEdit() {
            clearEditModal();
            if (!_selectedRowData) {
                showToast("Warning", "Please select 1 row to update.", false);
                return;
            }

            $(SEL.ID).val(_selectedRowData.id);
            setTomSelectValue(SEL.transactionEdit,_selectedRowData.transactionCode)
            setTomSelectValue(SEL.articleEdit,_selectedRowData.articleCode)

            if (typeof applyValidationErrors === "function") {
                applyValidationErrors([], SEL.modalEdit);
            }

            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).show();
        }

        function saveNew() {
            showLoading(true);

            const selectedArticles = _tomSelected[SEL.articleCodeSelect]?.items || [];
            const selectedTransactions = _tomSelected[SEL.transactionListSelect]?.items || [];

            const dto = {
                SelectedArticles: selectedArticles,
                SelectedTransactions: selectedTransactions
            };

            $.ajax({
                url: "/Administration/Transaction/InsertTAL",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(dto),
                headers: csrfHeaders(),
                success: function (response) {
                    showLoading(false);

                    if (response && response.success) {
                        showToast("Success", "Number of links created: " + response.data.count, true);
                        clearNewModal();
                        bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalNew)).hide();
                        refreshGrid();
                    } else {
                        if (response && Array.isArray(response.errors) && typeof applyValidationErrors === "function") {
                            applyValidationErrors(response.errors, SEL.modalNew);
                            syncTomSelectValidation(SEL.modalNew, response.errors);
                        } else {
                            showToast("Error", (response && response.message) ? response.message : "Validation failed.", false);
                        }
                    }
                },
                error: function (xhr, status, error) {
                    showLoading(false);

                    const errs = xhr.responseJSON?.errors;
                    if (Array.isArray(errs)) {
                        errs.forEach((err, idx) => setTimeout(() => showToast("Error", err.message || err, false), idx * 800));
                        return;
                    }
                    showToast("Error", error || "Unknown error", false);
                }
            });
        }

        function refreshNewModal() {
            // Original behavior: trigger New again
            clearNewModal();
        }

        function refreshEditModal() {
            // Original behavior: trigger New again
            clearEditModal();
        }

        function saveEdit() {
            showLoading(true);

            const data = {
                ID: parseInt($(SEL.ID).val(), 10) || 0,
                TransactionEdit: ($(SEL.transactionEdit).val() || "").trim(),
                ArticleEdit: ($(SEL.articleEdit).val() || "").trim()
            };

            $.ajax({
                url: "/Administration/Transaction/UpdateTAL",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(data),
                headers: csrfHeaders(),
                success: function (response) {
                    showLoading(false);

                    if (response && response.success) {
                        showToast("Success", "Update success ID: " + response.data.id, true);
                        bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalEdit)).hide();
                        refreshGrid();
                    } else {
                        if (Array.isArray(response?.errors) && typeof applyValidationErrors === "function") {
                            applyValidationErrors(response.errors, SEL.modalEdit);
                        } else {
                            showToast("Error", response?.errors || response?.message || "Unknown error", false);
                        }
                    }
                },
                error: function (xhr, status, error) {
                    showLoading(false);

                    const response = xhr.responseJSON;
                    if (Array.isArray(response?.errors)) {
                        response.errors.forEach((err, idx) => {
                            setTimeout(() => showToast("Error", err.message || err, false), idx * 800);
                        });
                        return;
                    }
                    if (response?.message) {
                        showToast("Error", response.message, false);
                        return;
                    }
                    showToast("Error", error || "Unknown error", false);
                }
            });
        }

        function deleteNotImplemented() {
            showToast("Error", "No information available regarding the dependent table. The functionality has not yet been implemented.");
        }

        // -----------------------
        // Excel export (preserve)
        // -----------------------
        function exportExcel() {
            const grid = $(SEL.grid).dxDataGrid("instance");
            if (!grid) {
                showToast("Warning", "No grid data to export.", false);
                return;
            }

            const workbook = new ExcelJS.Workbook();
            const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
            const worksheet = workbook.addWorksheet("Sheet 1");

            worksheet.addRow([companyName]);
            worksheet.mergeCells("A1:D1");
            worksheet.getRow(1).font = { bold: true };
            worksheet.getRow(1).alignment = { vertical: "middle", horizontal: "left" };

            const now = new Date();
            const exportDate = now.toLocaleString("vi-VN");
            worksheet.addRow(["", "", "", exportDate]);
            worksheet.mergeCells("D2:D2");
            worksheet.getRow(2).alignment = { vertical: "middle", horizontal: "right" };

            worksheet.addRow([]);
            worksheet.addRow([]);

            const reportRow = worksheet.addRow(["Transaction&ArticleLink"]);
            worksheet.mergeCells("A5:D5");
            reportRow.font = { bold: true, size: 14 };
            reportRow.alignment = { vertical: "middle", horizontal: "center" };

            worksheet.addRow([]);

            DevExpress.excelExporter.exportDataGrid({
                component: grid,
                worksheet: worksheet,
                autoFilterEnabled: true,
                topLeftCell: { row: 7, column: 1 }
            }).then(function () {
                const lastRow = worksheet.lastRow.number + 2;
                worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
                worksheet.getCell(`A${lastRow}`).alignment = { horizontal: "center" };
                worksheet.getCell(`A${lastRow}`).font = { italic: true };

                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), "Transaction&ArticleLink.xlsx");
                });
            });
        }

        // -----------------------
        // binding + lifecycle
        // -----------------------
        function bindEventsOnce() {
            initTomSelect(".tomselect-custom")
            if (_bound) return;
            _bound = true;

            // Enter key triggers view/refresh
            $(document).off("keydown.transArL", `${SEL.transCode},${SEL.transDes},${SEL.articleCode},${SEL.articleDes}`)
                .on("keydown.transArL", `${SEL.transCode},${SEL.transDes},${SEL.articleCode},${SEL.articleDes}`, function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault();
                        refreshGrid();
                    }
                });

            $(document)
                .off("click.transArL", SEL.btnView).on("click.transArL", SEL.btnView, refreshGrid)
                .off("click.transArL", SEL.btnNew).on("click.transArL", SEL.btnNew, openNew)
                .off("click.transArL", SEL.btnEdit).on("click.transArL", SEL.btnEdit, openEdit)
                .off("click.transArL", SEL.btnDelete).on("click.transArL", SEL.btnDelete, deleteNotImplemented)
                .off("click.transArL", SEL.btnExportExcel).on("click.transArL", SEL.btnExportExcel, exportExcel)

                .off("click.transArL", SEL.btnSaveNew).on("click.transArL", SEL.btnSaveNew, saveNew)
                .off("click.transArL", SEL.btnRefreshNew).on("click.transArL", SEL.btnRefreshNew, refreshNewModal)
                .off("click.transArL", SEL.btnRefreshEdit).on("click.transArL", SEL.btnRefreshEdit, refreshEditModal)
                .off("click.transArL", SEL.btnSaveEdit).on("click.transArL", SEL.btnSaveEdit, saveEdit);

            // blur main when child modals open
            $(SEL.modalNew)
                .off("shown.bs.modal.transArL").on("shown.bs.modal.transArL", function () {  })
                .off("hidden.bs.modal.transArL").on("hidden.bs.modal.transArL", function () {
                    clearNewModal();
                    showLoading(false);
                });

            $(SEL.modalEdit)
                .off("shown.bs.modal.transArL").on("shown.bs.modal.transArL", function () {  })
                .off("hidden.bs.modal.transArL").on("hidden.bs.modal.transArL", function () {
                    if (typeof applyValidationErrors === "function") applyValidationErrors([], SEL.modalEdit);
                    showLoading(false);
                });

            // main cleanup
            $(SEL.modalMain)
                .off("hidden.bs.modal.transArL").on("hidden.bs.modal.transArL", function () {
                    _selectedRowData = null;

                    // reset filters
                    $(SEL.transCode).val("");
                    $(SEL.transDes).val("");
                    $(SEL.articleCode).val("");
                    $(SEL.articleDes).val("");

                    disposeGrid();
                    showLoading(false);
                });
        }

        function init() {
            bindEventsOnce();
            initGrid();
        }

        function open() {
            init();
            bootstrap.Modal.getOrCreateInstance(document.querySelector(SEL.modalMain)).show();
            refreshGrid(); // same as clicking View
        }

        return { init, open };
    })();

    // Global entry
    window.openModalTransArL = function () {
        transArL_Module.open();
    };

    // Optional auto-open (remove if you open from menu)
    $(document).ready(function () {
        window.openModalTransArL();
    });
</script>