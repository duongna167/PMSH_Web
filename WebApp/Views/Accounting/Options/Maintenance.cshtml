                                        <input type="text" class="form-control clearable" id="folioMaintenance">
                                    </div>
                                </div>
                            </div>

                        </div>
                        <div class="row">
                                                        <!-- Date checkbox -->
                            <div class="col-12 col-sm-6 col-md-1 col-lg-1 mt-2">
                                <div class="row g-2">
                                    <label class="col-12 col-md-8 col-form-label text-md-end">
                                        Date
                                    </label>
                                    <div class="col-12 col-md-4 d-flex align-items-center">
                                        <input type="checkbox" class="clearable" name="dateMaintenance" id="dateMaintenance"
                                            value="1">
                                    </div>
                                </div>
                            </div>

                            <!-- Payments / Active -->
                            <div class="col-12 col-md-5 col-lg-5 col-xl-4 mt-2">
                                <div class="row g-2">

                                    <label class="col-12 col-md-2 col-form-label text-md-end">
                                        Payments:
                                    </label>

                                    <div class="col-12 col-md-9 d-flex align-items-center flex-wrap gap-2">
                                        <div class="form-check form-check-inline mb-0">
                                            <input type="checkbox" class="clearable" name="paymentMaintenance"
                                                id="paymentMaintenance" value="1">
                                            <label class="form-check-label">Only</label>
                                        </div>

                                        <div class="form-check form-check-inline mb-0">
                                            <input type="radio" class="clearable" name="isActiveMaintenance" value=""
                                                checked>
                                            <label class="form-check-label">All</label>
                                        </div>

                                        <div class="form-check form-check-inline mb-0">
                                            <input type="radio" class="clearable" name="isActiveMaintenance" value="1">
                                            <label class="form-check-label">Open</label>
                                        </div>
                                    </div>

                                </div>
                            </div>

                            <!-- Print -->
                            <div class="col-12 col-md-5 col-lg-5 col-xl-4 mt-2">
                                <div class="row g-1">
                                    <label class="col-12 col-md-2 col-form-label text-md-end">
                                        Print:
                                    </label>

                                    <div class="col-12 col-md-10 d-flex align-items-center flex-wrap gap-2">
                                        <div class="form-check form-check-inline mb-0">
                                            <input type="radio" class="clearable" name="printMaintenance" value="" checked>
                                            <label class="form-check-label">All</label>
                                        </div>
                                        <div class="form-check form-check-inline mb-0">
                                            <input type="radio" class="clearable" name="printMaintenance" value="1">
                                            <label class="form-check-label">Printed</label>
                                        </div>
                                        <div class="form-check form-check-inline mb-0">
                                            <input type="radio" class="clearable" name="printMaintenance" value="0">
                                            <label class="form-check-label">Not Printed</label>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div id="gridContainerMaintenance" class="gridContainer mt-2"></div>

            </div>
        </div>
    </div>
</div>

