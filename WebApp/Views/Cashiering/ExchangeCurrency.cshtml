@using DevExpress.XtraReports.UI

@{
    var selectedReport = @ViewBag.ReportHeader;

}

<div class="modal fade" id="exchangeCurrency" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content modal-full-height">
            <div class="modal-header py-2 bg-light">
                <h5 class="modal-title fw-bold text-primary">Exchange Currency</h5>
            </div>

            <div class="modal-body d-flex flex-column p-0" style="height: calc(100vh - 120px);">
                <div class="py-2 border-bottom bg-white d-flex gap-2">
                    <button id="btnView" class="mui-button mui-button-new">View</button>
                    <button id="btnExportExcel" class="mui-button mui-button-new" type="button">Excel</button>
                    <button id="btnPrintGrid" class="mui-button mui-button-new">Print</button>
                    <button id="close" class="mui-button mui-button-new" onclick="window.location.href='/Home/Index'">Close</button>
                </div>

                <div class="px-3 py-2 bg-light border-bottom">
                    <div class="d-flex flex-wrap align-items-center gap-3">
                        <div class="d-flex align-items-center gap-2">
                            <div class="d-flex align-items-center">
                                <label class="small fw-bold me-2 mb-0 text-nowrap" for="fromDate">From:</label>
                                <div data-date-input data-format="DD/MM/YYYY" business-date data-name="fromDate">
                                    <input type="text" class="date-ui form-control form-control-sm" placeholder="dd/mm/yyyy" autocomplete="off" />
                                </div>
                            </div>
                            <div class="d-flex align-items-center">
                                <label class="small fw-bold me-2 mb-0 text-nowrap">To:</label>
                                <div data-date-input data-format="DD/MM/YYYY" business-date data-name="toDate">
                                    <input type="text" class="date-ui form-control form-control-sm" placeholder="dd/mm/yyyy" autocomplete="off" />
                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-2">
                            <div class="d-flex align-items-center">
                                <label class="small fw-bold me-2 mb-0 text-nowrap">Account:</label>
                                <input type="text" id="account" name="account" class="form-control form-control-sm" style="width: 100px;" />
                            </div>
                            <div class="d-flex align-items-center">
                                <label class="small fw-bold me-2 mb-0 text-nowrap">Room:</label>
                                <input type="text" id="roomNo" name="roomNo" class="form-control form-control-sm" style="width: 70px;" />
                            </div>
                            <div class="d-flex align-items-center">
                                <label class="small fw-bold me-2 mb-0 text-nowrap">ID/Passport:</label>
                                <input type="text" id="passPort" name="passPort" class="form-control form-control-sm" style="width: 120px;" />
                            </div>
                        </div>

                        <div class="form-check d-flex align-items-center gap-1 mb-0 border-start ps-3">
                            <input class="form-check-input mt-0" type="checkbox" id="isDelete">
                            <label class="form-check-label small fw-bold text-danger mb-0" for="isDelete" style="cursor:pointer;">
                                Include Delete
                            </label>
                        </div>
                    </div>
                </div>

                <div class="gridContainer flex-grow-1 bg-white position-relative" id="gridWrapper">
                    <div id="gridContainer" style="height: 100%; width: 100%;"></div>
                </div>

                <div id="loadingSpinner" style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:1000;">
                    <div class="bg-white p-3 rounded-circle shadow-lg text-primary">
                        <i class="fa-solid fa-spinner fa-spin fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    let selectedRowData = null;
    DevExpress.localization.locale("vi");
    $(document).ready(async function () {
        await window.initDateInputs();
        await reloadGrid(isInitial = true);
        $('#exchangeCurrency').modal('show');
    });

    $(document).off("click", "#btnView").on("click", "#btnView", function () {
        callAPI();
    });


    async function reloadGrid(isInitial = false) {
        $("#loadingSpinner").show();
        let fromDateISO = $("#fromDate").val() || '';
        let toDateISO = $("#toDate").val() || '';

        // Nếu là load lần đầu (initial) và fromDate chưa có → bắt buộc chờ business date
        if (isInitial && (!fromDateISO || !toDateISO)) {
            fromDateISO = await waitForBusinessDate("fromDate", 10000); // timeout 10s để an toàn
            toDateISO = await waitForBusinessDate("toDate", 10000); // timeout 10s để an toàn
        }

        // Nếu vẫn rỗng sau khi chờ → báo lỗi hoặc fallback (tùy yêu cầu)
        if (!fromDateISO || !toDateISO) {
            console.log("Không tải được ngày mặc định. Vui lòng chọn From Date thủ công.");
            $("#loadingSpinner").hide();
            return;

        }
        callAPI();
    }

    function callAPI() {
        $.ajax({
            url: '/Cashiering/GetExchangeCurrency',
            type: 'GET',
            data: {
                account: $("#account").val(),
                passPort: $("#passPort").val(),
                roomNo: $("#roomNo").val(),
                fromDate: $("#fromDate").val(),
                toDate: $("#toDate").val(),
                isDelete: $("#isDelete").is(":checked") ? 1 : 0
            },
            success: function (data) {
                loadTelephoneGrid(data);
                console.log(data);
                $("#loadingSpinner").hide();
            },
            error: function (xhr, status, error) {
                console.error("AJAX Error", status, error);
                console.error("Response Text:", xhr.responseText);
                alert("Không thể tải dữ liệu");
                $("#loadingSpinner").hide();
            }
        });
    }

    function loadTelephoneGrid(data) {
        $("#gridContainer").dxDataGrid({
            dataSource: data,
            showBorders: true,
            height: "100%",

            columnAutoWidth: true,   // 🔥 tự co giãn theo nội dung
            allowColumnResizing: true,

            selection: { mode: "single" },

            scrolling: {
                mode: "standard",
                showScrollbar: "always",
                scrollByContent: true
            },

            paging: {
                pageSize: 50
            },

            pager: {
                visible: true,
                allowedPageSizes: [50, 100, "all"],
                showPageSizeSelector: true,
                showInfo: true,
                showNavigationButtons: true
            },

            filterRow: {
                visible: true,
                applyFilter: "auto"
            },

            columns: [
                { dataField: "invoiceNo", caption: "Invoice No", width: 90 },
                { dataField: "transactionDate", caption: "Trans. Date", dataType: "datetime", format: "dd/MM/yyyy", width: 110 },

                { dataField: "account", caption: "Guest Name", width: 160 },
                { dataField: "passPort", caption: "PassPort", width: 120 },
                { dataField: "roomNo", caption: "Room No", width: 80 },

                { dataField: "totalAmount", caption: "Total Amount", dataType: "number", format: "#,##0.00", width: 120, alignment: "right" },

                { dataField: "address", caption: "Address", width: 200 },
                { dataField: "description", caption: "Description", width: 240 },

                { dataField: "statusText", caption: "Status", width: 90 },
                { dataField: "cashierName", caption: "Cashier Name", width: 130 },

                { dataField: "createdBy", caption: "Created By", width: 100 },
                { dataField: "createddate", caption: "Created Date", dataType: "datetime", format: "dd/MM/yyyy HH:mm", width: 150 },

                { dataField: "updatedBy", caption: "Updated By", width: 100 },
                { dataField: "updatedDate", caption: "Updated Date", dataType: "datetime", format: "dd/MM/yyyy HH:mm", width: 150 }
            ],

            // 🔥 bắt row được chọn
            onRowClick: function (e) {
                selectedRowData = e.data;
                console.log("Selected Row:", selectedRowData);
            }
        });
    }

    $(document).off("click", "#btnPrintGrid").on("click", "#btnPrintGrid", function () {
        $("#loadingSpinner").show();

        $.ajax({
            url: '/Cashiering/ExchangeCurrencyPrint',
            type: 'GET',
            data: {
                id: selectedRowData.id,

            },
            success: function (data) {

                if (data && data.pdfBase64) {
                    // Mở cửa sổ mới để hiển thị PDF
                    var pdfWindow = window.open("");
                    pdfWindow.document.write(
                        "<iframe width='100%' height='100%' style='border:none' src='" + data.pdfBase64 + "'></iframe>"
                    );
                } else {
                    alert("Không có dữ liệu PDF để hiển thị");
                }
                $("#loadingSpinner").hide();
            },
            error: function (xhr, status, error) {
                console.error("AJAX Error", status, error);
                console.error("Response Text:", xhr.responseText);
                alert("Không thể tải dữ liệu");
                $("#loadingSpinner").hide();
            }
        });
    });

    $("#btnExportExcel").click(function () {
        const grid = $("#gridContainer").dxDataGrid("instance");   // 🔥 khai báo grid

        const workbook = new ExcelJS.Workbook();
        const companyName = localStorage.getItem("CompanyName") || "Tên công ty chưa xác định";
        const worksheet = workbook.addWorksheet("Sheet 1");

        // === Dòng 1: Tên công ty (merge theo 4 cột) ===
        worksheet.addRow([companyName]);
        worksheet.mergeCells('A1:D1');
        worksheet.getRow(1).font = { bold: true };
        worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'left' };

        // === Dòng 2: Ngày giờ xuất (bên phải) ===
        const now = new Date();
        const exportDate = now.toLocaleString("vi-VN");
        worksheet.addRow(['', '', '', exportDate]);
        worksheet.mergeCells('D2:D2');  // cột D thôi
        worksheet.getRow(2).alignment = { vertical: 'middle', horizontal: 'right' };

        // === Dòng 3–4: trống
        worksheet.addRow([]);
        worksheet.addRow([]);

        // === Dòng 5: Tiêu đề báo cáo (ở giữa) ===
        const reportRow = worksheet.addRow(['ExchangeCurrency']);
        worksheet.mergeCells('A5:D5');
        reportRow.font = { bold: true, size: 14 };
        reportRow.alignment = { vertical: 'middle', horizontal: 'center' };

        // === Dòng 6: trống
        worksheet.addRow([]);

        // === Xuất dữ liệu grid bắt đầu từ dòng 7 ===
        DevExpress.excelExporter.exportDataGrid({
            component: grid,
            worksheet: worksheet,
            autoFilterEnabled: true,
            topLeftCell: { row: 7, column: 1 }
        }).then(function () {
            // Footer (sau cùng)
            const lastRow = worksheet.lastRow.number + 2;
            worksheet.mergeCells(`A${lastRow}:D${lastRow}`);
            worksheet.getCell(`A${lastRow}`).alignment = { horizontal: 'center' };
            worksheet.getCell(`A${lastRow}`).font = { italic: true };

            // Ghi file
            let fileName = "Exchange Currency.xlsx";
            workbook.xlsx.writeBuffer().then(function (buffer) {
                saveAs(new Blob([buffer], { type: "application/octet-stream" }), fileName);
            });
        });
    });
</script>
