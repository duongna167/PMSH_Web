<div class="modal fade" id="css_mainModal" tabindex="-1" aria-labelledby="css_mainModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md-4by3 modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="css_mainModalLabel">Config Status Color</h5>
            </div>

            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <button id="css_btnSave" type="button" class="mui-button mui-button-save">Save</button> 
                        <button type="button" class="mui-button mui-button-save" data-bs-dismiss="modal" aria-label="Close">Close</button>  
                    </div>  
                    <form id="css_form">
                        <div class="row g-2 mt-1">
                            <div class="col-12 col-md-4 col-lg-4">
                                <div class="row g-2 align-items-center">
                                    <label for="css_name" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                        Name
                                    </label>
                                    <div class="col-md-8">
                                        <input id="css_name"
                                               name="css_name"
                                               type="text"
                                               class="form-control form-control-sm"
                                               >
                                        <div class="invalid-feedback" id="css_nameError"></div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-md-4 col-lg-4">
                                <div class="row g-2 align-items-center">
                                    <label for="css_bgColorPicker" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                        Color
                                    </label>
                                    <div class="col-md-8">
                                        <div class="input-group input-group-sm">

                                            <input id="css_backgroundColor"
                                                   name="css_backgroundColor"
                                                   type="text"
                                                   class="form-control "
                                                   >
                                                <input id="css_bgColorPicker"
                                                   name="css_bgColorPicker"
                                                   type="color"
                                                   class="form-control flex-grow-0"
                                                   value="#00ffff"
                                                   style="width:42px;">
                                        </div>
                                        <div class="invalid-feedback" id="css_backgroundColorError"></div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-md-4 col-lg-4">
                                <div class="row g-2 align-items-center">
                                    <label for="css_fontColorPicker" class="col-md-4 col-form-label col-form-label-sm text-md-end">
                                        Font Color
                                    </label>
                                    <div class="col-md-8">
                                        <div class="input-group input-group-sm">

                                            <input id="css_fontColorHidden"
                                                   name="css_fontColorHidden"
                                                   type="text"
                                                   class="form-control "
                                                   >
                                            <input id="css_fontColorPicker"
                                                   name="css_fontColorPicker"
                                                   type="color"
                                                   class="form-control flex-grow-0"
                                                   value="#ff0000"
                                                   style="width:42px;">                                        </div>
                                        <div class="invalid-feedback" id="css_fontColorError"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <input type="hidden" id="css_id" name="css_id" value="0" />
                    </form>

                </div>
                <div class="mui-card mt-1">
                    <div id="css_gridContainer" class="gridContainer"></div>
                </div>

                <div id="css_loadingSpinner"
                    style="position: absolute;top: 50%;left: 50%;transform: translate(-50%, -50%);
                    z-index: 999;background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(2px);width: 100%;
                    height: 100%;display: flex;align-items: center;justify-content: center;">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>

    var css_Module = (function () {
        let selectedRowData = null;

        const selectors = {
            mainModal: "#css_mainModal",
            form: "#css_form",
            grid: "#css_gridContainer",
            loading: "#css_loadingSpinner",

            btnSave: "#css_btnSave",

            id: "#css_id",
            name: "#css_name",
            bgColorPicker: "#css_bgColorPicker",
            backgroundColor: "#css_backgroundColor",
            fontColorPicker: "#css_fontColorPicker",
            fontColorHidden: "#css_fontColorHidden"
        };

        const endpoints = {
            getList: "/Administration/GetStatusList",
            update: "/Administration/UpdateConfigStatusColor"
        };

        function init() {
            bindEvents();
            syncColorInputs();
            loadGrid();
        }

        function bindEvents() {
            $(selectors.btnSave).off("click").on("click", saveRecord);

            $(selectors.bgColorPicker).off("input").on("input", function () {
                $(selectors.backgroundColor).val(hexToArgb($(this).val()));
            });

            $(selectors.fontColorPicker).off("input").on("input", function () {
                $(selectors.fontColorHidden).val(hexToArgb($(this).val()));
            });

            $(selectors.form).off("input change", "input, select, textarea").on("input change", "input, select, textarea", function () {
                clearFieldError(this);
            });

            $(selectors.mainModal).off("hidden.bs.modal").on("hidden.bs.modal", function () {
                resetForm();
            });
        }

        function syncColorInputs() {
            $(selectors.backgroundColor).val(hexToArgb($(selectors.bgColorPicker).val()));
            $(selectors.fontColorHidden).val(hexToArgb($(selectors.fontColorPicker).val()));
        }

        function loadGrid() {
            $(selectors.loading).show();

            $.ajax({
                url: endpoints.getList,
                type: "GET",
                success: function (data) {
                    const parsedData = parseColorData(data || []);
                    renderGrid(parsedData);
                    $(selectors.loading).hide();
                },
                error: function () {
                    $(selectors.loading).hide();
                    showToast("Error", "Unable to load data.", false);
                }
            });
        }

        function renderGrid(data) {
            $(selectors.grid).dxDataGrid({
                dataSource: data,
                keyExpr: "id",
                width: "100%",
                columnAutoWidth: true,
                allowColumnResizing: true,
                columnResizingMode: "widget",
                selection: { mode: "single" },
                hoverStateEnabled: true,
                filterRow: { visible: true, applyFilter: "auto" },
                paging: { pageSize: 20 },
                pager: {
                    visible: true,
                    allowedPageSizes: [20, 50, "all"],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                scrolling: {
                    mode: "standard",
                    showScrollbar: "always",
                    scrollByContent: true
                },
                columns: [
                    {
                        dataField: "statusName",
                        caption: "Status Name",
                        cellTemplate: function (container, options) {
                            $("<div>")
                                .text(options.data.statusName)
                                .css({
                                    "background-color": options.data.colorHex || "#ffffff",
                                    "color": options.data.fontHex || "#000000",
                                    "padding": "3px 8px",
                                    "display": "inline-block"
                                })
                                .appendTo(container);
                        }
                    },
                    {
                        dataField: "description",
                        caption: "Description",
                        cellTemplate: function (container, options) {
                            $("<div>")
                                .text(options.data.description)
                                .css({
                                    "background-color": options.data.colorHex || "#ffffff",
                                    "color": options.data.fontHex || "#000000",
                                    "padding": "3px 8px",
                                    "display": "inline-block"
                                })
                                .appendTo(container);
                        }
                    }
                ],
                onSelectionChanged: function (e) {
                    selectedRowData = e.selectedRowsData.length > 0 ? e.selectedRowsData[0] : null;

                    if (!selectedRowData) {
                        return;
                    }

                    fillForm(selectedRowData);
                }
            });
        }

        function fillForm(data) {
            $(selectors.name).val(data.statusName ?? "");
            $(selectors.id).val(data.id || 0);

            if (data.colorHex) {
                $(selectors.bgColorPicker).val(data.colorHex);
                $(selectors.backgroundColor).val(hexToArgb(data.colorHex));
            } else {
                $(selectors.bgColorPicker).val("#00ffff");
                $(selectors.backgroundColor).val(hexToArgb("#00ffff"));
            }

            if (data.fontHex) {
                $(selectors.fontColorPicker).val(data.fontHex);
                $(selectors.fontColorHidden).val(hexToArgb(data.fontHex));
            } else {
                $(selectors.fontColorPicker).val("#ff0000");
                $(selectors.fontColorHidden).val(hexToArgb("#ff0000"));
            }
        }

        function saveRecord() {
            if (!selectedRowData) {
                showToast("Warning", "Please select 1 row to edit.", false);
                return;
            }

            $(selectors.backgroundColor).val(hexToArgb($(selectors.bgColorPicker).val()));
            $(selectors.fontColorHidden).val(hexToArgb($(selectors.fontColorPicker).val()));

            const formData = buildPostData();

            $.ajax({
                url: endpoints.update,
                type: "POST",
                data: formData,
                success: function (res) {
                    if (res.success) {
                        showToast("Success", "Update success", true);
                        resetForm();
                        selectedRowData = null;
                        loadGrid();
                    } else {
                        showToast("Error", res.message || "Action failed!", false);
                    }
                },
                error: function (xhr) {
                    console.error("Save error:", xhr.responseText);
                    showToast("Error", "Request error!", false);
                }
            });
        }

        function buildPostData() {
            return {
                id: $(selectors.id).val(),
                name: $(selectors.name).val(),
                bgColor: $(selectors.backgroundColor).val(),
                fontColor: $(selectors.fontColorHidden).val()
            };
        }

        function resetForm() {
            $(selectors.form)[0].reset();
            $(selectors.id).val("0");
            $(selectors.name).val("");
            $(selectors.bgColorPicker).val("#00ffff");
            $(selectors.fontColorPicker).val("#ff0000");
            syncColorInputs();
        }

        function parseColorData(data) {
            return data.map(function (item) {
                const newItem = { ...item };

                if (item.colorName !== undefined && item.colorName !== null) {
                    newItem.colorHex = argbToHex(parseInt(item.colorName));
                }

                if (item.fontColorName !== undefined && item.fontColorName !== null) {
                    newItem.fontHex = argbToHex(parseInt(item.fontColorName));
                }

                return newItem;
            });
        }

        function hexToArgb(hex) {
            const r = parseInt(hex.substring(1, 3), 16);
            const g = parseInt(hex.substring(3, 5), 16);
            const b = parseInt(hex.substring(5, 7), 16);

            let argb = (255 << 24) | (r << 16) | (g << 8) | b;

            if (argb > 0x7FFFFFFF) {
                argb = argb - 0x100000000;
            }

            return argb;
        }

        function argbToHex(argb) {
            let value = parseInt(argb);

            if (value < 0) {
                value = 0xFFFFFFFF + value + 1;
            }

            const r = (value >> 16) & 0xFF;
            const g = (value >> 8) & 0xFF;
            const b = value & 0xFF;

            return "#" + [r, g, b].map(function (x) {
                return x.toString(16).padStart(2, "0");
            }).join("");
        }

        function clearFieldError(element) {
            const $element = $(element);

            if ($element.hasClass("is-invalid")) {
                $element.removeClass("is-invalid");
            }

            const $feedback = $element.siblings(".invalid-feedback");
            if ($feedback.length) {
                $feedback.text("");
            }
        }

        function open(){
            const modalEl = document.querySelector(selectors.mainModal);
            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

            $(modalEl).one("shown.bs.modal", function () {
                init();
            });

            modal.show();

        }

        return {
            open: open,
            init: init,
            loadGrid: loadGrid
        };
    })();

    window.openModalConfigStatusColor = function () {
        css_Module.open();
    };
</script>