@{
    Layout = null;
}

<!-- Modal new group reservation-->
<div class="modal fade modal-lg" id="modalNewGroupReservation" data-bs-backdrop="static" data-bs-keyboard="false"
    tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="staticBackdropLabel">New Group Reservation</h5>
                @* <button type="button" class="btn-close" onclick="closemodalNewGroupReservation()"></button> *@
            </div>
            <div class="modal-body">
                <div class="search-filter">
                    <div>
                        <button class="mui-button mui-button-new" onclick="searchRoomAvailale()">Search</button>
                        <button class="mui-button mui-button-new" onclick="SaveGroupReservation();">Save</button>
                        <button class="mui-button mui-button-new"
                            onclick="clearModalNewGroupReservation();">Refesh</button>
                        <button class="mui-button mui-button-search"
                            onclick="closeModalNewGroupReservation();">Close</button>

                    </div>
                </div>
                <div class="mt-1">
                    <div class="row g-2">

                        <!-- Book From -->
                        <div class="col-12 col-md-6 col-lg-4 mt-1">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Book from
                                </label>
                                <div class="col-12 col-md-8">
                                    <select id="bookForm" class="">
                                        <option value="0" selected>Availability</option>
                                        <option value="1">Allotment</option>
                                        <option value="2">Rate Code</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Res Type -->
                        <div class="col-12 col-md-6 col-lg-4 mt-1">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Res. Type
                                </label>
                                <div class="col-12 col-md-8">
                                    <select id="resType" class="" asp-items="ViewBag.cboReservationType"></select>
                                </div>
                            </div>
                        </div>

                        <!-- Currency -->
                        <div class="col-12 col-md-6 col-lg-4 mt-1">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Currency
                                </label>
                                <div class="col-12 col-md-8">
                                    <select id="currency" class="">
                                        <option value="VND" selected>VND</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Arrival -->
                        <div class="col-12 col-md-6 col-lg-4 mt-1">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Arrival
                                </label>
                                <div class="col-12 col-md-8">
                                    <div class="clearable" data-date-input data-format="DD/MM/YYYY" business-date
                                        data-name="arrival2">
                                        <input type="text" id="arrivalNGRShow" class="date-ui form-control"
                                            placeholder="dd/mm/yyyy" autocomplete="off" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Departure -->
                        <div class="col-12 col-md-6 col-lg-4 mt-1">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Departure
                                </label>
                                <div class="col-12 col-md-8">
                                    <div class="clearable" data-date-input data-format="DD/MM/YYYY"
                                        data-name="departure2">
                                        <input type="text" id="departureNGRShow" class="date-ui form-control"
                                            placeholder="dd/mm/yyyy" autocomplete="off" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Nights -->
                        <div class="col-12 col-md-6 col-lg-4 mt-1">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Nights
                                </label>
                                <div class="col-6 col-md-4">
                                    <input id="nights2" class="form-control text-end" />
                                </div>
                            </div>
                        </div>

                        <!-- Package -->
                        <div class="col-12 col-md-6 col-lg-4 mt-1">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Package
                                </label>
                                <div class="col-12 col-md-8">
                                    <select id="package" class="" asp-items="ViewBag.cboPackage"></select>
                                </div>
                            </div>
                        </div>

                        <!-- Market -->
                        <div class="col-12 col-md-6 col-lg-4 mt-1">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Market
                                </label>
                                <div class="col-12 col-md-8">
                                    <select id="market" class="" asp-items="ViewBag.cboMarket"></select>
                                </div>
                            </div>
                        </div>

                        <!-- Name -->
                        <div class="col-12 col-md-6 col-lg-4 mt-1">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-md-4 col-form-label text-md-end">
                                    Name
                                </label>
                                <div class="col-12 col-md-8 d-flex gap-1">
                                    <input id="nameText" class="form-control">
                                    <button type="button" onclick="openModalSearchProfile()" class="btn-search-icon">
                                        <i class="fa-solid fa-arrow-down"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>


                <div id="loadingSpinnerRoom" style="text-align: center; padding: 20px;">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
                <div class="mui-card mt-2">
                    <div id="gridContainerRoom" class="mt-2 gridContainer" style="display: none;"></div>
                </div>
            </div>
        </div>
    </div>
</div>
@await Html.PartialAsync("~/Views/Reservation/GroupReservation/ModalSearchProfile.cshtml")
<script>

    function openModalNewGroupReservation() {
        clearModalNewGroupReservation();
        const toDate = new Date(dateSystem);
        toDate.setDate(toDate.getDate() + 8);
        const toDateStr = toDate.toISOString().split('T')[0];
        console.log('toDateStr', toDateStr);

        UI.setHiddenDate("departure2", toDateStr);
        searchRoomAvailale();

        $('#modalNewGroupReservation').modal('show');
    }

    function closeModalNewGroupReservation() {
        clearModalNewGroupReservation();
        $('#modalNewGroupReservation').modal('hide');
    }

    function clearModalNewGroupReservation() {
        $('#nameProfileSearch, #firstNameProfileSearch, #keywordProfileSearch, #codeProfileSearch').val('');
        $('#cityProfileSearch').val(0);
        $('#sale').prop('checked', false);
    }

    function generateDateColumns(fromDate, toDate) {
        const columns = [];
        let start = new Date(fromDate);
        const end = new Date(toDate);

        while (start <= end) {
            const yyyy = start.getFullYear();
            const mm = String(start.getMonth() + 1).padStart(2, '0');
            const dd = String(start.getDate()).padStart(2, '0');

            const dateKey = `${yyyy}-${mm}-${dd}`; // MATCH API RESPONSE

            const month = start.toLocaleString('en-US', { month: 'short' });
            const weekday = start.toLocaleString('en-US', { weekday: 'short' });
            const weekNumber = getWeekNumber(start);

            const captionHtml = `${dd}-${month}<br>${weekday}<br>CW${weekNumber}`;

            columns.push({
                dataField: dateKey,     // ✅ QUAN TRỌNG
                caption: dateKey,
                width: 60,
                dataType: "number",
                alignment: "right",
                headerCellTemplate(container) {
                    container.html(
                        `<div style="white-space:normal;text-align:center;font-size:11px">
                        ${captionHtml}
                    </div>`
                    );
                }
            });

            start.setDate(start.getDate() + 1);
        }

        return columns;
    }

    function getWeekNumber(date) {
        const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
        const dayNum = d.getUTCDay() || 7;
        d.setUTCDate(d.getUTCDate() + 4 - dayNum);
        const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
        return Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
    }

    function searchRoomAvailale() {
        // Hiển thị biểu tượng tải DevExtreme
        const fromDate = $('#arrival2').val();
        const toDate = $('#departure2').val();

        $('#gridContainerRoom').hide();
        $('#loadingSpinnerRoom').show();
        $.ajax({
            url: '/Reservation/GetRoomAvailable',
            type: 'get',
            dataType: 'json',
            data: {
                fromDate: fromDate,
                toDate: toDate,
            },
            crossDomain: false,
            headers: { "X-CSRF-TOKEN-HEADERNAME": jQuery("input[name='__RequestVerificationToken']").val() },
            success: function (result) {
                // Ẩn biểu tượng tải sau khi dữ liệu tải xong
                $('#loadingSpinnerRoom').hide();
                $('#gridContainerRoom').show();
                initializeDataGridRoomAvailable(result, fromDate, toDate);
            },
            error: function (xhr, statusText, err) {
                // Ẩn biểu tượng tải nếu xảy ra lỗi
                $('#loadingSpinnerRoom').hide();
                if (xhr.status == 401) {
                    sessionTimeout();
                } else {
                    showToast('Error', 'Đã xảy ra lỗi khi tìm kiếm phòng trống.', false);
                }
            },
            complete: function () {
                $('#loadingSpinnerRoom').hide();
            }
        });
    }

    $('#nameText').on('blur', function () {
        var input = $(this).val().trim();
        // Regex hỗ trợ tiếng Việt, định dạng: "LastName, FirstName MiddleName"
        var regex = /^[a-zA-ZÀ-ỹ]+(?:\s[a-zA-ZÀ-ỹ]+)*,\s*[a-zA-ZÀ-ỹ]+(?:\s[a-zA-ZÀ-ỹ]+)*$/i;

        if (regex.test(input)) {
            $('#errorMessage').hide();
            $(this).removeClass('is-invalid').addClass('is-valid');

            // Tách chuỗi theo định dạng "LastName, FirstName MiddleName"
            var parts = input.split(',');
            var lastName = parts[0].trim();          // "Nguyễn Văn"
            var firstMiddlePart = parts[1].trim();   // "Tuấn Anh"
            var nameTokens = firstMiddlePart.split(/\s+/); // ["Tuấn", "Anh"]

            var firstName = nameTokens[0];
            var middleName = nameTokens.slice(1).join(' '); // Có thể là rỗng

            CreateProfile(input, lastName, firstName, middleName);

        } else {
            $('#errorMessage').show();
            $(this).removeClass('is-valid').addClass('is-invalid');

        }
    });

    function calculateNightsGR() {
        const arrival = new Date(document.getElementById('arrival2').value);
        const departure = new Date(document.getElementById('departure2').value);
        console.log('departure', departure);

        if (arrival && departure) {
            const diffTime = departure - arrival;
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            document.getElementById('nights2').value = diffDays >= 0 ? diffDays : 0;
        }
    }
    // Hàm cập nhật ngày và thứ
    function updateDatesGR() {
        const arrivalInputGR = document.getElementById('arrival2');
        const departureInputGR = document.getElementById('departure2');
        const arrivalDayGR = document.getElementById('arrival-day');
        const departureDayGR = document.getElementById('departure-day');
        const arrivalDateGR = new Date(arrivalInputGR.value);
        const departureDateGR = new Date(departureInputGR.value);
        calculateNightsGR();
    }

    // Lắng nghe sự kiện thay đổi ngày
    @* $(document).on('change', '#arrivalNGRShow', async function () {

        if (window.isSyncingDates) return;
        window.isSyncingDates = true;
        // 2. Chờ arrival ISO từ hidden (nguồn sự thật)
        const arrivalIso = dateSystem;
        console.log('dấdsadfvhaet', arrivalIso);

        const nights = parseInt($('#nights2').val(), 10) || 1;

        const departureIso = UI.addDaysIso(arrivalIso, nights);
        UI.setHiddenDate("departure2", departureIso);

        Promise.resolve().then(updateDatesGR);
        window.isSyncingDates = false;
    });

    $(document).on('change', '#departureNGRShow,#nights2', async function (e) {
        if (window.isSyncingDates) return;
        window.isSyncingDates = true;
        try {
            const targetId = e.target.id; // Kiểm tra xem cái nào vừa bị thay đổi
            const arrivalIso = $('#arrival2').val() || dateSystem;
            let departureIso = $('#departure2').val();
            const nights = parseInt($('#nights2').val(), 10) || 1;

            if (targetId === 'departureNGRShow') {
                if (arrivalIso && departureIso) {
                    if (departureIso <= arrivalIso) {
                        // Nếu chọn ngày đi <= ngày đến: Giữ nguyên số đêm, lùi ngày đến lại
                        const currentNights = nights > 0 ? nights : 1;
                        const newArrival = UI.addDaysIso(departureIso, -currentNights);
                        UI.setHiddenDate("arrival2", newArrival);
                    } else {
                        // Nếu ngày đi hợp lệ: Tính lại số đêm
                        calculateNightsGR();
                    }
                }
            }
            // TRƯỜNG HỢP 2: Người dùng thay đổi SỐ ĐÊM (Nights)
            else if (targetId === 'nights2') {
                if (arrivalIso && !isNaN(nights)) {
                    if (nights < 1) {
                        nights = 1;
                        $('#nights2').val(1);

                    }
                    // Giữ nguyên ngày đến, đẩy ngày đi ra xa theo số đêm
                    const newDeparture = UI.addDaysIso(arrivalIso, nights);
                    UI.setHiddenDate("departure2", newDeparture);
                }
            }
            // Cuối cùng cập nhật lại Thứ hiển thị và các logic phụ
            Promise.resolve().then(updateDatesGR);

        } catch (error) {
            console.error("Lỗi cập nhật ngày tháng:", error);
        } finally {
            window.isSyncingDates = false;
        }
    }); *@

        function initializeDataGridRoomAvailable(data, fromDate, toDate) {
            // Add default values for Currency and RateCode
            data.forEach(item => {
                item.Currency = "VND";
                item.RateCode = "0";
            });
            const columnWidth = 120;
            const dateColumns = generateDateColumns(fromDate, toDate);


            // Define the columns array
            const columns = [];

            // Explicitly define the desired columns in the specified order
            const predefinedColumns = [
                {
                    dataField: "Currency",
                    caption: "Currency",
                    alignment: "left",
                    width: 60 // Fixed width of 150px
                },
                {
                    dataField: "RateCode",
                    caption: "Rate Code",
                    alignment: "left",
                    width: 100 // Fixed width of 150px
                },
                {
                    dataField: "RoomType",
                    caption: "Room Type",
                    alignment: "left",
                    width: 100 // Fixed width of 150px
                },
                {
                    dataField: "NumofRoom",
                    caption: "Num of Room",
                    alignment: "right",
                    width: 100 // Fixed width of 150px
                }
            ];


            // Combine predefined columns with dynamically generated ones
            const finalColumns = [...predefinedColumns, ...dateColumns];

            // Hide RoomTypeID column (in case it was added elsewhere)
            const roomTypeIdColumn = finalColumns.find(col => col.dataField === "RoomTypeID");
            if (roomTypeIdColumn) {
                roomTypeIdColumn.visible = false;
            }

            // Initialize the DevExtreme DataGrid
            $("#gridContainerRoom").dxDataGrid({
                dataSource: data,
                columns: finalColumns,
                paging: {
                    pageSize: 15,
                    enabled: true
                },
                pager: {
                    visible: true,
                    allowedPageSizes: [15, 20, 'all'],
                    showPageSizeSelector: true,
                    showInfo: true,
                    showNavigationButtons: true
                },
                filterRow: {
                    visible: true,
                    applyFilter: "auto"
                },
                editing: {
                    mode: "cell",
                    allowUpdating: true,
                    allowAdding: false,
                    allowDeleting: false
                },
                scrolling: {
                    mode: 'standard',
                    showScrollbar: 'always',
                    useNative: false
                },
                selection: {
                    mode: "single"
                }, height: "500px",
            });
        }
    function SaveGroupReservation() {
        const userName = JSON.parse(localStorage.getItem("Loginname"));
        const userID = JSON.parse(localStorage.getItem("userID"));
        const gridData = $("#gridContainerRoom").dxDataGrid("instance").getVisibleRows().map(r => r.data);
        var formData = new FormData();
        formData.append('lastName', $('#nameText').val());
        formData.append('resType', $("#resType").val());
        formData.append("gridData", JSON.stringify(gridData));
        formData.append('arrivalDate', $("#arrival2").val());
        formData.append('departureDate', $("#departure2").val());
        formData.append('noOfNight', $("#nights2").val());
        formData.append('profileIndividualID', $("#name").val());
        formData.append('package', $("#package").val());
        formData.append('packageCode', $("#package").find('option:selected').text());
        formData.append('market', $("#market").val());
        formData.append('marketCode', $("#market").find('option:selected').text());
        formData.append('resTypeCode', $('#resType').find('option:selected').text());
        formData.append('userName', userName);
        formData.append('userID', userID);
        $.ajax({
            url: '/Reservation/SaveGroupReservation',
            type: 'POST',
            processData: false,
            contentType: false,
            data: formData,
            success: function (data) {
                if (data.code == 0) {
                    @* closeModalNew();
                    searchGroupReservation(); *@
                        showToast('Thành công', data.msg, true);
                } else {
                    showToast('Lỗi', data.msg, false);
                }
            },
            error: function (xhr, statusText, err) {
                showToast('Lỗi', 'Đã xảy ra lỗi khi lưu đặt phòng nhóm.', false);
            }
        });
    }

</script>
