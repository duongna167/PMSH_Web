<script>
    var pro_com_Module = {
        currentType: 2, // Mặc định là 2 (Company)

        init: function (type) {
            if (type) this.currentType = type;

            this.updateModalTitle();
            this.initDOMEvents();
            this.initTomSelects();
        },

        updateModalTitle: function() {
            let title = "Profile - Company";
            if (this.currentType === 1) title = "Profile - Travel Agent";
            if (this.currentType === 3) title = "Profile - Source";

            $("#modalCompany .modal-title").text(title);
        },

        initDOMEvents: function () {
            const self = this;
            const $blackCheckbox = $("#com_chkBlackList");
            const $blackInput = $("#com_txtBlackListReason");

            $('#com_btnSave').off('click').on('click', function () {
                self.saveProfile();
            });

            $('#com_btnClear').off('click').on('click', function () {
                self.clearForm();
            });

            function updateBlackList() {
                const isChecked = $blackCheckbox.is(":checked");
                if (isChecked) {
                    $blackInput.addClass("black-active").prop("disabled", false).focus();
                } else {
                    $blackInput.removeClass("black-active").prop("disabled", true).val('');
                }
            }

            updateBlackList();
        },

        getFormData: function () {

            const getTS = (id) => {
                const ts = getTomSelect(id);
                return ts ? ts.getValue() : null;
            };

            const loginUser = parseInt(localStorage.getItem("userID")) || 0;
            const defaultDate = "1900-01-01";

            return {

                ID: parseInt($("#com_id").val()) || 0,

                Type: this.currentType,

                Code: $("#com_txtCode").val()?.trim() || "",
                Account: $("#com_txtAccount").val()?.trim() || "",

                Address: $("#com_txtAddress").val()?.trim() || "",
                City: getTS("#com_txtCity") || "",
                PostalCode: $("#com_txtPostal").val()?.trim() || "",

                CountryID: parseInt(getTS("#com_txtCountry")) || 0,
                StateID: parseInt(getTS("#com_txtState")) || 0,

                Company: $("#com_txtCompany").val()?.trim() || "",
                TaxCode: $("#com_txtTax").val()?.trim() || "",
                HomeAddress: $("#com_txtBusAddress").val()?.trim() || "",

                Telephone: $("#com_txtTelephone").val()?.trim() || "",
                HandPhone: $("#com_txtHandPhone").val()?.trim() || "",
                Email: $("#com_txtEmail").val()?.trim() || "",
                Website: $("#com_txtWebsite").val()?.trim() || "",

                AcctContact: $("#com_txtContactName").val()?.trim() || "",

                BusinessTitle: $("#com_txtBusTitle").val()?.trim() || "",

                OwnerID: parseInt(getTS("#com_txtOwner")) || 0,
                TerritoryID: parseInt(getTS("#com_txtTerritory")) || 0,
                PersonInChargeID: parseInt(getTS("#com_txtSaleInCharge")) || 0,

                ARNo: $("#com_txtAR").val()?.trim() || "",

                CurrencyID: getTS("#com_txtCurrency") || "",

                Keyword: $("#com_txtKeyword").val()?.trim() || "",

                MarketID: parseInt(getTS("#com_txtMarket")) || 0,

                Active: $("#com_chkActive").is(":checked"),

                IsBlackList: $("#com_chkBlackList").is(":checked"),

                BlackListReason: $("#com_txtBlackListReason").val()?.trim() || "",

                Description: $("#com_txtNote").val()?.trim() || "",

                // ===== REQUIRED DATE FIELD =====

                DateOfBirth: defaultDate,
                Lastvisit: defaultDate,
                FirstReservation: defaultDate,
                LastReservation: defaultDate,
                WeddingAnniversary: defaultDate,
                Firstvisit: defaultDate,
                Expiry: defaultDate,
                LastContact: defaultDate,
                SpecialUpdateDate: defaultDate,

                StayNo: 0,

                UserInsertID: loginUser,
                UserUpdateID: loginUser
            };
        },

        clearForm: function () {
            const $container = $("#pro_com_formContainer");
            // Reset tất cả input text, hidden, email và textarea
            $container.find('input[type="text"], input[type="hidden"], input[type="email"], textarea').val('');

            // Reset Checkbox
            $("#com_chkActive").prop("checked", true);
            $("#com_chkBlackList").prop("checked", false);
            $("#com_txtBlackListReason").prop("disabled", true);

            // Reset TomSelect
            const tsIds = [
                "#com_txtCity", "#com_txtCountry", "#com_txtState",
                "#com_txtOwner", "#com_txtTerritory", "#com_txtCompanyType",
                "#com_txtCurrency", "#com_txtSaleInCharge", "#com_txtMarket"
            ];
            tsIds.forEach(id => {
                const ts = getTomSelect(id);
                if (ts) ts.clear();
            });

            // Xóa báo lỗi validation
            if (window.ValidationAdapter) {
                ValidationAdapter.clear("#pro_com_formContainer");
            }
        },

        saveProfile: function () {
            const self = this;
            const wasNew = !(parseInt($("#com_id").val(), 10) > 0);
            const data = this.getFormData();

            $.ajax({
                url: '/Profile/SaveProfile',
                type: 'POST',
                showLoading: true,
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {
                    if (res.success) {
                        showToast("Success", res.message || 'Profile saved successfully!', true);
                        if (wasNew) self.clearForm();
                        const modalEl = document.getElementById('modalCompany');
                        if (modalEl) {
                            const modalInstance = bootstrap.Modal.getInstance(modalEl);
                            if (modalInstance) modalInstance.hide();
                        }

                        if ($("#pro_search_btnSearch").length) {
                            $("#pro_search_btnSearch").trigger("click");
                        }
                    } else {
                        if (res.errors && res.errors.length > 0) {
                            ValidationAdapter.apply(res.errors, "#pro_com_formContainer");
                            showToast("Warning", 'Please check the highlighted fields.', false);
                        } else {
                            showToast("Error", res.message || 'An error occurred', false);
                        }
                    }
                },
                error: function (xhr) {
                    showToast("Error", 'Internal Server Error. Please try again.', false);
                }
            });
        },

        initTomSelects: async function (dataToFill = null) {
            initTomSelect('.tomselect-custom');

            const mapCode = (item) => ({
                value: item.id || item.ID,
                text: (item.code || item.Code) + " - " + (item.name || item.Name),
                data: item
            });

            const loadPromises = [
                new Promise(resolve => loadDataToTomSelect("#com_txtCity", "/Profile/GetAllCity", mapCode, resolve)),
                new Promise(resolve => loadDataToTomSelect("#com_txtCountry", "/Profile/GetAllCountry", mapCode, resolve)),
                new Promise(resolve => loadDataToTomSelect("#com_txtOwner", "/Profile/GetAllOwner", mapCode, resolve)),
                new Promise(resolve => loadDataToTomSelect("#com_txtTerritory", "/Profile/GetAllTerritory", mapCode, resolve)),
                new Promise(resolve => loadDataToTomSelect("#com_txtCompanyType", "/Profile/GetAllCompanyType", mapCode, resolve)),
                new Promise(resolve => loadDataToTomSelect("#com_txtSaleInCharge", "/Profile/GetAllOwner", mapCode, resolve)),

                new Promise(resolve => loadDataToTomSelect("#com_txtCurrency", "/Profile/GetAllCurrency", (item) => {
                    const id = item.id || item.ID || "";
                    const desc = item.description || item.Description || "";
                    return {
                        value: id,
                        text: (id && desc) ? `${id} - ${desc}` : (id || desc || "Unknown"),
                        data: item
                    };
                }, resolve)),

                new Promise(resolve => loadDataToTomSelect("#com_txtMarket", "/Profile/GetAllMarket", (item) => {
                    const code = item.code || item.Code || "";
                    const name = item.name || item.Name || "";
                    return {
                        value: item.id || item.ID,
                        text: (code && name) ? `${code} - ${name}` : (code || name || "Unknown"),
                        data: item
                    };
                }, resolve)),

                new Promise(resolve => loadDataToTomSelect("#com_txtState", "/Profile/GetAllState", (item) => {
                    const zip = item.zipCode || item.ZipCode || "";
                    const name = item.stateName || item.StateName || "";
                    return {
                        value: item.id || item.ID,
                        text: (zip && name) ? `${zip} - ${name}` : (zip || name || "Unknown"),
                        data: item
                    };
                }, resolve))
            ];

            try {
                await Promise.all(loadPromises);

                if (dataToFill) {
                    this.fillForm(dataToFill);
                }
            } catch (error) {
                console.error("Lỗi khi tải dữ liệu TomSelect:", error);
            }

        },

        fillForm: function (data) {

            if (!data) return;

            $("#com_id").val(data.id);
            $("#com_txtCode").val(data.code);
            $("#com_txtAccount").val(data.account);

            $("#com_txtAddress").val(data.address);
            $("#com_txtPostal").val(data.postalCode);

            $("#com_txtCompany").val(data.company);
            $("#com_txtTax").val(data.taxCode);
            $("#com_txtBusAddress").val(data.homeAddress);

            $("#com_txtTelephone").val(data.telephone);
            $("#com_txtHandPhone").val(data.handPhone);
            $("#com_txtEmail").val(data.email);
            $("#com_txtWebsite").val(data.website);

            $("#com_txtContactName").val(data.acctContact);

            $("#com_txtBusTitle").val(data.businessTitle);

            $("#com_txtKeyword").val(data.keyword);

            $("#com_txtAR").val(data.arNo);

            $("#com_txtNote").val(data.description);

            $("#com_chkActive").prop("checked", data.active);

            $("#com_chkBlackList").prop("checked", data.isBlackList);

            $("#com_txtBlackListReason")
                .val(data.blackListReason)
                .prop("disabled", !data.isBlackList);

            // ===== TOMSELECT =====

            const setTS = (id, val) => {
                const ts = getTomSelect(id);
                if (ts && val) ts.setValue(val);
            };

            setTS("#com_txtCity", data.city);
            setTS("#com_txtCountry", data.countryID);
            setTS("#com_txtState", data.stateID);
            setTS("#com_txtOwner", data.ownerID);
            setTS("#com_txtTerritory", data.territoryID);
            setTS("#com_txtCurrency", data.currencyID);
            setTS("#com_txtSaleInCharge", data.personInChargeID);
            setTS("#com_txtMarket", data.marketID);
        },

        loadProfileByID: function (id) {
            const self = this;
            
            $.ajax({
                url: '/Profile/GetProfileByID/',
                type: 'GET',
                data: { id: id },
                success: async function (res) {
                    if (res.code === 0) {
                        await self.initTomSelects();
                        self.fillForm(res.profile);
                    } else {
                        showToast("Error", res.msg, false);
                    }
                },
                error: function () {
                    showToast("Error", "Cannot load profile", false);
                }
            });
        }
    };

    window.initCompanyModal = function(type) {
        if (window.pro_com_Module) {
            window.pro_com_Module.init(type);
        }
    };
</script>

