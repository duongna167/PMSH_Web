<script>
    $(document).ready(async function () {
        window.tomSelectInstances = window.tomSelectInstances || {};
        await setSelectGroup();
        if (typeof initializeProfileGroupGrid === "function") {
            initializeProfileGroupGrid([]);
        }
    });

    // const tomSelectGroup = {};
    async function setSelectGroup() {
        const configs = [
            "#pro_search_select-beast-empty", "#pro_search_txtStateGroup",
            "#pro_search_txtCountryGroup", "#pro_search_txtLanguageGroup", "#pro_search_txtCurrencyGroup",
            "#pro_search_txtVIPGroup",
        ];

        for (const id of configs) {
            const el = document.querySelector(id);
            if (!el) continue;

            // Destroy nếu đã tồn tại (tránh duplicate khi mở modal nhiều lần)
            if (tomSelectInstances[id]) {
                tomSelectInstances[id].destroy();
            }

            tomSelectInstances[id] = new TomSelect(el, {
                valueField: 'value',
                labelField: 'text',
                searchField: 'text',
                create: false,
                allowEmptyOption: true,
                plugins: ['clear_button']
            });
        }
    }

    // --- GLOBAL EVENT BINDINGS (Unchanged Logic) ---
    document.getElementById("pro_search_searchName").addEventListener("keydown", async function (event) {
        if (event.key === "Enter") {
            event.preventDefault();
            const value = event.target.value;
            await getProfileGroupSreach(value);
        }
    });

    async function getProfileGroupSreach(value) {
        try {
            $("#pro_search_loadingSpinner").show();
            const res = await $.ajax({ url: '/ProfileGroupSreach/', method: "GET", data: { GroupName: value } });
            if (!res?.success) { showToast('Error', res?.message || 'Failed.', false); return; }
            initializeProfileGroupGrid(res.data);
            $("#pro_search_loadingSpinner").hide();
        } catch (error) { console.error(error); $("#pro_search_loadingSpinner").hide(); }
    }


    async function initializeProfileGroupGrid(data) {
        $("#pro_search_profileGroupGrid").dxDataGrid({
            dataSource: data || [],
            showBorders: true,
            selection: { mode: "single" },
            paging: { pageSize: 20 },
            height: "300px",
            pager: { showPageSizeSelector: true, allowedPageSizes: [5, 10, 20], showInfo: true },
            filterRow: { visible: true },
            columns: [{ dataField: "id", caption: "ID", visible: false }, { dataField: "account", caption: "Group Name" }],
            scrolling: { mode: "standard", showScrollbar: "always", scrollByContent: true },
            onRowClick: function (e) {
                selectedRowData = e.data;
                selectGroupPro(selectedRowData.id);

            },
            noDataText: "No records to display"
        });
    }

    async function selectGroupPro(id) {
        try {
            $("#pro_search_loadingSpinner").show();
            const res = await $.ajax({ url: 'FindGroupByID/', method: "GET", data: { id: id } });
            if (!res?.success) { showToast('Error', res?.message || 'Failed.', false); return; }
            const pkg = res.data;
            selectGroupGrid(pkg);
            $("#pro_search_loadingSpinner").hide();
        } catch (error) { console.error(error); $("#pro_search_loadingSpinner").hide(); }
    }

    function selectGroupGrid(data) {

        $('#pro_search_idGroup').val(data.id ?? '');

        // --- TAB 1: ADDRESS INFORMATION ---
        $("#pro_search_txtCodeGroup").val(data.code);
        $("#pro_search_txtGroupNameGroup").val(data.account);

        setTomSelectValue('#pro_search_txtLanguageGroup',
            data.languageID,
            data.languageName
        );
        $("#pro_search_txtAddressGroup").val(data.address);
        $("#pro_search_txtHomeAddressGroup").val(data.homeAddress);
        // Nếu city là select2/dropdown
        $("#pro_search_txtCityGroup").val(data.city);
        $("#pro_search_txtPostalCodeGroup").val(data.postalCode);

        // Country & State
        setTomSelectValue('#pro_search_txtCountryGroup',
            data.countryID,
            data.countryName
        );
        setTomSelectValue('#pro_search_txtStateGroup',
            data.stateID,
            data.stateName
        );
        // --- TAB 2: INTERNAL / COMMUNICATIONS / ATTRIBUTES ---
        // Cột bên trái (Internal)
        $("#pro_search_txtContactGroup").val(data.acctContact);
        setTomSelectValue('#pro_search_txtCurrencyGroup',
            data.currencyID,
            data.currencyName
        );

        $("#pro_search_txtAccountTypeGroup").val(data.type);

        $("#pro_search_txtVIPGroup").val(data.vipid).trigger('change');
        setTomSelectValue('#pro_search_txtVIPGroup',
            data.vipid,
            data.languageName
        );
        $("#pro_search_txtVIPReasonGroup").val(data.vipReason);
        $("#pro_search_txtNotesGroup").val(data.description); // Map 'description' vào 'Notes'

        // Checkbox History
        $("#pro_search_txtHistory").prop('checked', data.history);

        // Cột bên phải (Communications)
        $("#pro_search_txtTelephoneGroup").val(data.telephone);
        $("#pro_search_txtEmailGroup").val(data.email);
        $("#pro_search_txtWebsiteGroup").val(data.website);
        $("#pro_search_txtHandPhoneGroup").val(data.handPhone);

        // Các trường Disabled (Rate Code / AR No)
        $("#pro_search_txtRateCodeGroup").val(data.lastRateCode);
        $("#pro_search_txtARNoGroup").val(data.arNo);
    }

</script>
